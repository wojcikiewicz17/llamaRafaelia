`pkg_resources.declare_namespace({packageName!r})`.\\n\"\nL20445:         \"Implementing implicit namespace packages (as specified in PEP 420) \"\nL20446:         \"is preferred to `pkg_resources.declare_namespace`. \"\nL20447:         \"See https://setuptools.pypa.io/en/latest/references/\"\nL20448:         \"keywords.html#keyword-namespace-packages\"\nL20449:     )\nL20450:     warnings.warn(msg, DeprecationWarning, stacklevel=2)\nL20451: \nL20452:     _imp.acquire_lock()\nL20453:     try:\nL20454:         if packageName in _namespace_packages:\nL20455:             return\nL20456: \nL20457:         path: MutableSequence[str] = sys.path\nL20458:         parent, _, _ = packageName.rpartition('.')\nL20459: \nL20460:         if parent:\nL20461:             declare_namespace(parent)\nL20462:             if parent not in _namespace_packages:\nL20463:                 __import__(parent)\nL20464:             try:\nL20465:                 path = sys.modules[parent].__path__\nL20466:             except AttributeError as e:\nL20467:                 raise TypeError(\"Not a package:\", parent) from e\nL20468: \nL20469:         # Track what packages are namespaces, so when new path items are added,\nL20470:         # they can be updated\nL20471:         _namespace_packages.setdefault(parent or None, []).append(packageName)\nL20472:         _namespace_packages.setdefault(packageName, [])\nL20473: \nL20474:         for path_item in path:\nL20475:             # Ensure all the parent's path items are reflected in the child,\nL20476:             # if they apply\nL20477:             _handle_ns(packageName, path_item)\nL20478: \nL20479:     finally:\nL20480:         _imp.release_lock()\nL20481: \nL20482: \nL20483: def fixup_namespace_packages(path_item: str, parent: str | None = None) -> None:\nL20484:     \"\"\"Ensure that previously-declared namespace packages include path_item\"\"\"\nL20485:     _imp.acquire_lock()\nL20486:     try:\nL20487:         for package in _namespace_packages.get(parent, ()):\nL20488:             subpath = _handle_ns(package, path_item)\nL20489:             if subpath:\nL20490:                 fixup_namespace_packages(subpath, package)\nL20491:     finally:\nL20492:         _imp.release_lock()\nL20493: \nL20494: \nL20495: def file_ns_handler(\nL20496:     importer: object,\nL20497:     path_item: StrPath,\nL20498:     packageName: str,\nL20499:     module: types.ModuleType,\nL20500: ):\nL20501:     \"\"\"Compute an ns-package subpath for a filesystem or zipfile importer\"\"\"\nL20502: \nL20503:     subpath = os.path.join(path_item, packageName.split('.')[-1])\nL20504:     normalized = _normalize_cached(subpath)\nL20505:     for item in module.__path__:\nL20506:         if _normalize_cached(item) == normalized:\nL20507:             break\nL20508:     else:\nL20509:         # Only return the path if it's not already there\nL20510:         return subpath\nL20511: \nL20512: \nL20513: if hasattr(pkgutil, 'ImpImporter'):\nL20514:     register_namespace_handler(pkgutil.ImpImporter, file_ns_handler)\nL20515: \nL20516: register_namespace_handler(zipimport.zipimporter, file_ns_handler)\nL20517: register_namespace_handler(importlib.machinery.FileFinder, file_ns_handler)\nL20518: \nL20519: \nL20520: def null_ns_handler(\nL20521:     importer: object,\nL20522:     path_item: str | None,\nL20523:     packageName: str | None,\nL20524:     module: _ModuleLike | None,\nL20525: ) -> None:\nL20526:     return None\nL20527: \nL20528: \nL20529: register_namespace_handler(object, null_ns_handler)\nL20530: \nL20531: \nL20532: @overload\nL20533: def normalize_path(filename: StrPath) -> str: ...\nL20534: @overload\nL20535: def normalize_path(filename: BytesPath) -> bytes: ...\nL20536: def normalize_path(filename: StrOrBytesPath) -> str | bytes:\nL20537:     \"\"\"Normalize a file/dir name for comparison purposes\"\"\"\nL20538:     return os.path.normcase(os.path.realpath(os.path.normpath(_cygwin_patch(filename))))\nL20539: \nL20540: \nL20541: def _cygwin_patch(filename: StrOrBytesPath):  # pragma: nocover\nL20542:     \"\"\"\nL20543:     Contrary to POSIX 2008, on Cygwin, getcwd (3) contains\nL20544:     symlink components. Using\nL20545:     os.path.abspath() works around this limitation. A fix in os.getcwd()\nL20546:     would probably better, in Cygwin even more so, except\nL20547:     that this seems to be by design...\nL20548:     \"\"\"\nL20549:     return os.path.abspath(filename) if sys.platform == 'cygwin' else filename\nL20550: \nL20551: \nL20552: if TYPE_CHECKING:\nL20553:     # https://github.com/python/mypy/issues/16261\nL20554:     # https://github.com/python/typeshed/issues/6347\nL20555:     @overload\nL20556:     def _normalize_cached(filename: StrPath) -> str: ...\nL20557:     @overload\nL20558:     def _normalize_cached(filename: BytesPath) -> bytes: ...\nL20559:     def _normalize_cached(filename: StrOrBytesPath) -> str | bytes: ...\nL20560: \nL20561: else:\nL20562: \nL20563:     @functools.cache\nL20564:     def _normalize_cached(filename):\nL20565:         return normalize_path(filename)\nL20566: \nL20567: \nL20568: def _is_egg_path(path):\nL20569:     \"\"\"\nL20570:     Determine if given path appears to be an egg.\nL20571:     \"\"\"\nL20572:     return _is_zip_egg(path) or _is_unpacked_egg(path)\nL20573: \nL20574: \nL20575: def _is_zip_egg(path):\nL20576:     return (\nL20577:         path.lower().endswith('.egg')\nL20578:         and os.path.isfile(path)\nL20579:         and zipfile.is_zipfile(path)\nL20580:     )\nL20581: \nL20582: \nL20583: def _is_unpacked_egg(path):\nL20584:     \"\"\"\nL20585:     Determine if given path appears to be an unpacked egg.\nL20586:     \"\"\"\nL20587:     return path.lower().endswith('.egg') and os.path.isfile(\nL20588:         os.path.join(path, 'EGG-INFO', 'PKG-INFO')\nL20589:     )\nL20590: \nL20591: \nL20592: def _set_parent_ns(packageName) -> None:\nL20593:     parts = packageName.split('.')\nL20594:     name = parts.pop()\nL20595:     if parts:\nL20596:         parent = '.'.join(parts)\nL20597:         setattr(sys.modules[parent], name, sys.modules[packageName])\nL20598: \nL20599: \nL20600: MODULE = re.compile(r\"\\w+(\\.\\w+)*$\").match\nL20601: EGG_NAME = re.compile(\nL20602:     r\"\"\"\nL20603:     (?P<name>[^-]+) (\nL20604:         -(?P<ver>[^-]+) (\nL20605:             -py(?P<pyver>[^-]+) (\nL20606:                 -(?P<plat>.+)\nL20607:             )?\nL20608:         )?\nL20609:     )?\nL20610:     \"\"\",\nL20611:     re.VERBOSE | re.IGNORECASE,\nL20612: ).match\nL20613: \nL20614: \nL20615: class EntryPoint:\nL20616:     \"\"\"Object representing an advertised importable object\"\"\"\nL20617: \nL20618:     def __init__(\nL20619:         self,\nL20620:         name: str,\nL20621:         module_name: str,\nL20622:         attrs: Iterable[str] = (),\nL20623:         extras: Iterable[str] = (),\nL20624:         dist: Distribution | None = None,\nL20625:     ) -> None:\nL20626:         if not MODULE(module_name):\nL20627:             raise ValueError(\"Invalid module name\", module_name)\nL20628:         self.name = name\nL20629:         self.module_name = module_name\nL20630:         self.attrs = tuple(attrs)\nL20631:         self.extras = tuple(extras)\nL20632:         self.dist = dist\nL20633: \nL20634:     def __str__(self) -> str:\nL20635:         s = f\"{self.name} = {self.module_name}\"\nL20636:         if self.attrs:\nL20637:             s += ':' + '.'.join(self.attrs)\nL20638:         if self.extras:\nL20639:             extras = ','.join(self.extras)\nL20640:             s += f' [{extras}]'\nL20641:         return s\nL20642: \nL20643:     def __repr__(self) -> str:\nL20644:         return f\"EntryPoint.parse({str(self)!r})\"\nL20645: \nL20646:     @overload\nL20647:     def load(\nL20648:         self,\nL20649:         require: Literal[True] = True,\nL20650:         env: Environment | None = None,\nL20651:         installer: _InstallerType | None = None,\nL20652:     ) -> _ResolvedEntryPoint: ...\nL20653:     @overload\nL20654:     def load(\nL20655:         self,\nL20656:         require: Literal[False],\nL20657:         *args: Any,\nL20658:         **kwargs: Any,\nL20659:     ) -> _ResolvedEntryPoint: ...\nL20660:     def load(\nL20661:         self,\nL20662:         require: bool = True,\nL20663:         *args: Environment | _InstallerType | None,\nL20664:         **kwargs: Environment | _InstallerType | None,\nL20665:     ) -> _ResolvedEntryPoint:\nL20666:         \"\"\"\nL20667:         Require packages for this EntryPoint, then resolve it.\nL20668:         \"\"\"\nL20669:         if not require or args or kwargs:\nL20670:             warnings.warn(\nL20671:                 \"Parameters to load are deprecated.  Call .resolve and \"\nL20672:                 \".require separately.\",\nL20673:                 PkgResourcesDeprecationWarning,\nL20674:                 stacklevel=2,\nL20675:             )\nL20676:         if require:\nL20677:             # We could pass `env` and `installer` directly,\nL20678:             # but keeping `*args` and `**kwargs` for backwards compatibility\nL20679:             self.require(*args, **kwargs)  # type: ignore[arg-type]\nL20680:         return self.resolve()\nL20681: \nL20682:     def resolve(self) -> _ResolvedEntryPoint:\nL20683:         \"\"\"\nL20684:         Resolve the entry point from its module and attrs.\nL20685:         \"\"\"\nL20686:         module = __import__(self.module_name, fromlist=['__name__'], level=0)\nL20687:         try:\nL20688:             return functools.reduce(getattr, self.attrs, module)\nL20689:         except AttributeError as exc:\nL20690:             raise ImportError(str(exc)) from exc\nL20691: \nL20692:     def require(\nL20693:         self,\nL20694:         env: Environment | None = None,\nL20695:         installer: _InstallerType | None = None,\nL20696:     ) -> None:\nL20697:         if not self.dist:\nL20698:             error_cls = UnknownExtra if self.extras else AttributeError\nL20699:             raise error_cls(\"Can't require() without a distribution\", self)\nL20700: \nL20701:         # Get the requirements for this entry point with all its extras and\nL20702:         # then resolve them. We have to pass `extras` along when resolving so\nL20703:         # that the working set knows what extras we want. Otherwise, for\nL20704:         # dist-info distributions, the working set will assume that the\nL20705:         # requirements for that extra are purely optional and skip over them.\nL20706:         reqs = self.dist.requires(self.extras)\nL20707:         items = working_set.resolve(reqs, env, installer, extras=self.extras)\nL20708:         list(map(working_set.add, items))\nL20709: \nL20710:     pattern = re.compile(\nL20711:         r'\\s*'\nL20712:         r'(?P<name>.+?)\\s*'\nL20713:         r'=\\s*'\nL20714:         r'(?P<module>[\\w.]+)\\s*'\nL20715:         r'(:\\s*(?P<attr>[\\w.]+))?\\s*'\nL20716:         r'(?P<extras>\\[.*\\])?\\s*$'\nL20717:     )\nL20718: \nL20719:     @classmethod\nL20720:     def parse(cls, src: str, dist: Distribution | None = None) -> Self:\nL20721:         \"\"\"Parse a single entry point from string `src`\nL20722: \nL20723:         Entry point syntax follows the form::\nL20724: \nL20725:             name = some.module:some.attr [extra1, extra2]\nL20726: \nL20727:         The entry name and module name are required, but the ``:attrs`` and\nL20728:         ``[extras]`` parts are optional\nL20729:         \"\"\"\nL20730:         m = cls.pattern.match(src)\nL20731:         if not m:\nL20732:             msg = \"EntryPoint must be in 'name=module:attrs [extras]' format\"\nL20733:             raise ValueError(msg, src)\nL20734:         res = m.groupdict()\nL20735:         extras = cls._parse_extras(res['extras'])\nL20736:         attrs = res['attr'].split('.') if res['attr'] else ()\nL20737:         return cls(res['name'], res['module'], attrs, extras, dist)\nL20738: \nL20739:     @classmethod\nL20740:     def _parse_extras(cls, extras_spec):\nL20741:         if not extras_spec:\nL20742:             return ()\nL20743:         req = Requirement.parse('x' + extras_spec)\nL20744:         if req.specs:\nL20745:             raise ValueError\nL20746:         return req.extras\nL20747: \nL20748:     @classmethod\nL20749:     def parse_group(\nL20750:         cls,\nL20751:         group: str,\nL20752:         lines: _NestedStr,\nL20753:         dist: Distribution | None = None,\nL20754:     ) -> dict[str, Self]:\nL20755:         \"\"\"Parse an entry point group\"\"\"\nL20756:         if not MODULE(group):\nL20757:             raise ValueError(\"Invalid group name\", group)\nL20758:         this: dict[str, Self] = {}\nL20759:         for line in yield_lines(lines):\nL20760:             ep = cls.parse(line, dist)\nL20761:             if ep.name in this:\nL20762:                 raise ValueError(\"Duplicate entry point\", group, ep.name)\nL20763:             this[ep.name] = ep\nL20764:         return this\nL20765: \nL20766:     @classmethod\nL20767:     def parse_map(\nL20768:         cls,\nL20769:         data: str | Iterable[str] | dict[str, str | Iterable[str]],\nL20770:         dist: Distribution | None = None,\nL20771:     ) -> dict[str, dict[str, Self]]:\nL20772:         \"\"\"Parse a map of entry point groups\"\"\"\nL20773:         _data: Iterable[tuple[str | None, str | Iterable[str]]]\nL20774:         if isinstance(data, dict):\nL20775:             _data = data.items()\nL20776:         else:\nL20777:             _data = split_sections(data)\nL20778:         maps: dict[str, dict[str, Self]] = {}\nL20779:         for group, lines in _data:\nL20780:             if group is None:\nL20781:                 if not lines:\nL20782:                     continue\nL20783:                 raise ValueError(\"Entry points must be listed in groups\")\nL20784:             group = group.strip()\nL20785:             if group in maps:\nL20786:                 raise ValueError(\"Duplicate group name\", group)\nL20787:             maps[group] = cls.parse_group(group, lines, dist)\nL20788:         return maps\nL20789: \nL20790: \nL20791: def _version_from_file(lines):\nL20792:     \"\"\"\nL20793:     Given an iterable of lines from a Metadata file, return\nL20794:     the value of the Version field, if present, or None otherwise.\nL20795:     \"\"\"\nL20796: \nL20797:     def is_version_line(line):\nL20798:         return line.lower().startswith('version:')\nL20799: \nL20800:     version_lines = filter(is_version_line, lines)\nL20801:     line = next(iter(version_lines), '')\nL20802:     _, _, value = line.partition(':')\nL20803:     return safe_version(value.strip()) or None\nL20804: \nL20805: \nL20806: class Distribution:\nL20807:     \"\"\"Wrap an actual or potential sys.path entry w/metadata\"\"\"\nL20808: \nL20809:     PKG_INFO = 'PKG-INFO'\nL20810: \nL20811:     def __init__(\nL20812:         self,\nL20813:         location: str | None = None,\nL20814:         metadata: _MetadataType = None,\nL20815:         project_name: str | None = None,\nL20816:         version: str | None = None,\nL20817:         py_version: str | None = PY_MAJOR,\nL20818:         platform: str | None = None,\nL20819:         precedence: int = EGG_DIST,\nL20820:     ) -> None:\nL20821:         self.project_name = safe_name(project_name or 'Unknown')\nL20822:         if version is not None:\nL20823:             self._version = safe_version(version)\nL20824:         self.py_version = py_version\nL20825:         self.platform = platform\nL20826:         self.location = location\nL20827:         self.precedence = precedence\nL20828:         self._provider = metadata or empty_provider\nL20829: \nL20830:     @classmethod\nL20831:     def from_location(\nL20832:         cls,\nL20833:         location: str,\nL20834:         basename: StrPath,\nL20835:         metadata: _MetadataType = None,\nL20836:         **kw: int,  # We could set `precedence` explicitly, but keeping this as `**kw` for full backwards and subclassing compatibility\nL20837:     ) -> Distribution:\nL20838:         project_name, version, py_version, platform = [None] * 4\nL20839:         basename, ext = os.path.splitext(basename)\nL20840:         if ext.lower() in _distributionImpl:\nL20841:             cls = _distributionImpl[ext.lower()]\nL20842: \nL20843:             match = EGG_NAME(basename)\nL20844:             if match:\nL20845:                 project_name, version, py_version, platform = match.group(\nL20846:                     'name', 'ver', 'pyver', 'plat'\nL20847:                 )\nL20848:         return cls(\nL20849:             location,\nL20850:             metadata,\nL20851:             project_name=project_name,\nL20852:             version=version,\nL20853:             py_version=py_version,\nL20854:             platform=platform,\nL20855:             **kw,\nL20856:         )._reload_version()\nL20857: \nL20858:     def _reload_version(self):\nL20859:         return self\nL20860: \nL20861:     @property\nL20862:     def hashcmp(self):\nL20863:         return (\nL20864:             self._forgiving_parsed_version,\nL20865:             self.precedence,\nL20866:             self.key,\nL20867:             self.location,\nL20868:             self.py_version or '',\nL20869:             self.platform or '',\nL20870:         )\nL20871: \nL20872:     def __hash__(self) -> int:\nL20873:         return hash(self.hashcmp)\nL20874: \nL20875:     def __lt__(self, other: Distribution) -> bool:\nL20876:         return self.hashcmp < other.hashcmp\nL20877: \nL20878:     def __le__(self, other: Distribution) -> bool:\nL20879:         return self.hashcmp <= other.hashcmp\nL20880: \nL20881:     def __gt__(self, other: Distribution) -> bool:\nL20882:         return self.hashcmp > other.hashcmp\nL20883: \nL20884:     def __ge__(self, other: Distribution) -> bool:\nL20885:         return self.hashcmp >= other.hashcmp\nL20886: \nL20887:     def __eq__(self, other: object) -> bool:\nL20888:         if not isinstance(other, self.__class__):\nL20889:             # It's not a Distribution, so they are not equal\nL20890:             return False\nL20891:         return self.hashcmp == other.hashcmp\nL20892: \nL20893:     def __ne__(self, other: object) -> bool:\nL20894:         return not self == other\nL20895: \nL20896:     # These properties have to be lazy so that we don't have to load any\nL20897:     # metadata until/unless it's actually needed.  (i.e., some distributions\nL20898:     # may not know their name or version without loading PKG-INFO)\nL20899: \nL20900:     @property\nL20901:     def key(self):\nL20902:         try:\nL20903:             return self._key\nL20904:         except AttributeError:\nL20905:             self._key = key = self.project_name.lower()\nL20906:             return key\nL20907: \nL20908:     @property\nL20909:     def parsed_version(self):\nL20910:         if not hasattr(self, \"_parsed_version\"):\nL20911:             try:\nL20912:                 self._parsed_version = parse_version(self.version)\nL20913:             except packaging.version.InvalidVersion as ex:\nL20914:                 info = f\"(package: {self.project_name})\"\nL20915:                 if hasattr(ex, \"add_note\"):\nL20916:                     ex.add_note(info)  # PEP 678\nL20917:                     raise\nL20918:                 raise packaging.version.InvalidVersion(f\"{str(ex)} {info}\") from None\nL20919: \nL20920:         return self._parsed_version\nL20921: \nL20922:     @property\nL20923:     def _forgiving_parsed_version(self):\nL20924:         try:\nL20925:             return self.parsed_version\nL20926:         except packaging.version.InvalidVersion as ex:\nL20927:             self._parsed_version = parse_version(_forgiving_version(self.version))\nL20928: \nL20929:             notes = \"\\n\".join(getattr(ex, \"__notes__\", []))  # PEP 678\nL20930:             msg = f\"\"\"!!\\n\\n\nL20931:             *************************************************************************\nL20932:             {str(ex)}\\n{notes}\nL20933: \nL20934:             This is a long overdue deprecation.\nL20935:             For the time being, `pkg_resources` will use `{self._parsed_version}`\nL20936:             as a replacement to avoid breaking existing environments,\nL20937:             but no future compatibility is guaranteed.\nL20938: \nL20939:             If you maintain package {self.project_name} you should implement\nL20940:             the relevant changes to adequate the project to PEP 440 immediately.\nL20941:             *************************************************************************\nL20942:             \\n\\n!!\nL20943:             \"\"\"\nL20944:             warnings.warn(msg, DeprecationWarning)\nL20945: \nL20946:             return self._parsed_version\nL20947: \nL20948:     @property\nL20949:     def version(self):\nL20950:         try:\nL20951:             return self._version\nL20952:         except AttributeError as e:\nL20953:             version = self._get_version()\nL20954:             if version is None:\nL20955:                 path = self._get_metadata_path_for_display(self.PKG_INFO)\nL20956:                 msg = f\"Missing 'Version:' header and/or {self.PKG_INFO} file at path: {path}\"\nL20957:                 raise ValueError(msg, self) from e\nL20958: \nL20959:             return version\nL20960: \nL20961:     @property\nL20962:     def _dep_map(self):\nL20963:         \"\"\"\nL20964:         A map of extra to its list of (direct) requirements\nL20965:         for this distribution, including the null extra.\nL20966:         \"\"\"\nL20967:         try:\nL20968:             return self.__dep_map\nL20969:         except AttributeError:\nL20970:             self.__dep_map = self._filter_extras(self._build_dep_map())\nL20971:         return self.__dep_map\nL20972: \nL20973:     @staticmethod\nL20974:     def _filter_extras(\nL20975:         dm: dict[str | None, list[Requirement]],\nL20976:     ) -> dict[str | None, list[Requirement]]:\nL20977:         \"\"\"\nL20978:         Given a mapping of extras to dependencies, strip off\nL20979:         environment markers and filter out any dependencies\nL20980:         not matching the markers.\nL20981:         \"\"\"\nL20982:         for extra in list(filter(None, dm)):\nL20983:             new_extra: str | None = extra\nL20984:             reqs = dm.pop(extra)\nL20985:             new_extra, _, marker = extra.partition(':')\nL20986:             fails_marker = marker and (\nL20987:                 invalid_marker(marker) or not evaluate_marker(marker)\nL20988:             )\nL20989:             if fails_marker:\nL20990:                 reqs = []\nL20991:             new_extra = safe_extra(new_extra) or None\nL20992: \nL20993:             dm.setdefault(new_extra, []).extend(reqs)\nL20994:         return dm\nL20995: \nL20996:     def _build_dep_map(self):\nL20997:         dm = {}\nL20998:         for name in 'requires.txt', 'depends.txt':\nL20999:             for extra, reqs in split_sections(self._get_metadata(name)):\nL21000:                 dm.setdefault(extra, []).extend(parse_requirements(reqs))\nL21001:         return dm\nL21002: \nL21003:     def requires(self, extras: Iterable[str] = ()) -> list[Requirement]:\nL21004:         \"\"\"List of Requirements needed for this distro if `extras` are used\"\"\"\nL21005:         dm = self._dep_map\nL21006:         deps: list[Requirement] = []\nL21007:         deps.extend(dm.get(None, ()))\nL21008:         for ext in extras:\nL21009:             try:\nL21010:                 deps.extend(dm[safe_extra(ext)])\nL21011:             except KeyError as e:\nL21012:                 raise UnknownExtra(f\"{self} has no such extra feature {ext!r}\") from e\nL21013:         return deps\nL21014: \nL21015:     def _get_metadata_path_for_display(self, name):\nL21016:         \"\"\"\nL21017:         Return the path to the given metadata file, if available.\nL21018:         \"\"\"\nL21019:         try:\nL21020:             # We need to access _get_metadata_path() on the provider object\nL21021:             # directly rather than through this class's __getattr__()\nL21022:             # since _get_metadata_path() is marked private.\nL21023:             path = self._provider._get_metadata_path(name)\nL21024: \nL21025:         # Handle exceptions e.g. in case the distribution's metadata\nL21026:         # provider doesn't support _get_metadata_path().\nL21027:         except Exception:\nL21028:             return '[could not detect]'\nL21029: \nL21030:         return path\nL21031: \nL21032:     def _get_metadata(self, name):\nL21033:         if self.has_metadata(name):\nL21034:             yield from self.get_metadata_lines(name)\nL21035: \nL21036:     def _get_version(self):\nL21037:         lines = self._get_metadata(self.PKG_INFO)\nL21038:         return _version_from_file(lines)\nL21039: \nL21040:     def activate(self, path: list[str] | None = None, replace: bool = False) -> None:\nL21041:         \"\"\"Ensure distribution is importable on `path` (default=sys.path)\"\"\"\nL21042:         if path is None:\nL21043:             path = sys.path\nL21044:         self.insert_on(path, replace=replace)\nL21045:         if path is sys.path and self.location is not None:\nL21046:             fixup_namespace_packages(self.location)\nL21047:             for pkg in self._get_metadata('namespace_packages.txt'):\nL21048:                 if pkg in sys.modules:\nL21049:                     declare_namespace(pkg)\nL21050: \nL21051:     def egg_name(self):\nL21052:         \"\"\"Return what this distribution's standard .egg filename should be\"\"\"\nL21053:         filename = f\"{to_filename(self.project_name)}-{to_filename(self.version)}-py{self.py_version or PY_MAJOR}\"\nL21054: \nL21055:         if self.platform:\nL21056:             filename += '-' + self.platform\nL21057:         return filename\nL21058: \nL21059:     def __repr__(self) -> str:\nL21060:         if self.location:\nL21061:             return f\"{self} ({self.location})\"\nL21062:         else:\nL21063:             return str(self)\nL21064: \nL21065:     def __str__(self) -> str:\nL21066:         try:\nL21067:             version = getattr(self, 'version', None)\nL21068:         except ValueError:\nL21069:             version = None\nL21070:         version = version or \"[unknown version]\"\nL21071:         return f\"{self.project_name} {version}\"\nL21072: \nL21073:     def __getattr__(self, attr: str):\nL21074:         \"\"\"Delegate all unrecognized public attributes to .metadata provider\"\"\"\nL21075:         if attr.startswith('_'):\nL21076:             raise AttributeError(attr)\nL21077:         return getattr(self._provider, attr)\nL21078: \nL21079:     def __dir__(self):\nL21080:         return list(\nL21081:             set(super().__dir__())\nL21082:             | set(attr for attr in self._provider.__dir__() if not attr.startswith('_'))\nL21083:         )\nL21084: \nL21085:     @classmethod\nL21086:     def from_filename(\nL21087:         cls,\nL21088:         filename: StrPath,\nL21089:         metadata: _MetadataType = None,\nL21090:         **kw: int,  # We could set `precedence` explicitly, but keeping this as `**kw` for full backwards and subclassing compatibility\nL21091:     ) -> Distribution:\nL21092:         return cls.from_location(\nL21093:             _normalize_cached(filename), os.path.basename(filename), metadata, **kw\nL21094:         )\nL21095: \nL21096:     def as_requirement(self):\nL21097:         \"\"\"Return a ``Requirement`` that matches this distribution exactly\"\"\"\nL21098:         if isinstance(self.parsed_version, packaging.version.Version):\nL21099:             spec = f\"{self.project_name}=={self.parsed_version}\"\nL21100:         else:\nL21101:             spec = f\"{self.project_name}==={self.parsed_version}\"\nL21102: \nL21103:         return Requirement.parse(spec)\nL21104: \nL21105:     def load_entry_point(self, group: str, name: str) -> _ResolvedEntryPoint:\nL21106:         \"\"\"Return the `name` entry point of `group` or raise ImportError\"\"\"\nL21107:         ep = self.get_entry_info(group, name)\nL21108:         if ep is None:\nL21109:             raise ImportError(f\"Entry point {(group, name)!r} not found\")\nL21110:         return ep.load()\nL21111: \nL21112:     @overload\nL21113:     def get_entry_map(self, group: None = None) -> dict[str, dict[str, EntryPoint]]: ...\nL21114:     @overload\nL21115:     def get_entry_map(self, group: str) -> dict[str, EntryPoint]: ...\nL21116:     def get_entry_map(self, group: str | None = None):\nL21117:         \"\"\"Return the entry point map for `group`, or the full entry map\"\"\"\nL21118:         if not hasattr(self, \"_ep_map\"):\nL21119:             self._ep_map = EntryPoint.parse_map(\nL21120:                 self._get_metadata('entry_points.txt'), self\nL21121:             )\nL21122:         if group is not None:\nL21123:             return self._ep_map.get(group, {})\nL21124:         return self._ep_map\nL21125: \nL21126:     def get_entry_info(self, group: str, name: str) -> EntryPoint | None:\nL21127:         \"\"\"Return the EntryPoint object for `group`+`name`, or ``None``\"\"\"\nL21128:         return self.get_entry_map(group).get(name)\nL21129: \nL21130:     # FIXME: 'Distribution.insert_on' is too complex (13)\nL21131:     def insert_on(  # noqa: C901\nL21132:         self,\nL21133:         path: list[str],\nL21134:         loc=None,\nL21135:         replace: bool = False,\nL21136:     ) -> None:\nL21137:         \"\"\"Ensure self.location is on path\nL21138: \nL21139:         If replace=False (default):\nL21140:             - If location is already in path anywhere, do nothing.\nL21141:             - Else:\nL21142:               - If it's an egg and its parent directory is on path,\nL21143:                 insert just ahead of the parent.\nL21144:               - Else: add to the end of path.\nL21145:         If replace=True:\nL21146:             - If location is already on path anywhere (not eggs)\nL21147:               or higher priority than its parent (eggs)\nL21148:               do nothing.\nL21149:             - Else:\nL21150:               - If it's an egg and its parent directory is on path,\nL21151:                 insert just ahead of the parent,\nL21152:                 removing any lower-priority entries.\nL21153:               - Else: add it to the front of path.\nL21154:         \"\"\"\nL21155: \nL21156:         loc = loc or self.location\nL21157:         if not loc:\nL21158:             return\nL21159: \nL21160:         nloc = _normalize_cached(loc)\nL21161:         bdir = os.path.dirname(nloc)\nL21162:         npath = [(p and _normalize_cached(p) or p) for p in path]\nL21163: \nL21164:         for p, item in enumerate(npath):\nL21165:             if item == nloc:\nL21166:                 if replace:\nL21167:                     break\nL21168:                 else:\nL21169:                     # don't modify path (even removing duplicates) if\nL21170:                     # found and not replace\nL21171:                     return\nL21172:             elif item == bdir and self.precedence == EGG_DIST:\nL21173:                 # if it's an .egg, give it precedence over its directory\nL21174:                 # UNLESS it's already been added to sys.path and replace=False\nL21175:                 if (not replace) and nloc in npath[p:]:\nL21176:                     return\nL21177:                 if path is sys.path:\nL21178:                     self.check_version_conflict()\nL21179:                 path.insert(p, loc)\nL21180:                 npath.insert(p, nloc)\nL21181:                 break\nL21182:         else:\nL21183:             if path is sys.path:\nL21184:                 self.check_version_conflict()\nL21185:             if replace:\nL21186:                 path.insert(0, loc)\nL21187:             else:\nL21188:                 path.append(loc)\nL21189:             return\nL21190: \nL21191:         # p is the spot where we found or inserted loc; now remove duplicates\nL21192:         while True:\nL21193:             try:\nL21194:                 np = npath.index(nloc, p + 1)\nL21195:             except ValueError:\nL21196:                 break\nL21197:             else:\nL21198:                 del npath[np], path[np]\nL21199:                 # ha!\nL21200:                 p = np\nL21201: \nL21202:         return\nL21203: \nL21204:     def check_version_conflict(self):\nL21205:         if self.key == 'setuptools':\nL21206:             # ignore the inevitable setuptools self-conflicts  :(\nL21207:             return\nL21208: \nL21209:         nsp = dict.fromkeys(self._get_metadata('namespace_packages.txt'))\nL21210:         loc = normalize_path(self.location)\nL21211:         for modname in self._get_metadata('top_level.txt'):\nL21212:             if (\nL21213:                 modname not in sys.modules\nL21214:                 or modname in nsp\nL21215:                 or modname in _namespace_packages\nL21216:             ):\nL21217:                 continue\nL21218:             if modname in ('pkg_resources', 'setuptools', 'site'):\nL21219:                 continue\nL21220:             fn = getattr(sys.modules[modname], '__file__', None)\nL21221:             if fn and (\nL21222:                 normalize_path(fn).startswith(loc) or fn.startswith(self.location)\nL21223:             ):\nL21224:                 continue\nL21225:             issue_warning(\nL21226:                 f\"Module {modname} was already imported from {fn}, \"\nL21227:                 f\"but {self.location} is being added to sys.path\",\nL21228:             )\nL21229: \nL21230:     def has_version(self) -> bool:\nL21231:         try:\nL21232:             self.version\nL21233:         except ValueError:\nL21234:             issue_warning(\"Unbuilt egg for \" + repr(self))\nL21235:             return False\nL21236:         except SystemError:\nL21237:             # TODO: remove this except clause when python/cpython#103632 is fixed.\nL21238:             return False\nL21239:         return True\nL21240: \nL21241:     def clone(self, **kw: str | int | IResourceProvider | None) -> Self:\nL21242:         \"\"\"Copy this distribution, substituting in any changed keyword args\"\"\"\nL21243:         names = 'project_name version py_version platform location precedence'\nL21244:         for attr in names.split():\nL21245:             kw.setdefault(attr, getattr(self, attr, None))\nL21246:         kw.setdefault('metadata', self._provider)\nL21247:         # Unsafely unpacking. But keeping **kw for backwards and subclassing compatibility\nL21248:         return self.__class__(**kw)  # type:ignore[arg-type]\nL21249: \nL21250:     @property\nL21251:     def extras(self):\nL21252:         return [dep for dep in self._dep_map if dep]\nL21253: \nL21254: \nL21255: class EggInfoDistribution(Distribution):\nL21256:     def _reload_version(self):\nL21257:         \"\"\"\nL21258:         Packages installed by distutils (e.g. numpy or scipy),\nL21259:         which uses an old safe_version, and so\nL21260:         their version numbers can get mangled when\nL21261:         converted to filenames (e.g., 1.11.0.dev0+2329eae to\nL21262:         1.11.0.dev0_2329eae). These distributions will not be\nL21263:         parsed properly\nL21264:         downstream by Distribution and safe_version, so\nL21265:         take an extra step and try to get the version number from\nL21266:         the metadata file itself instead of the filename.\nL21267:         \"\"\"\nL21268:         md_version = self._get_version()\nL21269:         if md_version:\nL21270:             self._version = md_version\nL21271:         return self\nL21272: \nL21273: \nL21274: class DistInfoDistribution(Distribution):\nL21275:     \"\"\"\nL21276:     Wrap an actual or potential sys.path entry\nL21277:     w/metadata, .dist-info style.\nL21278:     \"\"\"\nL21279: \nL21280:     PKG_INFO = 'METADATA'\nL21281:     EQEQ = re.compile(r\"([\\(,])\\s*(\\d.*?)\\s*([,\\)])\")\nL21282: \nL21283:     @property\nL21284:     def _parsed_pkg_info(self):\nL21285:         \"\"\"Parse and cache metadata\"\"\"\nL21286:         try:\nL21287:             return self._pkg_info\nL21288:         except AttributeError:\nL21289:             metadata = self.get_metadata(self.PKG_INFO)\nL21290:             self._pkg_info = email.parser.Parser().parsestr(metadata)\nL21291:             return self._pkg_info\nL21292: \nL21293:     @property\nL21294:     def _dep_map(self):\nL21295:         try:\nL21296:             return self.__dep_map\nL21297:         except AttributeError:\nL21298:             self.__dep_map = self._compute_dependencies()\nL21299:             return self.__dep_map\nL21300: \nL21301:     def _compute_dependencies(self) -> dict[str | None, list[Requirement]]:\nL21302:         \"\"\"Recompute this distribution's dependencies.\"\"\"\nL21303:         self.__dep_map: dict[str | None, list[Requirement]] = {None: []}\nL21304: \nL21305:         reqs: list[Requirement] = []\nL21306:         # Including any condition expressions\nL21307:         for req in self._parsed_pkg_info.get_all('Requires-Dist') or []:\nL21308:             reqs.extend(parse_requirements(req))\nL21309: \nL21310:         def reqs_for_extra(extra):\nL21311:             for req in reqs:\nL21312:                 if not req.marker or req.marker.evaluate({'extra': extra}):\nL21313:                     yield req\nL21314: \nL21315:         common = types.MappingProxyType(dict.fromkeys(reqs_for_extra(None)))\nL21316:         self.__dep_map[None].extend(common)\nL21317: \nL21318:         for extra in self._parsed_pkg_info.get_all('Provides-Extra') or []:\nL21319:             s_extra = safe_extra(extra.strip())\nL21320:             self.__dep_map[s_extra] = [\nL21321:                 r for r in reqs_for_extra(extra) if r not in common\nL21322:             ]\nL21323: \nL21324:         return self.__dep_map\nL21325: \nL21326: \nL21327: _distributionImpl = {\nL21328:     '.egg': Distribution,\nL21329:     '.egg-info': EggInfoDistribution,\nL21330:     '.dist-info': DistInfoDistribution,\nL21331: }\nL21332: \nL21333: \nL21334: def issue_warning(*args, **kw):\nL21335:     level = 1\nL21336:     g = globals()\nL21337:     try:\nL21338:         # find the first stack frame that is *not* code in\nL21339:         # the pkg_resources module, to use for the warning\nL21340:         while sys._getframe(level).f_globals is g:\nL21341:             level += 1\nL21342:     except ValueError:\nL21343:         pass\nL21344:     warnings.warn(stacklevel=level + 1, *args, **kw)\nL21345: \nL21346: \nL21347: def parse_requirements(strs: _NestedStr) -> map[Requirement]:\nL21348:     \"\"\"\nL21349:     Yield ``Requirement`` objects for each specification in `strs`.\nL21350: \nL21351:     `strs` must be a string, or a (possibly-nested) iterable thereof.\nL21352:     \"\"\"\nL21353:     return map(Requirement, join_continuation(map(drop_comment, yield_lines(strs))))\nL21354: \nL21355: \nL21356: class RequirementParseError(packaging.requirements.InvalidRequirement):\nL21357:     \"Compatibility wrapper for InvalidRequirement\"\nL21358: \nL21359: \nL21360: class Requirement(packaging.requirements.Requirement):\nL21361:     # prefer variable length tuple to set (as found in\nL21362:     # packaging.requirements.Requirement)\nL21363:     extras: tuple[str, ...]  # type: ignore[assignment]\nL21364: \nL21365:     def __init__(self, requirement_string: str) -> None:\nL21366:         \"\"\"DO NOT CALL THIS UNDOCUMENTED METHOD; use Requirement.parse()!\"\"\"\nL21367:         super().__init__(requirement_string)\nL21368:         self.unsafe_name = self.name\nL21369:         project_name = safe_name(self.name)\nL21370:         self.project_name, self.key = project_name, project_name.lower()\nL21371:         self.specs = [(spec.operator, spec.version) for spec in self.specifier]\nL21372:         self.extras = tuple(map(safe_extra, self.extras))\nL21373:         self.hashCmp = (\nL21374:             self.key,\nL21375:             self.url,\nL21376:             self.specifier,\nL21377:             frozenset(self.extras),\nL21378:             str(self.marker) if self.marker else None,\nL21379:         )\nL21380:         self.__hash = hash(self.hashCmp)\nL21381: \nL21382:     def __eq__(self, other: object) -> bool:\nL21383:         return isinstance(other, Requirement) and self.hashCmp == other.hashCmp\nL21384: \nL21385:     def __ne__(self, other: object) -> bool:\nL21386:         return not self == other\nL21387: \nL21388:     def __contains__(\nL21389:         self, item: Distribution | packaging.specifiers.UnparsedVersion\nL21390:     ) -> bool:\nL21391:         if isinstance(item, Distribution):\nL21392:             if item.key != self.key:\nL21393:                 return False\nL21394: \nL21395:             version = item.version\nL21396:         else:\nL21397:             version = item\nL21398: \nL21399:         # Allow prereleases always in order to match the previous behavior of\nL21400:         # this method. In the future this should be smarter and follow PEP 440\nL21401:         # more accurately.\nL21402:         return self.specifier.contains(\nL21403:             version,\nL21404:             prereleases=True,\nL21405:         )\nL21406: \nL21407:     def __hash__(self) -> int:\nL21408:         return self.__hash\nL21409: \nL21410:     def __repr__(self) -> str:\nL21411:         return f\"Requirement.parse({str(self)!r})\"\nL21412: \nL21413:     @staticmethod\nL21414:     def parse(s: str | Iterable[str]) -> Requirement:\nL21415:         (req,) = parse_requirements(s)\nL21416:         return req\nL21417: \nL21418: \nL21419: def _always_object(classes):\nL21420:     \"\"\"\nL21421:     Ensure object appears in the mro even\nL21422:     for old-style classes.\nL21423:     \"\"\"\nL21424:     if object not in classes:\nL21425:         return classes + (object,)\nL21426:     return classes\nL21427: \nL21428: \nL21429: def _find_adapter(registry: Mapping[type, _AdapterT], ob: object) -> _AdapterT:\nL21430:     \"\"\"Return an adapter factory for `ob` from `registry`\"\"\"\nL21431:     types = _always_object(inspect.getmro(getattr(ob, '__class__', type(ob))))\nL21432:     for t in types:\nL21433:         if t in registry:\nL21434:             return registry[t]\nL21435:     # _find_adapter would previously return None, and immediately be called.\nL21436:     # So we're raising a TypeError to keep backward compatibility if anyone depended on that behaviour.\nL21437:     raise TypeError(f\"Could not find adapter for {registry} and {ob}\")\nL21438: \nL21439: \nL21440: def ensure_directory(path: StrOrBytesPath) -> None:\nL21441:     \"\"\"Ensure that the parent directory of `path` exists\"\"\"\nL21442:     dirname = os.path.dirname(path)\nL21443:     os.makedirs(dirname, exist_ok=True)\nL21444: \nL21445: \nL21446: def _bypass_ensure_directory(path) -> None:\nL21447:     \"\"\"Sandbox-bypassing version of ensure_directory()\"\"\"\nL21448:     if not WRITE_SUPPORT:\nL21449:         raise OSError('\"os.mkdir\" not supported on this platform.')\nL21450:     dirname, filename = split(path)\nL21451:     if dirname and filename and not isdir(dirname):\nL21452:         _bypass_ensure_directory(dirname)\nL21453:         try:\nL21454:             mkdir(dirname, 0o755)\nL21455:         except FileExistsError:\nL21456:             pass\nL21457: \nL21458: \nL21459: def split_sections(s: _NestedStr) -> Iterator[tuple[str | None, list[str]]]:\nL21460:     \"\"\"Split a string or iterable thereof into (section, content) pairs\nL21461: \nL21462:     Each ``section`` is a stripped version of the section header (\"[section]\")\nL21463:     and each ``content`` is a list of stripped lines excluding blank lines and\nL21464:     comment-only lines.  If there are any such lines before the first section\nL21465:     header, they're returned in a first ``section`` of ``None``.\nL21466:     \"\"\"\nL21467:     section = None\nL21468:     content: list[str] = []\nL21469:     for line in yield_lines(s):\nL21470:         if line.startswith(\"[\"):\nL21471:             if line.endswith(\"]\"):\nL21472:                 if section or content:\nL21473:                     yield section, content\nL21474:                 section = line[1:-1].strip()\nL21475:                 content = []\nL21476:             else:\nL21477:                 raise ValueError(\"Invalid section heading\", line)\nL21478:         else:\nL21479:             content.append(line)\nL21480: \nL21481:     # wrap up last segment\nL21482:     yield section, content\nL21483: \nL21484: \nL21485: def _mkstemp(*args, **kw):\nL21486:     old_open = os.open\nL21487:     try:\nL21488:         # temporarily bypass sandboxing\nL21489:         os.open = os_open\nL21490:         return tempfile.mkstemp(*args, **kw)\nL21491:     finally:\nL21492:         # and then put it back\nL21493:         os.open = old_open\nL21494: \nL21495: \nL21496: # Silence the PEP440Warning by default, so that end users don't get hit by it\nL21497: # randomly just because they use pkg_resources. We want to append the rule\nL21498: # because we want earlier uses of filterwarnings to take precedence over this\nL21499: # one.\nL21500: warnings.filterwarnings(\"ignore\", category=PEP440Warning, append=True)\nL21501: \nL21502: \nL21503: class PkgResourcesDeprecationWarning(Warning):\nL21504:     \"\"\"\nL21505:     Base class for warning about deprecations in ``pkg_resources``\nL21506: \nL21507:     This class is not derived from ``DeprecationWarning``, and as such is\nL21508:     visible by default.\nL21509:     \"\"\"\nL21510: \nL21511: \nL21512: # Ported from ``setuptools`` to avoid introducing an import inter-dependency:\nL21513: _LOCALE_ENCODING = \"locale\" if sys.version_info >= (3, 10) else None\nL21514: \nL21515: \nL21516: # This must go before calls to `_call_aside`. See https://github.com/pypa/setuptools/pull/4422\nL21517: def _read_utf8_with_fallback(file: str, fallback_encoding=_LOCALE_ENCODING) -> str:\nL21518:     \"\"\"See setuptools.unicode_utils._read_utf8_with_fallback\"\"\"\nL21519:     try:\nL21520:         with open(file, \"r\", encoding=\"utf-8\") as f:\nL21521:             return f.read()\nL21522:     except UnicodeDecodeError:  # pragma: no cover\nL21523:         msg = f\"\"\"\\\nL21524:         ********************************************************************************\nL21525:         `encoding=\"utf-8\"` fails with {file!r}, trying `encoding={fallback_encoding!r}`.\nL21526: \nL21527:         This fallback behaviour is considered **deprecated** and future versions of\nL21528:         `setuptools/pkg_resources` may not implement it.\nL21529: \nL21530:         Please encode {file!r} with \"utf-8\" to ensure future builds will succeed.\nL21531: \nL21532:         If this file was produced by `setuptools` itself, cleaning up the cached files\nL21533:         and re-building/re-installing the package with a newer version of `setuptools`\nL21534:         (e.g. by updating `build-system.requires` in its `pyproject.toml`)\nL21535:         might solve the problem.\nL21536:         ********************************************************************************\nL21537:         \"\"\"\nL21538:         # TODO: Add a deadline?\nL21539:         #       See comment in setuptools.unicode_utils._Utf8EncodingNeeded\nL21540:         warnings.warn(msg, PkgResourcesDeprecationWarning, stacklevel=2)\nL21541:         with open(file, \"r\", encoding=fallback_encoding) as f:\nL21542:             return f.read()\nL21543: \nL21544: \nL21545: # from jaraco.functools 1.3\nL21546: def _call_aside(f, *args, **kwargs):\nL21547:     f(*args, **kwargs)\nL21548:     return f\nL21549: \nL21550: \nL21551: @_call_aside\nL21552: def _initialize(g=globals()) -> None:\nL21553:     \"Set up global resource manager (deliberately not state-saved)\"\nL21554:     manager = ResourceManager()\nL21555:     g['_manager'] = manager\nL21556:     g.update(\nL21557:         (name, getattr(manager, name))\nL21558:         for name in dir(manager)\nL21559:         if not name.startswith('_')\nL21560:     )\nL21561: \nL21562: \nL21563: @_call_aside\nL21564: def _initialize_master_working_set() -> None:\nL21565:     \"\"\"\nL21566:     Prepare the master working set and make the ``require()``\nL21567:     API available.\nL21568: \nL21569:     This function has explicit effects on the global state\nL21570:     of pkg_resources. It is intended to be invoked once at\nL21571:     the initialization of this module.\nL21572: \nL21573:     Invocation by other packages is unsupported and done\nL21574:     at their own risk.\nL21575:     \"\"\"\nL21576:     working_set = _declare_state('object', 'working_set', WorkingSet._build_master())\nL21577: \nL21578:     require = working_set.require\nL21579:     iter_entry_points = working_set.iter_entry_points\nL21580:     add_activation_listener = working_set.subscribe\nL21581:     run_script = working_set.run_script\nL21582:     # backward compatibility\nL21583:     run_main = run_script\nL21584:     # Activate all distributions already on sys.path with replace=False and\nL21585:     # ensure that all distributions added to the working set in the future\nL21586:     # (e.g. by calling ``require()``) will get activated as well,\nL21587:     # with higher priority (replace=True).\nL21588:     tuple(dist.activate(replace=False) for dist in working_set)\nL21589:     add_activation_listener(\nL21590:         lambda dist: dist.activate(replace=True),\nL21591:         existing=False,\nL21592:     )\nL21593:     working_set.entries = []\nL21594:     # match order\nL21595:     list(map(working_set.add_entry, sys.path))\nL21596:     globals().update(locals())\nL21597: \nL21598: \nL21599: if TYPE_CHECKING:\nL21600:     # All of these are set by the @_call_aside methods above\nL21601:     __resource_manager = ResourceManager()  # Won't exist at runtime\nL21602:     resource_exists = __resource_manager.resource_exists\nL21603:     resource_isdir = __resource_manager.resource_isdir\nL21604:     resource_filename = __resource_manager.resource_filename\nL21605:     resource_stream = __resource_manager.resource_stream\nL21606:     resource_string = __resource_manager.resource_string\nL21607:     resource_listdir = __resource_manager.resource_listdir\nL21608:     set_extraction_path = __resource_manager.set_extraction_path\nL21609:     cleanup_resources = __resource_manager.cleanup_resources\nL21610: \nL21611:     working_set = WorkingSet()\nL21612:     require = working_set.require\nL21613:     iter_entry_points = working_set.iter_entry_points\nL21614:     add_activation_listener = working_set.subscribe\nL21615:     run_script = working_set.run_script\nL21616:     run_main = run_script\nL21617: \nL21618: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/pkg_resources/tests/test_resources.py\nL21619: #!/usr/bin/env python3\nL21620: import itertools\nL21621: import os\nL21622: import platform\nL21623: import string\nL21624: import sys\nL21625: \nL21626: import pytest\nL21627: from packaging.specifiers import SpecifierSet\nL21628: \nL21629: import pkg_resources\nL21630: from pkg_resources import (\nL21631:     Distribution,\nL21632:     EntryPoint,\nL21633:     Requirement,\nL21634:     VersionConflict,\nL21635:     WorkingSet,\nL21636:     parse_requirements,\nL21637:     parse_version,\nL21638:     safe_name,\nL21639:     safe_version,\nL21640: )\nL21641: \nL21642: \nL21643: # from Python 3.6 docs. Available from itertools on Python 3.10\nL21644: def pairwise(iterable):\nL21645:     \"s -> (s0,s1), (s1,s2), (s2, s3), ...\"\nL21646:     a, b = itertools.tee(iterable)\nL21647:     next(b, None)\nL21648:     return zip(a, b)\nL21649: \nL21650: \nL21651: class Metadata(pkg_resources.EmptyProvider):\nL21652:     \"\"\"Mock object to return metadata as if from an on-disk distribution\"\"\"\nL21653: \nL21654:     def __init__(self, *pairs) -> None:\nL21655:         self.metadata = dict(pairs)\nL21656: \nL21657:     def has_metadata(self, name) -> bool:\nL21658:         return name in self.metadata\nL21659: \nL21660:     def get_metadata(self, name):\nL21661:         return self.metadata[name]\nL21662: \nL21663:     def get_metadata_lines(self, name):\nL21664:         return pkg_resources.yield_lines(self.get_metadata(name))\nL21665: \nL21666: \nL21667: dist_from_fn = pkg_resources.Distribution.from_filename\nL21668: \nL21669: \nL21670: class TestDistro:\nL21671:     def testCollection(self):\nL21672:         # empty path should produce no distributions\nL21673:         ad = pkg_resources.Environment([], platform=None, python=None)\nL21674:         assert list(ad) == []\nL21675:         assert ad['FooPkg'] == []\nL21676:         ad.add(dist_from_fn(\"FooPkg-1.3_1.egg\"))\nL21677:         ad.add(dist_from_fn(\"FooPkg-1.4-py2.4-win32.egg\"))\nL21678:         ad.add(dist_from_fn(\"FooPkg-1.2-py2.4.egg\"))\nL21679: \nL21680:         # Name is in there now\nL21681:         assert ad['FooPkg']\nL21682:         # But only 1 package\nL21683:         assert list(ad) == ['foopkg']\nL21684: \nL21685:         # Distributions sort by version\nL21686:         expected = ['1.4', '1.3-1', '1.2']\nL21687:         assert [dist.version for dist in ad['FooPkg']] == expected\nL21688: \nL21689:         # Removing a distribution leaves sequence alone\nL21690:         ad.remove(ad['FooPkg'][1])\nL21691:         assert [dist.version for dist in ad['FooPkg']] == ['1.4', '1.2']\nL21692: \nL21693:         # And inserting adds them in order\nL21694:         ad.add(dist_from_fn(\"FooPkg-1.9.egg\"))\nL21695:         assert [dist.version for dist in ad['FooPkg']] == ['1.9', '1.4', '1.2']\nL21696: \nL21697:         ws = WorkingSet([])\nL21698:         foo12 = dist_from_fn(\"FooPkg-1.2-py2.4.egg\")\nL21699:         foo14 = dist_from_fn(\"FooPkg-1.4-py2.4-win32.egg\")\nL21700:         (req,) = parse_requirements(\"FooPkg>=1.3\")\nL21701: \nL21702:         # Nominal case: no distros on path, should yield all applicable\nL21703:         assert ad.best_match(req, ws).version == '1.9'\nL21704:         # If a matching distro is already installed, should return only that\nL21705:         ws.add(foo14)\nL21706:         assert ad.best_match(req, ws).version == '1.4'\nL21707: \nL21708:         # If the first matching distro is unsuitable, it's a version conflict\nL21709:         ws = WorkingSet([])\nL21710:         ws.add(foo12)\nL21711:         ws.add(foo14)\nL21712:         with pytest.raises(VersionConflict):\nL21713:             ad.best_match(req, ws)\nL21714: \nL21715:         # If more than one match on the path, the first one takes precedence\nL21716:         ws = WorkingSet([])\nL21717:         ws.add(foo14)\nL21718:         ws.add(foo12)\nL21719:         ws.add(foo14)\nL21720:         assert ad.best_match(req, ws).version == '1.4'\nL21721: \nL21722:     def checkFooPkg(self, d):\nL21723:         assert d.project_name == \"FooPkg\"\nL21724:         assert d.key == \"foopkg\"\nL21725:         assert d.version == \"1.3.post1\"\nL21726:         assert d.py_version == \"2.4\"\nL21727:         assert d.platform == \"win32\"\nL21728:         assert d.parsed_version == parse_version(\"1.3-1\")\nL21729: \nL21730:     def testDistroBasics(self):\nL21731:         d = Distribution(\nL21732:             \"/some/path\",\nL21733:             project_name=\"FooPkg\",\nL21734:             version=\"1.3-1\",\nL21735:             py_version=\"2.4\",\nL21736:             platform=\"win32\",\nL21737:         )\nL21738:         self.checkFooPkg(d)\nL21739: \nL21740:         d = Distribution(\"/some/path\")\nL21741:         assert d.py_version == f'{sys.version_info.major}.{sys.version_info.minor}'\nL21742:         assert d.platform is None\nL21743: \nL21744:     def testDistroParse(self):\nL21745:         d = dist_from_fn(\"FooPkg-1.3.post1-py2.4-win32.egg\")\nL21746:         self.checkFooPkg(d)\nL21747:         d = dist_from_fn(\"FooPkg-1.3.post1-py2.4-win32.egg-info\")\nL21748:         self.checkFooPkg(d)\nL21749: \nL21750:     def testDistroMetadata(self):\nL21751:         d = Distribution(\nL21752:             \"/some/path\",\nL21753:             project_name=\"FooPkg\",\nL21754:             py_version=\"2.4\",\nL21755:             platform=\"win32\",\nL21756:             metadata=Metadata(('PKG-INFO', \"Metadata-Version: 1.0\\nVersion: 1.3-1\\n\")),\nL21757:         )\nL21758:         self.checkFooPkg(d)\nL21759: \nL21760:     def distRequires(self, txt):\nL21761:         return Distribution(\"/foo\", metadata=Metadata(('depends.txt', txt)))\nL21762: \nL21763:     def checkRequires(self, dist, txt, extras=()):\nL21764:         assert list(dist.requires(extras)) == list(parse_requirements(txt))\nL21765: \nL21766:     def testDistroDependsSimple(self):\nL21767:         for v in \"Twisted>=1.5\", \"Twisted>=1.5\\nZConfig>=2.0\":\nL21768:             self.checkRequires(self.distRequires(v), v)\nL21769: \nL21770:     needs_object_dir = pytest.mark.skipif(\nL21771:         not hasattr(object, '__dir__'),\nL21772:         reason='object.__dir__ necessary for self.__dir__ implementation',\nL21773:     )\nL21774: \nL21775:     def test_distribution_dir(self):\nL21776:         d = pkg_resources.Distribution()\nL21777:         dir(d)\nL21778: \nL21779:     @needs_object_dir\nL21780:     def test_distribution_dir_includes_provider_dir(self):\nL21781:         d = pkg_resources.Distribution()\nL21782:         before = d.__dir__()\nL21783:         assert 'test_attr' not in before\nL21784:         d._provider.test_attr = None\nL21785:         after = d.__dir__()\nL21786:         assert len(after) == len(before) + 1\nL21787:         assert 'test_attr' in after\nL21788: \nL21789:     @needs_object_dir\nL21790:     def test_distribution_dir_ignores_provider_dir_leading_underscore(self):\nL21791:         d = pkg_resources.Distribution()\nL21792:         before = d.__dir__()\nL21793:         assert '_test_attr' not in before\nL21794:         d._provider._test_attr = None\nL21795:         after = d.__dir__()\nL21796:         assert len(after) == len(before)\nL21797:         assert '_test_attr' not in after\nL21798: \nL21799:     def testResolve(self):\nL21800:         ad = pkg_resources.Environment([])\nL21801:         ws = WorkingSet([])\nL21802:         # Resolving no requirements -> nothing to install\nL21803:         assert list(ws.resolve([], ad)) == []\nL21804:         # Request something not in the collection -> DistributionNotFound\nL21805:         with pytest.raises(pkg_resources.DistributionNotFound):\nL21806:             ws.resolve(parse_requirements(\"Foo\"), ad)\nL21807: \nL21808:         Foo = Distribution.from_filename(\nL21809:             \"/foo_dir/Foo-1.2.egg\",\nL21810:             metadata=Metadata(('depends.txt', \"[bar]\\nBaz>=2.0\")),\nL21811:         )\nL21812:         ad.add(Foo)\nL21813:         ad.add(Distribution.from_filename(\"Foo-0.9.egg\"))\nL21814: \nL21815:         # Request thing(s) that are available -> list to activate\nL21816:         for i in range(3):\nL21817:             targets = list(ws.resolve(parse_requirements(\"Foo\"), ad))\nL21818:             assert targets == [Foo]\nL21819:             list(map(ws.add, targets))\nL21820:         with pytest.raises(VersionConflict):\nL21821:             ws.resolve(parse_requirements(\"Foo==0.9\"), ad)\nL21822:         ws = WorkingSet([])  # reset\nL21823: \nL21824:         # Request an extra that causes an unresolved dependency for \"Baz\"\nL21825:         with pytest.raises(pkg_resources.DistributionNotFound):\nL21826:             ws.resolve(parse_requirements(\"Foo[bar]\"), ad)\nL21827:         Baz = Distribution.from_filename(\nL21828:             \"/foo_dir/Baz-2.1.egg\", metadata=Metadata(('depends.txt', \"Foo\"))\nL21829:         )\nL21830:         ad.add(Baz)\nL21831: \nL21832:         # Activation list now includes resolved dependency\nL21833:         assert list(ws.resolve(parse_requirements(\"Foo[bar]\"), ad)) == [Foo, Baz]\nL21834:         # Requests for conflicting versions produce VersionConflict\nL21835:         with pytest.raises(VersionConflict) as vc:\nL21836:             ws.resolve(parse_requirements(\"Foo==1.2\\nFoo!=1.2\"), ad)\nL21837: \nL21838:         msg = 'Foo 0.9 is installed but Foo==1.2 is required'\nL21839:         assert vc.value.report() == msg\nL21840: \nL21841:     def test_environment_marker_evaluation_negative(self):\nL21842:         \"\"\"Environment markers are evaluated at resolution time.\"\"\"\nL21843:         ad = pkg_resources.Environment([])\nL21844:         ws = WorkingSet([])\nL21845:         res = ws.resolve(parse_requirements(\"Foo;python_version<'2'\"), ad)\nL21846:         assert list(res) == []\nL21847: \nL21848:     def test_environment_marker_evaluation_positive(self):\nL21849:         ad = pkg_resources.Environment([])\nL21850:         ws = WorkingSet([])\nL21851:         Foo = Distribution.from_filename(\"/foo_dir/Foo-1.2.dist-info\")\nL21852:         ad.add(Foo)\nL21853:         res = ws.resolve(parse_requirements(\"Foo;python_version>='2'\"), ad)\nL21854:         assert list(res) == [Foo]\nL21855: \nL21856:     def test_environment_marker_evaluation_called(self):\nL21857:         \"\"\"\nL21858:         If one package foo requires bar without any extras,\nL21859:         markers should pass for bar without extras.\nL21860:         \"\"\"\nL21861:         (parent_req,) = parse_requirements(\"foo\")\nL21862:         (req,) = parse_requirements(\"bar;python_version>='2'\")\nL21863:         req_extras = pkg_resources._ReqExtras({req: parent_req.extras})\nL21864:         assert req_extras.markers_pass(req)\nL21865: \nL21866:         (parent_req,) = parse_requirements(\"foo[]\")\nL21867:         (req,) = parse_requirements(\"bar;python_version>='2'\")\nL21868:         req_extras = pkg_resources._ReqExtras({req: parent_req.extras})\nL21869:         assert req_extras.markers_pass(req)\nL21870: \nL21871:     def test_marker_evaluation_with_extras(self):\nL21872:         \"\"\"Extras are also evaluated as markers at resolution time.\"\"\"\nL21873:         ad = pkg_resources.Environment([])\nL21874:         ws = WorkingSet([])\nL21875:         Foo = Distribution.from_filename(\nL21876:             \"/foo_dir/Foo-1.2.dist-info\",\nL21877:             metadata=Metadata((\nL21878:                 \"METADATA\",\nL21879:                 \"Provides-Extra: baz\\nRequires-Dist: quux; extra=='baz'\",\nL21880:             )),\nL21881:         )\nL21882:         ad.add(Foo)\nL21883:         assert list(ws.resolve(parse_requirements(\"Foo\"), ad)) == [Foo]\nL21884:         quux = Distribution.from_filename(\"/foo_dir/quux-1.0.dist-info\")\nL21885:         ad.add(quux)\nL21886:         res = list(ws.resolve(parse_requirements(\"Foo[baz]\"), ad))\nL21887:         assert res == [Foo, quux]\nL21888: \nL21889:     def test_marker_evaluation_with_extras_normlized(self):\nL21890:         \"\"\"Extras are also evaluated as markers at resolution time.\"\"\"\nL21891:         ad = pkg_resources.Environment([])\nL21892:         ws = WorkingSet([])\nL21893:         Foo = Distribution.from_filename(\nL21894:             \"/foo_dir/Foo-1.2.dist-info\",\nL21895:             metadata=Metadata((\nL21896:                 \"METADATA\",\nL21897:                 \"Provides-Extra: baz-lightyear\\n\"\nL21898:                 \"Requires-Dist: quux; extra=='baz-lightyear'\",\nL21899:             )),\nL21900:         )\nL21901:         ad.add(Foo)\nL21902:         assert list(ws.resolve(parse_requirements(\"Foo\"), ad)) == [Foo]\nL21903:         quux = Distribution.from_filename(\"/foo_dir/quux-1.0.dist-info\")\nL21904:         ad.add(quux)\nL21905:         res = list(ws.resolve(parse_requirements(\"Foo[baz-lightyear]\"), ad))\nL21906:         assert res == [Foo, quux]\nL21907: \nL21908:     def test_marker_evaluation_with_multiple_extras(self):\nL21909:         ad = pkg_resources.Environment([])\nL21910:         ws = WorkingSet([])\nL21911:         Foo = Distribution.from_filename(\nL21912:             \"/foo_dir/Foo-1.2.dist-info\",\nL21913:             metadata=Metadata((\nL21914:                 \"METADATA\",\nL21915:                 \"Provides-Extra: baz\\n\"\nL21916:                 \"Requires-Dist: quux; extra=='baz'\\n\"\nL21917:                 \"Provides-Extra: bar\\n\"\nL21918:                 \"Requires-Dist: fred; extra=='bar'\\n\",\nL21919:             )),\nL21920:         )\nL21921:         ad.add(Foo)\nL21922:         quux = Distribution.from_filename(\"/foo_dir/quux-1.0.dist-info\")\nL21923:         ad.add(quux)\nL21924:         fred = Distribution.from_filename(\"/foo_dir/fred-0.1.dist-info\")\nL21925:         ad.add(fred)\nL21926:         res = list(ws.resolve(parse_requirements(\"Foo[baz,bar]\"), ad))\nL21927:         assert sorted(res) == [fred, quux, Foo]\nL21928: \nL21929:     def test_marker_evaluation_with_extras_loop(self):\nL21930:         ad = pkg_resources.Environment([])\nL21931:         ws = WorkingSet([])\nL21932:         a = Distribution.from_filename(\nL21933:             \"/foo_dir/a-0.2.dist-info\",\nL21934:             metadata=Metadata((\"METADATA\", \"Requires-Dist: c[a]\")),\nL21935:         )\nL21936:         b = Distribution.from_filename(\nL21937:             \"/foo_dir/b-0.3.dist-info\",\nL21938:             metadata=Metadata((\"METADATA\", \"Requires-Dist: c[b]\")),\nL21939:         )\nL21940:         c = Distribution.from_filename(\nL21941:             \"/foo_dir/c-1.0.dist-info\",\nL21942:             metadata=Metadata((\nL21943:                 \"METADATA\",\nL21944:                 \"Provides-Extra: a\\n\"\nL21945:                 \"Requires-Dist: b;extra=='a'\\n\"\nL21946:                 \"Provides-Extra: b\\n\"\nL21947:                 \"Requires-Dist: foo;extra=='b'\",\nL21948:             )),\nL21949:         )\nL21950:         foo = Distribution.from_filename(\"/foo_dir/foo-0.1.dist-info\")\nL21951:         for dist in (a, b, c, foo):\nL21952:             ad.add(dist)\nL21953:         res = list(ws.resolve(parse_requirements(\"a\"), ad))\nL21954:         assert res == [a, c, b, foo]\nL21955: \nL21956:     @pytest.mark.xfail(\nL21957:         sys.version_info[:2] == (3, 12) and sys.version_info.releaselevel != 'final',\nL21958:         reason=\"https://github.com/python/cpython/issues/103632\",\nL21959:     )\nL21960:     def testDistroDependsOptions(self):\nL21961:         d = self.distRequires(\nL21962:             \"\"\"\nL21963:             Twisted>=1.5\nL21964:             [docgen]\nL21965:             ZConfig>=2.0\nL21966:             docutils>=0.3\nL21967:             [fastcgi]\nL21968:             fcgiapp>=0.1\"\"\"\nL21969:         )\nL21970:         self.checkRequires(d, \"Twisted>=1.5\")\nL21971:         self.checkRequires(\nL21972:             d, \"Twisted>=1.5 ZConfig>=2.0 docutils>=0.3\".split(), [\"docgen\"]\nL21973:         )\nL21974:         self.checkRequires(d, \"Twisted>=1.5 fcgiapp>=0.1\".split(), [\"fastcgi\"])\nL21975:         self.checkRequires(\nL21976:             d,\nL21977:             \"Twisted>=1.5 ZConfig>=2.0 docutils>=0.3 fcgiapp>=0.1\".split(),\nL21978:             [\"docgen\", \"fastcgi\"],\nL21979:         )\nL21980:         self.checkRequires(\nL21981:             d,\nL21982:             \"Twisted>=1.5 fcgiapp>=0.1 ZConfig>=2.0 docutils>=0.3\".split(),\nL21983:             [\"fastcgi\", \"docgen\"],\nL21984:         )\nL21985:         with pytest.raises(pkg_resources.UnknownExtra):\nL21986:             d.requires([\"foo\"])\nL21987: \nL21988: \nL21989: class TestWorkingSet:\nL21990:     def test_find_conflicting(self):\nL21991:         ws = WorkingSet([])\nL21992:         Foo = Distribution.from_filename(\"/foo_dir/Foo-1.2.egg\")\nL21993:         ws.add(Foo)\nL21994: \nL21995:         # create a requirement that conflicts with Foo 1.2\nL21996:         req = next(parse_requirements(\"Foo<1.2\"))\nL21997: \nL21998:         with pytest.raises(VersionConflict) as vc:\nL21999:             ws.find(req)\nL22000: \nL22001:         msg = 'Foo 1.2 is installed but Foo<1.2 is required'\nL22002:         assert vc.value.report() == msg\nL22003: \nL22004:     def test_resolve_conflicts_with_prior(self):\nL22005:         \"\"\"\nL22006:         A ContextualVersionConflict should be raised when a requirement\nL22007:         conflicts with a prior requirement for a different package.\nL22008:         \"\"\"\nL22009:         # Create installation where Foo depends on Baz 1.0 and Bar depends on\nL22010:         # Baz 2.0.\nL22011:         ws = WorkingSet([])\nL22012:         md = Metadata(('depends.txt', \"Baz==1.0\"))\nL22013:         Foo = Distribution.from_filename(\"/foo_dir/Foo-1.0.egg\", metadata=md)\nL22014:         ws.add(Foo)\nL22015:         md = Metadata(('depends.txt', \"Baz==2.0\"))\nL22016:         Bar = Distribution.from_filename(\"/foo_dir/Bar-1.0.egg\", metadata=md)\nL22017:         ws.add(Bar)\nL22018:         Baz = Distribution.from_filename(\"/foo_dir/Baz-1.0.egg\")\nL22019:         ws.add(Baz)\nL22020:         Baz = Distribution.from_filename(\"/foo_dir/Baz-2.0.egg\")\nL22021:         ws.add(Baz)\nL22022: \nL22023:         with pytest.raises(VersionConflict) as vc:\nL22024:             ws.resolve(parse_requirements(\"Foo\\nBar\\n\"))\nL22025: \nL22026:         msg = \"Baz 1.0 is installed but Baz==2.0 is required by \"\nL22027:         msg += repr(set(['Bar']))\nL22028:         assert vc.value.report() == msg\nL22029: \nL22030: \nL22031: class TestEntryPoints:\nL22032:     def assertfields(self, ep):\nL22033:         assert ep.name == \"foo\"\nL22034:         assert ep.module_name == \"pkg_resources.tests.test_resources\"\nL22035:         assert ep.attrs == (\"TestEntryPoints\",)\nL22036:         assert ep.extras == (\"x\",)\nL22037:         assert ep.load() is TestEntryPoints\nL22038:         expect = \"foo = pkg_resources.tests.test_resources:TestEntryPoints [x]\"\nL22039:         assert str(ep) == expect\nL22040: \nL22041:     def setup_method(self, method):\nL22042:         self.dist = Distribution.from_filename(\nL22043:             \"FooPkg-1.2-py2.4.egg\", metadata=Metadata(('requires.txt', '[x]'))\nL22044:         )\nL22045: \nL22046:     def testBasics(self):\nL22047:         ep = EntryPoint(\nL22048:             \"foo\",\nL22049:             \"pkg_resources.tests.test_resources\",\nL22050:             [\"TestEntryPoints\"],\nL22051:             [\"x\"],\nL22052:             self.dist,\nL22053:         )\nL22054:         self.assertfields(ep)\nL22055: \nL22056:     def testParse(self):\nL22057:         s = \"foo = pkg_resources.tests.test_resources:TestEntryPoints [x]\"\nL22058:         ep = EntryPoint.parse(s, self.dist)\nL22059:         self.assertfields(ep)\nL22060: \nL22061:         ep = EntryPoint.parse(\"bar baz=  spammity[PING]\")\nL22062:         assert ep.name == \"bar baz\"\nL22063:         assert ep.module_name == \"spammity\"\nL22064:         assert ep.attrs == ()\nL22065:         assert ep.extras == (\"ping\",)\nL22066: \nL22067:         ep = EntryPoint.parse(\" fizzly =  wocka:foo\")\nL22068:         assert ep.name == \"fizzly\"\nL22069:         assert ep.module_name == \"wocka\"\nL22070:         assert ep.attrs == (\"foo\",)\nL22071:         assert ep.extras == ()\nL22072: \nL22073:         # plus in the name\nL22074:         spec = \"html+mako = mako.ext.pygmentplugin:MakoHtmlLexer\"\nL22075:         ep = EntryPoint.parse(spec)\nL22076:         assert ep.name == 'html+mako'\nL22077: \nL22078:     reject_specs = \"foo\", \"x=a:b:c\", \"q=x/na\", \"fez=pish:tush-z\", \"x=f[a]>2\"\nL22079: \nL22080:     @pytest.mark.parametrize(\"reject_spec\", reject_specs)\nL22081:     def test_reject_spec(self, reject_spec):\nL22082:         with pytest.raises(ValueError):\nL22083:             EntryPoint.parse(reject_spec)\nL22084: \nL22085:     def test_printable_name(self):\nL22086:         \"\"\"\nL22087:         Allow any printable character in the name.\nL22088:         \"\"\"\nL22089:         # Create a name with all printable characters; strip the whitespace.\nL22090:         name = string.printable.strip()\nL22091:         spec = \"{name} = module:attr\".format(**locals())\nL22092:         ep = EntryPoint.parse(spec)\nL22093:         assert ep.name == name\nL22094: \nL22095:     def checkSubMap(self, m):\nL22096:         assert len(m) == len(self.submap_expect)\nL22097:         for key, ep in self.submap_expect.items():\nL22098:             assert m.get(key).name == ep.name\nL22099:             assert m.get(key).module_name == ep.module_name\nL22100:             assert sorted(m.get(key).attrs) == sorted(ep.attrs)\nL22101:             assert sorted(m.get(key).extras) == sorted(ep.extras)\nL22102: \nL22103:     submap_expect = dict(\nL22104:         feature1=EntryPoint('feature1', 'somemodule', ['somefunction']),\nL22105:         feature2=EntryPoint(\nL22106:             'feature2', 'another.module', ['SomeClass'], ['extra1', 'extra2']\nL22107:         ),\nL22108:         feature3=EntryPoint('feature3', 'this.module', extras=['something']),\nL22109:     )\nL22110:     submap_str = \"\"\"\nL22111:             # define features for blah blah\nL22112:             feature1 = somemodule:somefunction\nL22113:             feature2 = another.module:SomeClass [extra1,extra2]\nL22114:             feature3 = this.module [something]\nL22115:     \"\"\"\nL22116: \nL22117:     def testParseList(self):\nL22118:         self.checkSubMap(EntryPoint.parse_group(\"xyz\", self.submap_str))\nL22119:         with pytest.raises(ValueError):\nL22120:             EntryPoint.parse_group(\"x a\", \"foo=bar\")\nL22121:         with pytest.raises(ValueError):\nL22122:             EntryPoint.parse_group(\"x\", [\"foo=baz\", \"foo=bar\"])\nL22123: \nL22124:     def testParseMap(self):\nL22125:         m = EntryPoint.parse_map({'xyz': self.submap_str})\nL22126:         self.checkSubMap(m['xyz'])\nL22127:         assert list(m.keys()) == ['xyz']\nL22128:         m = EntryPoint.parse_map(\"[xyz]\\n\" + self.submap_str)\nL22129:         self.checkSubMap(m['xyz'])\nL22130:         assert list(m.keys()) == ['xyz']\nL22131:         with pytest.raises(ValueError):\nL22132:             EntryPoint.parse_map([\"[xyz]\", \"[xyz]\"])\nL22133:         with pytest.raises(ValueError):\nL22134:             EntryPoint.parse_map(self.submap_str)\nL22135: \nL22136:     def testDeprecationWarnings(self):\nL22137:         ep = EntryPoint(\nL22138:             \"foo\", \"pkg_resources.tests.test_resources\", [\"TestEntryPoints\"], [\"x\"]\nL22139:         )\nL22140:         with pytest.warns(pkg_resources.PkgResourcesDeprecationWarning):\nL22141:             ep.load(require=False)\nL22142: \nL22143: \nL22144: class TestRequirements:\nL22145:     def testBasics(self):\nL22146:         r = Requirement.parse(\"Twisted>=1.2\")\nL22147:         assert str(r) == \"Twisted>=1.2\"\nL22148:         assert repr(r) == \"Requirement.parse('Twisted>=1.2')\"\nL22149:         assert r == Requirement(\"Twisted>=1.2\")\nL22150:         assert r == Requirement(\"twisTed>=1.2\")\nL22151:         assert r != Requirement(\"Twisted>=2.0\")\nL22152:         assert r != Requirement(\"Zope>=1.2\")\nL22153:         assert r != Requirement(\"Zope>=3.0\")\nL22154:         assert r != Requirement(\"Twisted[extras]>=1.2\")\nL22155: \nL22156:     def testOrdering(self):\nL22157:         r1 = Requirement(\"Twisted==1.2c1,>=1.2\")\nL22158:         r2 = Requirement(\"Twisted>=1.2,==1.2c1\")\nL22159:         assert r1 == r2\nL22160:         assert str(r1) == str(r2)\nL22161:         assert str(r2) == \"Twisted==1.2c1,>=1.2\"\nL22162:         assert Requirement(\"Twisted\") != Requirement(\nL22163:             \"Twisted @ https://localhost/twisted.zip\"\nL22164:         )\nL22165: \nL22166:     def testBasicContains(self):\nL22167:         r = Requirement(\"Twisted>=1.2\")\nL22168:         foo_dist = Distribution.from_filename(\"FooPkg-1.3_1.egg\")\nL22169:         twist11 = Distribution.from_filename(\"Twisted-1.1.egg\")\nL22170:         twist12 = Distribution.from_filename(\"Twisted-1.2.egg\")\nL22171:         assert parse_version('1.2') in r\nL22172:         assert parse_version('1.1') not in r\nL22173:         assert '1.2' in r\nL22174:         assert '1.1' not in r\nL22175:         assert foo_dist not in r\nL22176:         assert twist11 not in r\nL22177:         assert twist12 in r\nL22178: \nL22179:     def testOptionsAndHashing(self):\nL22180:         r1 = Requirement.parse(\"Twisted[foo,bar]>=1.2\")\nL22181:         r2 = Requirement.parse(\"Twisted[bar,FOO]>=1.2\")\nL22182:         assert r1 == r2\nL22183:         assert set(r1.extras) == set((\"foo\", \"bar\"))\nL22184:         assert set(r2.extras) == set((\"foo\", \"bar\"))\nL22185:         assert hash(r1) == hash(r2)\nL22186:         assert hash(r1) == hash((\nL22187:             \"twisted\",\nL22188:             None,\nL22189:             SpecifierSet(\">=1.2\"),\nL22190:             frozenset([\"foo\", \"bar\"]),\nL22191:             None,\nL22192:         ))\nL22193:         assert hash(\nL22194:             Requirement.parse(\"Twisted @ https://localhost/twisted.zip\")\nL22195:         ) == hash((\nL22196:             \"twisted\",\nL22197:             \"https://localhost/twisted.zip\",\nL22198:             SpecifierSet(),\nL22199:             frozenset(),\nL22200:             None,\nL22201:         ))\nL22202: \nL22203:     def testVersionEquality(self):\nL22204:         r1 = Requirement.parse(\"foo==0.3a2\")\nL22205:         r2 = Requirement.parse(\"foo!=0.3a4\")\nL22206:         d = Distribution.from_filename\nL22207: \nL22208:         assert d(\"foo-0.3a4.egg\") not in r1\nL22209:         assert d(\"foo-0.3a1.egg\") not in r1\nL22210:         assert d(\"foo-0.3a4.egg\") not in r2\nL22211: \nL22212:         assert d(\"foo-0.3a2.egg\") in r1\nL22213:         assert d(\"foo-0.3a2.egg\") in r2\nL22214:         assert d(\"foo-0.3a3.egg\") in r2\nL22215:         assert d(\"foo-0.3a5.egg\") in r2\nL22216: \nL22217:     def testSetuptoolsProjectName(self):\nL22218:         \"\"\"\nL22219:         The setuptools project should implement the setuptools package.\nL22220:         \"\"\"\nL22221: \nL22222:         assert Requirement.parse('setuptools').project_name == 'setuptools'\nL22223:         # setuptools 0.7 and higher means setuptools.\nL22224:         assert Requirement.parse('setuptools == 0.7').project_name == 'setuptools'\nL22225:         assert Requirement.parse('setuptools == 0.7a1').project_name == 'setuptools'\nL22226:         assert Requirement.parse('setuptools >= 0.7').project_name == 'setuptools'\nL22227: \nL22228: \nL22229: class TestParsing:\nL22230:     def testEmptyParse(self):\nL22231:         assert list(parse_requirements('')) == []\nL22232: \nL22233:     def testYielding(self):\nL22234:         for inp, out in [\nL22235:             ([], []),\nL22236:             ('x', ['x']),\nL22237:             ([[]], []),\nL22238:             (' x\\n y', ['x', 'y']),\nL22239:             (['x\\n\\n', 'y'], ['x', 'y']),\nL22240:         ]:\nL22241:             assert list(pkg_resources.yield_lines(inp)) == out\nL22242: \nL22243:     def testSplitting(self):\nL22244:         sample = \"\"\"\nL22245:                     x\nL22246:                     [Y]\nL22247:                     z\nL22248: \nL22249:                     a\nL22250:                     [b ]\nL22251:                     # foo\nL22252:                     c\nL22253:                     [ d]\nL22254:                     [q]\nL22255:                     v\nL22256:                     \"\"\"\nL22257:         assert list(pkg_resources.split_sections(sample)) == [\nL22258:             (None, [\"x\"]),\nL22259:             (\"Y\", [\"z\", \"a\"]),\nL22260:             (\"b\", [\"c\"]),\nL22261:             (\"d\", []),\nL22262:             (\"q\", [\"v\"]),\nL22263:         ]\nL22264:         with pytest.raises(ValueError):\nL22265:             list(pkg_resources.split_sections(\"[foo\"))\nL22266: \nL22267:     def testSafeName(self):\nL22268:         assert safe_name(\"adns-python\") == \"adns-python\"\nL22269:         assert safe_name(\"WSGI Utils\") == \"WSGI-Utils\"\nL22270:         assert safe_name(\"WSGI  Utils\") == \"WSGI-Utils\"\nL22271:         assert safe_name(\"Money$$$Maker\") == \"Money-Maker\"\nL22272:         assert safe_name(\"peak.web\") != \"peak-web\"\nL22273: \nL22274:     def testSafeVersion(self):\nL22275:         assert safe_version(\"1.2-1\") == \"1.2.post1\"\nL22276:         assert safe_version(\"1.2 alpha\") == \"1.2.alpha\"\nL22277:         assert safe_version(\"2.3.4 20050521\") == \"2.3.4.20050521\"\nL22278:         assert safe_version(\"Money$$$Maker\") == \"Money-Maker\"\nL22279:         assert safe_version(\"peak.web\") == \"peak.web\"\nL22280: \nL22281:     def testSimpleRequirements(self):\nL22282:         assert list(parse_requirements('Twis-Ted>=1.2-1')) == [\nL22283:             Requirement('Twis-Ted>=1.2-1')\nL22284:         ]\nL22285:         assert list(parse_requirements('Twisted >=1.2, \\\\ # more\\n<2.0')) == [\nL22286:             Requirement('Twisted>=1.2,<2.0')\nL22287:         ]\nL22288:         assert Requirement.parse(\"FooBar==1.99a3\") == Requirement(\"FooBar==1.99a3\")\nL22289:         with pytest.raises(ValueError):\nL22290:             Requirement.parse(\">=2.3\")\nL22291:         with pytest.raises(ValueError):\nL22292:             Requirement.parse(\"x\\\\\")\nL22293:         with pytest.raises(ValueError):\nL22294:             Requirement.parse(\"x==2 q\")\nL22295:         with pytest.raises(ValueError):\nL22296:             Requirement.parse(\"X==1\\nY==2\")\nL22297:         with pytest.raises(ValueError):\nL22298:             Requirement.parse(\"#\")\nL22299: \nL22300:     def test_requirements_with_markers(self):\nL22301:         assert Requirement.parse(\"foobar;os_name=='a'\") == Requirement.parse(\nL22302:             \"foobar;os_name=='a'\"\nL22303:         )\nL22304:         assert Requirement.parse(\nL22305:             \"name==1.1;python_version=='2.7'\"\nL22306:         ) != Requirement.parse(\"name==1.1;python_version=='3.6'\")\nL22307:         assert Requirement.parse(\nL22308:             \"name==1.0;python_version=='2.7'\"\nL22309:         ) != Requirement.parse(\"name==1.2;python_version=='2.7'\")\nL22310:         assert Requirement.parse(\nL22311:             \"name[foo]==1.0;python_version=='3.6'\"\nL22312:         ) != Requirement.parse(\"name[foo,bar]==1.0;python_version=='3.6'\")\nL22313: \nL22314:     def test_local_version(self):\nL22315:         parse_requirements('foo==1.0+org1')\nL22316: \nL22317:     def test_spaces_between_multiple_versions(self):\nL22318:         parse_requirements('foo>=1.0, <3')\nL22319:         parse_requirements('foo >= 1.0, < 3')\nL22320: \nL22321:     @pytest.mark.parametrize(\nL22322:         (\"lower\", \"upper\"),\nL22323:         [\nL22324:             ('1.2-rc1', '1.2rc1'),\nL22325:             ('0.4', '0.4.0'),\nL22326:             ('0.4.0.0', '0.4.0'),\nL22327:             ('0.4.0-0', '0.4-0'),\nL22328:             ('0post1', '0.0post1'),\nL22329:             ('0pre1', '0.0c1'),\nL22330:             ('0.0.0preview1', '0c1'),\nL22331:             ('0.0c1', '0-rc1'),\nL22332:             ('1.2a1', '1.2.a.1'),\nL22333:             ('1.2.a', '1.2a'),\nL22334:         ],\nL22335:     )\nL22336:     def testVersionEquality(self, lower, upper):\nL22337:         assert parse_version(lower) == parse_version(upper)\nL22338: \nL22339:     torture = \"\"\"\nL22340:         0.80.1-3 0.80.1-2 0.80.1-1 0.79.9999+0.80.0pre4-1\nL22341:         0.79.9999+0.80.0pre2-3 0.79.9999+0.80.0pre2-2\nL22342:         0.77.2-1 0.77.1-1 0.77.0-1\nL22343:         \"\"\"\nL22344: \nL22345:     @pytest.mark.parametrize(\nL22346:         (\"lower\", \"upper\"),\nL22347:         [\nL22348:             ('2.1', '2.1.1'),\nL22349:             ('2a1', '2b0'),\nL22350:             ('2a1', '2.1'),\nL22351:             ('2.3a1', '2.3'),\nL22352:             ('2.1-1', '2.1-2'),\nL22353:             ('2.1-1', '2.1.1'),\nL22354:             ('2.1', '2.1post4'),\nL22355:             ('2.1a0-20040501', '2.1'),\nL22356:             ('1.1', '02.1'),\nL22357:             ('3.2', '3.2.post0'),\nL22358:             ('3.2post1', '3.2post2'),\nL22359:             ('0.4', '4.0'),\nL22360:             ('0.0.4', '0.4.0'),\nL22361:             ('0post1', '0.4post1'),\nL22362:             ('2.1.0-rc1', '2.1.0'),\nL22363:             ('2.1dev', '2.1a0'),\nL22364:         ]\nL22365:         + list(pairwise(reversed(torture.split()))),\nL22366:     )\nL22367:     def testVersionOrdering(self, lower, upper):\nL22368:         assert parse_version(lower) < parse_version(upper)\nL22369: \nL22370:     def testVersionHashable(self):\nL22371:         \"\"\"\nL22372:         Ensure that our versions stay hashable even though we've subclassed\nL22373:         them and added some shim code to them.\nL22374:         \"\"\"\nL22375:         assert hash(parse_version(\"1.0\")) == hash(parse_version(\"1.0\"))\nL22376: \nL22377: \nL22378: class TestNamespaces:\nL22379:     ns_str = \"__import__('pkg_resources').declare_namespace(__name__)\\n\"\nL22380: \nL22381:     @pytest.fixture\nL22382:     def symlinked_tmpdir(self, tmpdir):\nL22383:         \"\"\"\nL22384:         Where available, return the tempdir as a symlink,\nL22385:         which as revealed in #231 is more fragile than\nL22386:         a natural tempdir.\nL22387:         \"\"\"\nL22388:         if not hasattr(os, 'symlink'):\nL22389:             yield str(tmpdir)\nL22390:             return\nL22391: \nL22392:         link_name = str(tmpdir) + '-linked'\nL22393:         os.symlink(str(tmpdir), link_name)\nL22394:         try:\nL22395:             yield type(tmpdir)(link_name)\nL22396:         finally:\nL22397:             os.unlink(link_name)\nL22398: \nL22399:     @pytest.fixture(autouse=True)\nL22400:     def patched_path(self, tmpdir):\nL22401:         \"\"\"\nL22402:         Patch sys.path to include the 'site-pkgs' dir. Also\nL22403:         restore pkg_resources._namespace_packages to its\nL22404:         former state.\nL22405:         \"\"\"\nL22406:         saved_ns_pkgs = pkg_resources._namespace_packages.copy()\nL22407:         saved_sys_path = sys.path[:]\nL22408:         site_pkgs = tmpdir.mkdir('site-pkgs')\nL22409:         sys.path.append(str(site_pkgs))\nL22410:         try:\nL22411:             yield\nL22412:         finally:\nL22413:             pkg_resources._namespace_packages = saved_ns_pkgs\nL22414:             sys.path = saved_sys_path\nL22415: \nL22416:     issue591 = pytest.mark.xfail(platform.system() == 'Windows', reason=\"#591\")\nL22417: \nL22418:     @issue591\nL22419:     def test_two_levels_deep(self, symlinked_tmpdir):\nL22420:         \"\"\"\nL22421:         Test nested namespace packages\nL22422:         Create namespace packages in the following tree :\nL22423:             site-packages-1/pkg1/pkg2\nL22424:             site-packages-2/pkg1/pkg2\nL22425:         Check both are in the _namespace_packages dict and that their __path__\nL22426:         is correct\nL22427:         \"\"\"\nL22428:         real_tmpdir = symlinked_tmpdir.realpath()\nL22429:         tmpdir = symlinked_tmpdir\nL22430:         sys.path.append(str(tmpdir / 'site-pkgs2'))\nL22431:         site_dirs = tmpdir / 'site-pkgs', tmpdir / 'site-pkgs2'\nL22432:         for site in site_dirs:\nL22433:             pkg1 = site / 'pkg1'\nL22434:             pkg2 = pkg1 / 'pkg2'\nL22435:             pkg2.ensure_dir()\nL22436:             (pkg1 / '__init__.py').write_text(self.ns_str, encoding='utf-8')\nL22437:             (pkg2 / '__init__.py').write_text(self.ns_str, encoding='utf-8')\nL22438:         with pytest.warns(DeprecationWarning, match=\"pkg_resources.declare_namespace\"):\nL22439:             import pkg1  # pyright: ignore[reportMissingImports] # Temporary package for test\nL22440:         assert \"pkg1\" in pkg_resources._namespace_packages\nL22441:         # attempt to import pkg2 from site-pkgs2\nL22442:         with pytest.warns(DeprecationWarning, match=\"pkg_resources.declare_namespace\"):\nL22443:             import pkg1.pkg2  # pyright: ignore[reportMissingImports] # Temporary package for test\nL22444:         # check the _namespace_packages dict\nL22445:         assert \"pkg1.pkg2\" in pkg_resources._namespace_packages\nL22446:         assert pkg_resources._namespace_packages[\"pkg1\"] == [\"pkg1.pkg2\"]\nL22447:         # check the __path__ attribute contains both paths\nL22448:         expected = [\nL22449:             str(real_tmpdir / \"site-pkgs\" / \"pkg1\" / \"pkg2\"),\nL22450:             str(real_tmpdir / \"site-pkgs2\" / \"pkg1\" / \"pkg2\"),\nL22451:         ]\nL22452:         assert pkg1.pkg2.__path__ == expected\nL22453: \nL22454:     @issue591\nL22455:     def test_path_order(self, symlinked_tmpdir):\nL22456:         \"\"\"\nL22457:         Test that if multiple versions of the same namespace package subpackage\nL22458:         are on different sys.path entries, that only the one earliest on\nL22459:         sys.path is imported, and that the namespace package's __path__ is in\nL22460:         the correct order.\nL22461: \nL22462:         Regression test for https://github.com/pypa/setuptools/issues/207\nL22463:         \"\"\"\nL22464: \nL22465:         tmpdir = symlinked_tmpdir\nL22466:         site_dirs = (\nL22467:             tmpdir / \"site-pkgs\",\nL22468:             tmpdir / \"site-pkgs2\",\nL22469:             tmpdir / \"site-pkgs3\",\nL22470:         )\nL22471: \nL22472:         vers_str = \"__version__ = %r\"\nL22473: \nL22474:         for number, site in enumerate(site_dirs, 1):\nL22475:             if number > 1:\nL22476:                 sys.path.append(str(site))\nL22477:             nspkg = site / 'nspkg'\nL22478:             subpkg = nspkg / 'subpkg'\nL22479:             subpkg.ensure_dir()\nL22480:             (nspkg / '__init__.py').write_text(self.ns_str, encoding='utf-8')\nL22481:             (subpkg / '__init__.py').write_text(vers_str % number, encoding='utf-8')\nL22482: \nL22483:         with pytest.warns(DeprecationWarning, match=\"pkg_resources.declare_namespace\"):\nL22484:             import nspkg  # pyright: ignore[reportMissingImports] # Temporary package for test\nL22485:             import nspkg.subpkg  # pyright: ignore[reportMissingImports] # Temporary package for test\nL22486:         expected = [str(site.realpath() / 'nspkg') for site in site_dirs]\nL22487:         assert nspkg.__path__ == expected\nL22488:         assert nspkg.subpkg.__version__ == 1\nL22489: \nL22490: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/__init__.py\nL22491: #!/usr/bin/env python3\nL22492: \"\"\"Extensions to the 'distutils' for large or complex distributions\"\"\"\nL22493: # mypy: disable_error_code=override\nL22494: # Command.reinitialize_command has an extra **kw param that distutils doesn't have\nL22495: # Can't disable on the exact line because distutils doesn't exists on Python 3.12\nL22496: # and mypy isn't aware of distutils_hack, causing distutils.core.Command to be Any,\nL22497: # and a [unused-ignore] to be raised on 3.12+\nL22498: \nL22499: from __future__ import annotations\nL22500: \nL22501: import functools\nL22502: import os\nL22503: import sys\nL22504: from abc import abstractmethod\nL22505: from collections.abc import Mapping\nL22506: from typing import TYPE_CHECKING, TypeVar, overload\nL22507: \nL22508: sys.path.extend(((vendor_path := os.path.join(os.path.dirname(os.path.dirname(__file__)), 'setuptools', '_vendor')) not in sys.path) * [vendor_path])  # fmt: skip\nL22509: # workaround for #4476\nL22510: sys.modules.pop('backports', None)\nL22511: \nL22512: import _distutils_hack.override  # noqa: F401\nL22513: \nL22514: from . import logging, monkey\nL22515: from .depends import Require\nL22516: from .discovery import PackageFinder, PEP420PackageFinder\nL22517: from .dist import Distribution\nL22518: from .extension import Extension\nL22519: from .version import __version__ as __version__\nL22520: from .warnings import SetuptoolsDeprecationWarning\nL22521: \nL22522: import distutils.core\nL22523: \nL22524: __all__ = [\nL22525:     'setup',\nL22526:     'Distribution',\nL22527:     'Command',\nL22528:     'Extension',\nL22529:     'Require',\nL22530:     'SetuptoolsDeprecationWarning',\nL22531:     'find_packages',\nL22532:     'find_namespace_packages',\nL22533: ]\nL22534: \nL22535: _CommandT = TypeVar(\"_CommandT\", bound=\"_Command\")\nL22536: \nL22537: bootstrap_install_from = None\nL22538: \nL22539: find_packages = PackageFinder.find\nL22540: find_namespace_packages = PEP420PackageFinder.find\nL22541: \nL22542: \nL22543: def _install_setup_requires(attrs):\nL22544:     # Note: do not use `setuptools.Distribution` directly, as\nL22545:     # our PEP 517 backend patch `distutils.core.Distribution`.\nL22546:     class MinimalDistribution(distutils.core.Distribution):\nL22547:         \"\"\"\nL22548:         A minimal version of a distribution for supporting the\nL22549:         fetch_build_eggs interface.\nL22550:         \"\"\"\nL22551: \nL22552:         def __init__(self, attrs: Mapping[str, object]) -> None:\nL22553:             _incl = 'dependency_links', 'setup_requires'\nL22554:             filtered = {k: attrs[k] for k in set(_incl) & set(attrs)}\nL22555:             super().__init__(filtered)\nL22556:             # Prevent accidentally triggering discovery with incomplete set of attrs\nL22557:             self.set_defaults._disable()\nL22558: \nL22559:         def _get_project_config_files(self, filenames=None):\nL22560:             \"\"\"Ignore ``pyproject.toml``, they are not related to setup_requires\"\"\"\nL22561:             try:\nL22562:                 cfg, _toml = super()._split_standard_project_metadata(filenames)\nL22563:             except Exception:\nL22564:                 return filenames, ()\nL22565:             return cfg, ()\nL22566: \nL22567:         def finalize_options(self):\nL22568:             \"\"\"\nL22569:             Disable finalize_options to avoid building the working set.\nL22570:             Ref #2158.\nL22571:             \"\"\"\nL22572: \nL22573:     dist = MinimalDistribution(attrs)\nL22574: \nL22575:     # Honor setup.cfg's options.\nL22576:     dist.parse_config_files(ignore_option_errors=True)\nL22577:     if dist.setup_requires:\nL22578:         _fetch_build_eggs(dist)\nL22579: \nL22580: \nL22581: def _fetch_build_eggs(dist: Distribution):\nL22582:     try:\nL22583:         dist.fetch_build_eggs(dist.setup_requires)\nL22584:     except Exception as ex:\nL22585:         msg = \"\"\"\nL22586:         It is possible a package already installed in your system\nL22587:         contains an version that is invalid according to PEP 440.\nL22588:         You can try `pip install --use-pep517` as a workaround for this problem,\nL22589:         or rely on a new virtual environment.\nL22590: \nL22591:         If the problem refers to a package that is not installed yet,\nL22592:         please contact that package's maintainers or distributors.\nL22593:         \"\"\"\nL22594:         if \"InvalidVersion\" in ex.__class__.__name__:\nL22595:             if hasattr(ex, \"add_note\"):\nL22596:                 ex.add_note(msg)  # PEP 678\nL22597:             else:\nL22598:                 dist.announce(f\"\\n{msg}\\n\")\nL22599:         raise\nL22600: \nL22601: \nL22602: def setup(**attrs):\nL22603:     logging.configure()\nL22604:     # Make sure we have any requirements needed to interpret 'attrs'.\nL22605:     _install_setup_requires(attrs)\nL22606:     return distutils.core.setup(**attrs)\nL22607: \nL22608: \nL22609: setup.__doc__ = distutils.core.setup.__doc__\nL22610: \nL22611: if TYPE_CHECKING:\nL22612:     # Work around a mypy issue where type[T] can't be used as a base: https://github.com/python/mypy/issues/10962\nL22613:     from distutils.core import Command as _Command\nL22614: else:\nL22615:     _Command = monkey.get_unpatched(distutils.core.Command)\nL22616: \nL22617: \nL22618: class Command(_Command):\nL22619:     \"\"\"\nL22620:     Setuptools internal actions are organized using a *command design pattern*.\nL22621:     This means that each action (or group of closely related actions) executed during\nL22622:     the build should be implemented as a ``Command`` subclass.\nL22623: \nL22624:     These commands are abstractions and do not necessarily correspond to a command that\nL22625:     can (or should) be executed via a terminal, in a CLI fashion (although historically\nL22626:     they would).\nL22627: \nL22628:     When creating a new command from scratch, custom defined classes **SHOULD** inherit\nL22629:     from ``setuptools.Command`` and implement a few mandatory methods.\nL22630:     Between these mandatory methods, are listed:\nL22631:     :meth:`initialize_options`, :meth:`finalize_options` and :meth:`run`.\nL22632: \nL22633:     A useful analogy for command classes is to think of them as subroutines with local\nL22634:     variables called \"options\".  The options are \"declared\" in :meth:`initialize_options`\nL22635:     and \"defined\" (given their final values, aka \"finalized\") in :meth:`finalize_options`,\nL22636:     both of which must be defined by every command class. The \"body\" of the subroutine,\nL22637:     (where it does all the work) is the :meth:`run` method.\nL22638:     Between :meth:`initialize_options` and :meth:`finalize_options`, ``setuptools`` may set\nL22639:     the values for options/attributes based on user's input (or circumstance),\nL22640:     which means that the implementation should be careful to not overwrite values in\nL22641:     :meth:`finalize_options` unless necessary.\nL22642: \nL22643:     Please note that other commands (or other parts of setuptools) may also overwrite\nL22644:     the values of the command's options/attributes multiple times during the build\nL22645:     process.\nL22646:     Therefore it is important to consistently implement :meth:`initialize_options` and\nL22647:     :meth:`finalize_options`. For example, all derived attributes (or attributes that\nL22648:     depend on the value of other attributes) **SHOULD** be recomputed in\nL22649:     :meth:`finalize_options`.\nL22650: \nL22651:     When overwriting existing commands, custom defined classes **MUST** abide by the\nL22652:     same APIs implemented by the original class. They also **SHOULD** inherit from the\nL22653:     original class.\nL22654:     \"\"\"\nL22655: \nL22656:     command_consumes_arguments = False\nL22657:     distribution: Distribution  # override distutils.dist.Distribution with setuptools.dist.Distribution\nL22658: \nL22659:     def __init__(self, dist: Distribution, **kw) -> None:\nL22660:         \"\"\"\nL22661:         Construct the command for dist, updating\nL22662:         vars(self) with any keyword parameters.\nL22663:         \"\"\"\nL22664:         super().__init__(dist)\nL22665:         vars(self).update(kw)\nL22666: \nL22667:     @overload\nL22668:     def reinitialize_command(\nL22669:         self, command: str, reinit_subcommands: bool = False, **kw\nL22670:     ) -> _Command: ...\nL22671:     @overload\nL22672:     def reinitialize_command(\nL22673:         self, command: _CommandT, reinit_subcommands: bool = False, **kw\nL22674:     ) -> _CommandT: ...\nL22675:     def reinitialize_command(\nL22676:         self, command: str | _Command, reinit_subcommands: bool = False, **kw\nL22677:     ) -> _Command:\nL22678:         cmd = _Command.reinitialize_command(self, command, reinit_subcommands)\nL22679:         vars(cmd).update(kw)\nL22680:         return cmd  # pyright: ignore[reportReturnType] # pypa/distutils#307\nL22681: \nL22682:     @abstractmethod\nL22683:     def initialize_options(self) -> None:\nL22684:         \"\"\"\nL22685:         Set or (reset) all options/attributes/caches used by the command\nL22686:         to their default values. Note that these values may be overwritten during\nL22687:         the build.\nL22688:         \"\"\"\nL22689:         raise NotImplementedError\nL22690: \nL22691:     @abstractmethod\nL22692:     def finalize_options(self) -> None:\nL22693:         \"\"\"\nL22694:         Set final values for all options/attributes used by the command.\nL22695:         Most of the time, each option/attribute/cache should only be set if it does not\nL22696:         have any value yet (e.g. ``if self.attr is None: self.attr = val``).\nL22697:         \"\"\"\nL22698:         raise NotImplementedError\nL22699: \nL22700:     @abstractmethod\nL22701:     def run(self) -> None:\nL22702:         \"\"\"\nL22703:         Execute the actions intended by the command.\nL22704:         (Side effects **SHOULD** only take place when :meth:`run` is executed,\nL22705:         for example, creating new files or writing to the terminal output).\nL22706:         \"\"\"\nL22707:         raise NotImplementedError\nL22708: \nL22709: \nL22710: def _find_all_simple(path):\nL22711:     \"\"\"\nL22712:     Find all files under 'path'\nL22713:     \"\"\"\nL22714:     results = (\nL22715:         os.path.join(base, file)\nL22716:         for base, dirs, files in os.walk(path, followlinks=True)\nL22717:         for file in files\nL22718:     )\nL22719:     return filter(os.path.isfile, results)\nL22720: \nL22721: \nL22722: def findall(dir=os.curdir):\nL22723:     \"\"\"\nL22724:     Find all files under 'dir' and return the list of full filenames.\nL22725:     Unless dir is '.', return full filenames with dir prepended.\nL22726:     \"\"\"\nL22727:     files = _find_all_simple(dir)\nL22728:     if dir == os.curdir:\nL22729:         make_rel = functools.partial(os.path.relpath, start=dir)\nL22730:         files = map(make_rel, files)\nL22731:     return list(files)\nL22732: \nL22733: \nL22734: class sic(str):\nL22735:     \"\"\"Treat this string as-is (https://en.wikipedia.org/wiki/Sic)\"\"\"\nL22736: \nL22737: \nL22738: # Apply monkey patches\nL22739: monkey.patch_all()\nL22740: \nL22741: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_core_metadata.py\nL22742: #!/usr/bin/env python3\nL22743: \"\"\"\nL22744: Handling of Core Metadata for Python packages (including reading and writing).\nL22745: \nL22746: See: https://packaging.python.org/en/latest/specifications/core-metadata/\nL22747: \"\"\"\nL22748: \nL22749: from __future__ import annotations\nL22750: \nL22751: import os\nL22752: import stat\nL22753: import textwrap\nL22754: from email import message_from_file\nL22755: from email.message import Message\nL22756: from tempfile import NamedTemporaryFile\nL22757: \nL22758: from packaging.markers import Marker\nL22759: from packaging.requirements import Requirement\nL22760: from packaging.utils import canonicalize_name, canonicalize_version\nL22761: from packaging.version import Version\nL22762: \nL22763: from . import _normalization, _reqs\nL22764: from ._static import is_static\nL22765: from .warnings import SetuptoolsDeprecationWarning\nL22766: \nL22767: from distutils.util import rfc822_escape\nL22768: \nL22769: \nL22770: def get_metadata_version(self):\nL22771:     mv = getattr(self, 'metadata_version', None)\nL22772:     if mv is None:\nL22773:         mv = Version('2.4')\nL22774:         self.metadata_version = mv\nL22775:     return mv\nL22776: \nL22777: \nL22778: def rfc822_unescape(content: str) -> str:\nL22779:     \"\"\"Reverse RFC-822 escaping by removing leading whitespaces from content.\"\"\"\nL22780:     lines = content.splitlines()\nL22781:     if len(lines) == 1:\nL22782:         return lines[0].lstrip()\nL22783:     return '\\n'.join((lines[0].lstrip(), textwrap.dedent('\\n'.join(lines[1:]))))\nL22784: \nL22785: \nL22786: def _read_field_from_msg(msg: Message, field: str) -> str | None:\nL22787:     \"\"\"Read Message header field.\"\"\"\nL22788:     value = msg[field]\nL22789:     if value == 'UNKNOWN':\nL22790:         return None\nL22791:     return value\nL22792: \nL22793: \nL22794: def _read_field_unescaped_from_msg(msg: Message, field: str) -> str | None:\nL22795:     \"\"\"Read Message header field and apply rfc822_unescape.\"\"\"\nL22796:     value = _read_field_from_msg(msg, field)\nL22797:     if value is None:\nL22798:         return value\nL22799:     return rfc822_unescape(value)\nL22800: \nL22801: \nL22802: def _read_list_from_msg(msg: Message, field: str) -> list[str] | None:\nL22803:     \"\"\"Read Message header field and return all results as list.\"\"\"\nL22804:     values = msg.get_all(field, None)\nL22805:     if values == []:\nL22806:         return None\nL22807:     return values\nL22808: \nL22809: \nL22810: def _read_payload_from_msg(msg: Message) -> str | None:\nL22811:     value = str(msg.get_payload()).strip()\nL22812:     if value == 'UNKNOWN' or not value:\nL22813:         return None\nL22814:     return value\nL22815: \nL22816: \nL22817: def read_pkg_file(self, file):\nL22818:     \"\"\"Reads the metadata values from a file object.\"\"\"\nL22819:     msg = message_from_file(file)\nL22820: \nL22821:     self.metadata_version = Version(msg['metadata-version'])\nL22822:     self.name = _read_field_from_msg(msg, 'name')\nL22823:     self.version = _read_field_from_msg(msg, 'version')\nL22824:     self.description = _read_field_from_msg(msg, 'summary')\nL22825:     # we are filling author only.\nL22826:     self.author = _read_field_from_msg(msg, 'author')\nL22827:     self.maintainer = None\nL22828:     self.author_email = _read_field_from_msg(msg, 'author-email')\nL22829:     self.maintainer_email = None\nL22830:     self.url = _read_field_from_msg(msg, 'home-page')\nL22831:     self.download_url = _read_field_from_msg(msg, 'download-url')\nL22832:     self.license = _read_field_unescaped_from_msg(msg, 'license')\nL22833:     self.license_expression = _read_field_unescaped_from_msg(msg, 'license-expression')\nL22834: \nL22835:     self.long_description = _read_field_unescaped_from_msg(msg, 'description')\nL22836:     if self.long_description is None and self.metadata_version >= Version('2.1'):\nL22837:         self.long_description = _read_payload_from_msg(msg)\nL22838:     self.description = _read_field_from_msg(msg, 'summary')\nL22839: \nL22840:     if 'keywords' in msg:\nL22841:         self.keywords = _read_field_from_msg(msg, 'keywords').split(',')\nL22842: \nL22843:     self.platforms = _read_list_from_msg(msg, 'platform')\nL22844:     self.classifiers = _read_list_from_msg(msg, 'classifier')\nL22845: \nL22846:     # PEP 314 - these fields only exist in 1.1\nL22847:     if self.metadata_version == Version('1.1'):\nL22848:         self.requires = _read_list_from_msg(msg, 'requires')\nL22849:         self.provides = _read_list_from_msg(msg, 'provides')\nL22850:         self.obsoletes = _read_list_from_msg(msg, 'obsoletes')\nL22851:     else:\nL22852:         self.requires = None\nL22853:         self.provides = None\nL22854:         self.obsoletes = None\nL22855: \nL22856:     self.license_files = _read_list_from_msg(msg, 'license-file')\nL22857: \nL22858: \nL22859: def single_line(val):\nL22860:     \"\"\"\nL22861:     Quick and dirty validation for Summary pypa/setuptools#1390.\nL22862:     \"\"\"\nL22863:     if '\\n' in val:\nL22864:         # TODO: Replace with `raise ValueError(\"newlines not allowed\")`\nL22865:         # after reviewing #2893.\nL22866:         msg = \"newlines are not allowed in `summary` and will break in the future\"\nL22867:         SetuptoolsDeprecationWarning.emit(\"Invalid config.\", msg)\nL22868:         # due_date is undefined. Controversial change, there was a lot of push back.\nL22869:         val = val.strip().split('\\n')[0]\nL22870:     return val\nL22871: \nL22872: \nL22873: def write_pkg_info(self, base_dir):\nL22874:     \"\"\"Write the PKG-INFO file into the release tree.\"\"\"\nL22875:     temp = \"\"\nL22876:     final = os.path.join(base_dir, 'PKG-INFO')\nL22877:     try:\nL22878:         # Use a temporary file while writing to avoid race conditions\nL22879:         # (e.g. `importlib.metadata` reading `.egg-info/PKG-INFO`):\nL22880:         with NamedTemporaryFile(\"w\", encoding=\"utf-8\", dir=base_dir, delete=False) as f:\nL22881:             temp = f.name\nL22882:             self.write_pkg_file(f)\nL22883:         permissions = stat.S_IMODE(os.lstat(temp).st_mode)\nL22884:         os.chmod(temp, permissions | stat.S_IRGRP | stat.S_IROTH)\nL22885:         os.replace(temp, final)  # atomic operation.\nL22886:     finally:\nL22887:         if temp and os.path.exists(temp):\nL22888:             os.remove(temp)\nL22889: \nL22890: \nL22891: # Based on Python 3.5 version\nL22892: def write_pkg_file(self, file):  # noqa: C901  # is too complex (14)  # FIXME\nL22893:     \"\"\"Write the PKG-INFO format data to a file object.\"\"\"\nL22894:     version = self.get_metadata_version()\nL22895: \nL22896:     def write_field(key, value):\nL22897:         file.write(f\"{key}: {value}\\n\")\nL22898: \nL22899:     write_field('Metadata-Version', str(version))\nL22900:     write_field('Name', self.get_name())\nL22901:     write_field('Version', self.get_version())\nL22902: \nL22903:     summary = self.get_description()\nL22904:     if summary:\nL22905:         write_field('Summary', single_line(summary))\nL22906: \nL22907:     optional_fields = (\nL22908:         ('Home-page', 'url'),\nL22909:         ('Download-URL', 'download_url'),\nL22910:         ('Author', 'author'),\nL22911:         ('Author-email', 'author_email'),\nL22912:         ('Maintainer', 'maintainer'),\nL22913:         ('Maintainer-email', 'maintainer_email'),\nL22914:     )\nL22915: \nL22916:     for field, attr in optional_fields:\nL22917:         attr_val = getattr(self, attr, None)\nL22918:         if attr_val is not None:\nL22919:             write_field(field, attr_val)\nL22920: \nL22921:     if license_expression := self.license_expression:\nL22922:         write_field('License-Expression', license_expression)\nL22923:     elif license := self.get_license():\nL22924:         write_field('License', rfc822_escape(license))\nL22925: \nL22926:     for label, url in self.project_urls.items():\nL22927:         write_field('Project-URL', f'{label}, {url}')\nL22928: \nL22929:     keywords = ','.join(self.get_keywords())\nL22930:     if keywords:\nL22931:         write_field('Keywords', keywords)\nL22932: \nL22933:     platforms = self.get_platforms() or []\nL22934:     for platform in platforms:\nL22935:         write_field('Platform', platform)\nL22936: \nL22937:     self._write_list(file, 'Classifier', self.get_classifiers())\nL22938: \nL22939:     # PEP 314\nL22940:     self._write_list(file, 'Requires', self.get_requires())\nL22941:     self._write_list(file, 'Provides', self.get_provides())\nL22942:     self._write_list(file, 'Obsoletes', self.get_obsoletes())\nL22943: \nL22944:     # Setuptools specific for PEP 345\nL22945:     if hasattr(self, 'python_requires'):\nL22946:         write_field('Requires-Python', self.python_requires)\nL22947: \nL22948:     # PEP 566\nL22949:     if self.long_description_content_type:\nL22950:         write_field('Description-Content-Type', self.long_description_content_type)\nL22951: \nL22952:     safe_license_files = map(_safe_license_file, self.license_files or [])\nL22953:     self._write_list(file, 'License-File', safe_license_files)\nL22954:     _write_requirements(self, file)\nL22955: \nL22956:     for field, attr in _POSSIBLE_DYNAMIC_FIELDS.items():\nL22957:         if (val := getattr(self, attr, None)) and not is_static(val):\nL22958:             write_field('Dynamic', field)\nL22959: \nL22960:     long_description = self.get_long_description()\nL22961:     if long_description:\nL22962:         file.write(f\"\\n{long_description}\")\nL22963:         if not long_description.endswith(\"\\n\"):\nL22964:             file.write(\"\\n\")\nL22965: \nL22966: \nL22967: def _write_requirements(self, file):\nL22968:     for req in _reqs.parse(self.install_requires):\nL22969:         file.write(f\"Requires-Dist: {req}\\n\")\nL22970: \nL22971:     processed_extras = {}\nL22972:     for augmented_extra, reqs in self.extras_require.items():\nL22973:         # Historically, setuptools allows \"augmented extras\": `<extra>:<condition>`\nL22974:         unsafe_extra, _, condition = augmented_extra.partition(\":\")\nL22975:         unsafe_extra = unsafe_extra.strip()\nL22976:         extra = _normalization.safe_extra(unsafe_extra)\nL22977: \nL22978:         if extra:\nL22979:             _write_provides_extra(file, processed_extras, extra, unsafe_extra)\nL22980:         for req in _reqs.parse_strings(reqs):\nL22981:             r = _include_extra(req, extra, condition.strip())\nL22982:             file.write(f\"Requires-Dist: {r}\\n\")\nL22983: \nL22984:     return processed_extras\nL22985: \nL22986: \nL22987: def _include_extra(req: str, extra: str, condition: str) -> Requirement:\nL22988:     r = Requirement(req)  # create a fresh object that can be modified\nL22989:     parts = (\nL22990:         f\"({r.marker})\" if r.marker else None,\nL22991:         f\"({condition})\" if condition else None,\nL22992:         f\"extra == {extra!r}\" if extra else None,\nL22993:     )\nL22994:     r.marker = Marker(\" and \".join(x for x in parts if x))\nL22995:     return r\nL22996: \nL22997: \nL22998: def _write_provides_extra(file, processed_extras, safe, unsafe):\nL22999:     previous = processed_extras.get(safe)\nL23000:     if previous == unsafe:\nL23001:         SetuptoolsDeprecationWarning.emit(\nL23002:             'Ambiguity during \"extra\" normalization for dependencies.',\nL23003:             f\"\"\"\nL23004:             {previous!r} and {unsafe!r} normalize to the same value:\\n\nL23005:                 {safe!r}\\n\nL23006:             In future versions, setuptools might halt the build process.\nL23007:             \"\"\",\nL23008:             see_url=\"https://peps.python.org/pep-0685/\",\nL23009:         )\nL23010:     else:\nL23011:         processed_extras[safe] = unsafe\nL23012:         file.write(f\"Provides-Extra: {safe}\\n\")\nL23013: \nL23014: \nL23015: # from pypa/distutils#244; needed only until that logic is always available\nL23016: def get_fullname(self):\nL23017:     return _distribution_fullname(self.get_name(), self.get_version())\nL23018: \nL23019: \nL23020: def _distribution_fullname(name: str, version: str) -> str:\nL23021:     \"\"\"\nL23022:     >>> _distribution_fullname('setup.tools', '1.0-2')\nL23023:     'setup_tools-1.0.post2'\nL23024:     >>> _distribution_fullname('setup-tools', '1.2post2')\nL23025:     'setup_tools-1.2.post2'\nL23026:     >>> _distribution_fullname('setup-tools', '1.0-r2')\nL23027:     'setup_tools-1.0.post2'\nL23028:     >>> _distribution_fullname('setup.tools', '1.0.post')\nL23029:     'setup_tools-1.0.post0'\nL23030:     >>> _distribution_fullname('setup.tools', '1.0+ubuntu-1')\nL23031:     'setup_tools-1.0+ubuntu.1'\nL23032:     \"\"\"\nL23033:     return \"{}-{}\".format(\nL23034:         canonicalize_name(name).replace('-', '_'),\nL23035:         canonicalize_version(version, strip_trailing_zero=False),\nL23036:     )\nL23037: \nL23038: \nL23039: def _safe_license_file(file):\nL23040:     # XXX: Do we need this after the deprecation discussed in #4892, #4896??\nL23041:     normalized = os.path.normpath(file).replace(os.sep, \"/\")\nL23042:     if \"../\" in normalized:\nL23043:         return os.path.basename(normalized)  # Temporarily restore pre PEP639 behaviour\nL23044:     return normalized\nL23045: \nL23046: \nL23047: _POSSIBLE_DYNAMIC_FIELDS = {\nL23048:     # Core Metadata Field x related Distribution attribute\nL23049:     \"author\": \"author\",\nL23050:     \"author-email\": \"author_email\",\nL23051:     \"classifier\": \"classifiers\",\nL23052:     \"description\": \"long_description\",\nL23053:     \"description-content-type\": \"long_description_content_type\",\nL23054:     \"download-url\": \"download_url\",\nL23055:     \"home-page\": \"url\",\nL23056:     \"keywords\": \"keywords\",\nL23057:     \"license\": \"license\",\nL23058:     # XXX: License-File is complicated because the user gives globs that are expanded\nL23059:     #      during the build. Without special handling it is likely always\nL23060:     #      marked as Dynamic, which is an acceptable outcome according to:\nL23061:     #      https://github.com/pypa/setuptools/issues/4629#issuecomment-2331233677\nL23062:     \"license-file\": \"license_files\",\nL23063:     \"license-expression\": \"license_expression\",  # PEP 639\nL23064:     \"maintainer\": \"maintainer\",\nL23065:     \"maintainer-email\": \"maintainer_email\",\nL23066:     \"obsoletes\": \"obsoletes\",\nL23067:     # \"obsoletes-dist\": \"obsoletes_dist\",  # NOT USED\nL23068:     \"platform\": \"platforms\",\nL23069:     \"project-url\": \"project_urls\",\nL23070:     \"provides\": \"provides\",\nL23071:     # \"provides-dist\": \"provides_dist\",  # NOT USED\nL23072:     \"provides-extra\": \"extras_require\",\nL23073:     \"requires\": \"requires\",\nL23074:     \"requires-dist\": \"install_requires\",\nL23075:     # \"requires-external\": \"requires_external\",  # NOT USED\nL23076:     \"requires-python\": \"python_requires\",\nL23077:     \"summary\": \"description\",\nL23078:     # \"supported-platform\": \"supported_platforms\",  # NOT USED\nL23079: }\nL23080: \nL23081: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_normalization.py\nL23082: #!/usr/bin/env python3\nL23083: \"\"\"\nL23084: Helpers for normalization as expected in wheel/sdist/module file names\nL23085: and core metadata\nL23086: \"\"\"\nL23087: \nL23088: import re\nL23089: from typing import TYPE_CHECKING\nL23090: \nL23091: import packaging\nL23092: \nL23093: # https://packaging.python.org/en/latest/specifications/core-metadata/#name\nL23094: _VALID_NAME = re.compile(r\"^([A-Z0-9]|[A-Z0-9][A-Z0-9._-]*[A-Z0-9])$\", re.I)\nL23095: _UNSAFE_NAME_CHARS = re.compile(r\"[^A-Z0-9._-]+\", re.I)\nL23096: _NON_ALPHANUMERIC = re.compile(r\"[^A-Z0-9]+\", re.I)\nL23097: _PEP440_FALLBACK = re.compile(r\"^v?(?P<safe>(?:[0-9]+!)?[0-9]+(?:\\.[0-9]+)*)\", re.I)\nL23098: \nL23099: \nL23100: def safe_identifier(name: str) -> str:\nL23101:     \"\"\"Make a string safe to be used as Python identifier.\nL23102:     >>> safe_identifier(\"12abc\")\nL23103:     '_12abc'\nL23104:     >>> safe_identifier(\"__editable__.myns.pkg-78.9.3_local\")\nL23105:     '__editable___myns_pkg_78_9_3_local'\nL23106:     \"\"\"\nL23107:     safe = re.sub(r'\\W|^(?=\\d)', '_', name)\nL23108:     assert safe.isidentifier()\nL23109:     return safe\nL23110: \nL23111: \nL23112: def safe_name(component: str) -> str:\nL23113:     \"\"\"Escape a component used as a project name according to Core Metadata.\nL23114:     >>> safe_name(\"hello world\")\nL23115:     'hello-world'\nL23116:     >>> safe_name(\"hello?world\")\nL23117:     'hello-world'\nL23118:     >>> safe_name(\"hello_world\")\nL23119:     'hello_world'\nL23120:     \"\"\"\nL23121:     return _UNSAFE_NAME_CHARS.sub(\"-\", component)\nL23122: \nL23123: \nL23124: def safe_version(version: str) -> str:\nL23125:     \"\"\"Convert an arbitrary string into a valid version string.\nL23126:     Can still raise an ``InvalidVersion`` exception.\nL23127:     To avoid exceptions use ``best_effort_version``.\nL23128:     >>> safe_version(\"1988 12 25\")\nL23129:     '1988.12.25'\nL23130:     >>> safe_version(\"v0.2.1\")\nL23131:     '0.2.1'\nL23132:     >>> safe_version(\"v0.2?beta\")\nL23133:     '0.2b0'\nL23134:     >>> safe_version(\"v0.2 beta\")\nL23135:     '0.2b0'\nL23136:     >>> safe_version(\"ubuntu lts\")\nL23137:     Traceback (most recent call last):\nL23138:     ...\nL23139:     packaging.version.InvalidVersion: Invalid version: 'ubuntu.lts'\nL23140:     \"\"\"\nL23141:     v = version.replace(' ', '.')\nL23142:     try:\nL23143:         return str(packaging.version.Version(v))\nL23144:     except packaging.version.InvalidVersion:\nL23145:         attempt = _UNSAFE_NAME_CHARS.sub(\"-\", v)\nL23146:         return str(packaging.version.Version(attempt))\nL23147: \nL23148: \nL23149: def best_effort_version(version: str) -> str:\nL23150:     \"\"\"Convert an arbitrary string into a version-like string.\nL23151:     Fallback when ``safe_version`` is not safe enough.\nL23152:     >>> best_effort_version(\"v0.2 beta\")\nL23153:     '0.2b0'\nL23154:     >>> best_effort_version(\"ubuntu lts\")\nL23155:     '0.dev0+sanitized.ubuntu.lts'\nL23156:     >>> best_effort_version(\"0.23ubuntu1\")\nL23157:     '0.23.dev0+sanitized.ubuntu1'\nL23158:     >>> best_effort_version(\"0.23-\")\nL23159:     '0.23.dev0+sanitized'\nL23160:     >>> best_effort_version(\"0.-_\")\nL23161:     '0.dev0+sanitized'\nL23162:     >>> best_effort_version(\"42.+?1\")\nL23163:     '42.dev0+sanitized.1'\nL23164:     \"\"\"\nL23165:     try:\nL23166:         return safe_version(version)\nL23167:     except packaging.version.InvalidVersion:\nL23168:         v = version.replace(' ', '.')\nL23169:         match = _PEP440_FALLBACK.search(v)\nL23170:         if match:\nL23171:             safe = match[\"safe\"]\nL23172:             rest = v[len(safe) :]\nL23173:         else:\nL23174:             safe = \"0\"\nL23175:             rest = version\nL23176:         safe_rest = _NON_ALPHANUMERIC.sub(\".\", rest).strip(\".\")\nL23177:         local = f\"sanitized.{safe_rest}\".strip(\".\")\nL23178:         return safe_version(f\"{safe}.dev0+{local}\")\nL23179: \nL23180: \nL23181: def safe_extra(extra: str) -> str:\nL23182:     \"\"\"Normalize extra name according to PEP 685\nL23183:     >>> safe_extra(\"_FrIeNdLy-._.-bArD\")\nL23184:     'friendly-bard'\nL23185:     >>> safe_extra(\"FrIeNdLy-._.-bArD__._-\")\nL23186:     'friendly-bard'\nL23187:     \"\"\"\nL23188:     return _NON_ALPHANUMERIC.sub(\"-\", extra).strip(\"-\").lower()\nL23189: \nL23190: \nL23191: def filename_component(value: str) -> str:\nL23192:     \"\"\"Normalize each component of a filename (e.g. distribution/version part of wheel)\nL23193:     Note: ``value`` needs to be already normalized.\nL23194:     >>> filename_component(\"my-pkg\")\nL23195:     'my_pkg'\nL23196:     \"\"\"\nL23197:     return value.replace(\"-\", \"_\").strip(\"_\")\nL23198: \nL23199: \nL23200: def filename_component_broken(value: str) -> str:\nL23201:     \"\"\"\nL23202:     Produce the incorrect filename component for compatibility.\nL23203: \nL23204:     See pypa/setuptools#4167 for detailed analysis.\nL23205: \nL23206:     TODO: replace this with filename_component after pip 24 is\nL23207:     nearly-ubiquitous.\nL23208: \nL23209:     >>> filename_component_broken('foo_bar-baz')\nL23210:     'foo-bar-baz'\nL23211:     \"\"\"\nL23212:     return value.replace('_', '-')\nL23213: \nL23214: \nL23215: def safer_name(value: str) -> str:\nL23216:     \"\"\"Like ``safe_name`` but can be used as filename component for wheel\"\"\"\nL23217:     # See bdist_wheel.safer_name\nL23218:     return (\nL23219:         # Per https://packaging.python.org/en/latest/specifications/name-normalization/#name-normalization\nL23220:         re.sub(r\"[-_.]+\", \"-\", safe_name(value))\nL23221:         .lower()\nL23222:         # Per https://packaging.python.org/en/latest/specifications/binary-distribution-format/#escaping-and-unicode\nL23223:         .replace(\"-\", \"_\")\nL23224:     )\nL23225: \nL23226: \nL23227: def safer_best_effort_version(value: str) -> str:\nL23228:     \"\"\"Like ``best_effort_version`` but can be used as filename component for wheel\"\"\"\nL23229:     # See bdist_wheel.safer_verion\nL23230:     # TODO: Replace with only safe_version in the future (no need for best effort)\nL23231:     return filename_component(best_effort_version(value))\nL23232: \nL23233: \nL23234: def _missing_canonicalize_license_expression(expression: str) -> str:\nL23235:     \"\"\"\nL23236:     Defer import error to affect only users that actually use it\nL23237:     https://github.com/pypa/setuptools/issues/4894\nL23238:     >>> _missing_canonicalize_license_expression(\"a OR b\")\nL23239:     Traceback (most recent call last):\nL23240:     ...\nL23241:     ImportError: ...Cannot import `packaging.licenses`...\nL23242:     \"\"\"\nL23243:     raise ImportError(\nL23244:         \"Cannot import `packaging.licenses`.\"\nL23245:         \"\"\"\nL23246:         Setuptools>=77.0.0 requires \"packaging>=24.2\" to work properly.\nL23247:         Please make sure you have a suitable version installed.\nL23248:         \"\"\"\nL23249:     )\nL23250: \nL23251: \nL23252: try:\nL23253:     from packaging.licenses import (\nL23254:         canonicalize_license_expression as _canonicalize_license_expression,\nL23255:     )\nL23256: except ImportError:  # pragma: nocover\nL23257:     if not TYPE_CHECKING:\nL23258:         # XXX: pyright is still upset even with # pyright: ignore[reportAssignmentType]\nL23259:         _canonicalize_license_expression = _missing_canonicalize_license_expression\nL23260: \nL23261: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_static.py\nL23262: #!/usr/bin/env python3\nL23263: from functools import wraps\nL23264: from typing import TypeVar\nL23265: \nL23266: import packaging.specifiers\nL23267: \nL23268: from .warnings import SetuptoolsDeprecationWarning\nL23269: \nL23270: \nL23271: class Static:\nL23272:     \"\"\"\nL23273:     Wrapper for built-in object types that are allow setuptools to identify\nL23274:     static core metadata (in opposition to ``Dynamic``, as defined :pep:`643`).\nL23275: \nL23276:     The trick is to mark values with :class:`Static` when they come from\nL23277:     ``pyproject.toml`` or ``setup.cfg``, so if any plugin overwrite the value\nL23278:     with a built-in, setuptools will be able to recognise the change.\nL23279: \nL23280:     We inherit from built-in classes, so that we don't need to change the existing\nL23281:     code base to deal with the new types.\nL23282:     We also should strive for immutability objects to avoid changes after the\nL23283:     initial parsing.\nL23284:     \"\"\"\nL23285: \nL23286:     _mutated_: bool = False  # TODO: Remove after deprecation warning is solved\nL23287: \nL23288: \nL23289: def _prevent_modification(target: type, method: str, copying: str) -> None:\nL23290:     \"\"\"\nL23291:     Because setuptools is very flexible we cannot fully prevent\nL23292:     plugins and user customizations from modifying static values that were\nL23293:     parsed from config files.\nL23294:     But we can attempt to block \"in-place\" mutations and identify when they\nL23295:     were done.\nL23296:     \"\"\"\nL23297:     fn = getattr(target, method, None)\nL23298:     if fn is None:\nL23299:         return\nL23300: \nL23301:     @wraps(fn)\nL23302:     def _replacement(self: Static, *args, **kwargs):\nL23303:         # TODO: After deprecation period raise NotImplementedError instead of warning\nL23304:         #       which obviated the existence and checks of the `_mutated_` attribute.\nL23305:         self._mutated_ = True\nL23306:         SetuptoolsDeprecationWarning.emit(\nL23307:             \"Direct modification of value will be disallowed\",\nL23308:             f\"\"\"\nL23309:             In an effort to implement PEP 643, direct/in-place changes of static values\nL23310:             that come from configuration files are deprecated.\nL23311:             If you need to modify this value, please first create a copy with {copying}\nL23312:             and make sure conform to all relevant standards when overriding setuptools\nL23313:             functionality (https://packaging.python.org/en/latest/specifications/).\nL23314:             \"\"\",\nL23315:             due_date=(2025, 10, 10),  # Initially introduced in 2024-09-06\nL23316:         )\nL23317:         return fn(self, *args, **kwargs)\nL23318: \nL23319:     _replacement.__doc__ = \"\"  # otherwise doctest may fail.\nL23320:     setattr(target, method, _replacement)\nL23321: \nL23322: \nL23323: class Str(str, Static):\nL23324:     pass\nL23325: \nL23326: \nL23327: class Tuple(tuple, Static):\nL23328:     pass\nL23329: \nL23330: \nL23331: class List(list, Static):\nL23332:     \"\"\"\nL23333:     :meta private:\nL23334:     >>> x = List([1, 2, 3])\nL23335:     >>> is_static(x)\nL23336:     True\nL23337:     >>> x += [0]  # doctest: +IGNORE_EXCEPTION_DETAIL\nL23338:     Traceback (most recent call last):\nL23339:     SetuptoolsDeprecationWarning: Direct modification ...\nL23340:     >>> is_static(x)  # no longer static after modification\nL23341:     False\nL23342:     >>> y = list(x)\nL23343:     >>> y.clear()\nL23344:     >>> y\nL23345:     []\nL23346:     >>> y == x\nL23347:     False\nL23348:     >>> is_static(List(y))\nL23349:     True\nL23350:     \"\"\"\nL23351: \nL23352: \nL23353: # Make `List` immutable-ish\nL23354: # (certain places of setuptools/distutils issue a warn if we use tuple instead of list)\nL23355: for _method in (\nL23356:     '__delitem__',\nL23357:     '__iadd__',\nL23358:     '__setitem__',\nL23359:     'append',\nL23360:     'clear',\nL23361:     'extend',\nL23362:     'insert',\nL23363:     'remove',\nL23364:     'reverse',\nL23365:     'pop',\nL23366: ):\nL23367:     _prevent_modification(List, _method, \"`list(value)`\")\nL23368: \nL23369: \nL23370: class Dict(dict, Static):\nL23371:     \"\"\"\nL23372:     :meta private:\nL23373:     >>> x = Dict({'a': 1, 'b': 2})\nL23374:     >>> is_static(x)\nL23375:     True\nL23376:     >>> x['c'] = 0  # doctest: +IGNORE_EXCEPTION_DETAIL\nL23377:     Traceback (most recent call last):\nL23378:     SetuptoolsDeprecationWarning: Direct modification ...\nL23379:     >>> x._mutated_\nL23380:     True\nL23381:     >>> is_static(x)  # no longer static after modification\nL23382:     False\nL23383:     >>> y = dict(x)\nL23384:     >>> y.popitem()\nL23385:     ('b', 2)\nL23386:     >>> y == x\nL23387:     False\nL23388:     >>> is_static(Dict(y))\nL23389:     True\nL23390:     \"\"\"\nL23391: \nL23392: \nL23393: # Make `Dict` immutable-ish (we cannot inherit from types.MappingProxyType):\nL23394: for _method in (\nL23395:     '__delitem__',\nL23396:     '__ior__',\nL23397:     '__setitem__',\nL23398:     'clear',\nL23399:     'pop',\nL23400:     'popitem',\nL23401:     'setdefault',\nL23402:     'update',\nL23403: ):\nL23404:     _prevent_modification(Dict, _method, \"`dict(value)`\")\nL23405: \nL23406: \nL23407: class SpecifierSet(packaging.specifiers.SpecifierSet, Static):\nL23408:     \"\"\"Not exactly a built-in type but useful for ``requires-python``\"\"\"\nL23409: \nL23410: \nL23411: T = TypeVar(\"T\")\nL23412: \nL23413: \nL23414: def noop(value: T) -> T:\nL23415:     \"\"\"\nL23416:     >>> noop(42)\nL23417:     42\nL23418:     \"\"\"\nL23419:     return value\nL23420: \nL23421: \nL23422: _CONVERSIONS = {str: Str, tuple: Tuple, list: List, dict: Dict}\nL23423: \nL23424: \nL23425: def attempt_conversion(value: T) -> T:\nL23426:     \"\"\"\nL23427:     >>> is_static(attempt_conversion(\"hello\"))\nL23428:     True\nL23429:     >>> is_static(object())\nL23430:     False\nL23431:     \"\"\"\nL23432:     return _CONVERSIONS.get(type(value), noop)(value)  # type: ignore[call-overload]\nL23433: \nL23434: \nL23435: def is_static(value: object) -> bool:\nL23436:     \"\"\"\nL23437:     >>> is_static(a := Dict({'a': 1}))\nL23438:     True\nL23439:     >>> is_static(dict(a))\nL23440:     False\nL23441:     >>> is_static(b := List([1, 2, 3]))\nL23442:     True\nL23443:     >>> is_static(list(b))\nL23444:     False\nL23445:     \"\"\"\nL23446:     return isinstance(value, Static) and not value._mutated_\nL23447: \nL23448: \nL23449: EMPTY_LIST = List()\nL23450: EMPTY_DICT = Dict()\nL23451: \nL23452: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/build_meta.py\nL23453: #!/usr/bin/env python3\nL23454: \"\"\"A PEP 517 interface to setuptools\nL23455: \nL23456: Previously, when a user or a command line tool (let's call it a \"frontend\")\nL23457: needed to make a request of setuptools to take a certain action, for\nL23458: example, generating a list of installation requirements, the frontend\nL23459: would call \"setup.py egg_info\" or \"setup.py bdist_wheel\" on the command line.\nL23460: \nL23461: PEP 517 defines a different method of interfacing with setuptools. Rather\nL23462: than calling \"setup.py\" directly, the frontend should:\nL23463: \nL23464:   1. Set the current directory to the directory with a setup.py file\nL23465:   2. Import this module into a safe python interpreter (one in which\nL23466:      setuptools can potentially set global variables or crash hard).\nL23467:   3. Call one of the functions defined in PEP 517.\nL23468: \nL23469: What each function does is defined in PEP 517. However, here is a \"casual\"\nL23470: definition of the functions (this definition should not be relied on for\nL23471: bug reports or API stability):\nL23472: \nL23473:   - `build_wheel`: build a wheel in the folder and return the basename\nL23474:   - `get_requires_for_build_wheel`: get the `setup_requires` to build\nL23475:   - `prepare_metadata_for_build_wheel`: get the `install_requires`\nL23476:   - `build_sdist`: build an sdist in the folder and return the basename\nL23477:   - `get_requires_for_build_sdist`: get the `setup_requires` to build\nL23478: \nL23479: Again, this is not a formal definition! Just a \"taste\" of the module.\nL23480: \"\"\"\nL23481: \nL23482: from __future__ import annotations\nL23483: \nL23484: import contextlib\nL23485: import io\nL23486: import os\nL23487: import shlex\nL23488: import shutil\nL23489: import sys\nL23490: import tempfile\nL23491: import tokenize\nL23492: import warnings\nL23493: from collections.abc import Iterable, Iterator, Mapping\nL23494: from pathlib import Path\nL23495: from typing import TYPE_CHECKING, Union\nL23496: \nL23497: import setuptools\nL23498: \nL23499: from . import errors\nL23500: from ._path import StrPath, same_path\nL23501: from ._reqs import parse_strings\nL23502: from .warnings import SetuptoolsDeprecationWarning\nL23503: \nL23504: import distutils\nL23505: from distutils.util import strtobool\nL23506: \nL23507: if TYPE_CHECKING:\nL23508:     from typing_extensions import TypeAlias\nL23509: \nL23510: __all__ = [\nL23511:     'get_requires_for_build_sdist',\nL23512:     'get_requires_for_build_wheel',\nL23513:     'prepare_metadata_for_build_wheel',\nL23514:     'build_wheel',\nL23515:     'build_sdist',\nL23516:     'get_requires_for_build_editable',\nL23517:     'prepare_metadata_for_build_editable',\nL23518:     'build_editable',\nL23519:     '__legacy__',\nL23520:     'SetupRequirementsError',\nL23521: ]\nL23522: \nL23523: \nL23524: class SetupRequirementsError(BaseException):\nL23525:     def __init__(self, specifiers) -> None:\nL23526:         self.specifiers = specifiers\nL23527: \nL23528: \nL23529: class Distribution(setuptools.dist.Distribution):\nL23530:     def fetch_build_eggs(self, specifiers):\nL23531:         specifier_list = list(parse_strings(specifiers))\nL23532: \nL23533:         raise SetupRequirementsError(specifier_list)\nL23534: \nL23535:     @classmethod\nL23536:     @contextlib.contextmanager\nL23537:     def patch(cls):\nL23538:         \"\"\"\nL23539:         Replace\nL23540:         distutils.dist.Distribution with this class\nL23541:         for the duration of this context.\nL23542:         \"\"\"\nL23543:         orig = distutils.core.Distribution\nL23544:         distutils.core.Distribution = cls  # type: ignore[misc] # monkeypatching\nL23545:         try:\nL23546:             yield\nL23547:         finally:\nL23548:             distutils.core.Distribution = orig  # type: ignore[misc] # monkeypatching\nL23549: \nL23550: \nL23551: @contextlib.contextmanager\nL23552: def no_install_setup_requires():\nL23553:     \"\"\"Temporarily disable installing setup_requires\nL23554: \nL23555:     Under PEP 517, the backend reports build dependencies to the frontend,\nL23556:     and the frontend is responsible for ensuring they're installed.\nL23557:     So setuptools (acting as a backend) should not try to install them.\nL23558:     \"\"\"\nL23559:     orig = setuptools._install_setup_requires\nL23560:     setuptools._install_setup_requires = lambda attrs: None\nL23561:     try:\nL23562:         yield\nL23563:     finally:\nL23564:         setuptools._install_setup_requires = orig\nL23565: \nL23566: \nL23567: def _get_immediate_subdirectories(a_dir):\nL23568:     return [\nL23569:         name for name in os.listdir(a_dir) if os.path.isdir(os.path.join(a_dir, name))\nL23570:     ]\nL23571: \nL23572: \nL23573: def _file_with_extension(directory: StrPath, extension: str | tuple[str, ...]):\nL23574:     matching = (f for f in os.listdir(directory) if f.endswith(extension))\nL23575:     try:\nL23576:         (file,) = matching\nL23577:     except ValueError:\nL23578:         raise ValueError(\nL23579:             'No distribution was found. Ensure that `setup.py` '\nL23580:             'is not empty and that it calls `setup()`.'\nL23581:         ) from None\nL23582:     return file\nL23583: \nL23584: \nL23585: def _open_setup_script(setup_script):\nL23586:     if not os.path.exists(setup_script):\nL23587:         # Supply a default setup.py\nL23588:         return io.StringIO(\"from setuptools import setup; setup()\")\nL23589: \nL23590:     return tokenize.open(setup_script)\nL23591: \nL23592: \nL23593: @contextlib.contextmanager\nL23594: def suppress_known_deprecation():\nL23595:     with warnings.catch_warnings():\nL23596:         warnings.filterwarnings('ignore', 'setup.py install is deprecated')\nL23597:         yield\nL23598: \nL23599: \nL23600: _ConfigSettings: TypeAlias = Union[Mapping[str, Union[str, list[str], None]], None]\nL23601: \"\"\"\nL23602: Currently the user can run::\nL23603: \nL23604:     pip install -e . --config-settings key=value\nL23605:     python -m build -C--key=value -C key=value\nL23606: \nL23607: - pip will pass both key and value as strings and overwriting repeated keys\nL23608:   (pypa/pip#11059).\nL23609: - build will accumulate values associated with repeated keys in a list.\nL23610:   It will also accept keys with no associated value.\nL23611:   This means that an option passed by build can be ``str | list[str] | None``.\nL23612: - PEP 517 specifies that ``config_settings`` is an optional dict.\nL23613: \"\"\"\nL23614: \nL23615: \nL23616: class _ConfigSettingsTranslator:\nL23617:     \"\"\"Translate ``config_settings`` into distutils-style command arguments.\nL23618:     Only a limited number of options is currently supported.\nL23619:     \"\"\"\nL23620: \nL23621:     # See pypa/setuptools#1928 pypa/setuptools#2491\nL23622: \nL23623:     def _get_config(self, key: str, config_settings: _ConfigSettings) -> list[str]:\nL23624:         \"\"\"\nL23625:         Get the value of a specific key in ``config_settings`` as a list of strings.\nL23626: \nL23627:         >>> fn = _ConfigSettingsTranslator()._get_config\nL23628:         >>> fn(\"--global-option\", None)\nL23629:         []\nL23630:         >>> fn(\"--global-option\", {})\nL23631:         []\nL23632:         >>> fn(\"--global-option\", {'--global-option': 'foo'})\nL23633:         ['foo']\nL23634:         >>> fn(\"--global-option\", {'--global-option': ['foo']})\nL23635:         ['foo']\nL23636:         >>> fn(\"--global-option\", {'--global-option': 'foo'})\nL23637:         ['foo']\nL23638:         >>> fn(\"--global-option\", {'--global-option': 'foo bar'})\nL23639:         ['foo', 'bar']\nL23640:         \"\"\"\nL23641:         cfg = config_settings or {}\nL23642:         opts = cfg.get(key) or []\nL23643:         return shlex.split(opts) if isinstance(opts, str) else opts\nL23644: \nL23645:     def _global_args(self, config_settings: _ConfigSettings) -> Iterator[str]:\nL23646:         \"\"\"\nL23647:         Let the user specify ``verbose`` or ``quiet`` + escape hatch via\nL23648:         ``--global-option``.\nL23649:         Note: ``-v``, ``-vv``, ``-vvv`` have similar effects in setuptools,\nL23650:         so we just have to cover the basic scenario ``-v``.\nL23651: \nL23652:         >>> fn = _ConfigSettingsTranslator()._global_args\nL23653:         >>> list(fn(None))\nL23654:         []\nL23655:         >>> list(fn({\"verbose\": \"False\"}))\nL23656:         ['-q']\nL23657:         >>> list(fn({\"verbose\": \"1\"}))\nL23658:         ['-v']\nL23659:         >>> list(fn({\"--verbose\": None}))\nL23660:         ['-v']\nL23661:         >>> list(fn({\"verbose\": \"true\", \"--global-option\": \"-q --no-user-cfg\"}))\nL23662:         ['-v', '-q', '--no-user-cfg']\nL23663:         >>> list(fn({\"--quiet\": None}))\nL23664:         ['-q']\nL23665:         \"\"\"\nL23666:         cfg = config_settings or {}\nL23667:         falsey = {\"false\", \"no\", \"0\", \"off\"}\nL23668:         if \"verbose\" in cfg or \"--verbose\" in cfg:\nL23669:             level = str(cfg.get(\"verbose\") or cfg.get(\"--verbose\") or \"1\")\nL23670:             yield (\"-q\" if level.lower() in falsey else \"-v\")\nL23671:         if \"quiet\" in cfg or \"--quiet\" in cfg:\nL23672:             level = str(cfg.get(\"quiet\") or cfg.get(\"--quiet\") or \"1\")\nL23673:             yield (\"-v\" if level.lower() in falsey else \"-q\")\nL23674: \nL23675:         yield from self._get_config(\"--global-option\", config_settings)\nL23676: \nL23677:     def __dist_info_args(self, config_settings: _ConfigSettings) -> Iterator[str]:\nL23678:         \"\"\"\nL23679:         The ``dist_info`` command accepts ``tag-date`` and ``tag-build``.\nL23680: \nL23681:         .. warning::\nL23682:            We cannot use this yet as it requires the ``sdist`` and ``bdist_wheel``\nL23683:            commands run in ``build_sdist`` and ``build_wheel`` to reuse the egg-info\nL23684:            directory created in ``prepare_metadata_for_build_wheel``.\nL23685: \nL23686:         >>> fn = _ConfigSettingsTranslator()._ConfigSettingsTranslator__dist_info_args\nL23687:         >>> list(fn(None))\nL23688:         []\nL23689:         >>> list(fn({\"tag-date\": \"False\"}))\nL23690:         ['--no-date']\nL23691:         >>> list(fn({\"tag-date\": None}))\nL23692:         ['--no-date']\nL23693:         >>> list(fn({\"tag-date\": \"true\", \"tag-build\": \".a\"}))\nL23694:         ['--tag-date', '--tag-build', '.a']\nL23695:         \"\"\"\nL23696:         cfg = config_settings or {}\nL23697:         if \"tag-date\" in cfg:\nL23698:             val = strtobool(str(cfg[\"tag-date\"] or \"false\"))\nL23699:             yield (\"--tag-date\" if val else \"--no-date\")\nL23700:         if \"tag-build\" in cfg:\nL23701:             yield from [\"--tag-build\", str(cfg[\"tag-build\"])]\nL23702: \nL23703:     def _editable_args(self, config_settings: _ConfigSettings) -> Iterator[str]:\nL23704:         \"\"\"\nL23705:         The ``editable_wheel`` command accepts ``editable-mode=strict``.\nL23706: \nL23707:         >>> fn = _ConfigSettingsTranslator()._editable_args\nL23708:         >>> list(fn(None))\nL23709:         []\nL23710:         >>> list(fn({\"editable-mode\": \"strict\"}))\nL23711:         ['--mode', 'strict']\nL23712:         \"\"\"\nL23713:         cfg = config_settings or {}\nL23714:         mode = cfg.get(\"editable-mode\") or cfg.get(\"editable_mode\")\nL23715:         if not mode:\nL23716:             return\nL23717:         yield from [\"--mode\", str(mode)]\nL23718: \nL23719:     def _arbitrary_args(self, config_settings: _ConfigSettings) -> Iterator[str]:\nL23720:         \"\"\"\nL23721:         Users may expect to pass arbitrary lists of arguments to a command\nL23722:         via \"--global-option\" (example provided in PEP 517 of a \"escape hatch\").\nL23723: \nL23724:         >>> fn = _ConfigSettingsTranslator()._arbitrary_args\nL23725:         >>> list(fn(None))\nL23726:         []\nL23727:         >>> list(fn({}))\nL23728:         []\nL23729:         >>> list(fn({'--build-option': 'foo'}))\nL23730:         ['foo']\nL23731:         >>> list(fn({'--build-option': ['foo']}))\nL23732:         ['foo']\nL23733:         >>> list(fn({'--build-option': 'foo'}))\nL23734:         ['foo']\nL23735:         >>> list(fn({'--build-option': 'foo bar'}))\nL23736:         ['foo', 'bar']\nL23737:         >>> list(fn({'--global-option': 'foo'}))\nL23738:         []\nL23739:         \"\"\"\nL23740:         yield from self._get_config(\"--build-option\", config_settings)\nL23741: \nL23742: \nL23743: class _BuildMetaBackend(_ConfigSettingsTranslator):\nL23744:     def _get_build_requires(\nL23745:         self, config_settings: _ConfigSettings, requirements: list[str]\nL23746:     ):\nL23747:         sys.argv = [\nL23748:             *sys.argv[:1],\nL23749:             *self._global_args(config_settings),\nL23750:             \"egg_info\",\nL23751:         ]\nL23752:         try:\nL23753:             with Distribution.patch():\nL23754:                 self.run_setup()\nL23755:         except SetupRequirementsError as e:\nL23756:             requirements += e.specifiers\nL23757: \nL23758:         return requirements\nL23759: \nL23760:     def run_setup(self, setup_script: str = 'setup.py'):\nL23761:         # Note that we can reuse our build directory between calls\nL23762:         # Correctness comes first, then optimization later\nL23763:         __file__ = os.path.abspath(setup_script)\nL23764:         __name__ = '__main__'\nL23765: \nL23766:         with _open_setup_script(__file__) as f:\nL23767:             code = f.read().replace(r'\\r\\n', r'\\n')\nL23768: \nL23769:         try:\nL23770:             exec(code, locals())\nL23771:         except SystemExit as e:\nL23772:             if e.code:\nL23773:                 raise\nL23774:             # We ignore exit code indicating success\nL23775:             SetuptoolsDeprecationWarning.emit(\nL23776:                 \"Running `setup.py` directly as CLI tool is deprecated.\",\nL23777:                 \"Please avoid using `sys.exit(0)` or similar statements \"\nL23778:                 \"that don't fit in the paradigm of a configuration file.\",\nL23779:                 see_url=\"https://blog.ganssle.io/articles/2021/10/\"\nL23780:                 \"setup-py-deprecated.html\",\nL23781:             )\nL23782: \nL23783:     def get_requires_for_build_wheel(self, config_settings: _ConfigSettings = None):\nL23784:         return self._get_build_requires(config_settings, requirements=[])\nL23785: \nL23786:     def get_requires_for_build_sdist(self, config_settings: _ConfigSettings = None):\nL23787:         return self._get_build_requires(config_settings, requirements=[])\nL23788: \nL23789:     def _bubble_up_info_directory(\nL23790:         self, metadata_directory: StrPath, suffix: str\nL23791:     ) -> str:\nL23792:         \"\"\"\nL23793:         PEP 517 requires that the .dist-info directory be placed in the\nL23794:         metadata_directory. To comply, we MUST copy the directory to the root.\nL23795: \nL23796:         Returns the basename of the info directory, e.g. `proj-0.0.0.dist-info`.\nL23797:         \"\"\"\nL23798:         info_dir = self._find_info_directory(metadata_directory, suffix)\nL23799:         if not same_path(info_dir.parent, metadata_directory):\nL23800:             shutil.move(str(info_dir), metadata_directory)\nL23801:             # PEP 517 allow other files and dirs to exist in metadata_directory\nL23802:         return info_dir.name\nL23803: \nL23804:     def _find_info_directory(self, metadata_directory: StrPath, suffix: str) -> Path:\nL23805:         for parent, dirs, _ in os.walk(metadata_directory):\nL23806:             candidates = [f for f in dirs if f.endswith(suffix)]\nL23807: \nL23808:             if len(candidates) != 0 or len(dirs) != 1:\nL23809:                 assert len(candidates) == 1, f\"Multiple {suffix} directories found\"\nL23810:                 return Path(parent, candidates[0])\nL23811: \nL23812:         msg = f\"No {suffix} directory found in {metadata_directory}\"\nL23813:         raise errors.InternalError(msg)\nL23814: \nL23815:     def prepare_metadata_for_build_wheel(\nL23816:         self, metadata_directory: StrPath, config_settings: _ConfigSettings = None\nL23817:     ):\nL23818:         sys.argv = [\nL23819:             *sys.argv[:1],\nL23820:             *self._global_args(config_settings),\nL23821:             \"dist_info\",\nL23822:             \"--output-dir\",\nL23823:             str(metadata_directory),\nL23824:             \"--keep-egg-info\",\nL23825:         ]\nL23826:         with no_install_setup_requires():\nL23827:             self.run_setup()\nL23828: \nL23829:         self._bubble_up_info_directory(metadata_directory, \".egg-info\")\nL23830:         return self._bubble_up_info_directory(metadata_directory, \".dist-info\")\nL23831: \nL23832:     def _build_with_temp_dir(\nL23833:         self,\nL23834:         setup_command: Iterable[str],\nL23835:         result_extension: str | tuple[str, ...],\nL23836:         result_directory: StrPath,\nL23837:         config_settings: _ConfigSettings,\nL23838:         arbitrary_args: Iterable[str] = (),\nL23839:     ):\nL23840:         result_directory = os.path.abspath(result_directory)\nL23841: \nL23842:         # Build in a temporary directory, then copy to the target.\nL23843:         os.makedirs(result_directory, exist_ok=True)\nL23844: \nL23845:         with tempfile.TemporaryDirectory(\nL23846:             prefix=\".tmp-\", dir=result_directory\nL23847:         ) as tmp_dist_dir:\nL23848:             sys.argv = [\nL23849:                 *sys.argv[:1],\nL23850:                 *self._global_args(config_settings),\nL23851:                 *setup_command,\nL23852:                 \"--dist-dir\",\nL23853:                 tmp_dist_dir,\nL23854:                 *arbitrary_args,\nL23855:             ]\nL23856:             with no_install_setup_requires():\nL23857:                 self.run_setup()\nL23858: \nL23859:             result_basename = _file_with_extension(tmp_dist_dir, result_extension)\nL23860:             result_path = os.path.join(result_directory, result_basename)\nL23861:             if os.path.exists(result_path):\nL23862:                 # os.rename will fail overwriting on non-Unix.\nL23863:                 os.remove(result_path)\nL23864:             os.rename(os.path.join(tmp_dist_dir, result_basename), result_path)\nL23865: \nL23866:         return result_basename\nL23867: \nL23868:     def build_wheel(\nL23869:         self,\nL23870:         wheel_directory: StrPath,\nL23871:         config_settings: _ConfigSettings = None,\nL23872:         metadata_directory: StrPath | None = None,\nL23873:     ):\nL23874:         def _build(cmd: list[str]):\nL23875:             with suppress_known_deprecation():\nL23876:                 return self._build_with_temp_dir(\nL23877:                     cmd,\nL23878:                     '.whl',\nL23879:                     wheel_directory,\nL23880:                     config_settings,\nL23881:                     self._arbitrary_args(config_settings),\nL23882:                 )\nL23883: \nL23884:         if metadata_directory is None:\nL23885:             return _build(['bdist_wheel'])\nL23886: \nL23887:         try:\nL23888:             return _build(['bdist_wheel', '--dist-info-dir', str(metadata_directory)])\nL23889:         except SystemExit as ex:  # pragma: nocover\nL23890:             # pypa/setuptools#4683\nL23891:             if \"--dist-info-dir not recognized\" not in str(ex):\nL23892:                 raise\nL23893:             _IncompatibleBdistWheel.emit()\nL23894:             return _build(['bdist_wheel'])\nL23895: \nL23896:     def build_sdist(\nL23897:         self, sdist_directory: StrPath, config_settings: _ConfigSettings = None\nL23898:     ):\nL23899:         return self._build_with_temp_dir(\nL23900:             ['sdist', '--formats', 'gztar'], '.tar.gz', sdist_directory, config_settings\nL23901:         )\nL23902: \nL23903:     def _get_dist_info_dir(self, metadata_directory: StrPath | None) -> str | None:\nL23904:         if not metadata_directory:\nL23905:             return None\nL23906:         dist_info_candidates = list(Path(metadata_directory).glob(\"*.dist-info\"))\nL23907:         assert len(dist_info_candidates) <= 1\nL23908:         return str(dist_info_candidates[0]) if dist_info_candidates else None\nL23909: \nL23910:     def build_editable(\nL23911:         self,\nL23912:         wheel_directory: StrPath,\nL23913:         config_settings: _ConfigSettings = None,\nL23914:         metadata_directory: StrPath | None = None,\nL23915:     ):\nL23916:         # XXX can or should we hide our editable_wheel command normally?\nL23917:         info_dir = self._get_dist_info_dir(metadata_directory)\nL23918:         opts = [\"--dist-info-dir\", info_dir] if info_dir else []\nL23919:         cmd = [\"editable_wheel\", *opts, *self._editable_args(config_settings)]\nL23920:         with suppress_known_deprecation():\nL23921:             return self._build_with_temp_dir(\nL23922:                 cmd, \".whl\", wheel_directory, config_settings\nL23923:             )\nL23924: \nL23925:     def get_requires_for_build_editable(self, config_settings: _ConfigSettings = None):\nL23926:         return self.get_requires_for_build_wheel(config_settings)\nL23927: \nL23928:     def prepare_metadata_for_build_editable(\nL23929:         self, metadata_directory: StrPath, config_settings: _ConfigSettings = None\nL23930:     ):\nL23931:         return self.prepare_metadata_for_build_wheel(\nL23932:             metadata_directory, config_settings\nL23933:         )\nL23934: \nL23935: \nL23936: class _BuildMetaLegacyBackend(_BuildMetaBackend):\nL23937:     \"\"\"Compatibility backend for setuptools\nL23938: \nL23939:     This is a version of setuptools.build_meta that endeavors\nL23940:     to maintain backwards\nL23941:     compatibility with pre-PEP 517 modes of invocation. It\nL23942:     exists as a temporary\nL23943:     bridge between the old packaging mechanism and the new\nL23944:     packaging mechanism,\nL23945:     and will eventually be removed.\nL23946:     \"\"\"\nL23947: \nL23948:     def run_setup(self, setup_script: str = 'setup.py'):\nL23949:         # In order to maintain compatibility with scripts assuming that\nL23950:         # the setup.py script is in a directory on the PYTHONPATH, inject\nL23951:         # '' into sys.path. (pypa/setuptools#1642)\nL23952:         sys_path = list(sys.path)  # Save the original path\nL23953: \nL23954:         script_dir = os.path.dirname(os.path.abspath(setup_script))\nL23955:         if script_dir not in sys.path:\nL23956:             sys.path.insert(0, script_dir)\nL23957: \nL23958:         # Some setup.py scripts (e.g. in pygame and numpy) use sys.argv[0] to\nL23959:         # get the directory of the source code. They expect it to refer to the\nL23960:         # setup.py script.\nL23961:         sys_argv_0 = sys.argv[0]\nL23962:         sys.argv[0] = setup_script\nL23963: \nL23964:         try:\nL23965:             super().run_setup(setup_script=setup_script)\nL23966:         finally:\nL23967:             # While PEP 517 frontends should be calling each hook in a fresh\nL23968:             # subprocess according to the standard (and thus it should not be\nL23969:             # strictly necessary to restore the old sys.path), we'll restore\nL23970:             # the original path so that the path manipulation does not persist\nL23971:             # within the hook after run_setup is called.\nL23972:             sys.path[:] = sys_path\nL23973:             sys.argv[0] = sys_argv_0\nL23974: \nL23975: \nL23976: class _IncompatibleBdistWheel(SetuptoolsDeprecationWarning):\nL23977:     _SUMMARY = \"wheel.bdist_wheel is deprecated, please import it from setuptools\"\nL23978:     _DETAILS = \"\"\"\nL23979:     Ensure that any custom bdist_wheel implementation is a subclass of\nL23980:     setuptools.command.bdist_wheel.bdist_wheel.\nL23981:     \"\"\"\nL23982:     _DUE_DATE = (2025, 10, 15)\nL23983:     # Initially introduced in 2024/10/15, but maybe too disruptive to be enforced?\nL23984:     _SEE_URL = \"https://github.com/pypa/wheel/pull/631\"\nL23985: \nL23986: \nL23987: # The primary backend\nL23988: _BACKEND = _BuildMetaBackend()\nL23989: \nL23990: get_requires_for_build_wheel = _BACKEND.get_requires_for_build_wheel\nL23991: get_requires_for_build_sdist = _BACKEND.get_requires_for_build_sdist\nL23992: prepare_metadata_for_build_wheel = _BACKEND.prepare_metadata_for_build_wheel\nL23993: build_wheel = _BACKEND.build_wheel\nL23994: build_sdist = _BACKEND.build_sdist\nL23995: get_requires_for_build_editable = _BACKEND.get_requires_for_build_editable\nL23996: prepare_metadata_for_build_editable = _BACKEND.prepare_metadata_for_build_editable\nL23997: build_editable = _BACKEND.build_editable\nL23998: \nL23999: \nL24000: # The legacy backend\nL24001: __legacy__ = _BuildMetaLegacyBackend()\nL24002: \nL24003: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/dist.py\nL24004: #!/usr/bin/env python3\nL24005: from __future__ import annotations\nL24006: \nL24007: import functools\nL24008: import io\nL24009: import itertools\nL24010: import numbers\nL24011: import os\nL24012: import re\nL24013: import sys\nL24014: from collections.abc import Iterable, Iterator, MutableMapping, Sequence\nL24015: from glob import glob\nL24016: from pathlib import Path\nL24017: from typing import TYPE_CHECKING, Any, Union\nL24018: \nL24019: from more_itertools import partition, unique_everseen\nL24020: from packaging.markers import InvalidMarker, Marker\nL24021: from packaging.specifiers import InvalidSpecifier, SpecifierSet\nL24022: from packaging.version import Version\nL24023: \nL24024: from . import (\nL24025:     _entry_points,\nL24026:     _reqs,\nL24027:     _static,\nL24028:     command as _,  # noqa: F401 # imported for side-effects\nL24029: )\nL24030: from ._importlib import metadata\nL24031: from ._normalization import _canonicalize_license_expression\nL24032: from ._path import StrPath\nL24033: from ._reqs import _StrOrIter\nL24034: from .config import pyprojecttoml, setupcfg\nL24035: from .discovery import ConfigDiscovery\nL24036: from .errors import InvalidConfigError\nL24037: from .monkey import get_unpatched\nL24038: from .warnings import InformationOnly, SetuptoolsDeprecationWarning\nL24039: \nL24040: import distutils.cmd\nL24041: import distutils.command\nL24042: import distutils.core\nL24043: import distutils.dist\nL24044: import distutils.log\nL24045: from distutils.debug import DEBUG\nL24046: from distutils.errors import DistutilsOptionError, DistutilsSetupError\nL24047: from distutils.fancy_getopt import translate_longopt\nL24048: from distutils.util import strtobool\nL24049: \nL24050: if TYPE_CHECKING:\nL24051:     from typing_extensions import TypeAlias\nL24052: \nL24053: \nL24054: __all__ = ['Distribution']\nL24055: \nL24056: _sequence = tuple, list\nL24057: \"\"\"\nL24058: :meta private:\nL24059: \nL24060: Supported iterable types that are known to be:\nL24061: - ordered (which `set` isn't)\nL24062: - not match a str (which `Sequence[str]` does)\nL24063: - not imply a nested type (like `dict`)\nL24064: for use with `isinstance`.\nL24065: \"\"\"\nL24066: _Sequence: TypeAlias = Union[tuple[str, ...], list[str]]\nL24067: # This is how stringifying _Sequence would look in Python 3.10\nL24068: _sequence_type_repr = \"tuple[str, ...] | list[str]\"\nL24069: _OrderedStrSequence: TypeAlias = Union[str, dict[str, Any], Sequence[str]]\nL24070: \"\"\"\nL24071: :meta private:\nL24072: Avoid single-use iterable. Disallow sets.\nL24073: A poor approximation of an OrderedSequence (dict doesn't match a Sequence).\nL24074: \"\"\"\nL24075: \nL24076: \nL24077: def __getattr__(name: str) -> Any:  # pragma: no cover\nL24078:     if name == \"sequence\":\nL24079:         SetuptoolsDeprecationWarning.emit(\nL24080:             \"`setuptools.dist.sequence` is an internal implementation detail.\",\nL24081:             \"Please define your own `sequence = tuple, list` instead.\",\nL24082:             due_date=(2025, 8, 28),  # Originally added on 2024-08-27\nL24083:         )\nL24084:         return _sequence\nL24085:     raise AttributeError(f\"module {__name__!r} has no attribute {name!r}\")\nL24086: \nL24087: \nL24088: def check_importable(dist, attr, value):\nL24089:     try:\nL24090:         ep = metadata.EntryPoint(value=value, name=None, group=None)\nL24091:         assert not ep.extras\nL24092:     except (TypeError, ValueError, AttributeError, AssertionError) as e:\nL24093:         raise DistutilsSetupError(\nL24094:             f\"{attr!r} must be importable 'module:attrs' string (got {value!r})\"\nL24095:         ) from e\nL24096: \nL24097: \nL24098: def assert_string_list(dist, attr: str, value: _Sequence) -> None:\nL24099:     \"\"\"Verify that value is a string list\"\"\"\nL24100:     try:\nL24101:         # verify that value is a list or tuple to exclude unordered\nL24102:         # or single-use iterables\nL24103:         assert isinstance(value, _sequence)\nL24104:         # verify that elements of value are strings\nL24105:         assert ''.join(value) != value\nL24106:     except (TypeError, ValueError, AttributeError, AssertionError) as e:\nL24107:         raise DistutilsSetupError(\nL24108:             f\"{attr!r} must be of type <{_sequence_type_repr}> (got {value!r})\"\nL24109:         ) from e\nL24110: \nL24111: \nL24112: def check_nsp(dist, attr, value):\nL24113:     \"\"\"Verify that namespace packages are valid\"\"\"\nL24114:     ns_packages = value\nL24115:     assert_string_list(dist, attr, ns_packages)\nL24116:     for nsp in ns_packages:\nL24117:         if not dist.has_contents_for(nsp):\nL24118:             raise DistutilsSetupError(\nL24119:                 f\"Distribution contains no modules or packages for namespace package {nsp!r}\"\nL24120:             )\nL24121:         parent, _sep, _child = nsp.rpartition('.')\nL24122:         if parent and parent not in ns_packages:\nL24123:             distutils.log.warn(\nL24124:                 \"WARNING: %r is declared as a package namespace, but %r\"\nL24125:                 \" is not: please correct this in setup.py\",\nL24126:                 nsp,\nL24127:                 parent,\nL24128:             )\nL24129:         SetuptoolsDeprecationWarning.emit(\nL24130:             \"The namespace_packages parameter is deprecated.\",\nL24131:             \"Please replace its usage with implicit namespaces (PEP 420).\",\nL24132:             see_docs=\"references/keywords.html#keyword-namespace-packages\",\nL24133:             # TODO: define due_date, it may break old packages that are no longer\nL24134:             # maintained (e.g. sphinxcontrib extensions) when installed from source.\nL24135:             # Warning officially introduced in May 2022, however the deprecation\nL24136:             # was mentioned much earlier in the docs (May 2020, see #2149).\nL24137:         )\nL24138: \nL24139: \nL24140: def check_extras(dist, attr, value):\nL24141:     \"\"\"Verify that extras_require mapping is valid\"\"\"\nL24142:     try:\nL24143:         list(itertools.starmap(_check_extra, value.items()))\nL24144:     except (TypeError, ValueError, AttributeError) as e:\nL24145:         raise DistutilsSetupError(\nL24146:             \"'extras_require' must be a dictionary whose values are \"\nL24147:             \"strings or lists of strings containing valid project/version \"\nL24148:             \"requirement specifiers.\"\nL24149:         ) from e\nL24150: \nL24151: \nL24152: def _check_extra(extra, reqs):\nL24153:     _name, _sep, marker = extra.partition(':')\nL24154:     try:\nL24155:         _check_marker(marker)\nL24156:     except InvalidMarker:\nL24157:         msg = f\"Invalid environment marker: {marker} ({extra!r})\"\nL24158:         raise DistutilsSetupError(msg) from None\nL24159:     list(_reqs.parse(reqs))\nL24160: \nL24161: \nL24162: def _check_marker(marker):\nL24163:     if not marker:\nL24164:         return\nL24165:     m = Marker(marker)\nL24166:     m.evaluate()\nL24167: \nL24168: \nL24169: def assert_bool(dist, attr, value):\nL24170:     \"\"\"Verify that value is True, False, 0, or 1\"\"\"\nL24171:     if bool(value) != value:\nL24172:         raise DistutilsSetupError(f\"{attr!r} must be a boolean value (got {value!r})\")\nL24173: \nL24174: \nL24175: def invalid_unless_false(dist, attr, value):\nL24176:     if not value:\nL24177:         DistDeprecationWarning.emit(f\"{attr} is ignored.\")\nL24178:         # TODO: should there be a `due_date` here?\nL24179:         return\nL24180:     raise DistutilsSetupError(f\"{attr} is invalid.\")\nL24181: \nL24182: \nL24183: def check_requirements(dist, attr: str, value: _OrderedStrSequence) -> None:\nL24184:     \"\"\"Verify that install_requires is a valid requirements list\"\"\"\nL24185:     try:\nL24186:         list(_reqs.parse(value))\nL24187:         if isinstance(value, set):\nL24188:             raise TypeError(\"Unordered types are not allowed\")\nL24189:     except (TypeError, ValueError) as error:\nL24190:         msg = (\nL24191:             f\"{attr!r} must be a string or iterable of strings \"\nL24192:             f\"containing valid project/version requirement specifiers; {error}\"\nL24193:         )\nL24194:         raise DistutilsSetupError(msg) from error\nL24195: \nL24196: \nL24197: def check_specifier(dist, attr, value):\nL24198:     \"\"\"Verify that value is a valid version specifier\"\"\"\nL24199:     try:\nL24200:         SpecifierSet(value)\nL24201:     except (InvalidSpecifier, AttributeError) as error:\nL24202:         msg = f\"{attr!r} must be a string containing valid version specifiers; {error}\"\nL24203:         raise DistutilsSetupError(msg) from error\nL24204: \nL24205: \nL24206: def check_entry_points(dist, attr, value):\nL24207:     \"\"\"Verify that entry_points map is parseable\"\"\"\nL24208:     try:\nL24209:         _entry_points.load(value)\nL24210:     except Exception as e:\nL24211:         raise DistutilsSetupError(e) from e\nL24212: \nL24213: \nL24214: def check_package_data(dist, attr, value):\nL24215:     \"\"\"Verify that value is a dictionary of package names to glob lists\"\"\"\nL24216:     if not isinstance(value, dict):\nL24217:         raise DistutilsSetupError(\nL24218:             f\"{attr!r} must be a dictionary mapping package names to lists of \"\nL24219:             \"string wildcard patterns\"\nL24220:         )\nL24221:     for k, v in value.items():\nL24222:         if not isinstance(k, str):\nL24223:             raise DistutilsSetupError(\nL24224:                 f\"keys of {attr!r} dict must be strings (got {k!r})\"\nL24225:             )\nL24226:         assert_string_list(dist, f'values of {attr!r} dict', v)\nL24227: \nL24228: \nL24229: def check_packages(dist, attr, value):\nL24230:     for pkgname in value:\nL24231:         if not re.match(r'\\w+(\\.\\w+)*', pkgname):\nL24232:             distutils.log.warn(\nL24233:                 \"WARNING: %r not a valid package name; please use only \"\nL24234:                 \".-separated package names in setup.py\",\nL24235:                 pkgname,\nL24236:             )\nL24237: \nL24238: \nL24239: if TYPE_CHECKING:\nL24240:     # Work around a mypy issue where type[T] can't be used as a base: https://github.com/python/mypy/issues/10962\nL24241:     from distutils.core import Distribution as _Distribution\nL24242: else:\nL24243:     _Distribution = get_unpatched(distutils.core.Distribution)\nL24244: \nL24245: \nL24246: class Distribution(_Distribution):\nL24247:     \"\"\"Distribution with support for tests and package data\nL24248: \nL24249:     This is an enhanced version of 'distutils.dist.Distribution' that\nL24250:     effectively adds the following new optional keyword arguments to 'setup()':\nL24251: \nL24252:      'install_requires' -- a string or sequence of strings specifying project\nL24253:         versions that the distribution requires when installed, in the format\nL24254:         used by 'pkg_resources.require()'.  They will be installed\nL24255:         automatically when the package is installed.  If you wish to use\nL24256:         packages that are not available in PyPI, or want to give your users an\nL24257:         alternate download location, you can add a 'find_links' option to the\nL24258:         '[easy_install]' section of your project's 'setup.cfg' file, and then\nL24259:         setuptools will scan the listed web pages for links that satisfy the\nL24260:         requirements.\nL24261: \nL24262:      'extras_require' -- a dictionary mapping names of optional \"extras\" to the\nL24263:         additional requirement(s) that using those extras incurs. For example,\nL24264:         this::\nL24265: \nL24266:             extras_require = dict(reST = [\"docutils>=0.3\", \"reSTedit\"])\nL24267: \nL24268:         indicates that the distribution can optionally provide an extra\nL24269:         capability called \"reST\", but it can only be used if docutils and\nL24270:         reSTedit are installed.  If the user installs your package using\nL24271:         EasyInstall and requests one of your extras, the corresponding\nL24272:         additional requirements will be installed if needed.\nL24273: \nL24274:      'package_data' -- a dictionary mapping package names to lists of filenames\nL24275:         or globs to use to find data files contained in the named packages.\nL24276:         If the dictionary has filenames or globs listed under '\"\"' (the empty\nL24277:         string), those names will be searched for in every package, in addition\nL24278:         to any names for the specific package.  Data files found using these\nL24279:         names/globs will be installed along with the package, in the same\nL24280:         location as the package.  Note that globs are allowed to reference\nL24281:         the contents of non-package subdirectories, as long as you use '/' as\nL24282:         a path separator.  (Globs are automatically converted to\nL24283:         platform-specific paths at runtime.)\nL24284: \nL24285:     In addition to these new keywords, this class also has several new methods\nL24286:     for manipulating the distribution's contents.  For example, the 'include()'\nL24287:     and 'exclude()' methods can be thought of as in-place add and subtract\nL24288:     commands that add or remove packages, modules, extensions, and so on from\nL24289:     the distribution.\nL24290:     \"\"\"\nL24291: \nL24292:     _DISTUTILS_UNSUPPORTED_METADATA = {\nL24293:         'long_description_content_type': lambda: None,\nL24294:         'project_urls': dict,\nL24295:         'provides_extras': dict,  # behaves like an ordered set\nL24296:         'license_expression': lambda: None,\nL24297:         'license_file': lambda: None,\nL24298:         'license_files': lambda: None,\nL24299:         'install_requires': list,\nL24300:         'extras_require': dict,\nL24301:     }\nL24302: \nL24303:     # Used by build_py, editable_wheel and install_lib commands for legacy namespaces\nL24304:     namespace_packages: list[str]  #: :meta private: DEPRECATED\nL24305: \nL24306:     # Any: Dynamic assignment results in Incompatible types in assignment\nL24307:     def __init__(self, attrs: MutableMapping[str, Any] | None = None) -> None:\nL24308:         have_package_data = hasattr(self, \"package_data\")\nL24309:         if not have_package_data:\nL24310:             self.package_data: dict[str, list[str]] = {}\nL24311:         attrs = attrs or {}\nL24312:         self.dist_files: list[tuple[str, str, str]] = []\nL24313:         self.include_package_data: bool | None = None\nL24314:         self.exclude_package_data: dict[str, list[str]] | None = None\nL24315:         # Filter-out setuptools' specific options.\nL24316:         self.src_root: str | None = attrs.pop(\"src_root\", None)\nL24317:         self.dependency_links: list[str] = attrs.pop('dependency_links', [])\nL24318:         self.setup_requires: list[str] = attrs.pop('setup_requires', [])\nL24319:         for ep in metadata.entry_points(group='distutils.setup_keywords'):\nL24320:             vars(self).setdefault(ep.name, None)\nL24321: \nL24322:         metadata_only = set(self._DISTUTILS_UNSUPPORTED_METADATA)\nL24323:         metadata_only -= {\"install_requires\", \"extras_require\"}\nL24324:         dist_attrs = {k: v for k, v in attrs.items() if k not in metadata_only}\nL24325:         _Distribution.__init__(self, dist_attrs)\nL24326: \nL24327:         # Private API (setuptools-use only, not restricted to Distribution)\nL24328:         # Stores files that are referenced by the configuration and need to be in the\nL24329:         # sdist (e.g. `version = file: VERSION.txt`)\nL24330:         self._referenced_files = set[str]()\nL24331: \nL24332:         self.set_defaults = ConfigDiscovery(self)\nL24333: \nL24334:         self._set_metadata_defaults(attrs)\nL24335: \nL24336:         self.metadata.version = self._normalize_version(self.metadata.version)\nL24337:         self._finalize_requires()\nL24338: \nL24339:     def _validate_metadata(self):\nL24340:         required = {\"name\"}\nL24341:         provided = {\nL24342:             key\nL24343:             for key in vars(self.metadata)\nL24344:             if getattr(self.metadata, key, None) is not None\nL24345:         }\nL24346:         missing = required - provided\nL24347: \nL24348:         if missing:\nL24349:             msg = f\"Required package metadata is missing: {missing}\"\nL24350:             raise DistutilsSetupError(msg)\nL24351: \nL24352:     def _set_metadata_defaults(self, attrs):\nL24353:         \"\"\"\nL24354:         Fill-in missing metadata fields not supported by distutils.\nL24355:         Some fields may have been set by other tools (e.g. pbr).\nL24356:         Those fields (vars(self.metadata)) take precedence to\nL24357:         supplied attrs.\nL24358:         \"\"\"\nL24359:         for option, default in self._DISTUTILS_UNSUPPORTED_METADATA.items():\nL24360:             vars(self.metadata).setdefault(option, attrs.get(option, default()))\nL24361: \nL24362:     @staticmethod\nL24363:     def _normalize_version(version):\nL24364:         from . import sic\nL24365: \nL24366:         if isinstance(version, numbers.Number):\nL24367:             # Some people apparently take \"version number\" too literally :)\nL24368:             version = str(version)\nL24369:         elif isinstance(version, sic) or version is None:\nL24370:             return version\nL24371: \nL24372:         normalized = str(Version(version))\nL24373:         if version != normalized:\nL24374:             InformationOnly.emit(f\"Normalizing '{version}' to '{normalized}'\")\nL24375:             return normalized\nL24376:         return version\nL24377: \nL24378:     def _finalize_requires(self):\nL24379:         \"\"\"\nL24380:         Set `metadata.python_requires` and fix environment markers\nL24381:         in `install_requires` and `extras_require`.\nL24382:         \"\"\"\nL24383:         if getattr(self, 'python_requires', None):\nL24384:             self.metadata.python_requires = self.python_requires\nL24385: \nL24386:         self._normalize_requires()\nL24387:         self.metadata.install_requires = self.install_requires\nL24388:         self.metadata.extras_require = self.extras_require\nL24389: \nL24390:         if self.extras_require:\nL24391:             for extra in self.extras_require.keys():\nL24392:                 # Setuptools allows a weird \"<name>:<env markers> syntax for extras\nL24393:                 extra = extra.split(':')[0]\nL24394:                 if extra:\nL24395:                     self.metadata.provides_extras.setdefault(extra)\nL24396: \nL24397:     def _normalize_requires(self):\nL24398:         \"\"\"Make sure requirement-related attributes exist and are normalized\"\"\"\nL24399:         install_requires = getattr(self, \"install_requires\", None) or []\nL24400:         extras_require = getattr(self, \"extras_require\", None) or {}\nL24401: \nL24402:         # Preserve the \"static\"-ness of values parsed from config files\nL24403:         list_ = _static.List if _static.is_static(install_requires) else list\nL24404:         self.install_requires = list_(map(str, _reqs.parse(install_requires)))\nL24405: \nL24406:         dict_ = _static.Dict if _static.is_static(extras_require) else dict\nL24407:         self.extras_require = dict_(\nL24408:             (k, list(map(str, _reqs.parse(v or [])))) for k, v in extras_require.items()\nL24409:         )\nL24410: \nL24411:     def _finalize_license_expression(self) -> None:\nL24412:         \"\"\"\nL24413:         Normalize license and license_expression.\nL24414:         >>> dist = Distribution({\"license_expression\": _static.Str(\"mit aNd  gpl-3.0-OR-later\")})\nL24415:         >>> _static.is_static(dist.metadata.license_expression)\nL24416:         True\nL24417:         >>> dist._finalize_license_expression()\nL24418:         >>> _static.is_static(dist.metadata.license_expression)  # preserve \"static-ness\"\nL24419:         True\nL24420:         >>> print(dist.metadata.license_expression)\nL24421:         MIT AND GPL-3.0-or-later\nL24422:         \"\"\"\nL24423:         classifiers = self.metadata.get_classifiers()\nL24424:         license_classifiers = [cl for cl in classifiers if cl.startswith(\"License :: \")]\nL24425: \nL24426:         license_expr = self.metadata.license_expression\nL24427:         if license_expr:\nL24428:             str_ = _static.Str if _static.is_static(license_expr) else str\nL24429:             normalized = str_(_canonicalize_license_expression(license_expr))\nL24430:             if license_expr != normalized:\nL24431:                 InformationOnly.emit(f\"Normalizing '{license_expr}' to '{normalized}'\")\nL24432:                 self.metadata.license_expression = normalized\nL24433:             if license_classifiers:\nL24434:                 raise InvalidConfigError(\nL24435:                     \"License classifiers have been superseded by license expressions \"\nL24436:                     \"(see https://peps.python.org/pep-0639/). Please remove:\\n\\n\"\nL24437:                     + \"\\n\".join(license_classifiers),\nL24438:                 )\nL24439:         elif license_classifiers:\nL24440:             pypa_guides = \"guides/writing-pyproject-toml/#license\"\nL24441:             SetuptoolsDeprecationWarning.emit(\nL24442:                 \"License classifiers are deprecated.\",\nL24443:                 \"Please consider removing the following classifiers in favor of a \"\nL24444:                 \"SPDX license expression:\\n\\n\" + \"\\n\".join(license_classifiers),\nL24445:                 see_url=f\"https://packaging.python.org/en/latest/{pypa_guides}\",\nL24446:                 # Warning introduced on 2025-02-17\nL24447:                 # TODO: Should we add a due date? It may affect old/unmaintained\nL24448:                 #       packages in the ecosystem and cause problems...\nL24449:             )\nL24450: \nL24451:     def _finalize_license_files(self) -> None:\nL24452:         \"\"\"Compute names of all license files which should be included.\"\"\"\nL24453:         license_files: list[str] | None = self.metadata.license_files\nL24454:         patterns = license_files or []\nL24455: \nL24456:         license_file: str | None = self.metadata.license_file\nL24457:         if license_file and license_file not in patterns:\nL24458:             patterns.append(license_file)\nL24459: \nL24460:         if license_files is None and license_file is None:\nL24461:             # Default patterns match the ones wheel uses\nL24462:             # See https://wheel.readthedocs.io/en/stable/user_guide.html\nL24463:             # -> 'Including license files in the generated wheel file'\nL24464:             patterns = ['LICEN[CS]E*', 'COPYING*', 'NOTICE*', 'AUTHORS*']\nL24465:             files = self._expand_patterns(patterns, enforce_match=False)\nL24466:         else:  # Patterns explicitly given by the user\nL24467:             files = self._expand_patterns(patterns, enforce_match=True)\nL24468: \nL24469:         self.metadata.license_files = list(unique_everseen(files))\nL24470: \nL24471:     @classmethod\nL24472:     def _expand_patterns(\nL24473:         cls, patterns: list[str], enforce_match: bool = True\nL24474:     ) -> Iterator[str]:\nL24475:         \"\"\"\nL24476:         >>> getfixture('sample_project_cwd')\nL24477:         >>> list(Distribution._expand_patterns(['LICENSE.txt']))\nL24478:         ['LICENSE.txt']\nL24479:         >>> list(Distribution._expand_patterns(['pyproject.toml', 'LIC*']))\nL24480:         ['pyproject.toml', 'LICENSE.txt']\nL24481:         >>> list(Distribution._expand_patterns(['src/**/*.dat']))\nL24482:         ['src/sample/package_data.dat']\nL24483:         \"\"\"\nL24484:         return (\nL24485:             path.replace(os.sep, \"/\")\nL24486:             for pattern in patterns\nL24487:             for path in sorted(cls._find_pattern(pattern, enforce_match))\nL24488:             if not path.endswith('~') and os.path.isfile(path)\nL24489:         )\nL24490: \nL24491:     @staticmethod\nL24492:     def _find_pattern(pattern: str, enforce_match: bool = True) -> list[str]:\nL24493:         r\"\"\"\nL24494:         >>> getfixture('sample_project_cwd')\nL24495:         >>> Distribution._find_pattern(\"LICENSE.txt\")\nL24496:         ['LICENSE.txt']\nL24497:         >>> Distribution._find_pattern(\"/LICENSE.MIT\")\nL24498:         Traceback (most recent call last):\nL24499:         ...\nL24500:         setuptools.errors.InvalidConfigError: Pattern '/LICENSE.MIT' should be relative...\nL24501:         >>> Distribution._find_pattern(\"../LICENSE.MIT\")\nL24502:         Traceback (most recent call last):\nL24503:         ...\nL24504:         setuptools.warnings.SetuptoolsDeprecationWarning: ...Pattern '../LICENSE.MIT' cannot contain '..'...\nL24505:         >>> Distribution._find_pattern(\"LICEN{CSE*\")\nL24506:         Traceback (most recent call last):\nL24507:         ...\nL24508:         setuptools.warnings.SetuptoolsDeprecationWarning: ...Pattern 'LICEN{CSE*' contains invalid characters...\nL24509:         \"\"\"\nL24510:         pypa_guides = \"specifications/glob-patterns/\"\nL24511:         if \"..\" in pattern:\nL24512:             SetuptoolsDeprecationWarning.emit(\nL24513:                 f\"Pattern {pattern!r} cannot contain '..'\",\nL24514:                 \"\"\"\nL24515:                 Please ensure the files specified are contained by the root\nL24516:                 of the Python package (normally marked by `pyproject.toml`).\nL24517:                 \"\"\",\nL24518:                 see_url=f\"https://packaging.python.org/en/latest/{pypa_guides}\",\nL24519:                 due_date=(2026, 3, 20),  # Introduced in 2025-03-20\nL24520:                 # Replace with InvalidConfigError after deprecation\nL24521:             )\nL24522:         if pattern.startswith((os.sep, \"/\")) or \":\\\\\" in pattern:\nL24523:             raise InvalidConfigError(\nL24524:                 f\"Pattern {pattern!r} should be relative and must not start with '/'\"\nL24525:             )\nL24526:         if re.match(r'^[\\w\\-\\.\\/\\*\\?\\[\\]]+$', pattern) is None:\nL24527:             SetuptoolsDeprecationWarning.emit(\nL24528:                 \"Please provide a valid glob pattern.\",\nL24529:                 \"Pattern {pattern!r} contains invalid characters.\",\nL24530:                 pattern=pattern,\nL24531:                 see_url=f\"https://packaging.python.org/en/latest/{pypa_guides}\",\nL24532:                 due_date=(2026, 3, 20),  # Introduced in 2025-02-20\nL24533:             )\nL24534: \nL24535:         found = glob(pattern, recursive=True)\nL24536: \nL24537:         if enforce_match and not found:\nL24538:             SetuptoolsDeprecationWarning.emit(\nL24539:                 \"Cannot find any files for the given pattern.\",\nL24540:                 \"Pattern {pattern!r} did not match any files.\",\nL24541:                 pattern=pattern,\nL24542:                 due_date=(2026, 3, 20),  # Introduced in 2025-02-20\nL24543:                 # PEP 639 requires us to error, but as a transition period\nL24544:                 # we will only issue a warning to give people time to prepare.\nL24545:                 # After the transition, this should raise an InvalidConfigError.\nL24546:             )\nL24547:         return found\nL24548: \nL24549:     # FIXME: 'Distribution._parse_config_files' is too complex (14)\nL24550:     def _parse_config_files(self, filenames=None):  # noqa: C901\nL24551:         \"\"\"\nL24552:         Adapted from distutils.dist.Distribution.parse_config_files,\nL24553:         this method provides the same functionality in subtly-improved\nL24554:         ways.\nL24555:         \"\"\"\nL24556:         from configparser import ConfigParser\nL24557: \nL24558:         # Ignore install directory options if we have a venv\nL24559:         ignore_options = (\nL24560:             []\nL24561:             if sys.prefix == sys.base_prefix\nL24562:             else [\nL24563:                 'install-base',\nL24564:                 'install-platbase',\nL24565:                 'install-lib',\nL24566:                 'install-platlib',\nL24567:                 'install-purelib',\nL24568:                 'install-headers',\nL24569:                 'install-scripts',\nL24570:                 'install-data',\nL24571:                 'prefix',\nL24572:                 'exec-prefix',\nL24573:                 'home',\nL24574:                 'user',\nL24575:                 'root',\nL24576:             ]\nL24577:         )\nL24578: \nL24579:         ignore_options = frozenset(ignore_options)\nL24580: \nL24581:         if filenames is None:\nL24582:             filenames = self.find_config_files()\nL24583: \nL24584:         if DEBUG:\nL24585:             self.announce(\"Distribution.parse_config_files():\")\nL24586: \nL24587:         parser = ConfigParser()\nL24588:         parser.optionxform = str\nL24589:         for filename in filenames:\nL24590:             with open(filename, encoding='utf-8') as reader:\nL24591:                 if DEBUG:\nL24592:                     self.announce(\"  reading {filename}\".format(**locals()))\nL24593:                 parser.read_file(reader)\nL24594:             for section in parser.sections():\nL24595:                 options = parser.options(section)\nL24596:                 opt_dict = self.get_option_dict(section)\nL24597: \nL24598:                 for opt in options:\nL24599:                     if opt == '__name__' or opt in ignore_options:\nL24600:                         continue\nL24601: \nL24602:                     val = parser.get(section, opt)\nL24603:                     opt = self._enforce_underscore(opt, section)\nL24604:                     opt = self._enforce_option_lowercase(opt, section)\nL24605:                     opt_dict[opt] = (filename, val)\nL24606: \nL24607:             # Make the ConfigParser forget everything (so we retain\nL24608:             # the original filenames that options come from)\nL24609:             parser.__init__()\nL24610: \nL24611:         if 'global' not in self.command_options:\nL24612:             return\nL24613: \nL24614:         # If there was a \"global\" section in the config file, use it\nL24615:         # to set Distribution options.\nL24616: \nL24617:         for opt, (src, val) in self.command_options['global'].items():\nL24618:             alias = self.negative_opt.get(opt)\nL24619:             if alias:\nL24620:                 val = not strtobool(val)\nL24621:             elif opt in ('verbose', 'dry_run'):  # ugh!\nL24622:                 val = strtobool(val)\nL24623: \nL24624:             try:\nL24625:                 setattr(self, alias or opt, val)\nL24626:             except ValueError as e:\nL24627:                 raise DistutilsOptionError(e) from e\nL24628: \nL24629:     def _enforce_underscore(self, opt: str, section: str) -> str:\nL24630:         if \"-\" not in opt or self._skip_setupcfg_normalization(section):\nL24631:             return opt\nL24632: \nL24633:         underscore_opt = opt.replace('-', '_')\nL24634:         affected = f\"(Affected: {self.metadata.name}).\" if self.metadata.name else \"\"\nL24635:         SetuptoolsDeprecationWarning.emit(\nL24636:             f\"Invalid dash-separated key {opt!r} in {section!r} (setup.cfg), \"\nL24637:             f\"please use the underscore name {underscore_opt!r} instead.\",\nL24638:             f\"\"\"\nL24639:             Usage of dash-separated {opt!r} will not be supported in future\nL24640:             versions. Please use the underscore name {underscore_opt!r} instead.\nL24641:             {affected}\nL24642:             \"\"\",\nL24643:             see_docs=\"userguide/declarative_config.html\",\nL24644:             due_date=(2026, 3, 3),\nL24645:             # Warning initially introduced in 3 Mar 2021\nL24646:         )\nL24647:         return underscore_opt\nL24648: \nL24649:     def _enforce_option_lowercase(self, opt: str, section: str) -> str:\nL24650:         if opt.islower() or self._skip_setupcfg_normalization(section):\nL24651:             return opt\nL24652: \nL24653:         lowercase_opt = opt.lower()\nL24654:         affected = f\"(Affected: {self.metadata.name}).\" if self.metadata.name else \"\"\nL24655:         SetuptoolsDeprecationWarning.emit(\nL24656:             f\"Invalid uppercase key {opt!r} in {section!r} (setup.cfg), \"\nL24657:             f\"please use lowercase {lowercase_opt!r} instead.\",\nL24658:             f\"\"\"\nL24659:             Usage of uppercase key {opt!r} in {section!r} will not be supported in\nL24660:             future versions. Please use lowercase {lowercase_opt!r} instead.\nL24661:             {affected}\nL24662:             \"\"\",\nL24663:             see_docs=\"userguide/declarative_config.html\",\nL24664:             due_date=(2026, 3, 3),\nL24665:             # Warning initially introduced in 6 Mar 2021\nL24666:         )\nL24667:         return lowercase_opt\nL24668: \nL24669:     def _skip_setupcfg_normalization(self, section: str) -> bool:\nL24670:         skip = (\nL24671:             'options.extras_require',\nL24672:             'options.data_files',\nL24673:             'options.entry_points',\nL24674:             'options.package_data',\nL24675:             'options.exclude_package_data',\nL24676:         )\nL24677:         return section in skip or not self._is_setuptools_section(section)\nL24678: \nL24679:     def _is_setuptools_section(self, section: str) -> bool:\nL24680:         return (\nL24681:             section == \"metadata\"\nL24682:             or section.startswith(\"options\")\nL24683:             or section in _setuptools_commands()\nL24684:         )\nL24685: \nL24686:     # FIXME: 'Distribution._set_command_options' is too complex (14)\nL24687:     def _set_command_options(self, command_obj, option_dict=None):  # noqa: C901\nL24688:         \"\"\"\nL24689:         Set the options for 'command_obj' from 'option_dict'.  Basically\nL24690:         this means copying elements of a dictionary ('option_dict') to\nL24691:         attributes of an instance ('command').\nL24692: \nL24693:         'command_obj' must be a Command instance.  If 'option_dict' is not\nL24694:         supplied, uses the standard option dictionary for this command\nL24695:         (from 'self.command_options').\nL24696: \nL24697:         (Adopted from distutils.dist.Distribution._set_command_options)\nL24698:         \"\"\"\nL24699:         command_name = command_obj.get_command_name()\nL24700:         if option_dict is None:\nL24701:             option_dict = self.get_option_dict(command_name)\nL24702: \nL24703:         if DEBUG:\nL24704:             self.announce(f\"  setting options for '{command_name}' command:\")\nL24705:         for option, (source, value) in option_dict.items():\nL24706:             if DEBUG:\nL24707:                 self.announce(f\"    {option} = {value} (from {source})\")\nL24708:             try:\nL24709:                 bool_opts = [translate_longopt(o) for o in command_obj.boolean_options]\nL24710:             except AttributeError:\nL24711:                 bool_opts = []\nL24712:             try:\nL24713:                 neg_opt = command_obj.negative_opt\nL24714:             except AttributeError:\nL24715:                 neg_opt = {}\nL24716: \nL24717:             try:\nL24718:                 is_string = isinstance(value, str)\nL24719:                 if option in neg_opt and is_string:\nL24720:                     setattr(command_obj, neg_opt[option], not strtobool(value))\nL24721:                 elif option in bool_opts and is_string:\nL24722:                     setattr(command_obj, option, strtobool(value))\nL24723:                 elif hasattr(command_obj, option):\nL24724:                     setattr(command_obj, option, value)\nL24725:                 else:\nL24726:                     raise DistutilsOptionError(\nL24727:                         f\"error in {source}: command '{command_name}' has no such option '{option}'\"\nL24728:                     )\nL24729:             except ValueError as e:\nL24730:                 raise DistutilsOptionError(e) from e\nL24731: \nL24732:     def _get_project_config_files(self, filenames: Iterable[StrPath] | None):\nL24733:         \"\"\"Add default file and split between INI and TOML\"\"\"\nL24734:         tomlfiles = []\nL24735:         standard_project_metadata = Path(self.src_root or os.curdir, \"pyproject.toml\")\nL24736:         if filenames is not None:\nL24737:             parts = partition(lambda f: Path(f).suffix == \".toml\", filenames)\nL24738:             filenames = list(parts[0])  # 1st element => predicate is False\nL24739:             tomlfiles = list(parts[1])  # 2nd element => predicate is True\nL24740:         elif standard_project_metadata.exists():\nL24741:             tomlfiles = [standard_project_metadata]\nL24742:         return filenames, tomlfiles\nL24743: \nL24744:     def parse_config_files(\nL24745:         self,\nL24746:         filenames: Iterable[StrPath] | None = None,\nL24747:         ignore_option_errors: bool = False,\nL24748:     ) -> None:\nL24749:         \"\"\"Parses configuration files from various levels\nL24750:         and loads configuration.\nL24751:         \"\"\"\nL24752:         inifiles, tomlfiles = self._get_project_config_files(filenames)\nL24753: \nL24754:         self._parse_config_files(filenames=inifiles)\nL24755: \nL24756:         setupcfg.parse_configuration(\nL24757:             self, self.command_options, ignore_option_errors=ignore_option_errors\nL24758:         )\nL24759:         for filename in tomlfiles:\nL24760:             pyprojecttoml.apply_configuration(self, filename, ignore_option_errors)\nL24761: \nL24762:         self._finalize_requires()\nL24763:         self._finalize_license_expression()\nL24764:         self._finalize_license_files()\nL24765: \nL24766:     def fetch_build_eggs(self, requires: _StrOrIter) -> list[metadata.Distribution]:\nL24767:         \"\"\"Resolve pre-setup requirements\"\"\"\nL24768:         from .installer import _fetch_build_eggs\nL24769: \nL24770:         return _fetch_build_eggs(self, requires)\nL24771: \nL24772:     def finalize_options(self) -> None:\nL24773:         \"\"\"\nL24774:         Allow plugins to apply arbitrary operations to the\nL24775:         distribution. Each hook may optionally define a 'order'\nL24776:         to influence the order of execution. Smaller numbers\nL24777:         go first and the default is 0.\nL24778:         \"\"\"\nL24779:         group = 'setuptools.finalize_distribution_options'\nL24780: \nL24781:         def by_order(hook):\nL24782:             return getattr(hook, 'order', 0)\nL24783: \nL24784:         defined = metadata.entry_points(group=group)\nL24785:         filtered = itertools.filterfalse(self._removed, defined)\nL24786:         loaded = map(lambda e: e.load(), filtered)\nL24787:         for ep in sorted(loaded, key=by_order):\nL24788:             ep(self)\nL24789: \nL24790:     @staticmethod\nL24791:     def _removed(ep):\nL24792:         \"\"\"\nL24793:         When removing an entry point, if metadata is loaded\nL24794:         from an older version of Setuptools, that removed\nL24795:         entry point will attempt to be loaded and will fail.\nL24796:         See #2765 for more details.\nL24797:         \"\"\"\nL24798:         removed = {\nL24799:             # removed 2021-09-05\nL24800:             '2to3_doctests',\nL24801:         }\nL24802:         return ep.name in removed\nL24803: \nL24804:     def _finalize_setup_keywords(self):\nL24805:         for ep in metadata.entry_points(group='distutils.setup_keywords'):\nL24806:             value = getattr(self, ep.name, None)\nL24807:             if value is not None:\nL24808:                 ep.load()(self, ep.name, value)\nL24809: \nL24810:     def get_egg_cache_dir(self):\nL24811:         from . import windows_support\nL24812: \nL24813:         egg_cache_dir = os.path.join(os.curdir, '.eggs')\nL24814:         if not os.path.exists(egg_cache_dir):\nL24815:             os.mkdir(egg_cache_dir)\nL24816:             windows_support.hide_file(egg_cache_dir)\nL24817:             readme_txt_filename = os.path.join(egg_cache_dir, 'README.txt')\nL24818:             with open(readme_txt_filename, 'w', encoding=\"utf-8\") as f:\nL24819:                 f.write(\nL24820:                     'This directory contains eggs that were downloaded '\nL24821:                     'by setuptools to build, test, and run plug-ins.\\n\\n'\nL24822:                 )\nL24823:                 f.write(\nL24824:                     'This directory caches those eggs to prevent '\nL24825:                     'repeated downloads.\\n\\n'\nL24826:                 )\nL24827:                 f.write('However, it is safe to delete this directory.\\n\\n')\nL24828: \nL24829:         return egg_cache_dir\nL24830: \nL24831:     def fetch_build_egg(self, req):\nL24832:         \"\"\"Fetch an egg needed for building\"\"\"\nL24833:         from .installer import fetch_build_egg\nL24834: \nL24835:         return fetch_build_egg(self, req)\nL24836: \nL24837:     def get_command_class(self, command: str) -> type[distutils.cmd.Command]:  # type: ignore[override] # Not doing complex overrides yet\nL24838:         \"\"\"Pluggable version of get_command_class()\"\"\"\nL24839:         if command in self.cmdclass:\nL24840:             return self.cmdclass[command]\nL24841: \nL24842:         # Special case bdist_wheel so it's never loaded from \"wheel\"\nL24843:         if command == 'bdist_wheel':\nL24844:             from .command.bdist_wheel import bdist_wheel\nL24845: \nL24846:             return bdist_wheel\nL24847: \nL24848:         eps = metadata.entry_points(group='distutils.commands', name=command)\nL24849:         for ep in eps:\nL24850:             self.cmdclass[command] = cmdclass = ep.load()\nL24851:             return cmdclass\nL24852:         else:\nL24853:             return _Distribution.get_command_class(self, command)\nL24854: \nL24855:     def print_commands(self):\nL24856:         for ep in metadata.entry_points(group='distutils.commands'):\nL24857:             if ep.name not in self.cmdclass:\nL24858:                 cmdclass = ep.load()\nL24859:                 self.cmdclass[ep.name] = cmdclass\nL24860:         return _Distribution.print_commands(self)\nL24861: \nL24862:     def get_command_list(self):\nL24863:         for ep in metadata.entry_points(group='distutils.commands'):\nL24864:             if ep.name not in self.cmdclass:\nL24865:                 cmdclass = ep.load()\nL24866:                 self.cmdclass[ep.name] = cmdclass\nL24867:         return _Distribution.get_command_list(self)\nL24868: \nL24869:     def include(self, **attrs) -> None:\nL24870:         \"\"\"Add items to distribution that are named in keyword arguments\nL24871: \nL24872:         For example, 'dist.include(py_modules=[\"x\"])' would add 'x' to\nL24873:         the distribution's 'py_modules' attribute, if it was not already\nL24874:         there.\nL24875: \nL24876:         Currently, this method only supports inclusion for attributes that are\nL24877:         lists or tuples.  If you need to add support for adding to other\nL24878:         attributes in this or a subclass, you can add an '_include_X' method,\nL24879:         where 'X' is the name of the attribute.  The method will be called with\nL24880:         the value passed to 'include()'.  So, 'dist.include(foo={\"bar\":\"baz\"})'\nL24881:         will try to call 'dist._include_foo({\"bar\":\"baz\"})', which can then\nL24882:         handle whatever special inclusion logic is needed.\nL24883:         \"\"\"\nL24884:         for k, v in attrs.items():\nL24885:             include = getattr(self, '_include_' + k, None)\nL24886:             if include:\nL24887:                 include(v)\nL24888:             else:\nL24889:                 self._include_misc(k, v)\nL24890: \nL24891:     def exclude_package(self, package: str) -> None:\nL24892:         \"\"\"Remove packages, modules, and extensions in named package\"\"\"\nL24893: \nL24894:         pfx = package + '.'\nL24895:         if self.packages:\nL24896:             self.packages = [\nL24897:                 p for p in self.packages if p != package and not p.startswith(pfx)\nL24898:             ]\nL24899: \nL24900:         if self.py_modules:\nL24901:             self.py_modules = [\nL24902:                 p for p in self.py_modules if p != package and not p.startswith(pfx)\nL24903:             ]\nL24904: \nL24905:         if self.ext_modules:\nL24906:             self.ext_modules = [\nL24907:                 p\nL24908:                 for p in self.ext_modules\nL24909:                 if p.name != package and not p.name.startswith(pfx)\nL24910:             ]\nL24911: \nL24912:     def has_contents_for(self, package: str) -> bool:\nL24913:         \"\"\"Return true if 'exclude_package(package)' would do something\"\"\"\nL24914: \nL24915:         pfx = package + '.'\nL24916: \nL24917:         for p in self.iter_distribution_names():\nL24918:             if p == package or p.startswith(pfx):\nL24919:                 return True\nL24920: \nL24921:         return False\nL24922: \nL24923:     def _exclude_misc(self, name: str, value: _Sequence) -> None:\nL24924:         \"\"\"Handle 'exclude()' for list/tuple attrs without a special handler\"\"\"\nL24925:         if not isinstance(value, _sequence):\nL24926:             raise DistutilsSetupError(\nL24927:                 f\"{name}: setting must be of type <{_sequence_type_repr}> (got {value!r})\"\nL24928:             )\nL24929:         try:\nL24930:             old = getattr(self, name)\nL24931:         except AttributeError as e:\nL24932:             raise DistutilsSetupError(f\"{name}: No such distribution setting\") from e\nL24933:         if old is not None and not isinstance(old, _sequence):\nL24934:             raise DistutilsSetupError(\nL24935:                 name + \": this setting cannot be changed via include/exclude\"\nL24936:             )\nL24937:         elif old:\nL24938:             setattr(self, name, [item for item in old if item not in value])\nL24939: \nL24940:     def _include_misc(self, name: str, value: _Sequence) -> None:\nL24941:         \"\"\"Handle 'include()' for list/tuple attrs without a special handler\"\"\"\nL24942: \nL24943:         if not isinstance(value, _sequence):\nL24944:             raise DistutilsSetupError(\nL24945:                 f\"{name}: setting must be of type <{_sequence_type_repr}> (got {value!r})\"\nL24946:             )\nL24947:         try:\nL24948:             old = getattr(self, name)\nL24949:         except AttributeError as e:\nL24950:             raise DistutilsSetupError(f\"{name}: No such distribution setting\") from e\nL24951:         if old is None:\nL24952:             setattr(self, name, value)\nL24953:         elif not isinstance(old, _sequence):\nL24954:             raise DistutilsSetupError(\nL24955:                 name + \": this setting cannot be changed via include/exclude\"\nL24956:             )\nL24957:         else:\nL24958:             new = [item for item in value if item not in old]\nL24959:             setattr(self, name, list(old) + new)\nL24960: \nL24961:     def exclude(self, **attrs) -> None:\nL24962:         \"\"\"Remove items from distribution that are named in keyword arguments\nL24963: \nL24964:         For example, 'dist.exclude(py_modules=[\"x\"])' would remove 'x' from\nL24965:         the distribution's 'py_modules' attribute.  Excluding packages uses\nL24966:         the 'exclude_package()' method, so all of the package's contained\nL24967:         packages, modules, and extensions are also excluded.\nL24968: \nL24969:         Currently, this method only supports exclusion from attributes that are\nL24970:         lists or tuples.  If you need to add support for excluding from other\nL24971:         attributes in this or a subclass, you can add an '_exclude_X' method,\nL24972:         where 'X' is the name of the attribute.  The method will be called with\nL24973:         the value passed to 'exclude()'.  So, 'dist.exclude(foo={\"bar\":\"baz\"})'\nL24974:         will try to call 'dist._exclude_foo({\"bar\":\"baz\"})', which can then\nL24975:         handle whatever special exclusion logic is needed.\nL24976:         \"\"\"\nL24977:         for k, v in attrs.items():\nL24978:             exclude = getattr(self, '_exclude_' + k, None)\nL24979:             if exclude:\nL24980:                 exclude(v)\nL24981:             else:\nL24982:                 self._exclude_misc(k, v)\nL24983: \nL24984:     def _exclude_packages(self, packages: _Sequence) -> None:\nL24985:         if not isinstance(packages, _sequence):\nL24986:             raise DistutilsSetupError(\nL24987:                 f\"packages: setting must be of type <{_sequence_type_repr}> (got {packages!r})\"\nL24988:             )\nL24989:         list(map(self.exclude_package, packages))\nL24990: \nL24991:     def _parse_command_opts(self, parser, args):\nL24992:         # Remove --with-X/--without-X options when processing command args\nL24993:         self.global_options = self.__class__.global_options\nL24994:         self.negative_opt = self.__class__.negative_opt\nL24995: \nL24996:         # First, expand any aliases\nL24997:         command = args[0]\nL24998:         aliases = self.get_option_dict('aliases')\nL24999:         while command in aliases:\nL25000:             _src, alias = aliases[command]\nL25001:             del aliases[command]  # ensure each alias can expand only once!\nL25002:             import shlex\nL25003: \nL25004:             args[:1] = shlex.split(alias, True)\nL25005:             command = args[0]\nL25006: \nL25007:         nargs = _Distribution._parse_command_opts(self, parser, args)\nL25008: \nL25009:         # Handle commands that want to consume all remaining arguments\nL25010:         cmd_class = self.get_command_class(command)\nL25011:         if getattr(cmd_class, 'command_consumes_arguments', None):\nL25012:             self.get_option_dict(command)['args'] = (\"command line\", nargs)\nL25013:             if nargs is not None:\nL25014:                 return []\nL25015: \nL25016:         return nargs\nL25017: \nL25018:     def get_cmdline_options(self) -> dict[str, dict[str, str | None]]:\nL25019:         \"\"\"Return a '{cmd: {opt:val}}' map of all command-line options\nL25020: \nL25021:         Option names are all long, but do not include the leading '--', and\nL25022:         contain dashes rather than underscores.  If the option doesn't take\nL25023:         an argument (e.g. '--quiet'), the 'val' is 'None'.\nL25024: \nL25025:         Note that options provided by config files are intentionally excluded.\nL25026:         \"\"\"\nL25027: \nL25028:         d: dict[str, dict[str, str | None]] = {}\nL25029: \nL25030:         for cmd, opts in self.command_options.items():\nL25031:             val: str | None\nL25032:             for opt, (src, val) in opts.items():\nL25033:                 if src != \"command line\":\nL25034:                     continue\nL25035: \nL25036:                 opt = opt.replace('_', '-')\nL25037: \nL25038:                 if val == 0:\nL25039:                     cmdobj = self.get_command_obj(cmd)\nL25040:                     neg_opt = self.negative_opt.copy()\nL25041:                     neg_opt.update(getattr(cmdobj, 'negative_opt', {}))\nL25042:                     for neg, pos in neg_opt.items():\nL25043:                         if pos == opt:\nL25044:                             opt = neg\nL25045:                             val = None\nL25046:                             break\nL25047:                     else:\nL25048:                         raise AssertionError(\"Shouldn't be able to get here\")\nL25049: \nL25050:                 elif val == 1:\nL25051:                     val = None\nL25052: \nL25053:                 d.setdefault(cmd, {})[opt] = val\nL25054: \nL25055:         return d\nL25056: \nL25057:     def iter_distribution_names(self):\nL25058:         \"\"\"Yield all packages, modules, and extension names in distribution\"\"\"\nL25059: \nL25060:         yield from self.packages or ()\nL25061: \nL25062:         yield from self.py_modules or ()\nL25063: \nL25064:         for ext in self.ext_modules or ():\nL25065:             if isinstance(ext, tuple):\nL25066:                 name, _buildinfo = ext\nL25067:             else:\nL25068:                 name = ext.name\nL25069:             if name.endswith('module'):\nL25070:                 name = name[:-6]\nL25071:             yield name\nL25072: \nL25073:     def handle_display_options(self, option_order):\nL25074:         \"\"\"If there were any non-global \"display-only\" options\nL25075:         (--help-commands or the metadata display options) on the command\nL25076:         line, display the requested info and return true; else return\nL25077:         false.\nL25078:         \"\"\"\nL25079:         import sys\nL25080: \nL25081:         if self.help_commands:\nL25082:             return _Distribution.handle_display_options(self, option_order)\nL25083: \nL25084:         # Stdout may be StringIO (e.g. in tests)\nL25085:         if not isinstance(sys.stdout, io.TextIOWrapper):\nL25086:             return _Distribution.handle_display_options(self, option_order)\nL25087: \nL25088:         # Don't wrap stdout if utf-8 is already the encoding. Provides\nL25089:         #  workaround for #334.\nL25090:         if sys.stdout.encoding.lower() in ('utf-8', 'utf8'):\nL25091:             return _Distribution.handle_display_options(self, option_order)\nL25092: \nL25093:         # Print metadata in UTF-8 no matter the platform\nL25094:         encoding = sys.stdout.encoding\nL25095:         sys.stdout.reconfigure(encoding='utf-8')\nL25096:         try:\nL25097:             return _Distribution.handle_display_options(self, option_order)\nL25098:         finally:\nL25099:             sys.stdout.reconfigure(encoding=encoding)\nL25100: \nL25101:     def run_command(self, command) -> None:\nL25102:         self.set_defaults()\nL25103:         # Postpone defaults until all explicit configuration is considered\nL25104:         # (setup() args, config files, command line and plugins)\nL25105: \nL25106:         super().run_command(command)\nL25107: \nL25108: \nL25109: @functools.cache\nL25110: def _setuptools_commands() -> set[str]:\nL25111:     try:\nL25112:         # Use older API for importlib.metadata compatibility\nL25113:         entry_points = metadata.distribution('setuptools').entry_points\nL25114:         eps: Iterable[str] = (ep.name for ep in entry_points)\nL25115:     except metadata.PackageNotFoundError:\nL25116:         # during bootstrapping, distribution doesn't exist\nL25117:         eps = []\nL25118:     return {*distutils.command.__all__, *eps}\nL25119: \nL25120: \nL25121: class DistDeprecationWarning(SetuptoolsDeprecationWarning):\nL25122:     \"\"\"Class for warning about deprecations in dist in\nL25123:     setuptools. Not ignored by default, unlike DeprecationWarning.\"\"\"\nL25124: \nL25125: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/extension.py\nL25126: #!/usr/bin/env python3\nL25127: from __future__ import annotations\nL25128: \nL25129: import functools\nL25130: import re\nL25131: from typing import TYPE_CHECKING\nL25132: \nL25133: from setuptools._path import StrPath\nL25134: \nL25135: from .monkey import get_unpatched\nL25136: \nL25137: import distutils.core\nL25138: import distutils.errors\nL25139: import distutils.extension\nL25140: \nL25141: \nL25142: def _have_cython():\nL25143:     \"\"\"\nL25144:     Return True if Cython can be imported.\nL25145:     \"\"\"\nL25146:     cython_impl = 'Cython.Distutils.build_ext'\nL25147:     try:\nL25148:         # from (cython_impl) import build_ext\nL25149:         __import__(cython_impl, fromlist=['build_ext']).build_ext\nL25150:     except Exception:\nL25151:         return False\nL25152:     return True\nL25153: \nL25154: \nL25155: # for compatibility\nL25156: have_pyrex = _have_cython\nL25157: if TYPE_CHECKING:\nL25158:     # Work around a mypy issue where type[T] can't be used as a base: https://github.com/python/mypy/issues/10962\nL25159:     from distutils.core import Extension as _Extension\nL25160: else:\nL25161:     _Extension = get_unpatched(distutils.core.Extension)\nL25162: \nL25163: \nL25164: class Extension(_Extension):\nL25165:     \"\"\"\nL25166:     Describes a single extension module.\nL25167: \nL25168:     This means that all source files will be compiled into a single binary file\nL25169:     ``<module path>.<suffix>`` (with ``<module path>`` derived from ``name`` and\nL25170:     ``<suffix>`` defined by one of the values in\nL25171:     ``importlib.machinery.EXTENSION_SUFFIXES``).\nL25172: \nL25173:     In the case ``.pyx`` files are passed as ``sources and`` ``Cython`` is **not**\nL25174:     installed in the build environment, ``setuptools`` may also try to look for the\nL25175:     equivalent ``.cpp`` or ``.c`` files.\nL25176: \nL25177:     :arg str name:\nL25178:       the full name of the extension, including any packages -- ie.\nL25179:       *not* a filename or pathname, but Python dotted name\nL25180: \nL25181:     :arg list[str|os.PathLike[str]] sources:\nL25182:       list of source filenames, relative to the distribution root\nL25183:       (where the setup script lives), in Unix form (slash-separated)\nL25184:       for portability.  Source files may be C, C++, SWIG (.i),\nL25185:       platform-specific resource files, or whatever else is recognized\nL25186:       by the \"build_ext\" command as source for a Python extension.\nL25187: \nL25188:     :keyword list[str] include_dirs:\nL25189:       list of directories to search for C/C++ header files (in Unix\nL25190:       form for portability)\nL25191: \nL25192:     :keyword list[tuple[str, str|None]] define_macros:\nL25193:       list of macros to define; each macro is defined using a 2-tuple:\nL25194:       the first item corresponding to the name of the macro and the second\nL25195:       item either a string with its value or None to\nL25196:       define it without a particular value (equivalent of \"#define\nL25197:       FOO\" in source or -DFOO on Unix C compiler command line)\nL25198: \nL25199:     :keyword list[str] undef_macros:\nL25200:       list of macros to undefine explicitly\nL25201: \nL25202:     :keyword list[str] library_dirs:\nL25203:       list of directories to search for C/C++ libraries at link time\nL25204: \nL25205:     :keyword list[str] libraries:\nL25206:       list of library names (not filenames or paths) to link against\nL25207: \nL25208:     :keyword list[str] runtime_library_dirs:\nL25209:       list of directories to search for C/C++ libraries at run time\nL25210:       (for shared extensions, this is when the extension is loaded).\nL25211:       Setting this will cause an exception during build on Windows\nL25212:       platforms.\nL25213: \nL25214:     :keyword list[str] extra_objects:\nL25215:       list of extra files to link with (eg. object files not implied\nL25216:       by 'sources', static library that must be explicitly specified,\nL25217:       binary resource files, etc.)\nL25218: \nL25219:     :keyword list[str] extra_compile_args:\nL25220:       any extra platform- and compiler-specific information to use\nL25221:       when compiling the source files in 'sources'.  For platforms and\nL25222:       compilers where \"command line\" makes sense, this is typically a\nL25223:       list of command-line arguments, but for other platforms it could\nL25224:       be anything.\nL25225: \nL25226:     :keyword list[str] extra_link_args:\nL25227:       any extra platform- and compiler-specific information to use\nL25228:       when linking object files together to create the extension (or\nL25229:       to create a new static Python interpreter).  Similar\nL25230:       interpretation as for 'extra_compile_args'.\nL25231: \nL25232:     :keyword list[str] export_symbols:\nL25233:       list of symbols to be exported from a shared extension.  Not\nL25234:       used on all platforms, and not generally necessary for Python\nL25235:       extensions, which typically export exactly one symbol: \"init\" +\nL25236:       extension_name.\nL25237: \nL25238:     :keyword list[str] swig_opts:\nL25239:       any extra options to pass to SWIG if a source file has the .i\nL25240:       extension.\nL25241: \nL25242:     :keyword list[str] depends:\nL25243:       list of files that the extension depends on\nL25244: \nL25245:     :keyword str language:\nL25246:       extension language (i.e. \"c\", \"c++\", \"objc\"). Will be detected\nL25247:       from the source extensions if not provided.\nL25248: \nL25249:     :keyword bool optional:\nL25250:       specifies that a build failure in the extension should not abort the\nL25251:       build process, but simply not install the failing extension.\nL25252: \nL25253:     :keyword bool py_limited_api:\nL25254:       opt-in flag for the usage of :doc:`Python's limited API <python:c-api/stable>`.\nL25255: \nL25256:     :raises setuptools.errors.PlatformError: if ``runtime_library_dirs`` is\nL25257:       specified on Windows. (since v63)\nL25258:     \"\"\"\nL25259: \nL25260:     # These 4 are set and used in setuptools/command/build_ext.py\nL25261:     # The lack of a default value and risk of `AttributeError` is purposeful\nL25262:     # to avoid people forgetting to call finalize_options if they modify the extension list.\nL25263:     # See example/rationale in https://github.com/pypa/setuptools/issues/4529.\nL25264:     _full_name: str  #: Private API, internal use only.\nL25265:     _links_to_dynamic: bool  #: Private API, internal use only.\nL25266:     _needs_stub: bool  #: Private API, internal use only.\nL25267:     _file_name: str  #: Private API, internal use only.\nL25268: \nL25269:     def __init__(\nL25270:         self,\nL25271:         name: str,\nL25272:         sources: list[StrPath],\nL25273:         *args,\nL25274:         py_limited_api: bool = False,\nL25275:         **kw,\nL25276:     ) -> None:\nL25277:         # The *args is needed for compatibility as calls may use positional\nL25278:         # arguments. py_limited_api may be set only via keyword.\nL25279:         self.py_limited_api = py_limited_api\nL25280:         super().__init__(\nL25281:             name,\nL25282:             sources,  # type: ignore[arg-type] # Vendored version of setuptools supports PathLike\nL25283:             *args,\nL25284:             **kw,\nL25285:         )\nL25286: \nL25287:     def _convert_pyx_sources_to_lang(self):\nL25288:         \"\"\"\nL25289:         Replace sources with .pyx extensions to sources with the target\nL25290:         language extension. This mechanism allows language authors to supply\nL25291:         pre-converted sources but to prefer the .pyx sources.\nL25292:         \"\"\"\nL25293:         if _have_cython():\nL25294:             # the build has Cython, so allow it to compile the .pyx files\nL25295:             return\nL25296:         lang = self.language or ''\nL25297:         target_ext = '.cpp' if lang.lower() == 'c++' else '.c'\nL25298:         sub = functools.partial(re.sub, '.pyx$', target_ext)\nL25299:         self.sources = list(map(sub, self.sources))\nL25300: \nL25301: \nL25302: class Library(Extension):\nL25303:     \"\"\"Just like a regular Extension, but built as a library instead\"\"\"\nL25304: \nL25305: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/monkey.py\nL25306: #!/usr/bin/env python3\nL25307: \"\"\"\nL25308: Monkey patching of distutils.\nL25309: \"\"\"\nL25310: \nL25311: from __future__ import annotations\nL25312: \nL25313: import inspect\nL25314: import platform\nL25315: import sys\nL25316: import types\nL25317: from typing import TypeVar, cast, overload\nL25318: \nL25319: import distutils.filelist\nL25320: \nL25321: _T = TypeVar(\"_T\")\nL25322: _UnpatchT = TypeVar(\"_UnpatchT\", type, types.FunctionType)\nL25323: \nL25324: \nL25325: __all__: list[str] = []\nL25326: \"\"\"\nL25327: Everything is private. Contact the project team\nL25328: if you think you need this functionality.\nL25329: \"\"\"\nL25330: \nL25331: \nL25332: def _get_mro(cls):\nL25333:     \"\"\"\nL25334:     Returns the bases classes for cls sorted by the MRO.\nL25335: \nL25336:     Works around an issue on Jython where inspect.getmro will not return all\nL25337:     base classes if multiple classes share the same name. Instead, this\nL25338:     function will return a tuple containing the class itself, and the contents\nL25339:     of cls.__bases__. See https://github.com/pypa/setuptools/issues/1024.\nL25340:     \"\"\"\nL25341:     if platform.python_implementation() == \"Jython\":\nL25342:         return (cls,) + cls.__bases__\nL25343:     return inspect.getmro(cls)\nL25344: \nL25345: \nL25346: @overload\nL25347: def get_unpatched(item: _UnpatchT) -> _UnpatchT: ...\nL25348: @overload\nL25349: def get_unpatched(item: object) -> None: ...\nL25350: def get_unpatched(\nL25351:     item: type | types.FunctionType | object,\nL25352: ) -> type | types.FunctionType | None:\nL25353:     if isinstance(item, type):\nL25354:         return get_unpatched_class(item)\nL25355:     if isinstance(item, types.FunctionType):\nL25356:         return get_unpatched_function(item)\nL25357:     return None\nL25358: \nL25359: \nL25360: def get_unpatched_class(cls: type[_T]) -> type[_T]:\nL25361:     \"\"\"Protect against re-patching the distutils if reloaded\nL25362: \nL25363:     Also ensures that no other distutils extension monkeypatched the distutils\nL25364:     first.\nL25365:     \"\"\"\nL25366:     external_bases = (\nL25367:         cast(type[_T], cls)\nL25368:         for cls in _get_mro(cls)\nL25369:         if not cls.__module__.startswith('setuptools')\nL25370:     )\nL25371:     base = next(external_bases)\nL25372:     if not base.__module__.startswith('distutils'):\nL25373:         msg = f\"distutils has already been patched by {cls!r}\"\nL25374:         raise AssertionError(msg)\nL25375:     return base\nL25376: \nL25377: \nL25378: def patch_all():\nL25379:     import setuptools\nL25380: \nL25381:     # we can't patch distutils.cmd, alas\nL25382:     distutils.core.Command = setuptools.Command  # type: ignore[misc,assignment] # monkeypatching\nL25383: \nL25384:     _patch_distribution_metadata()\nL25385: \nL25386:     # Install Distribution throughout the distutils\nL25387:     for module in distutils.dist, distutils.core, distutils.cmd:\nL25388:         module.Distribution = setuptools.dist.Distribution\nL25389: \nL25390:     # Install the patched Extension\nL25391:     distutils.core.Extension = setuptools.extension.Extension  # type: ignore[misc,assignment] # monkeypatching\nL25392:     distutils.extension.Extension = setuptools.extension.Extension  # type: ignore[misc,assignment] # monkeypatching\nL25393:     if 'distutils.command.build_ext' in sys.modules:\nL25394:         sys.modules[\nL25395:             'distutils.command.build_ext'\nL25396:         ].Extension = setuptools.extension.Extension\nL25397: \nL25398: \nL25399: def _patch_distribution_metadata():\nL25400:     from . import _core_metadata\nL25401: \nL25402:     \"\"\"Patch write_pkg_file and read_pkg_file for higher metadata standards\"\"\"\nL25403:     for attr in (\nL25404:         'write_pkg_info',\nL25405:         'write_pkg_file',\nL25406:         'read_pkg_file',\nL25407:         'get_metadata_version',\nL25408:         'get_fullname',\nL25409:     ):\nL25410:         new_val = getattr(_core_metadata, attr)\nL25411:         setattr(distutils.dist.DistributionMetadata, attr, new_val)\nL25412: \nL25413: \nL25414: def patch_func(replacement, target_mod, func_name):\nL25415:     \"\"\"\nL25416:     Patch func_name in target_mod with replacement\nL25417: \nL25418:     Important - original must be resolved by name to avoid\nL25419:     patching an already patched function.\nL25420:     \"\"\"\nL25421:     original = getattr(target_mod, func_name)\nL25422: \nL25423:     # set the 'unpatched' attribute on the replacement to\nL25424:     # point to the original.\nL25425:     vars(replacement).setdefault('unpatched', original)\nL25426: \nL25427:     # replace the function in the original module\nL25428:     setattr(target_mod, func_name, replacement)\nL25429: \nL25430: \nL25431: def get_unpatched_function(candidate):\nL25432:     return candidate.unpatched\nL25433: \nL25434: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/msvc.py\nL25435: #!/usr/bin/env python3\nL25436: \"\"\"\nL25437: Environment info about Microsoft Compilers.\nL25438: \nL25439: >>> getfixture('windows_only')\nL25440: >>> ei = EnvironmentInfo('amd64')\nL25441: \"\"\"\nL25442: \nL25443: from __future__ import annotations\nL25444: \nL25445: import contextlib\nL25446: import itertools\nL25447: import json\nL25448: import os\nL25449: import os.path\nL25450: import platform\nL25451: from typing import TYPE_CHECKING, TypedDict\nL25452: \nL25453: from more_itertools import unique_everseen\nL25454: \nL25455: import distutils.errors\nL25456: \nL25457: if TYPE_CHECKING:\nL25458:     from typing_extensions import LiteralString, NotRequired\nL25459: \nL25460: # https://github.com/python/mypy/issues/8166\nL25461: if not TYPE_CHECKING and platform.system() == 'Windows':\nL25462:     import winreg\nL25463:     from os import environ\nL25464: else:\nL25465:     # Mock winreg and environ so the module can be imported on this platform.\nL25466: \nL25467:     class winreg:\nL25468:         HKEY_USERS = None\nL25469:         HKEY_CURRENT_USER = None\nL25470:         HKEY_LOCAL_MACHINE = None\nL25471:         HKEY_CLASSES_ROOT = None\nL25472: \nL25473:     environ: dict[str, str] = dict()\nL25474: \nL25475: \nL25476: class PlatformInfo:\nL25477:     \"\"\"\nL25478:     Current and Target Architectures information.\nL25479: \nL25480:     Parameters\nL25481:     ----------\nL25482:     arch: str\nL25483:         Target architecture.\nL25484:     \"\"\"\nL25485: \nL25486:     current_cpu = environ.get('processor_architecture', '').lower()\nL25487: \nL25488:     def __init__(self, arch) -> None:\nL25489:         self.arch = arch.lower().replace('x64', 'amd64')\nL25490: \nL25491:     @property\nL25492:     def target_cpu(self):\nL25493:         \"\"\"\nL25494:         Return Target CPU architecture.\nL25495: \nL25496:         Return\nL25497:         ------\nL25498:         str\nL25499:             Target CPU\nL25500:         \"\"\"\nL25501:         return self.arch[self.arch.find('_') + 1 :]\nL25502: \nL25503:     def target_is_x86(self):\nL25504:         \"\"\"\nL25505:         Return True if target CPU is x86 32 bits..\nL25506: \nL25507:         Return\nL25508:         ------\nL25509:         bool\nL25510:             CPU is x86 32 bits\nL25511:         \"\"\"\nL25512:         return self.target_cpu == 'x86'\nL25513: \nL25514:     def current_is_x86(self):\nL25515:         \"\"\"\nL25516:         Return True if current CPU is x86 32 bits..\nL25517: \nL25518:         Return\nL25519:         ------\nL25520:         bool\nL25521:             CPU is x86 32 bits\nL25522:         \"\"\"\nL25523:         return self.current_cpu == 'x86'\nL25524: \nL25525:     def current_dir(self, hidex86=False, x64=False) -> str:\nL25526:         \"\"\"\nL25527:         Current platform specific subfolder.\nL25528: \nL25529:         Parameters\nL25530:         ----------\nL25531:         hidex86: bool\nL25532:             return '' and not '\\x86' if architecture is x86.\nL25533:         x64: bool\nL25534:             return '\\x64' and not '\\amd64' if architecture is amd64.\nL25535: \nL25536:         Return\nL25537:         ------\nL25538:         str\nL25539:             subfolder: '\\target', or '' (see hidex86 parameter)\nL25540:         \"\"\"\nL25541:         return (\nL25542:             ''\nL25543:             if (self.current_cpu == 'x86' and hidex86)\nL25544:             else r'\\x64'\nL25545:             if (self.current_cpu == 'amd64' and x64)\nL25546:             else rf'\\{self.current_cpu}'\nL25547:         )\nL25548: \nL25549:     def target_dir(self, hidex86=False, x64=False) -> str:\nL25550:         r\"\"\"\nL25551:         Target platform specific subfolder.\nL25552: \nL25553:         Parameters\nL25554:         ----------\nL25555:         hidex86: bool\nL25556:             return '' and not '\\x86' if architecture is x86.\nL25557:         x64: bool\nL25558:             return '\\x64' and not '\\amd64' if architecture is amd64.\nL25559: \nL25560:         Return\nL25561:         ------\nL25562:         str\nL25563:             subfolder: '\\current', or '' (see hidex86 parameter)\nL25564:         \"\"\"\nL25565:         return (\nL25566:             ''\nL25567:             if (self.target_cpu == 'x86' and hidex86)\nL25568:             else r'\\x64'\nL25569:             if (self.target_cpu == 'amd64' and x64)\nL25570:             else rf'\\{self.target_cpu}'\nL25571:         )\nL25572: \nL25573:     def cross_dir(self, forcex86=False):\nL25574:         r\"\"\"\nL25575:         Cross platform specific subfolder.\nL25576: \nL25577:         Parameters\nL25578:         ----------\nL25579:         forcex86: bool\nL25580:             Use 'x86' as current architecture even if current architecture is\nL25581:             not x86.\nL25582: \nL25583:         Return\nL25584:         ------\nL25585:         str\nL25586:             subfolder: '' if target architecture is current architecture,\nL25587:             '\\current_target' if not.\nL25588:         \"\"\"\nL25589:         current = 'x86' if forcex86 else self.current_cpu\nL25590:         return (\nL25591:             ''\nL25592:             if self.target_cpu == current\nL25593:             else self.target_dir().replace('\\\\', f'\\\\{current}_')\nL25594:         )\nL25595: \nL25596: \nL25597: class RegistryInfo:\nL25598:     \"\"\"\nL25599:     Microsoft Visual Studio related registry information.\nL25600: \nL25601:     Parameters\nL25602:     ----------\nL25603:     platform_info: PlatformInfo\nL25604:         \"PlatformInfo\" instance.\nL25605:     \"\"\"\nL25606: \nL25607:     HKEYS = (\nL25608:         winreg.HKEY_USERS,\nL25609:         winreg.HKEY_CURRENT_USER,\nL25610:         winreg.HKEY_LOCAL_MACHINE,\nL25611:         winreg.HKEY_CLASSES_ROOT,\nL25612:     )\nL25613: \nL25614:     def __init__(self, platform_info) -> None:\nL25615:         self.pi = platform_info\nL25616: \nL25617:     @property\nL25618:     def visualstudio(self) -> str:\nL25619:         \"\"\"\nL25620:         Microsoft Visual Studio root registry key.\nL25621: \nL25622:         Return\nL25623:         ------\nL25624:         str\nL25625:             Registry key\nL25626:         \"\"\"\nL25627:         return 'VisualStudio'\nL25628: \nL25629:     @property\nL25630:     def sxs(self):\nL25631:         \"\"\"\nL25632:         Microsoft Visual Studio SxS registry key.\nL25633: \nL25634:         Return\nL25635:         ------\nL25636:         str\nL25637:             Registry key\nL25638:         \"\"\"\nL25639:         return os.path.join(self.visualstudio, 'SxS')\nL25640: \nL25641:     @property\nL25642:     def vc(self):\nL25643:         \"\"\"\nL25644:         Microsoft Visual C++ VC7 registry key.\nL25645: \nL25646:         Return\nL25647:         ------\nL25648:         str\nL25649:             Registry key\nL25650:         \"\"\"\nL25651:         return os.path.join(self.sxs, 'VC7')\nL25652: \nL25653:     @property\nL25654:     def vs(self):\nL25655:         \"\"\"\nL25656:         Microsoft Visual Studio VS7 registry key.\nL25657: \nL25658:         Return\nL25659:         ------\nL25660:         str\nL25661:             Registry key\nL25662:         \"\"\"\nL25663:         return os.path.join(self.sxs, 'VS7')\nL25664: \nL25665:     @property\nL25666:     def vc_for_python(self) -> str:\nL25667:         \"\"\"\nL25668:         Microsoft Visual C++ for Python registry key.\nL25669: \nL25670:         Return\nL25671:         ------\nL25672:         str\nL25673:             Registry key\nL25674:         \"\"\"\nL25675:         return r'DevDiv\\VCForPython'\nL25676: \nL25677:     @property\nL25678:     def microsoft_sdk(self) -> str:\nL25679:         \"\"\"\nL25680:         Microsoft SDK registry key.\nL25681: \nL25682:         Return\nL25683:         ------\nL25684:         str\nL25685:             Registry key\nL25686:         \"\"\"\nL25687:         return 'Microsoft SDKs'\nL25688: \nL25689:     @property\nL25690:     def windows_sdk(self):\nL25691:         \"\"\"\nL25692:         Microsoft Windows/Platform SDK registry key.\nL25693: \nL25694:         Return\nL25695:         ------\nL25696:         str\nL25697:             Registry key\nL25698:         \"\"\"\nL25699:         return os.path.join(self.microsoft_sdk, 'Windows')\nL25700: \nL25701:     @property\nL25702:     def netfx_sdk(self):\nL25703:         \"\"\"\nL25704:         Microsoft .NET Framework SDK registry key.\nL25705: \nL25706:         Return\nL25707:         ------\nL25708:         str\nL25709:             Registry key\nL25710:         \"\"\"\nL25711:         return os.path.join(self.microsoft_sdk, 'NETFXSDK')\nL25712: \nL25713:     @property\nL25714:     def windows_kits_roots(self) -> str:\nL25715:         \"\"\"\nL25716:         Microsoft Windows Kits Roots registry key.\nL25717: \nL25718:         Return\nL25719:         ------\nL25720:         str\nL25721:             Registry key\nL25722:         \"\"\"\nL25723:         return r'Windows Kits\\Installed Roots'\nL25724: \nL25725:     def microsoft(self, key, x86=False):\nL25726:         \"\"\"\nL25727:         Return key in Microsoft software registry.\nL25728: \nL25729:         Parameters\nL25730:         ----------\nL25731:         key: str\nL25732:             Registry key path where look.\nL25733:         x86: str\nL25734:             Force x86 software registry.\nL25735: \nL25736:         Return\nL25737:         ------\nL25738:         str\nL25739:             Registry key\nL25740:         \"\"\"\nL25741:         node64 = '' if self.pi.current_is_x86() or x86 else 'Wow6432Node'\nL25742:         return os.path.join('Software', node64, 'Microsoft', key)\nL25743: \nL25744:     def lookup(self, key, name):\nL25745:         \"\"\"\nL25746:         Look for values in registry in Microsoft software registry.\nL25747: \nL25748:         Parameters\nL25749:         ----------\nL25750:         key: str\nL25751:             Registry key path where look.\nL25752:         name: str\nL25753:             Value name to find.\nL25754: \nL25755:         Return\nL25756:         ------\nL25757:         str\nL25758:             value\nL25759:         \"\"\"\nL25760:         key_read = winreg.KEY_READ\nL25761:         openkey = winreg.OpenKey\nL25762:         closekey = winreg.CloseKey\nL25763:         ms = self.microsoft\nL25764:         for hkey in self.HKEYS:\nL25765:             bkey = None\nL25766:             try:\nL25767:                 bkey = openkey(hkey, ms(key), 0, key_read)\nL25768:             except OSError:\nL25769:                 if not self.pi.current_is_x86():\nL25770:                     try:\nL25771:                         bkey = openkey(hkey, ms(key, True), 0, key_read)\nL25772:                     except OSError:\nL25773:                         continue\nL25774:                 else:\nL25775:                     continue\nL25776:             try:\nL25777:                 return winreg.QueryValueEx(bkey, name)[0]\nL25778:             except OSError:\nL25779:                 pass\nL25780:             finally:\nL25781:                 if bkey:\nL25782:                     closekey(bkey)\nL25783:         return None\nL25784: \nL25785: \nL25786: class SystemInfo:\nL25787:     \"\"\"\nL25788:     Microsoft Windows and Visual Studio related system information.\nL25789: \nL25790:     Parameters\nL25791:     ----------\nL25792:     registry_info: RegistryInfo\nL25793:         \"RegistryInfo\" instance.\nL25794:     vc_ver: float\nL25795:         Required Microsoft Visual C++ version.\nL25796:     \"\"\"\nL25797: \nL25798:     # Variables and properties in this class use originals CamelCase variables\nL25799:     # names from Microsoft source files for more easy comparison.\nL25800:     WinDir = environ.get('WinDir', '')\nL25801:     ProgramFiles = environ.get('ProgramFiles', '')\nL25802:     ProgramFilesx86 = environ.get('ProgramFiles(x86)', ProgramFiles)\nL25803: \nL25804:     def __init__(self, registry_info, vc_ver=None) -> None:\nL25805:         self.ri = registry_info\nL25806:         self.pi = self.ri.pi\nL25807: \nL25808:         self.known_vs_paths = self.find_programdata_vs_vers()\nL25809: \nL25810:         # Except for VS15+, VC version is aligned with VS version\nL25811:         self.vs_ver = self.vc_ver = vc_ver or self._find_latest_available_vs_ver()\nL25812: \nL25813:     def _find_latest_available_vs_ver(self):\nL25814:         \"\"\"\nL25815:         Find the latest VC version\nL25816: \nL25817:         Return\nL25818:         ------\nL25819:         float\nL25820:             version\nL25821:         \"\"\"\nL25822:         reg_vc_vers = self.find_reg_vs_vers()\nL25823: \nL25824:         if not (reg_vc_vers or self.known_vs_paths):\nL25825:             raise distutils.errors.DistutilsPlatformError(\nL25826:                 'No Microsoft Visual C++ version found'\nL25827:             )\nL25828: \nL25829:         vc_vers = set(reg_vc_vers)\nL25830:         vc_vers.update(self.known_vs_paths)\nL25831:         return sorted(vc_vers)[-1]\nL25832: \nL25833:     def find_reg_vs_vers(self):\nL25834:         \"\"\"\nL25835:         Find Microsoft Visual Studio versions available in registry.\nL25836: \nL25837:         Return\nL25838:         ------\nL25839:         list of float\nL25840:             Versions\nL25841:         \"\"\"\nL25842:         ms = self.ri.microsoft\nL25843:         vckeys = (self.ri.vc, self.ri.vc_for_python, self.ri.vs)\nL25844:         vs_vers = []\nL25845:         for hkey, key in itertools.product(self.ri.HKEYS, vckeys):\nL25846:             try:\nL25847:                 bkey = winreg.OpenKey(hkey, ms(key), 0, winreg.KEY_READ)\nL25848:             except OSError:\nL25849:                 continue\nL25850:             with bkey:\nL25851:                 subkeys, values, _ = winreg.QueryInfoKey(bkey)\nL25852:                 for i in range(values):\nL25853:                     with contextlib.suppress(ValueError):\nL25854:                         ver = float(winreg.EnumValue(bkey, i)[0])\nL25855:                         if ver not in vs_vers:\nL25856:                             vs_vers.append(ver)\nL25857:                 for i in range(subkeys):\nL25858:                     with contextlib.suppress(ValueError):\nL25859:                         ver = float(winreg.EnumKey(bkey, i))\nL25860:                         if ver not in vs_vers:\nL25861:                             vs_vers.append(ver)\nL25862:         return sorted(vs_vers)\nL25863: \nL25864:     def find_programdata_vs_vers(self) -> dict[float, str]:\nL25865:         r\"\"\"\nL25866:         Find Visual studio 2017+ versions from information in\nL25867:         \"C:\\ProgramData\\Microsoft\\VisualStudio\\Packages\\_Instances\".\nL25868: \nL25869:         Return\nL25870:         ------\nL25871:         dict\nL25872:             float version as key, path as value.\nL25873:         \"\"\"\nL25874:         vs_versions: dict[float, str] = {}\nL25875:         instances_dir = r'C:\\ProgramData\\Microsoft\\VisualStudio\\Packages\\_Instances'\nL25876: \nL25877:         try:\nL25878:             hashed_names = os.listdir(instances_dir)\nL25879: \nL25880:         except OSError:\nL25881:             # Directory not exists with all Visual Studio versions\nL25882:             return vs_versions\nL25883: \nL25884:         for name in hashed_names:\nL25885:             try:\nL25886:                 # Get VS installation path from \"state.json\" file\nL25887:                 state_path = os.path.join(instances_dir, name, 'state.json')\nL25888:                 with open(state_path, 'rt', encoding='utf-8') as state_file:\nL25889:                     state = json.load(state_file)\nL25890:                 vs_path = state['installationPath']\nL25891: \nL25892:                 # Raises OSError if this VS installation does not contain VC\nL25893:                 os.listdir(os.path.join(vs_path, r'VC\\Tools\\MSVC'))\nL25894: \nL25895:                 # Store version and path\nL25896:                 vs_versions[self._as_float_version(state['installationVersion'])] = (\nL25897:                     vs_path\nL25898:                 )\nL25899: \nL25900:             except (OSError, KeyError):\nL25901:                 # Skip if \"state.json\" file is missing or bad format\nL25902:                 continue\nL25903: \nL25904:         return vs_versions\nL25905: \nL25906:     @staticmethod\nL25907:     def _as_float_version(version):\nL25908:         \"\"\"\nL25909:         Return a string version as a simplified float version (major.minor)\nL25910: \nL25911:         Parameters\nL25912:         ----------\nL25913:         version: str\nL25914:             Version.\nL25915: \nL25916:         Return\nL25917:         ------\nL25918:         float\nL25919:             version\nL25920:         \"\"\"\nL25921:         return float('.'.join(version.split('.')[:2]))\nL25922: \nL25923:     @property\nL25924:     def VSInstallDir(self):\nL25925:         \"\"\"\nL25926:         Microsoft Visual Studio directory.\nL25927: \nL25928:         Return\nL25929:         ------\nL25930:         str\nL25931:             path\nL25932:         \"\"\"\nL25933:         # Default path\nL25934:         default = os.path.join(\nL25935:             self.ProgramFilesx86, f'Microsoft Visual Studio {self.vs_ver:0.1f}'\nL25936:         )\nL25937: \nL25938:         # Try to get path from registry, if fail use default path\nL25939:         return self.ri.lookup(self.ri.vs, f'{self.vs_ver:0.1f}') or default\nL25940: \nL25941:     @property\nL25942:     def VCInstallDir(self):\nL25943:         \"\"\"\nL25944:         Microsoft Visual C++ directory.\nL25945: \nL25946:         Return\nL25947:         ------\nL25948:         str\nL25949:             path\nL25950:         \"\"\"\nL25951:         path = self._guess_vc() or self._guess_vc_legacy()\nL25952: \nL25953:         if not os.path.isdir(path):\nL25954:             msg = 'Microsoft Visual C++ directory not found'\nL25955:             raise distutils.errors.DistutilsPlatformError(msg)\nL25956: \nL25957:         return path\nL25958: \nL25959:     def _guess_vc(self):\nL25960:         \"\"\"\nL25961:         Locate Visual C++ for VS2017+.\nL25962: \nL25963:         Return\nL25964:         ------\nL25965:         str\nL25966:             path\nL25967:         \"\"\"\nL25968:         if self.vs_ver <= 14.0:\nL25969:             return ''\nL25970: \nL25971:         try:\nL25972:             # First search in known VS paths\nL25973:             vs_dir = self.known_vs_paths[self.vs_ver]\nL25974:         except KeyError:\nL25975:             # Else, search with path from registry\nL25976:             vs_dir = self.VSInstallDir\nL25977: \nL25978:         guess_vc = os.path.join(vs_dir, r'VC\\Tools\\MSVC')\nL25979: \nL25980:         # Subdir with VC exact version as name\nL25981:         try:\nL25982:             # Update the VC version with real one instead of VS version\nL25983:             vc_ver = os.listdir(guess_vc)[-1]\nL25984:             self.vc_ver = self._as_float_version(vc_ver)\nL25985:             return os.path.join(guess_vc, vc_ver)\nL25986:         except (OSError, IndexError):\nL25987:             return ''\nL25988: \nL25989:     def _guess_vc_legacy(self):\nL25990:         \"\"\"\nL25991:         Locate Visual C++ for versions prior to 2017.\nL25992: \nL25993:         Return\nL25994:         ------\nL25995:         str\nL25996:             path\nL25997:         \"\"\"\nL25998:         default = os.path.join(\nL25999:             self.ProgramFilesx86,\nL26000:             rf'Microsoft Visual Studio {self.vs_ver:0.1f}\\VC',\nL26001:         )\nL26002: \nL26003:         # Try to get \"VC++ for Python\" path from registry as default path\nL26004:         reg_path = os.path.join(self.ri.vc_for_python, f'{self.vs_ver:0.1f}')\nL26005:         python_vc = self.ri.lookup(reg_path, 'installdir')\nL26006:         default_vc = os.path.join(python_vc, 'VC') if python_vc else default\nL26007: \nL26008:         # Try to get path from registry, if fail use default path\nL26009:         return self.ri.lookup(self.ri.vc, f'{self.vs_ver:0.1f}') or default_vc\nL26010: \nL26011:     @property\nL26012:     def WindowsSdkVersion(self) -> tuple[LiteralString, ...]:\nL26013:         \"\"\"\nL26014:         Microsoft Windows SDK versions for specified MSVC++ version.\nL26015: \nL26016:         Return\nL26017:         ------\nL26018:         tuple of str\nL26019:             versions\nL26020:         \"\"\"\nL26021:         if self.vs_ver <= 9.0:\nL26022:             return '7.0', '6.1', '6.0a'\nL26023:         elif self.vs_ver == 10.0:\nL26024:             return '7.1', '7.0a'\nL26025:         elif self.vs_ver == 11.0:\nL26026:             return '8.0', '8.0a'\nL26027:         elif self.vs_ver == 12.0:\nL26028:             return '8.1', '8.1a'\nL26029:         elif self.vs_ver >= 14.0:\nL26030:             return '10.0', '8.1'\nL26031:         return ()\nL26032: \nL26033:     @property\nL26034:     def WindowsSdkLastVersion(self):\nL26035:         \"\"\"\nL26036:         Microsoft Windows SDK last version.\nL26037: \nL26038:         Return\nL26039:         ------\nL26040:         str\nL26041:             version\nL26042:         \"\"\"\nL26043:         return self._use_last_dir_name(os.path.join(self.WindowsSdkDir, 'lib'))\nL26044: \nL26045:     @property\nL26046:     def WindowsSdkDir(self) -> str | None:  # noqa: C901  # is too complex (12)  # FIXME\nL26047:         \"\"\"\nL26048:         Microsoft Windows SDK directory.\nL26049: \nL26050:         Return\nL26051:         ------\nL26052:         str\nL26053:             path\nL26054:         \"\"\"\nL26055:         sdkdir: str | None = ''\nL26056:         for ver in self.WindowsSdkVersion:\nL26057:             # Try to get it from registry\nL26058:             loc = os.path.join(self.ri.windows_sdk, f'v{ver}')\nL26059:             sdkdir = self.ri.lookup(loc, 'installationfolder')\nL26060:             if sdkdir:\nL26061:                 break\nL26062:         if not sdkdir or not os.path.isdir(sdkdir):\nL26063:             # Try to get \"VC++ for Python\" version from registry\nL26064:             path = os.path.join(self.ri.vc_for_python, f'{self.vc_ver:0.1f}')\nL26065:             install_base = self.ri.lookup(path, 'installdir')\nL26066:             if install_base:\nL26067:                 sdkdir = os.path.join(install_base, 'WinSDK')\nL26068:         if not sdkdir or not os.path.isdir(sdkdir):\nL26069:             # If fail, use default new path\nL26070:             for ver in self.WindowsSdkVersion:\nL26071:                 intver = ver[: ver.rfind('.')]\nL26072:                 path = rf'Microsoft SDKs\\Windows Kits\\{intver}'\nL26073:                 d = os.path.join(self.ProgramFiles, path)\nL26074:                 if os.path.isdir(d):\nL26075:                     sdkdir = d\nL26076:         if not sdkdir or not os.path.isdir(sdkdir):\nL26077:             # If fail, use default old path\nL26078:             for ver in self.WindowsSdkVersion:\nL26079:                 path = rf'Microsoft SDKs\\Windows\\v{ver}'\nL26080:                 d = os.path.join(self.ProgramFiles, path)\nL26081:                 if os.path.isdir(d):\nL26082:                     sdkdir = d\nL26083:         if not sdkdir:\nL26084:             # If fail, use Platform SDK\nL26085:             sdkdir = os.path.join(self.VCInstallDir, 'PlatformSDK')\nL26086:         return sdkdir\nL26087: \nL26088:     @property\nL26089:     def WindowsSDKExecutablePath(self):\nL26090:         \"\"\"\nL26091:         Microsoft Windows SDK executable directory.\nL26092: \nL26093:         Return\nL26094:         ------\nL26095:         str\nL26096:             path\nL26097:         \"\"\"\nL26098:         # Find WinSDK NetFx Tools registry dir name\nL26099:         if self.vs_ver <= 11.0:\nL26100:             netfxver = 35\nL26101:             arch = ''\nL26102:         else:\nL26103:             netfxver = 40\nL26104:             hidex86 = True if self.vs_ver <= 12.0 else False\nL26105:             arch = self.pi.current_dir(x64=True, hidex86=hidex86).replace('\\\\', '-')\nL26106:         fx = f'WinSDK-NetFx{netfxver}Tools{arch}'\nL26107: \nL26108:         # list all possibles registry paths\nL26109:         regpaths = []\nL26110:         if self.vs_ver >= 14.0:\nL26111:             for ver in self.NetFxSdkVersion:\nL26112:                 regpaths += [os.path.join(self.ri.netfx_sdk, ver, fx)]\nL26113: \nL26114:         for ver in self.WindowsSdkVersion:\nL26115:             regpaths += [os.path.join(self.ri.windows_sdk, f'v{ver}A', fx)]\nL26116: \nL26117:         # Return installation folder from the more recent path\nL26118:         for path in regpaths:\nL26119:             execpath = self.ri.lookup(path, 'installationfolder')\nL26120:             if execpath:\nL26121:                 return execpath\nL26122: \nL26123:         return None\nL26124: \nL26125:     @property\nL26126:     def FSharpInstallDir(self):\nL26127:         \"\"\"\nL26128:         Microsoft Visual F# directory.\nL26129: \nL26130:         Return\nL26131:         ------\nL26132:         str\nL26133:             path\nL26134:         \"\"\"\nL26135:         path = os.path.join(self.ri.visualstudio, rf'{self.vs_ver:0.1f}\\Setup\\F#')\nL26136:         return self.ri.lookup(path, 'productdir') or ''\nL26137: \nL26138:     @property\nL26139:     def UniversalCRTSdkDir(self):\nL26140:         \"\"\"\nL26141:         Microsoft Universal CRT SDK directory.\nL26142: \nL26143:         Return\nL26144:         ------\nL26145:         str\nL26146:             path\nL26147:         \"\"\"\nL26148:         # Set Kit Roots versions for specified MSVC++ version\nL26149:         vers = ('10', '81') if self.vs_ver >= 14.0 else ()\nL26150: \nL26151:         # Find path of the more recent Kit\nL26152:         for ver in vers:\nL26153:             sdkdir = self.ri.lookup(self.ri.windows_kits_roots, f'kitsroot{ver}')\nL26154:             if sdkdir:\nL26155:                 return sdkdir or ''\nL26156: \nL26157:         return None\nL26158: \nL26159:     @property\nL26160:     def UniversalCRTSdkLastVersion(self):\nL26161:         \"\"\"\nL26162:         Microsoft Universal C Runtime SDK last version.\nL26163: \nL26164:         Return\nL26165:         ------\nL26166:         str\nL26167:             version\nL26168:         \"\"\"\nL26169:         return self._use_last_dir_name(os.path.join(self.UniversalCRTSdkDir, 'lib'))\nL26170: \nL26171:     @property\nL26172:     def NetFxSdkVersion(self):\nL26173:         \"\"\"\nL26174:         Microsoft .NET Framework SDK versions.\nL26175: \nL26176:         Return\nL26177:         ------\nL26178:         tuple of str\nL26179:             versions\nL26180:         \"\"\"\nL26181:         # Set FxSdk versions for specified VS version\nL26182:         return (\nL26183:             ('4.7.2', '4.7.1', '4.7', '4.6.2', '4.6.1', '4.6', '4.5.2', '4.5.1', '4.5')\nL26184:             if self.vs_ver >= 14.0\nL26185:             else ()\nL26186:         )\nL26187: \nL26188:     @property\nL26189:     def NetFxSdkDir(self):\nL26190:         \"\"\"\nL26191:         Microsoft .NET Framework SDK directory.\nL26192: \nL26193:         Return\nL26194:         ------\nL26195:         str\nL26196:             path\nL26197:         \"\"\"\nL26198:         sdkdir = ''\nL26199:         for ver in self.NetFxSdkVersion:\nL26200:             loc = os.path.join(self.ri.netfx_sdk, ver)\nL26201:             sdkdir = self.ri.lookup(loc, 'kitsinstallationfolder')\nL26202:             if sdkdir:\nL26203:                 break\nL26204:         return sdkdir\nL26205: \nL26206:     @property\nL26207:     def FrameworkDir32(self):\nL26208:         \"\"\"\nL26209:         Microsoft .NET Framework 32bit directory.\nL26210: \nL26211:         Return\nL26212:         ------\nL26213:         str\nL26214:             path\nL26215:         \"\"\"\nL26216:         # Default path\nL26217:         guess_fw = os.path.join(self.WinDir, r'Microsoft.NET\\Framework')\nL26218: \nL26219:         # Try to get path from registry, if fail use default path\nL26220:         return self.ri.lookup(self.ri.vc, 'frameworkdir32') or guess_fw\nL26221: \nL26222:     @property\nL26223:     def FrameworkDir64(self):\nL26224:         \"\"\"\nL26225:         Microsoft .NET Framework 64bit directory.\nL26226: \nL26227:         Return\nL26228:         ------\nL26229:         str\nL26230:             path\nL26231:         \"\"\"\nL26232:         # Default path\nL26233:         guess_fw = os.path.join(self.WinDir, r'Microsoft.NET\\Framework64')\nL26234: \nL26235:         # Try to get path from registry, if fail use default path\nL26236:         return self.ri.lookup(self.ri.vc, 'frameworkdir64') or guess_fw\nL26237: \nL26238:     @property\nL26239:     def FrameworkVersion32(self) -> tuple[str, ...]:\nL26240:         \"\"\"\nL26241:         Microsoft .NET Framework 32bit versions.\nL26242: \nL