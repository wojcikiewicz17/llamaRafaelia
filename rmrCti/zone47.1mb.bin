6737:         return [os.path.join(self.si.VSInstallDir, r'VSTSDB\\Deploy')]\nL26738: \nL26739:     @property\nL26740:     def MSBuild(self):\nL26741:         \"\"\"\nL26742:         Microsoft Build Engine.\nL26743: \nL26744:         Return\nL26745:         ------\nL26746:         list of str\nL26747:             paths\nL26748:         \"\"\"\nL26749:         if self.vs_ver < 12.0:\nL26750:             return []\nL26751:         elif self.vs_ver < 15.0:\nL26752:             base_path = self.si.ProgramFilesx86\nL26753:             arch_subdir = self.pi.current_dir(hidex86=True)\nL26754:         else:\nL26755:             base_path = self.si.VSInstallDir\nL26756:             arch_subdir = ''\nL26757: \nL26758:         path = rf'MSBuild\\{self.vs_ver:0.1f}\\bin{arch_subdir}'\nL26759:         build = [os.path.join(base_path, path)]\nL26760: \nL26761:         if self.vs_ver >= 15.0:\nL26762:             # Add Roslyn C# & Visual Basic Compiler\nL26763:             build += [os.path.join(base_path, path, 'Roslyn')]\nL26764: \nL26765:         return build\nL26766: \nL26767:     @property\nL26768:     def HTMLHelpWorkshop(self):\nL26769:         \"\"\"\nL26770:         Microsoft HTML Help Workshop.\nL26771: \nL26772:         Return\nL26773:         ------\nL26774:         list of str\nL26775:             paths\nL26776:         \"\"\"\nL26777:         if self.vs_ver < 11.0:\nL26778:             return []\nL26779: \nL26780:         return [os.path.join(self.si.ProgramFilesx86, 'HTML Help Workshop')]\nL26781: \nL26782:     @property\nL26783:     def UCRTLibraries(self):\nL26784:         \"\"\"\nL26785:         Microsoft Universal C Runtime SDK Libraries.\nL26786: \nL26787:         Return\nL26788:         ------\nL26789:         list of str\nL26790:             paths\nL26791:         \"\"\"\nL26792:         if self.vs_ver < 14.0:\nL26793:             return []\nL26794: \nL26795:         arch_subdir = self.pi.target_dir(x64=True)\nL26796:         lib = os.path.join(self.si.UniversalCRTSdkDir, 'lib')\nL26797:         ucrtver = self._ucrt_subdir\nL26798:         return [os.path.join(lib, f'{ucrtver}ucrt{arch_subdir}')]\nL26799: \nL26800:     @property\nL26801:     def UCRTIncludes(self):\nL26802:         \"\"\"\nL26803:         Microsoft Universal C Runtime SDK Include.\nL26804: \nL26805:         Return\nL26806:         ------\nL26807:         list of str\nL26808:             paths\nL26809:         \"\"\"\nL26810:         if self.vs_ver < 14.0:\nL26811:             return []\nL26812: \nL26813:         include = os.path.join(self.si.UniversalCRTSdkDir, 'include')\nL26814:         return [os.path.join(include, f'{self._ucrt_subdir}ucrt')]\nL26815: \nL26816:     @property\nL26817:     def _ucrt_subdir(self):\nL26818:         \"\"\"\nL26819:         Microsoft Universal C Runtime SDK version subdir.\nL26820: \nL26821:         Return\nL26822:         ------\nL26823:         str\nL26824:             subdir\nL26825:         \"\"\"\nL26826:         ucrtver = self.si.UniversalCRTSdkLastVersion\nL26827:         return (f'{ucrtver}\\\\') if ucrtver else ''\nL26828: \nL26829:     @property\nL26830:     def FSharp(self):\nL26831:         \"\"\"\nL26832:         Microsoft Visual F#.\nL26833: \nL26834:         Return\nL26835:         ------\nL26836:         list of str\nL26837:             paths\nL26838:         \"\"\"\nL26839:         if 11.0 > self.vs_ver > 12.0:\nL26840:             return []\nL26841: \nL26842:         return [self.si.FSharpInstallDir]\nL26843: \nL26844:     @property\nL26845:     def VCRuntimeRedist(self) -> str | None:\nL26846:         \"\"\"\nL26847:         Microsoft Visual C++ runtime redistributable dll.\nL26848: \nL26849:         Returns the first suitable path found or None.\nL26850:         \"\"\"\nL26851:         vcruntime = f'vcruntime{self.vc_ver}0.dll'\nL26852:         arch_subdir = self.pi.target_dir(x64=True).strip('\\\\')\nL26853: \nL26854:         # Installation prefixes candidates\nL26855:         prefixes = []\nL26856:         tools_path = self.si.VCInstallDir\nL26857:         redist_path = os.path.dirname(tools_path.replace(r'\\Tools', r'\\Redist'))\nL26858:         if os.path.isdir(redist_path):\nL26859:             # Redist version may not be exactly the same as tools\nL26860:             redist_path = os.path.join(redist_path, os.listdir(redist_path)[-1])\nL26861:             prefixes += [redist_path, os.path.join(redist_path, 'onecore')]\nL26862: \nL26863:         prefixes += [os.path.join(tools_path, 'redist')]  # VS14 legacy path\nL26864: \nL26865:         # CRT directory\nL26866:         crt_dirs = (\nL26867:             f'Microsoft.VC{self.vc_ver * 10}.CRT',\nL26868:             # Sometime store in directory with VS version instead of VC\nL26869:             f'Microsoft.VC{int(self.vs_ver) * 10}.CRT',\nL26870:         )\nL26871: \nL26872:         # vcruntime path\nL26873:         candidate_paths = (\nL26874:             os.path.join(prefix, arch_subdir, crt_dir, vcruntime)\nL26875:             for (prefix, crt_dir) in itertools.product(prefixes, crt_dirs)\nL26876:         )\nL26877:         return next(filter(os.path.isfile, candidate_paths), None)  # type: ignore[arg-type] #python/mypy#12682\nL26878: \nL26879:     def return_env(self, exists: bool = True) -> _EnvironmentDict:\nL26880:         \"\"\"\nL26881:         Return environment dict.\nL26882: \nL26883:         Parameters\nL26884:         ----------\nL26885:         exists: bool\nL26886:             It True, only return existing paths.\nL26887: \nL26888:         Return\nL26889:         ------\nL26890:         dict\nL26891:             environment\nL26892:         \"\"\"\nL26893:         env = _EnvironmentDict(\nL26894:             include=self._build_paths(\nL26895:                 'include',\nL26896:                 [\nL26897:                     self.VCIncludes,\nL26898:                     self.OSIncludes,\nL26899:                     self.UCRTIncludes,\nL26900:                     self.NetFxSDKIncludes,\nL26901:                 ],\nL26902:                 exists,\nL26903:             ),\nL26904:             lib=self._build_paths(\nL26905:                 'lib',\nL26906:                 [\nL26907:                     self.VCLibraries,\nL26908:                     self.OSLibraries,\nL26909:                     self.FxTools,\nL26910:                     self.UCRTLibraries,\nL26911:                     self.NetFxSDKLibraries,\nL26912:                 ],\nL26913:                 exists,\nL26914:             ),\nL26915:             libpath=self._build_paths(\nL26916:                 'libpath',\nL26917:                 [self.VCLibraries, self.FxTools, self.VCStoreRefs, self.OSLibpath],\nL26918:                 exists,\nL26919:             ),\nL26920:             path=self._build_paths(\nL26921:                 'path',\nL26922:                 [\nL26923:                     self.VCTools,\nL26924:                     self.VSTools,\nL26925:                     self.VsTDb,\nL26926:                     self.SdkTools,\nL26927:                     self.SdkSetup,\nL26928:                     self.FxTools,\nL26929:                     self.MSBuild,\nL26930:                     self.HTMLHelpWorkshop,\nL26931:                     self.FSharp,\nL26932:                 ],\nL26933:                 exists,\nL26934:             ),\nL26935:         )\nL26936:         if self.vs_ver >= 14 and self.VCRuntimeRedist:\nL26937:             env['py_vcruntime_redist'] = self.VCRuntimeRedist\nL26938:         return env\nL26939: \nL26940:     def _build_paths(self, name, spec_path_lists, exists):\nL26941:         \"\"\"\nL26942:         Given an environment variable name and specified paths,\nL26943:         return a pathsep-separated string of paths containing\nL26944:         unique, extant, directories from those paths and from\nL26945:         the environment variable. Raise an error if no paths\nL26946:         are resolved.\nL26947: \nL26948:         Parameters\nL26949:         ----------\nL26950:         name: str\nL26951:             Environment variable name\nL26952:         spec_path_lists: list of str\nL26953:             Paths\nL26954:         exists: bool\nL26955:             It True, only return existing paths.\nL26956: \nL26957:         Return\nL26958:         ------\nL26959:         str\nL26960:             Pathsep-separated paths\nL26961:         \"\"\"\nL26962:         # flatten spec_path_lists\nL26963:         spec_paths = itertools.chain.from_iterable(spec_path_lists)\nL26964:         env_paths = environ.get(name, '').split(os.pathsep)\nL26965:         paths = itertools.chain(spec_paths, env_paths)\nL26966:         extant_paths = list(filter(os.path.isdir, paths)) if exists else paths\nL26967:         if not extant_paths:\nL26968:             msg = f\"{name.upper()} environment variable is empty\"\nL26969:             raise distutils.errors.DistutilsPlatformError(msg)\nL26970:         unique_paths = unique_everseen(extant_paths)\nL26971:         return os.pathsep.join(unique_paths)\nL26972: \nL26973: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/core.py\nL26974: #!/usr/bin/env python3\nL26975: \"\"\"distutils.core\nL26976: \nL26977: The only module that needs to be imported to use the Distutils; provides\nL26978: the 'setup' function (which is to be called from the setup script).  Also\nL26979: indirectly provides the Distribution and Command classes, although they are\nL26980: really defined in distutils.dist and distutils.cmd.\nL26981: \"\"\"\nL26982: \nL26983: from __future__ import annotations\nL26984: \nL26985: import os\nL26986: import sys\nL26987: import tokenize\nL26988: from collections.abc import Iterable\nL26989: \nL26990: from .cmd import Command\nL26991: from .debug import DEBUG\nL26992: \nL26993: # Mainly import these so setup scripts can \"from distutils.core import\" them.\nL26994: from .dist import Distribution\nL26995: from .errors import (\nL26996:     CCompilerError,\nL26997:     DistutilsArgError,\nL26998:     DistutilsError,\nL26999:     DistutilsSetupError,\nL27000: )\nL27001: from .extension import Extension\nL27002: \nL27003: __all__ = ['Distribution', 'Command', 'Extension', 'setup']\nL27004: \nL27005: # This is a barebones help message generated displayed when the user\nL27006: # runs the setup script with no arguments at all.  More useful help\nL27007: # is generated with various --help options: global help, list commands,\nL27008: # and per-command help.\nL27009: USAGE = \"\"\"\\\nL27010: usage: %(script)s [global_opts] cmd1 [cmd1_opts] [cmd2 [cmd2_opts] ...]\nL27011:    or: %(script)s --help [cmd1 cmd2 ...]\nL27012:    or: %(script)s --help-commands\nL27013:    or: %(script)s cmd --help\nL27014: \"\"\"\nL27015: \nL27016: \nL27017: def gen_usage(script_name):\nL27018:     script = os.path.basename(script_name)\nL27019:     return USAGE % locals()\nL27020: \nL27021: \nL27022: # Some mild magic to control the behaviour of 'setup()' from 'run_setup()'.\nL27023: _setup_stop_after = None\nL27024: _setup_distribution = None\nL27025: \nL27026: # Legal keyword arguments for the setup() function\nL27027: setup_keywords = (\nL27028:     'distclass',\nL27029:     'script_name',\nL27030:     'script_args',\nL27031:     'options',\nL27032:     'name',\nL27033:     'version',\nL27034:     'author',\nL27035:     'author_email',\nL27036:     'maintainer',\nL27037:     'maintainer_email',\nL27038:     'url',\nL27039:     'license',\nL27040:     'description',\nL27041:     'long_description',\nL27042:     'keywords',\nL27043:     'platforms',\nL27044:     'classifiers',\nL27045:     'download_url',\nL27046:     'requires',\nL27047:     'provides',\nL27048:     'obsoletes',\nL27049: )\nL27050: \nL27051: # Legal keyword arguments for the Extension constructor\nL27052: extension_keywords = (\nL27053:     'name',\nL27054:     'sources',\nL27055:     'include_dirs',\nL27056:     'define_macros',\nL27057:     'undef_macros',\nL27058:     'library_dirs',\nL27059:     'libraries',\nL27060:     'runtime_library_dirs',\nL27061:     'extra_objects',\nL27062:     'extra_compile_args',\nL27063:     'extra_link_args',\nL27064:     'swig_opts',\nL27065:     'export_symbols',\nL27066:     'depends',\nL27067:     'language',\nL27068: )\nL27069: \nL27070: \nL27071: def setup(**attrs):  # noqa: C901\nL27072:     \"\"\"The gateway to the Distutils: do everything your setup script needs\nL27073:     to do, in a highly flexible and user-driven way.  Briefly: create a\nL27074:     Distribution instance; find and parse config files; parse the command\nL27075:     line; run each Distutils command found there, customized by the options\nL27076:     supplied to 'setup()' (as keyword arguments), in config files, and on\nL27077:     the command line.\nL27078: \nL27079:     The Distribution instance might be an instance of a class supplied via\nL27080:     the 'distclass' keyword argument to 'setup'; if no such class is\nL27081:     supplied, then the Distribution class (in dist.py) is instantiated.\nL27082:     All other arguments to 'setup' (except for 'cmdclass') are used to set\nL27083:     attributes of the Distribution instance.\nL27084: \nL27085:     The 'cmdclass' argument, if supplied, is a dictionary mapping command\nL27086:     names to command classes.  Each command encountered on the command line\nL27087:     will be turned into a command class, which is in turn instantiated; any\nL27088:     class found in 'cmdclass' is used in place of the default, which is\nL27089:     (for command 'foo_bar') class 'foo_bar' in module\nL27090:     'distutils.command.foo_bar'.  The command class must provide a\nL27091:     'user_options' attribute which is a list of option specifiers for\nL27092:     'distutils.fancy_getopt'.  Any command-line options between the current\nL27093:     and the next command are used to set attributes of the current command\nL27094:     object.\nL27095: \nL27096:     When the entire command-line has been successfully parsed, calls the\nL27097:     'run()' method on each command object in turn.  This method will be\nL27098:     driven entirely by the Distribution object (which each command object\nL27099:     has a reference to, thanks to its constructor), and the\nL27100:     command-specific options that became attributes of each command\nL27101:     object.\nL27102:     \"\"\"\nL27103: \nL27104:     global _setup_stop_after, _setup_distribution\nL27105: \nL27106:     # Determine the distribution class -- either caller-supplied or\nL27107:     # our Distribution (see below).\nL27108:     klass = attrs.get('distclass')\nL27109:     if klass:\nL27110:         attrs.pop('distclass')\nL27111:     else:\nL27112:         klass = Distribution\nL27113: \nL27114:     if 'script_name' not in attrs:\nL27115:         attrs['script_name'] = os.path.basename(sys.argv[0])\nL27116:     if 'script_args' not in attrs:\nL27117:         attrs['script_args'] = sys.argv[1:]\nL27118: \nL27119:     # Create the Distribution instance, using the remaining arguments\nL27120:     # (ie. everything except distclass) to initialize it\nL27121:     try:\nL27122:         _setup_distribution = dist = klass(attrs)\nL27123:     except DistutilsSetupError as msg:\nL27124:         if 'name' not in attrs:\nL27125:             raise SystemExit(f\"error in setup command: {msg}\")\nL27126:         else:\nL27127:             raise SystemExit(\"error in {} setup command: {}\".format(attrs['name'], msg))\nL27128: \nL27129:     if _setup_stop_after == \"init\":\nL27130:         return dist\nL27131: \nL27132:     # Find and parse the config file(s): they will override options from\nL27133:     # the setup script, but be overridden by the command line.\nL27134:     dist.parse_config_files()\nL27135: \nL27136:     if DEBUG:\nL27137:         print(\"options (after parsing config files):\")\nL27138:         dist.dump_option_dicts()\nL27139: \nL27140:     if _setup_stop_after == \"config\":\nL27141:         return dist\nL27142: \nL27143:     # Parse the command line and override config files; any\nL27144:     # command-line errors are the end user's fault, so turn them into\nL27145:     # SystemExit to suppress tracebacks.\nL27146:     try:\nL27147:         ok = dist.parse_command_line()\nL27148:     except DistutilsArgError as msg:\nL27149:         raise SystemExit(gen_usage(dist.script_name) + f\"\\nerror: {msg}\")\nL27150: \nL27151:     if DEBUG:\nL27152:         print(\"options (after parsing command line):\")\nL27153:         dist.dump_option_dicts()\nL27154: \nL27155:     if _setup_stop_after == \"commandline\":\nL27156:         return dist\nL27157: \nL27158:     # And finally, run all the commands found on the command line.\nL27159:     if ok:\nL27160:         return run_commands(dist)\nL27161: \nL27162:     return dist\nL27163: \nL27164: \nL27165: # setup ()\nL27166: \nL27167: \nL27168: def run_commands(dist):\nL27169:     \"\"\"Given a Distribution object run all the commands,\nL27170:     raising ``SystemExit`` errors in the case of failure.\nL27171: \nL27172:     This function assumes that either ``sys.argv`` or ``dist.script_args``\nL27173:     is already set accordingly.\nL27174:     \"\"\"\nL27175:     try:\nL27176:         dist.run_commands()\nL27177:     except KeyboardInterrupt:\nL27178:         raise SystemExit(\"interrupted\")\nL27179:     except OSError as exc:\nL27180:         if DEBUG:\nL27181:             sys.stderr.write(f\"error: {exc}\\n\")\nL27182:             raise\nL27183:         else:\nL27184:             raise SystemExit(f\"error: {exc}\")\nL27185: \nL27186:     except (DistutilsError, CCompilerError) as msg:\nL27187:         if DEBUG:\nL27188:             raise\nL27189:         else:\nL27190:             raise SystemExit(\"error: \" + str(msg))\nL27191: \nL27192:     return dist\nL27193: \nL27194: \nL27195: def run_setup(script_name, script_args: Iterable[str] | None = None, stop_after=\"run\"):\nL27196:     \"\"\"Run a setup script in a somewhat controlled environment, and\nL27197:     return the Distribution instance that drives things.  This is useful\nL27198:     if you need to find out the distribution meta-data (passed as\nL27199:     keyword args from 'script' to 'setup()', or the contents of the\nL27200:     config files or command-line.\nL27201: \nL27202:     'script_name' is a file that will be read and run with 'exec()';\nL27203:     'sys.argv[0]' will be replaced with 'script' for the duration of the\nL27204:     call.  'script_args' is a list of strings; if supplied,\nL27205:     'sys.argv[1:]' will be replaced by 'script_args' for the duration of\nL27206:     the call.\nL27207: \nL27208:     'stop_after' tells 'setup()' when to stop processing; possible\nL27209:     values:\nL27210:       init\nL27211:         stop after the Distribution instance has been created and\nL27212:         populated with the keyword arguments to 'setup()'\nL27213:       config\nL27214:         stop after config files have been parsed (and their data\nL27215:         stored in the Distribution instance)\nL27216:       commandline\nL27217:         stop after the command-line ('sys.argv[1:]' or 'script_args')\nL27218:         have been parsed (and the data stored in the Distribution)\nL27219:       run [default]\nL27220:         stop after all commands have been run (the same as if 'setup()'\nL27221:         had been called in the usual way\nL27222: \nL27223:     Returns the Distribution instance, which provides all information\nL27224:     used to drive the Distutils.\nL27225:     \"\"\"\nL27226:     if stop_after not in ('init', 'config', 'commandline', 'run'):\nL27227:         raise ValueError(f\"invalid value for 'stop_after': {stop_after!r}\")\nL27228: \nL27229:     global _setup_stop_after, _setup_distribution\nL27230:     _setup_stop_after = stop_after\nL27231: \nL27232:     save_argv = sys.argv.copy()\nL27233:     g = {'__file__': script_name, '__name__': '__main__'}\nL27234:     try:\nL27235:         try:\nL27236:             sys.argv[0] = script_name\nL27237:             if script_args is not None:\nL27238:                 sys.argv[1:] = script_args\nL27239:             # tokenize.open supports automatic encoding detection\nL27240:             with tokenize.open(script_name) as f:\nL27241:                 code = f.read().replace(r'\\r\\n', r'\\n')\nL27242:                 exec(code, g)\nL27243:         finally:\nL27244:             sys.argv = save_argv\nL27245:             _setup_stop_after = None\nL27246:     except SystemExit:\nL27247:         # Hmm, should we do something if exiting with a non-zero code\nL27248:         # (ie. error)?\nL27249:         pass\nL27250: \nL27251:     if _setup_distribution is None:\nL27252:         raise RuntimeError(\nL27253:             \"'distutils.core.setup()' was never called -- \"\nL27254:             f\"perhaps '{script_name}' is not a Distutils setup script?\"\nL27255:         )\nL27256: \nL27257:     # I wonder if the setup script's namespace -- g and l -- would be of\nL27258:     # any interest to callers?\nL27259:     # print \"_setup_distribution:\", _setup_distribution\nL27260:     return _setup_distribution\nL27261: \nL27262: \nL27263: # run_setup ()\nL27264: \nL27265: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/dist.py\nL27266: #!/usr/bin/env python3\nL27267: \"\"\"distutils.dist\nL27268: \nL27269: Provides the Distribution class, which represents the module distribution\nL27270: being built/installed/distributed.\nL27271: \"\"\"\nL27272: \nL27273: from __future__ import annotations\nL27274: \nL27275: import contextlib\nL27276: import logging\nL27277: import os\nL27278: import pathlib\nL27279: import re\nL27280: import sys\nL27281: import warnings\nL27282: from collections.abc import Iterable, MutableMapping\nL27283: from email import message_from_file\nL27284: from typing import (\nL27285:     IO,\nL27286:     TYPE_CHECKING,\nL27287:     Any,\nL27288:     ClassVar,\nL27289:     Literal,\nL27290:     TypeVar,\nL27291:     Union,\nL27292:     overload,\nL27293: )\nL27294: \nL27295: from packaging.utils import canonicalize_name, canonicalize_version\nL27296: \nL27297: from ._log import log\nL27298: from .debug import DEBUG\nL27299: from .errors import (\nL27300:     DistutilsArgError,\nL27301:     DistutilsClassError,\nL27302:     DistutilsModuleError,\nL27303:     DistutilsOptionError,\nL27304: )\nL27305: from .fancy_getopt import FancyGetopt, translate_longopt\nL27306: from .util import check_environ, rfc822_escape, strtobool\nL27307: \nL27308: if TYPE_CHECKING:\nL27309:     from _typeshed import SupportsWrite\nL27310:     from typing_extensions import TypeAlias\nL27311: \nL27312:     # type-only import because of mutual dependence between these modules\nL27313:     from .cmd import Command\nL27314: \nL27315: _CommandT = TypeVar(\"_CommandT\", bound=\"Command\")\nL27316: _OptionsList: TypeAlias = list[\nL27317:     Union[tuple[str, Union[str, None], str, int], tuple[str, Union[str, None], str]]\nL27318: ]\nL27319: \nL27320: \nL27321: # Regex to define acceptable Distutils command names.  This is not *quite*\nL27322: # the same as a Python NAME -- I don't allow leading underscores.  The fact\nL27323: # that they're very similar is no coincidence; the default naming scheme is\nL27324: # to look for a Python module named after the command.\nL27325: command_re = re.compile(r'^[a-zA-Z]([a-zA-Z0-9_]*)$')\nL27326: \nL27327: \nL27328: def _ensure_list(value: str | Iterable[str], fieldname) -> str | list[str]:\nL27329:     if isinstance(value, str):\nL27330:         # a string containing comma separated values is okay.  It will\nL27331:         # be converted to a list by Distribution.finalize_options().\nL27332:         pass\nL27333:     elif not isinstance(value, list):\nL27334:         # passing a tuple or an iterator perhaps, warn and convert\nL27335:         typename = type(value).__name__\nL27336:         msg = \"Warning: '{fieldname}' should be a list, got type '{typename}'\"\nL27337:         msg = msg.format(**locals())\nL27338:         log.warning(msg)\nL27339:         value = list(value)\nL27340:     return value\nL27341: \nL27342: \nL27343: class Distribution:\nL27344:     \"\"\"The core of the Distutils.  Most of the work hiding behind 'setup'\nL27345:     is really done within a Distribution instance, which farms the work out\nL27346:     to the Distutils commands specified on the command line.\nL27347: \nL27348:     Setup scripts will almost never instantiate Distribution directly,\nL27349:     unless the 'setup()' function is totally inadequate to their needs.\nL27350:     However, it is conceivable that a setup script might wish to subclass\nL27351:     Distribution for some specialized purpose, and then pass the subclass\nL27352:     to 'setup()' as the 'distclass' keyword argument.  If so, it is\nL27353:     necessary to respect the expectations that 'setup' has of Distribution.\nL27354:     See the code for 'setup()', in core.py, for details.\nL27355:     \"\"\"\nL27356: \nL27357:     # 'global_options' describes the command-line options that may be\nL27358:     # supplied to the setup script prior to any actual commands.\nL27359:     # Eg. \"./setup.py -n\" or \"./setup.py --quiet\" both take advantage of\nL27360:     # these global options.  This list should be kept to a bare minimum,\nL27361:     # since every global option is also valid as a command option -- and we\nL27362:     # don't want to pollute the commands with too many options that they\nL27363:     # have minimal control over.\nL27364:     # The fourth entry for verbose means that it can be repeated.\nL27365:     global_options: ClassVar[_OptionsList] = [\nL27366:         ('verbose', 'v', \"run verbosely (default)\", 1),\nL27367:         ('quiet', 'q', \"run quietly (turns verbosity off)\"),\nL27368:         ('dry-run', 'n', \"don't actually do anything\"),\nL27369:         ('help', 'h', \"show detailed help message\"),\nL27370:         ('no-user-cfg', None, 'ignore pydistutils.cfg in your home directory'),\nL27371:     ]\nL27372: \nL27373:     # 'common_usage' is a short (2-3 line) string describing the common\nL27374:     # usage of the setup script.\nL27375:     common_usage: ClassVar[str] = \"\"\"\\\nL27376: Common commands: (see '--help-commands' for more)\nL27377: \nL27378:   setup.py build      will build the package underneath 'build/'\nL27379:   setup.py install    will install the package\nL27380: \"\"\"\nL27381: \nL27382:     # options that are not propagated to the commands\nL27383:     display_options: ClassVar[_OptionsList] = [\nL27384:         ('help-commands', None, \"list all available commands\"),\nL27385:         ('name', None, \"print package name\"),\nL27386:         ('version', 'V', \"print package version\"),\nL27387:         ('fullname', None, \"print <package name>-<version>\"),\nL27388:         ('author', None, \"print the author's name\"),\nL27389:         ('author-email', None, \"print the author's email address\"),\nL27390:         ('maintainer', None, \"print the maintainer's name\"),\nL27391:         ('maintainer-email', None, \"print the maintainer's email address\"),\nL27392:         ('contact', None, \"print the maintainer's name if known, else the author's\"),\nL27393:         (\nL27394:             'contact-email',\nL27395:             None,\nL27396:             \"print the maintainer's email address if known, else the author's\",\nL27397:         ),\nL27398:         ('url', None, \"print the URL for this package\"),\nL27399:         ('license', None, \"print the license of the package\"),\nL27400:         ('licence', None, \"alias for --license\"),\nL27401:         ('description', None, \"print the package description\"),\nL27402:         ('long-description', None, \"print the long package description\"),\nL27403:         ('platforms', None, \"print the list of platforms\"),\nL27404:         ('classifiers', None, \"print the list of classifiers\"),\nL27405:         ('keywords', None, \"print the list of keywords\"),\nL27406:         ('provides', None, \"print the list of packages/modules provided\"),\nL27407:         ('requires', None, \"print the list of packages/modules required\"),\nL27408:         ('obsoletes', None, \"print the list of packages/modules made obsolete\"),\nL27409:     ]\nL27410:     display_option_names: ClassVar[list[str]] = [\nL27411:         translate_longopt(x[0]) for x in display_options\nL27412:     ]\nL27413: \nL27414:     # negative options are options that exclude other options\nL27415:     negative_opt: ClassVar[dict[str, str]] = {'quiet': 'verbose'}\nL27416: \nL27417:     # -- Creation/initialization methods -------------------------------\nL27418: \nL27419:     # Can't Unpack a TypedDict with optional properties, so using Any instead\nL27420:     def __init__(self, attrs: MutableMapping[str, Any] | None = None) -> None:  # noqa: C901\nL27421:         \"\"\"Construct a new Distribution instance: initialize all the\nL27422:         attributes of a Distribution, and then use 'attrs' (a dictionary\nL27423:         mapping attribute names to values) to assign some of those\nL27424:         attributes their \"real\" values.  (Any attributes not mentioned in\nL27425:         'attrs' will be assigned to some null value: 0, None, an empty list\nL27426:         or dictionary, etc.)  Most importantly, initialize the\nL27427:         'command_obj' attribute to the empty dictionary; this will be\nL27428:         filled in with real command objects by 'parse_command_line()'.\nL27429:         \"\"\"\nL27430: \nL27431:         # Default values for our command-line options\nL27432:         self.verbose = True\nL27433:         self.dry_run = False\nL27434:         self.help = False\nL27435:         for attr in self.display_option_names:\nL27436:             setattr(self, attr, False)\nL27437: \nL27438:         # Store the distribution meta-data (name, version, author, and so\nL27439:         # forth) in a separate object -- we're getting to have enough\nL27440:         # information here (and enough command-line options) that it's\nL27441:         # worth it.  Also delegate 'get_XXX()' methods to the 'metadata'\nL27442:         # object in a sneaky and underhanded (but efficient!) way.\nL27443:         self.metadata = DistributionMetadata()\nL27444:         for basename in self.metadata._METHOD_BASENAMES:\nL27445:             method_name = \"get_\" + basename\nL27446:             setattr(self, method_name, getattr(self.metadata, method_name))\nL27447: \nL27448:         # 'cmdclass' maps command names to class objects, so we\nL27449:         # can 1) quickly figure out which class to instantiate when\nL27450:         # we need to create a new command object, and 2) have a way\nL27451:         # for the setup script to override command classes\nL27452:         self.cmdclass: dict[str, type[Command]] = {}\nL27453: \nL27454:         # 'command_packages' is a list of packages in which commands\nL27455:         # are searched for.  The factory for command 'foo' is expected\nL27456:         # to be named 'foo' in the module 'foo' in one of the packages\nL27457:         # named here.  This list is searched from the left; an error\nL27458:         # is raised if no named package provides the command being\nL27459:         # searched for.  (Always access using get_command_packages().)\nL27460:         self.command_packages: str | list[str] | None = None\nL27461: \nL27462:         # 'script_name' and 'script_args' are usually set to sys.argv[0]\nL27463:         # and sys.argv[1:], but they can be overridden when the caller is\nL27464:         # not necessarily a setup script run from the command-line.\nL27465:         self.script_name: str | os.PathLike[str] | None = None\nL27466:         self.script_args: list[str] | None = None\nL27467: \nL27468:         # 'command_options' is where we store command options between\nL27469:         # parsing them (from config files, the command-line, etc.) and when\nL27470:         # they are actually needed -- ie. when the command in question is\nL27471:         # instantiated.  It is a dictionary of dictionaries of 2-tuples:\nL27472:         #   command_options = { command_name : { option : (source, value) } }\nL27473:         self.command_options: dict[str, dict[str, tuple[str, str]]] = {}\nL27474: \nL27475:         # 'dist_files' is the list of (command, pyversion, file) that\nL27476:         # have been created by any dist commands run so far. This is\nL27477:         # filled regardless of whether the run is dry or not. pyversion\nL27478:         # gives sysconfig.get_python_version() if the dist file is\nL27479:         # specific to a Python version, 'any' if it is good for all\nL27480:         # Python versions on the target platform, and '' for a source\nL27481:         # file. pyversion should not be used to specify minimum or\nL27482:         # maximum required Python versions; use the metainfo for that\nL27483:         # instead.\nL27484:         self.dist_files: list[tuple[str, str, str]] = []\nL27485: \nL27486:         # These options are really the business of various commands, rather\nL27487:         # than of the Distribution itself.  We provide aliases for them in\nL27488:         # Distribution as a convenience to the developer.\nL27489:         self.packages = None\nL27490:         self.package_data: dict[str, list[str]] = {}\nL27491:         self.package_dir = None\nL27492:         self.py_modules = None\nL27493:         self.libraries = None\nL27494:         self.headers = None\nL27495:         self.ext_modules = None\nL27496:         self.ext_package = None\nL27497:         self.include_dirs = None\nL27498:         self.extra_path = None\nL27499:         self.scripts = None\nL27500:         self.data_files = None\nL27501:         self.password = ''\nL27502: \nL27503:         # And now initialize bookkeeping stuff that can't be supplied by\nL27504:         # the caller at all.  'command_obj' maps command names to\nL27505:         # Command instances -- that's how we enforce that every command\nL27506:         # class is a singleton.\nL27507:         self.command_obj: dict[str, Command] = {}\nL27508: \nL27509:         # 'have_run' maps command names to boolean values; it keeps track\nL27510:         # of whether we have actually run a particular command, to make it\nL27511:         # cheap to \"run\" a command whenever we think we might need to -- if\nL27512:         # it's already been done, no need for expensive filesystem\nL27513:         # operations, we just check the 'have_run' dictionary and carry on.\nL27514:         # It's only safe to query 'have_run' for a command class that has\nL27515:         # been instantiated -- a false value will be inserted when the\nL27516:         # command object is created, and replaced with a true value when\nL27517:         # the command is successfully run.  Thus it's probably best to use\nL27518:         # '.get()' rather than a straight lookup.\nL27519:         self.have_run: dict[str, bool] = {}\nL27520: \nL27521:         # Now we'll use the attrs dictionary (ultimately, keyword args from\nL27522:         # the setup script) to possibly override any or all of these\nL27523:         # distribution options.\nL27524: \nL27525:         if attrs:\nL27526:             # Pull out the set of command options and work on them\nL27527:             # specifically.  Note that this order guarantees that aliased\nL27528:             # command options will override any supplied redundantly\nL27529:             # through the general options dictionary.\nL27530:             options = attrs.get('options')\nL27531:             if options is not None:\nL27532:                 del attrs['options']\nL27533:                 for command, cmd_options in options.items():\nL27534:                     opt_dict = self.get_option_dict(command)\nL27535:                     for opt, val in cmd_options.items():\nL27536:                         opt_dict[opt] = (\"setup script\", val)\nL27537: \nL27538:             if 'licence' in attrs:\nL27539:                 attrs['license'] = attrs['licence']\nL27540:                 del attrs['licence']\nL27541:                 msg = \"'licence' distribution option is deprecated; use 'license'\"\nL27542:                 warnings.warn(msg)\nL27543: \nL27544:             # Now work on the rest of the attributes.  Any attribute that's\nL27545:             # not already defined is invalid!\nL27546:             for key, val in attrs.items():\nL27547:                 if hasattr(self.metadata, \"set_\" + key):\nL27548:                     getattr(self.metadata, \"set_\" + key)(val)\nL27549:                 elif hasattr(self.metadata, key):\nL27550:                     setattr(self.metadata, key, val)\nL27551:                 elif hasattr(self, key):\nL27552:                     setattr(self, key, val)\nL27553:                 else:\nL27554:                     msg = f\"Unknown distribution option: {key!r}\"\nL27555:                     warnings.warn(msg)\nL27556: \nL27557:         # no-user-cfg is handled before other command line args\nL27558:         # because other args override the config files, and this\nL27559:         # one is needed before we can load the config files.\nL27560:         # If attrs['script_args'] wasn't passed, assume false.\nL27561:         #\nL27562:         # This also make sure we just look at the global options\nL27563:         self.want_user_cfg = True\nL27564: \nL27565:         if self.script_args is not None:\nL27566:             # Coerce any possible iterable from attrs into a list\nL27567:             self.script_args = list(self.script_args)\nL27568:             for arg in self.script_args:\nL27569:                 if not arg.startswith('-'):\nL27570:                     break\nL27571:                 if arg == '--no-user-cfg':\nL27572:                     self.want_user_cfg = False\nL27573:                     break\nL27574: \nL27575:         self.finalize_options()\nL27576: \nL27577:     def get_option_dict(self, command):\nL27578:         \"\"\"Get the option dictionary for a given command.  If that\nL27579:         command's option dictionary hasn't been created yet, then create it\nL27580:         and return the new dictionary; otherwise, return the existing\nL27581:         option dictionary.\nL27582:         \"\"\"\nL27583:         dict = self.command_options.get(command)\nL27584:         if dict is None:\nL27585:             dict = self.command_options[command] = {}\nL27586:         return dict\nL27587: \nL27588:     def dump_option_dicts(self, header=None, commands=None, indent: str = \"\") -> None:\nL27589:         from pprint import pformat\nL27590: \nL27591:         if commands is None:  # dump all command option dicts\nL27592:             commands = sorted(self.command_options.keys())\nL27593: \nL27594:         if header is not None:\nL27595:             self.announce(indent + header)\nL27596:             indent = indent + \"  \"\nL27597: \nL27598:         if not commands:\nL27599:             self.announce(indent + \"no commands known yet\")\nL27600:             return\nL27601: \nL27602:         for cmd_name in commands:\nL27603:             opt_dict = self.command_options.get(cmd_name)\nL27604:             if opt_dict is None:\nL27605:                 self.announce(indent + f\"no option dict for '{cmd_name}' command\")\nL27606:             else:\nL27607:                 self.announce(indent + f\"option dict for '{cmd_name}' command:\")\nL27608:                 out = pformat(opt_dict)\nL27609:                 for line in out.split('\\n'):\nL27610:                     self.announce(indent + \"  \" + line)\nL27611: \nL27612:     # -- Config file finding/parsing methods ---------------------------\nL27613: \nL27614:     def find_config_files(self):\nL27615:         \"\"\"Find as many configuration files as should be processed for this\nL27616:         platform, and return a list of filenames in the order in which they\nL27617:         should be parsed.  The filenames returned are guaranteed to exist\nL27618:         (modulo nasty race conditions).\nL27619: \nL27620:         There are multiple possible config files:\nL27621:         - distutils.cfg in the Distutils installation directory (i.e.\nL27622:           where the top-level Distutils __inst__.py file lives)\nL27623:         - a file in the user's home directory named .pydistutils.cfg\nL27624:           on Unix and pydistutils.cfg on Windows/Mac; may be disabled\nL27625:           with the ``--no-user-cfg`` option\nL27626:         - setup.cfg in the current directory\nL27627:         - a file named by an environment variable\nL27628:         \"\"\"\nL27629:         check_environ()\nL27630:         files = [str(path) for path in self._gen_paths() if os.path.isfile(path)]\nL27631: \nL27632:         if DEBUG:\nL27633:             self.announce(\"using config files: {}\".format(', '.join(files)))\nL27634: \nL27635:         return files\nL27636: \nL27637:     def _gen_paths(self):\nL27638:         # The system-wide Distutils config file\nL27639:         sys_dir = pathlib.Path(sys.modules['distutils'].__file__).parent\nL27640:         yield sys_dir / \"distutils.cfg\"\nL27641: \nL27642:         # The per-user config file\nL27643:         prefix = '.' * (os.name == 'posix')\nL27644:         filename = prefix + 'pydistutils.cfg'\nL27645:         if self.want_user_cfg:\nL27646:             with contextlib.suppress(RuntimeError):\nL27647:                 yield pathlib.Path('~').expanduser() / filename\nL27648: \nL27649:         # All platforms support local setup.cfg\nL27650:         yield pathlib.Path('setup.cfg')\nL27651: \nL27652:         # Additional config indicated in the environment\nL27653:         with contextlib.suppress(TypeError):\nL27654:             yield pathlib.Path(os.getenv(\"DIST_EXTRA_CONFIG\"))\nL27655: \nL27656:     def parse_config_files(self, filenames=None):  # noqa: C901\nL27657:         from configparser import ConfigParser\nL27658: \nL27659:         # Ignore install directory options if we have a venv\nL27660:         if sys.prefix != sys.base_prefix:\nL27661:             ignore_options = [\nL27662:                 'install-base',\nL27663:                 'install-platbase',\nL27664:                 'install-lib',\nL27665:                 'install-platlib',\nL27666:                 'install-purelib',\nL27667:                 'install-headers',\nL27668:                 'install-scripts',\nL27669:                 'install-data',\nL27670:                 'prefix',\nL27671:                 'exec-prefix',\nL27672:                 'home',\nL27673:                 'user',\nL27674:                 'root',\nL27675:             ]\nL27676:         else:\nL27677:             ignore_options = []\nL27678: \nL27679:         ignore_options = frozenset(ignore_options)\nL27680: \nL27681:         if filenames is None:\nL27682:             filenames = self.find_config_files()\nL27683: \nL27684:         if DEBUG:\nL27685:             self.announce(\"Distribution.parse_config_files():\")\nL27686: \nL27687:         parser = ConfigParser()\nL27688:         for filename in filenames:\nL27689:             if DEBUG:\nL27690:                 self.announce(f\"  reading {filename}\")\nL27691:             parser.read(filename, encoding='utf-8')\nL27692:             for section in parser.sections():\nL27693:                 options = parser.options(section)\nL27694:                 opt_dict = self.get_option_dict(section)\nL27695: \nL27696:                 for opt in options:\nL27697:                     if opt != '__name__' and opt not in ignore_options:\nL27698:                         val = parser.get(section, opt)\nL27699:                         opt = opt.replace('-', '_')\nL27700:                         opt_dict[opt] = (filename, val)\nL27701: \nL27702:             # Make the ConfigParser forget everything (so we retain\nL27703:             # the original filenames that options come from)\nL27704:             parser.__init__()\nL27705: \nL27706:         # If there was a \"global\" section in the config file, use it\nL27707:         # to set Distribution options.\nL27708: \nL27709:         if 'global' in self.command_options:\nL27710:             for opt, (_src, val) in self.command_options['global'].items():\nL27711:                 alias = self.negative_opt.get(opt)\nL27712:                 try:\nL27713:                     if alias:\nL27714:                         setattr(self, alias, not strtobool(val))\nL27715:                     elif opt in ('verbose', 'dry_run'):  # ugh!\nL27716:                         setattr(self, opt, strtobool(val))\nL27717:                     else:\nL27718:                         setattr(self, opt, val)\nL27719:                 except ValueError as msg:\nL27720:                     raise DistutilsOptionError(msg)\nL27721: \nL27722:     # -- Command-line parsing methods ----------------------------------\nL27723: \nL27724:     def parse_command_line(self):\nL27725:         \"\"\"Parse the setup script's command line, taken from the\nL27726:         'script_args' instance attribute (which defaults to 'sys.argv[1:]'\nL27727:         -- see 'setup()' in core.py).  This list is first processed for\nL27728:         \"global options\" -- options that set attributes of the Distribution\nL27729:         instance.  Then, it is alternately scanned for Distutils commands\nL27730:         and options for that command.  Each new command terminates the\nL27731:         options for the previous command.  The allowed options for a\nL27732:         command are determined by the 'user_options' attribute of the\nL27733:         command class -- thus, we have to be able to load command classes\nL27734:         in order to parse the command line.  Any error in that 'options'\nL27735:         attribute raises DistutilsGetoptError; any error on the\nL27736:         command-line raises DistutilsArgError.  If no Distutils commands\nL27737:         were found on the command line, raises DistutilsArgError.  Return\nL27738:         true if command-line was successfully parsed and we should carry\nL27739:         on with executing commands; false if no errors but we shouldn't\nL27740:         execute commands (currently, this only happens if user asks for\nL27741:         help).\nL27742:         \"\"\"\nL27743:         #\nL27744:         # We now have enough information to show the Macintosh dialog\nL27745:         # that allows the user to interactively specify the \"command line\".\nL27746:         #\nL27747:         toplevel_options = self._get_toplevel_options()\nL27748: \nL27749:         # We have to parse the command line a bit at a time -- global\nL27750:         # options, then the first command, then its options, and so on --\nL27751:         # because each command will be handled by a different class, and\nL27752:         # the options that are valid for a particular class aren't known\nL27753:         # until we have loaded the command class, which doesn't happen\nL27754:         # until we know what the command is.\nL27755: \nL27756:         self.commands = []\nL27757:         parser = FancyGetopt(toplevel_options + self.display_options)\nL27758:         parser.set_negative_aliases(self.negative_opt)\nL27759:         parser.set_aliases({'licence': 'license'})\nL27760:         args = parser.getopt(args=self.script_args, object=self)\nL27761:         option_order = parser.get_option_order()\nL27762:         logging.getLogger().setLevel(logging.WARN - 10 * self.verbose)\nL27763: \nL27764:         # for display options we return immediately\nL27765:         if self.handle_display_options(option_order):\nL27766:             return\nL27767:         while args:\nL27768:             args = self._parse_command_opts(parser, args)\nL27769:             if args is None:  # user asked for help (and got it)\nL27770:                 return\nL27771: \nL27772:         # Handle the cases of --help as a \"global\" option, ie.\nL27773:         # \"setup.py --help\" and \"setup.py --help command ...\".  For the\nL27774:         # former, we show global options (--verbose, --dry-run, etc.)\nL27775:         # and display-only options (--name, --version, etc.); for the\nL27776:         # latter, we omit the display-only options and show help for\nL27777:         # each command listed on the command line.\nL27778:         if self.help:\nL27779:             self._show_help(\nL27780:                 parser, display_options=len(self.commands) == 0, commands=self.commands\nL27781:             )\nL27782:             return\nL27783: \nL27784:         # Oops, no commands found -- an end-user error\nL27785:         if not self.commands:\nL27786:             raise DistutilsArgError(\"no commands supplied\")\nL27787: \nL27788:         # All is well: return true\nL27789:         return True\nL27790: \nL27791:     def _get_toplevel_options(self):\nL27792:         \"\"\"Return the non-display options recognized at the top level.\nL27793: \nL27794:         This includes options that are recognized *only* at the top\nL27795:         level as well as options recognized for commands.\nL27796:         \"\"\"\nL27797:         return self.global_options + [\nL27798:             (\nL27799:                 \"command-packages=\",\nL27800:                 None,\nL27801:                 \"list of packages that provide distutils commands\",\nL27802:             ),\nL27803:         ]\nL27804: \nL27805:     def _parse_command_opts(self, parser, args):  # noqa: C901\nL27806:         \"\"\"Parse the command-line options for a single command.\nL27807:         'parser' must be a FancyGetopt instance; 'args' must be the list\nL27808:         of arguments, starting with the current command (whose options\nL27809:         we are about to parse).  Returns a new version of 'args' with\nL27810:         the next command at the front of the list; will be the empty\nL27811:         list if there are no more commands on the command line.  Returns\nL27812:         None if the user asked for help on this command.\nL27813:         \"\"\"\nL27814:         # late import because of mutual dependence between these modules\nL27815:         from distutils.cmd import Command\nL27816: \nL27817:         # Pull the current command from the head of the command line\nL27818:         command = args[0]\nL27819:         if not command_re.match(command):\nL27820:             raise SystemExit(f\"invalid command name '{command}'\")\nL27821:         self.commands.append(command)\nL27822: \nL27823:         # Dig up the command class that implements this command, so we\nL27824:         # 1) know that it's a valid command, and 2) know which options\nL27825:         # it takes.\nL27826:         try:\nL27827:             cmd_class = self.get_command_class(command)\nL27828:         except DistutilsModuleError as msg:\nL27829:             raise DistutilsArgError(msg)\nL27830: \nL27831:         # Require that the command class be derived from Command -- want\nL27832:         # to be sure that the basic \"command\" interface is implemented.\nL27833:         if not issubclass(cmd_class, Command):\nL27834:             raise DistutilsClassError(\nL27835:                 f\"command class {cmd_class} must subclass Command\"\nL27836:             )\nL27837: \nL27838:         # Also make sure that the command object provides a list of its\nL27839:         # known options.\nL27840:         if not (\nL27841:             hasattr(cmd_class, 'user_options')\nL27842:             and isinstance(cmd_class.user_options, list)\nL27843:         ):\nL27844:             msg = (\nL27845:                 \"command class %s must provide \"\nL27846:                 \"'user_options' attribute (a list of tuples)\"\nL27847:             )\nL27848:             raise DistutilsClassError(msg % cmd_class)\nL27849: \nL27850:         # If the command class has a list of negative alias options,\nL27851:         # merge it in with the global negative aliases.\nL27852:         negative_opt = self.negative_opt\nL27853:         if hasattr(cmd_class, 'negative_opt'):\nL27854:             negative_opt = negative_opt.copy()\nL27855:             negative_opt.update(cmd_class.negative_opt)\nL27856: \nL27857:         # Check for help_options in command class.  They have a different\nL27858:         # format (tuple of four) so we need to preprocess them here.\nL27859:         if hasattr(cmd_class, 'help_options') and isinstance(\nL27860:             cmd_class.help_options, list\nL27861:         ):\nL27862:             help_options = fix_help_options(cmd_class.help_options)\nL27863:         else:\nL27864:             help_options = []\nL27865: \nL27866:         # All commands support the global options too, just by adding\nL27867:         # in 'global_options'.\nL27868:         parser.set_option_table(\nL27869:             self.global_options + cmd_class.user_options + help_options\nL27870:         )\nL27871:         parser.set_negative_aliases(negative_opt)\nL27872:         (args, opts) = parser.getopt(args[1:])\nL27873:         if hasattr(opts, 'help') and opts.help:\nL27874:             self._show_help(parser, display_options=False, commands=[cmd_class])\nL27875:             return\nL27876: \nL27877:         if hasattr(cmd_class, 'help_options') and isinstance(\nL27878:             cmd_class.help_options, list\nL27879:         ):\nL27880:             help_option_found = 0\nL27881:             for help_option, _short, _desc, func in cmd_class.help_options:\nL27882:                 if hasattr(opts, parser.get_attr_name(help_option)):\nL27883:                     help_option_found = 1\nL27884:                     if callable(func):\nL27885:                         func()\nL27886:                     else:\nL27887:                         raise DistutilsClassError(\nL27888:                             f\"invalid help function {func!r} for help option '{help_option}': \"\nL27889:                             \"must be a callable object (function, etc.)\"\nL27890:                         )\nL27891: \nL27892:             if help_option_found:\nL27893:                 return\nL27894: \nL27895:         # Put the options from the command-line into their official\nL27896:         # holding pen, the 'command_options' dictionary.\nL27897:         opt_dict = self.get_option_dict(command)\nL27898:         for name, value in vars(opts).items():\nL27899:             opt_dict[name] = (\"command line\", value)\nL27900: \nL27901:         return args\nL27902: \nL27903:     def finalize_options(self) -> None:\nL27904:         \"\"\"Set final values for all the options on the Distribution\nL27905:         instance, analogous to the .finalize_options() method of Command\nL27906:         objects.\nL27907:         \"\"\"\nL27908:         for attr in ('keywords', 'platforms'):\nL27909:             value = getattr(self.metadata, attr)\nL27910:             if value is None:\nL27911:                 continue\nL27912:             if isinstance(value, str):\nL27913:                 value = [elm.strip() for elm in value.split(',')]\nL27914:                 setattr(self.metadata, attr, value)\nL27915: \nL27916:     def _show_help(\nL27917:         self, parser, global_options=True, display_options=True, commands: Iterable = ()\nL27918:     ):\nL27919:         \"\"\"Show help for the setup script command-line in the form of\nL27920:         several lists of command-line options.  'parser' should be a\nL27921:         FancyGetopt instance; do not expect it to be returned in the\nL27922:         same state, as its option table will be reset to make it\nL27923:         generate the correct help text.\nL27924: \nL27925:         If 'global_options' is true, lists the global options:\nL27926:         --verbose, --dry-run, etc.  If 'display_options' is true, lists\nL27927:         the \"display-only\" options: --name, --version, etc.  Finally,\nL27928:         lists per-command help for every command name or command class\nL27929:         in 'commands'.\nL27930:         \"\"\"\nL27931:         # late import because of mutual dependence between these modules\nL27932:         from distutils.cmd import Command\nL27933:         from distutils.core import gen_usage\nL27934: \nL27935:         if global_options:\nL27936:             if display_options:\nL27937:                 options = self._get_toplevel_options()\nL27938:             else:\nL27939:                 options = self.global_options\nL27940:             parser.set_option_table(options)\nL27941:             parser.print_help(self.common_usage + \"\\nGlobal options:\")\nL27942:             print()\nL27943: \nL27944:         if display_options:\nL27945:             parser.set_option_table(self.display_options)\nL27946:             parser.print_help(\nL27947:                 \"Information display options (just display information, ignore any commands)\"\nL27948:             )\nL27949:             print()\nL27950: \nL27951:         for command in commands:\nL27952:             if isinstance(command, type) and issubclass(command, Command):\nL27953:                 klass = command\nL27954:             else:\nL27955:                 klass = self.get_command_class(command)\nL27956:             if hasattr(klass, 'help_options') and isinstance(klass.help_options, list):\nL27957:                 parser.set_option_table(\nL27958:                     klass.user_options + fix_help_options(klass.help_options)\nL27959:                 )\nL27960:             else:\nL27961:                 parser.set_option_table(klass.user_options)\nL27962:             parser.print_help(f\"Options for '{klass.__name__}' command:\")\nL27963:             print()\nL27964: \nL27965:         print(gen_usage(self.script_name))\nL27966: \nL27967:     def handle_display_options(self, option_order):\nL27968:         \"\"\"If there were any non-global \"display-only\" options\nL27969:         (--help-commands or the metadata display options) on the command\nL27970:         line, display the requested info and return true; else return\nL27971:         false.\nL27972:         \"\"\"\nL27973:         from distutils.core import gen_usage\nL27974: \nL27975:         # User just wants a list of commands -- we'll print it out and stop\nL27976:         # processing now (ie. if they ran \"setup --help-commands foo bar\",\nL27977:         # we ignore \"foo bar\").\nL27978:         if self.help_commands:\nL27979:             self.print_commands()\nL27980:             print()\nL27981:             print(gen_usage(self.script_name))\nL27982:             return 1\nL27983: \nL27984:         # If user supplied any of the \"display metadata\" options, then\nL27985:         # display that metadata in the order in which the user supplied the\nL27986:         # metadata options.\nL27987:         any_display_options = 0\nL27988:         is_display_option = set()\nL27989:         for option in self.display_options:\nL27990:             is_display_option.add(option[0])\nL27991: \nL27992:         for opt, val in option_order:\nL27993:             if val and opt in is_display_option:\nL27994:                 opt = translate_longopt(opt)\nL27995:                 value = getattr(self.metadata, \"get_\" + opt)()\nL27996:                 if opt in ('keywords', 'platforms'):\nL27997:                     print(','.join(value))\nL27998:                 elif opt in ('classifiers', 'provides', 'requires', 'obsoletes'):\nL27999:                     print('\\n'.join(value))\nL28000:                 else:\nL28001:                     print(value)\nL28002:                 any_display_options = 1\nL28003: \nL28004:         return any_display_options\nL28005: \nL28006:     def print_command_list(self, commands, header, max_length) -> None:\nL28007:         \"\"\"Print a subset of the list of all commands -- used by\nL28008:         'print_commands()'.\nL28009:         \"\"\"\nL28010:         print(header + \":\")\nL28011: \nL28012:         for cmd in commands:\nL28013:             klass = self.cmdclass.get(cmd)\nL28014:             if not klass:\nL28015:                 klass = self.get_command_class(cmd)\nL28016:             try:\nL28017:                 description = klass.description\nL28018:             except AttributeError:\nL28019:                 description = \"(no description available)\"\nL28020: \nL28021:             print(f\"  {cmd:<{max_length}}  {description}\")\nL28022: \nL28023:     def print_commands(self) -> None:\nL28024:         \"\"\"Print out a help message listing all available commands with a\nL28025:         description of each.  The list is divided into \"standard commands\"\nL28026:         (listed in distutils.command.__all__) and \"extra commands\"\nL28027:         (mentioned in self.cmdclass, but not a standard command).  The\nL28028:         descriptions come from the command class attribute\nL28029:         'description'.\nL28030:         \"\"\"\nL28031:         import distutils.command\nL28032: \nL28033:         std_commands = distutils.command.__all__\nL28034:         is_std = set(std_commands)\nL28035: \nL28036:         extra_commands = [cmd for cmd in self.cmdclass.keys() if cmd not in is_std]\nL28037: \nL28038:         max_length = 0\nL28039:         for cmd in std_commands + extra_commands:\nL28040:             if len(cmd) > max_length:\nL28041:                 max_length = len(cmd)\nL28042: \nL28043:         self.print_command_list(std_commands, \"Standard commands\", max_length)\nL28044:         if extra_commands:\nL28045:             print()\nL28046:             self.print_command_list(extra_commands, \"Extra commands\", max_length)\nL28047: \nL28048:     def get_command_list(self):\nL28049:         \"\"\"Get a list of (command, description) tuples.\nL28050:         The list is divided into \"standard commands\" (listed in\nL28051:         distutils.command.__all__) and \"extra commands\" (mentioned in\nL28052:         self.cmdclass, but not a standard command).  The descriptions come\nL28053:         from the command class attribute 'description'.\nL28054:         \"\"\"\nL28055:         # Currently this is only used on Mac OS, for the Mac-only GUI\nL28056:         # Distutils interface (by Jack Jansen)\nL28057:         import distutils.command\nL28058: \nL28059:         std_commands = distutils.command.__all__\nL28060:         is_std = set(std_commands)\nL28061: \nL28062:         extra_commands = [cmd for cmd in self.cmdclass.keys() if cmd not in is_std]\nL28063: \nL28064:         rv = []\nL28065:         for cmd in std_commands + extra_commands:\nL28066:             klass = self.cmdclass.get(cmd)\nL28067:             if not klass:\nL28068:                 klass = self.get_command_class(cmd)\nL28069:             try:\nL28070:                 description = klass.description\nL28071:             except AttributeError:\nL28072:                 description = \"(no description available)\"\nL28073:             rv.append((cmd, description))\nL28074:         return rv\nL28075: \nL28076:     # -- Command class/object methods ----------------------------------\nL28077: \nL28078:     def get_command_packages(self):\nL28079:         \"\"\"Return a list of packages from which commands are loaded.\"\"\"\nL28080:         pkgs = self.command_packages\nL28081:         if not isinstance(pkgs, list):\nL28082:             if pkgs is None:\nL28083:                 pkgs = ''\nL28084:             pkgs = [pkg.strip() for pkg in pkgs.split(',') if pkg != '']\nL28085:             if \"distutils.command\" not in pkgs:\nL28086:                 pkgs.insert(0, \"distutils.command\")\nL28087:             self.command_packages = pkgs\nL28088:         return pkgs\nL28089: \nL28090:     def get_command_class(self, command: str) -> type[Command]:\nL28091:         \"\"\"Return the class that implements the Distutils command named by\nL28092:         'command'.  First we check the 'cmdclass' dictionary; if the\nL28093:         command is mentioned there, we fetch the class object from the\nL28094:         dictionary and return it.  Otherwise we load the command module\nL28095:         (\"distutils.command.\" + command) and fetch the command class from\nL28096:         the module.  The loaded class is also stored in 'cmdclass'\nL28097:         to speed future calls to 'get_command_class()'.\nL28098: \nL28099:         Raises DistutilsModuleError if the expected module could not be\nL28100:         found, or if that module does not define the expected class.\nL28101:         \"\"\"\nL28102:         klass = self.cmdclass.get(command)\nL28103:         if klass:\nL28104:             return klass\nL28105: \nL28106:         for pkgname in self.get_command_packages():\nL28107:             module_name = f\"{pkgname}.{command}\"\nL28108:             klass_name = command\nL28109: \nL28110:             try:\nL28111:                 __import__(module_name)\nL28112:                 module = sys.modules[module_name]\nL28113:             except ImportError:\nL28114:                 continue\nL28115: \nL28116:             try:\nL28117:                 klass = getattr(module, klass_name)\nL28118:             except AttributeError:\nL28119:                 raise DistutilsModuleError(\nL28120:                     f\"invalid command '{command}' (no class '{klass_name}' in module '{module_name}')\"\nL28121:                 )\nL28122: \nL28123:             self.cmdclass[command] = klass\nL28124:             return klass\nL28125: \nL28126:         raise DistutilsModuleError(f\"invalid command '{command}'\")\nL28127: \nL28128:     @overload\nL28129:     def get_command_obj(\nL28130:         self, command: str, create: Literal[True] = True\nL28131:     ) -> Command: ...\nL28132:     @overload\nL28133:     def get_command_obj(\nL28134:         self, command: str, create: Literal[False]\nL28135:     ) -> Command | None: ...\nL28136:     def get_command_obj(self, command: str, create: bool = True) -> Command | None:\nL28137:         \"\"\"Return the command object for 'command'.  Normally this object\nL28138:         is cached on a previous call to 'get_command_obj()'; if no command\nL28139:         object for 'command' is in the cache, then we either create and\nL28140:         return it (if 'create' is true) or return None.\nL28141:         \"\"\"\nL28142:         cmd_obj = self.command_obj.get(command)\nL28143:         if not cmd_obj and create:\nL28144:             if DEBUG:\nL28145:                 self.announce(\nL28146:                     \"Distribution.get_command_obj(): \"\nL28147:                     f\"creating '{command}' command object\"\nL28148:                 )\nL28149: \nL28150:             klass = self.get_command_class(command)\nL28151:             cmd_obj = self.command_obj[command] = klass(self)\nL28152:             self.have_run[command] = False\nL28153: \nL28154:             # Set any options that were supplied in config files\nL28155:             # or on the command line.  (NB. support for error\nL28156:             # reporting is lame here: any errors aren't reported\nL28157:             # until 'finalize_options()' is called, which means\nL28158:             # we won't report the source of the error.)\nL28159:             options = self.command_options.get(command)\nL28160:             if options:\nL28161:                 self._set_command_options(cmd_obj, options)\nL28162: \nL28163:         return cmd_obj\nL28164: \nL28165:     def _set_command_options(self, command_obj, option_dict=None):  # noqa: C901\nL28166:         \"\"\"Set the options for 'command_obj' from 'option_dict'.  Basically\nL28167:         this means copying elements of a dictionary ('option_dict') to\nL28168:         attributes of an instance ('command').\nL28169: \nL28170:         'command_obj' must be a Command instance.  If 'option_dict' is not\nL28171:         supplied, uses the standard option dictionary for this command\nL28172:         (from 'self.command_options').\nL28173:         \"\"\"\nL28174:         command_name = command_obj.get_command_name()\nL28175:         if option_dict is None:\nL28176:             option_dict = self.get_option_dict(command_name)\nL28177: \nL28178:         if DEBUG:\nL28179:             self.announce(f\"  setting options for '{command_name}' command:\")\nL28180:         for option, (source, value) in option_dict.items():\nL28181:             if DEBUG:\nL28182:                 self.announce(f\"    {option} = {value} (from {source})\")\nL28183:             try:\nL28184:                 bool_opts = [translate_longopt(o) for o in command_obj.boolean_options]\nL28185:             except AttributeError:\nL28186:                 bool_opts = []\nL28187:             try:\nL28188:                 neg_opt = command_obj.negative_opt\nL28189:             except AttributeError:\nL28190:                 neg_opt = {}\nL28191: \nL28192:             try:\nL28193:                 is_string = isinstance(value, str)\nL28194:                 if option in neg_opt and is_string:\nL28195:                     setattr(command_obj, neg_opt[option], not strtobool(value))\nL28196:                 elif option in bool_opts and is_string:\nL28197:                     setattr(command_obj, option, strtobool(value))\nL28198:                 elif hasattr(command_obj, option):\nL28199:                     setattr(command_obj, option, value)\nL28200:                 else:\nL28201:                     raise DistutilsOptionError(\nL28202:                         f\"error in {source}: command '{command_name}' has no such option '{option}'\"\nL28203:                     )\nL28204:             except ValueError as msg:\nL28205:                 raise DistutilsOptionError(msg)\nL28206: \nL28207:     @overload\nL28208:     def reinitialize_command(\nL28209:         self, command: str, reinit_subcommands: bool = False\nL28210:     ) -> Command: ...\nL28211:     @overload\nL28212:     def reinitialize_command(\nL28213:         self, command: _CommandT, reinit_subcommands: bool = False\nL28214:     ) -> _CommandT: ...\nL28215:     def reinitialize_command(\nL28216:         self, command: str | Command, reinit_subcommands=False\nL28217:     ) -> Command:\nL28218:         \"\"\"Reinitializes a command to the state it was in when first\nL28219:         returned by 'get_command_obj()': ie., initialized but not yet\nL28220:         finalized.  This provides the opportunity to sneak option\nL28221:         values in programmatically, overriding or supplementing\nL28222:         user-supplied values from the config files and command line.\nL28223:         You'll have to re-finalize the command object (by calling\nL28224:         'finalize_options()' or 'ensure_finalized()') before using it for\nL28225:         real.\nL28226: \nL28227:         'command' should be a command name (string) or command object.  If\nL28228:         'reinit_subcommands' is true, also reinitializes the command's\nL28229:         sub-commands, as declared by the 'sub_commands' class attribute (if\nL28230:         it has one).  See the \"install\" command for an example.  Only\nL28231:         reinitializes the sub-commands that actually matter, ie. those\nL28232:         whose test predicates return true.\nL28233: \nL28234:         Returns the reinitialized command object.\nL28235:         \"\"\"\nL28236:         from distutils.cmd import Command\nL28237: \nL28238:         if not isinstance(command, Command):\nL28239:             command_name = command\nL28240:             command = self.get_command_obj(command_name)\nL28241:         else:\nL28242:             command_name = command.get_command_name()\nL28243: \nL28244:         if not command.finalized:\nL28245:             return command\nL28246:         command.initialize_options()\nL28247:         command.finalized = False\nL28248:         self.have_run[command_name] = False\nL28249:         self._set_command_options(command)\nL28250: \nL28251:         if reinit_subcommands:\nL28252:             for sub in command.get_sub_commands():\nL28253:                 self.reinitialize_command(sub, reinit_subcommands)\nL28254: \nL28255:         return command\nL28256: \nL28257:     # -- Methods that operate on the Distribution ----------------------\nL28258: \nL28259:     def announce(self, msg, level: int = logging.INFO) -> None:\nL28260:         log.log(level, msg)\nL28261: \nL28262:     def run_commands(self) -> None:\nL28263:         \"\"\"Run each command that was seen on the setup script command line.\nL28264:         Uses the list of commands found and cache of command objects\nL28265:         created by 'get_command_obj()'.\nL28266:         \"\"\"\nL28267:         for cmd in self.commands:\nL28268:             self.run_command(cmd)\nL28269: \nL28270:     # -- Methods that operate on its Commands --------------------------\nL28271: \nL28272:     def run_command(self, command: str) -> None:\nL28273:         \"\"\"Do whatever it takes to run a command (including nothing at all,\nL28274:         if the command has already been run).  Specifically: if we have\nL28275:         already created and run the command named by 'command', return\nL28276:         silently without doing anything.  If the command named by 'command'\nL28277:         doesn't even have a command object yet, create one.  Then invoke\nL28278:         'run()' on that command object (or an existing one).\nL28279:         \"\"\"\nL28280:         # Already been here, done that? then return silently.\nL28281:         if self.have_run.get(command):\nL28282:             return\nL28283: \nL28284:         log.info(\"running %s\", command)\nL28285:         cmd_obj = self.get_command_obj(command)\nL28286:         cmd_obj.ensure_finalized()\nL28287:         cmd_obj.run()\nL28288:         self.have_run[command] = True\nL28289: \nL28290:     # -- Distribution query methods ------------------------------------\nL28291: \nL28292:     def has_pure_modules(self) -> bool:\nL28293:         return len(self.packages or self.py_modules or []) > 0\nL28294: \nL28295:     def has_ext_modules(self) -> bool:\nL28296:         return self.ext_modules and len(self.ext_modules) > 0\nL28297: \nL28298:     def has_c_libraries(self) -> bool:\nL28299:         return self.libraries and len(self.libraries) > 0\nL28300: \nL28301:     def has_modules(self) -> bool:\nL28302:         return self.has_pure_modules() or self.has_ext_modules()\nL28303: \nL28304:     def has_headers(self) -> bool:\nL28305:         return self.headers and len(self.headers) > 0\nL28306: \nL28307:     def has_scripts(self) -> bool:\nL28308:         return self.scripts and len(self.scripts) > 0\nL28309: \nL28310:     def has_data_files(self) -> bool:\nL28311:         return self.data_files and len(self.data_files) > 0\nL28312: \nL28313:     def is_pure(self) -> bool:\nL28314:         return (\nL28315:             self.has_pure_modules()\nL28316:             and not self.has_ext_modules()\nL28317:             and not self.has_c_libraries()\nL28318:         )\nL28319: \nL28320:     # -- Metadata query methods ----------------------------------------\nL28321: \nL28322:     # If you're looking for 'get_name()', 'get_version()', and so forth,\nL28323:     # they are defined in a sneaky way: the constructor binds self.get_XXX\nL28324:     # to self.metadata.get_XXX.  The actual code is in the\nL28325:     # DistributionMetadata class, below.\nL28326:     if TYPE_CHECKING:\nL28327:         # Unfortunately this means we need to specify them manually or not expose statically\nL28328:         def _(self) -> None:\nL28329:             self.get_name = self.metadata.get_name\nL28330:             self.get_version = self.metadata.get_version\nL28331:             self.get_fullname = self.metadata.get_fullname\nL28332:             self.get_author = self.metadata.get_author\nL28333:             self.get_author_email = self.metadata.get_author_email\nL28334:             self.get_maintainer = self.metadata.get_maintainer\nL28335:             self.get_maintainer_email = self.metadata.get_maintainer_email\nL28336:             self.get_contact = self.metadata.get_contact\nL28337:             self.get_contact_email = self.metadata.get_contact_email\nL28338:             self.get_url = self.metadata.get_url\nL28339:             self.get_license = self.metadata.get_license\nL28340:             self.get_licence = self.metadata.get_licence\nL28341:             self.get_description = self.metadata.get_description\nL28342:             self.get_long_description = self.metadata.get_long_description\nL28343:             self.get_keywords = self.metadata.get_keywords\nL28344:             self.get_platforms = self.metadata.get_platforms\nL28345:             self.get_classifiers = self.metadata.get_classifiers\nL28346:             self.get_download_url = self.metadata.get_download_url\nL28347:             self.get_requires = self.metadata.get_requires\nL28348:             self.get_provides = self.metadata.get_provides\nL28349:             self.get_obsoletes = self.metadata.get_obsoletes\nL28350: \nL28351:         # Default attributes generated in __init__ from self.display_option_names\nL28352:         help_commands: bool\nL28353:         name: str | Literal[False]\nL28354:         version: str | Literal[False]\nL28355:         fullname: str | Literal[False]\nL28356:         author: str | Literal[False]\nL28357:         author_email: str | Literal[False]\nL28358:         maintainer: str | Literal[False]\nL28359:         maintainer_email: str | Literal[False]\nL28360:         contact: str | Literal[False]\nL28361:         contact_email: str | Literal[False]\nL28362:         url: str | Literal[False]\nL28363:         license: str | Literal[False]\nL28364:         licence: str | Literal[False]\nL28365:         description: str | Literal[False]\nL28366:         long_description: str | Literal[False]\nL28367:         platforms: str | list[str] | Literal[False]\nL28368:         classifiers: str | list[str] | Literal[False]\nL28369:         keywords: str | list[str] | Literal[False]\nL28370:         provides: list[str] | Literal[False]\nL28371:         requires: list[str] | Literal[False]\nL28372:         obsoletes: list[str] | Literal[False]\nL28373: \nL28374: \nL28375: class DistributionMetadata:\nL28376:     \"\"\"Dummy class to hold the distribution meta-data: name, version,\nL28377:     author, and so forth.\nL28378:     \"\"\"\nL28379: \nL28380:     _METHOD_BASENAMES = (\nL28381:         \"name\",\nL28382:         \"version\",\nL28383:         \"author\",\nL28384:         \"author_email\",\nL28385:         \"maintainer\",\nL28386:         \"maintainer_email\",\nL28387:         \"url\",\nL28388:         \"license\",\nL28389:         \"description\",\nL28390:         \"long_description\",\nL28391:         \"keywords\",\nL28392:         \"platforms\",\nL28393:         \"fullname\",\nL28394:         \"contact\",\nL28395:         \"contact_email\",\nL28396:         \"classifiers\",\nL28397:         \"download_url\",\nL28398:         # PEP 314\nL28399:         \"provides\",\nL28400:         \"requires\",\nL28401:         \"obsoletes\",\nL28402:     )\nL28403: \nL28404:     def __init__(\nL28405:         self, path: str | bytes | os.PathLike[str] | os.PathLike[bytes] | None = None\nL28406:     ) -> None:\nL28407:         if path is not None:\nL28408:             self.read_pkg_file(open(path))\nL28409:         else:\nL28410:             self.name: str | None = None\nL28411:             self.version: str | None = None\nL28412:             self.author: str | None = None\nL28413:             self.author_email: str | None = None\nL28414:             self.maintainer: str | None = None\nL28415:             self.maintainer_email: str | None = None\nL28416:             self.url: str | None = None\nL28417:             self.license: str | None = None\nL28418:             self.description: str | None = None\nL28419:             self.long_description: str | None = None\nL28420:             self.keywords: str | list[str] | None = None\nL28421:             self.platforms: str | list[str] | None = None\nL28422:             self.classifiers: str | list[str] | None = None\nL28423:             self.download_url: str | None = None\nL28424:             # PEP 314\nL28425:             self.provides: str | list[str] | None = None\nL28426:             self.requires: str | list[str] | None = None\nL28427:             self.obsoletes: str | list[str] | None = None\nL28428: \nL28429:     def read_pkg_file(self, file: IO[str]) -> None:\nL28430:         \"\"\"Reads the metadata values from a file object.\"\"\"\nL28431:         msg = message_from_file(file)\nL28432: \nL28433:         def _read_field(name: str) -> str | None:\nL28434:             value = msg[name]\nL28435:             if value and value != \"UNKNOWN\":\nL28436:                 return value\nL28437:             return None\nL28438: \nL28439:         def _read_list(name):\nL28440:             values = msg.get_all(name, None)\nL28441:             if values == []:\nL28442:                 return None\nL28443:             return values\nL28444: \nL28445:         metadata_version = msg['metadata-version']\nL28446:         self.name = _read_field('name')\nL28447:         self.version = _read_field('version')\nL28448:         self.description = _read_field('summary')\nL28449:         # we are filling author only.\nL28450:         self.author = _read_field('author')\nL28451:         self.maintainer = None\nL28452:         self.author_email = _read_field('author-email')\nL28453:         self.maintainer_email = None\nL28454:         self.url = _read_field('home-page')\nL28455:         self.license = _read_field('license')\nL28456: \nL28457:         if 'download-url' in msg:\nL28458:             self.download_url = _read_field('download-url')\nL28459:         else:\nL28460:             self.download_url = None\nL28461: \nL28462:         self.long_description = _read_field('description')\nL28463:         self.description = _read_field('summary')\nL28464: \nL28465:         if 'keywords' in msg:\nL28466:             self.keywords = _read_field('keywords').split(',')\nL28467: \nL28468:         self.platforms = _read_list('platform')\nL28469:         self.classifiers = _read_list('classifier')\nL28470: \nL28471:         # PEP 314 - these fields only exist in 1.1\nL28472:         if metadata_version == '1.1':\nL28473:             self.requires = _read_list('requires')\nL28474:             self.provides = _read_list('provides')\nL28475:             self.obsoletes = _read_list('obsoletes')\nL28476:         else:\nL28477:             self.requires = None\nL28478:             self.provides = None\nL28479:             self.obsoletes = None\nL28480: \nL28481:     def write_pkg_info(self, base_dir: str | os.PathLike[str]) -> None:\nL28482:         \"\"\"Write the PKG-INFO file into the release tree.\"\"\"\nL28483:         with open(\nL28484:             os.path.join(base_dir, 'PKG-INFO'), 'w', encoding='UTF-8'\nL28485:         ) as pkg_info:\nL28486:             self.write_pkg_file(pkg_info)\nL28487: \nL28488:     def write_pkg_file(self, file: SupportsWrite[str]) -> None:\nL28489:         \"\"\"Write the PKG-INFO format data to a file object.\"\"\"\nL28490:         version = '1.0'\nL28491:         if (\nL28492:             self.provides\nL28493:             or self.requires\nL28494:             or self.obsoletes\nL28495:             or self.classifiers\nL28496:             or self.download_url\nL28497:         ):\nL28498:             version = '1.1'\nL28499: \nL28500:         # required fields\nL28501:         file.write(f'Metadata-Version: {version}\\n')\nL28502:         file.write(f'Name: {self.get_name()}\\n')\nL28503:         file.write(f'Version: {self.get_version()}\\n')\nL28504: \nL28505:         def maybe_write(header, val):\nL28506:             if val:\nL28507:                 file.write(f\"{header}: {val}\\n\")\nL28508: \nL28509:         # optional fields\nL28510:         maybe_write(\"Summary\", self.get_description())\nL28511:         maybe_write(\"Home-page\", self.get_url())\nL28512:         maybe_write(\"Author\", self.get_contact())\nL28513:         maybe_write(\"Author-email\", self.get_contact_email())\nL28514:         maybe_write(\"License\", self.get_license())\nL28515:         maybe_write(\"Download-URL\", self.download_url)\nL28516:         maybe_write(\"Description\", rfc822_escape(self.get_long_description() or \"\"))\nL28517:         maybe_write(\"Keywords\", \",\".join(self.get_keywords()))\nL28518: \nL28519:         self._write_list(file, 'Platform', self.get_platforms())\nL28520:         self._write_list(file, 'Classifier', self.get_classifiers())\nL28521: \nL28522:         # PEP 314\nL28523:         self._write_list(file, 'Requires', self.get_requires())\nL28524:         self._write_list(file, 'Provides', self.get_provides())\nL28525:         self._write_list(file, 'Obsoletes', self.get_obsoletes())\nL28526: \nL28527:     def _write_list(self, file, name, values):\nL28528:         values = values or []\nL28529:         for value in values:\nL28530:             file.write(f'{name}: {value}\\n')\nL28531: \nL28532:     # -- Metadata query methods ----------------------------------------\nL28533: \nL28534:     def get_name(self) -> str:\nL28535:         return self.name or \"UNKNOWN\"\nL28536: \nL28537:     def get_version(self) -> str:\nL28538:         return self.version or \"0.0.0\"\nL28539: \nL28540:     def get_fullname(self) -> str:\nL28541:         return self._fullname(self.get_name(), self.get_version())\nL28542: \nL28543:     @staticmethod\nL28544:     def _fullname(name: str, version: str) -> str:\nL28545:         \"\"\"\nL28546:         >>> DistributionMetadata._fullname('setup.tools', '1.0-2')\nL28547:         'setup_tools-1.0.post2'\nL28548:         >>> DistributionMetadata._fullname('setup-tools', '1.2post2')\nL28549:         'setup_tools-1.2.post2'\nL28550:         >>> DistributionMetadata._fullname('setup-tools', '1.0-r2')\nL28551:         'setup_tools-1.0.post2'\nL28552:         >>> DistributionMetadata._fullname('setup.tools', '1.0.post')\nL28553:         'setup_tools-1.0.post0'\nL28554:         >>> DistributionMetadata._fullname('setup.tools', '1.0+ubuntu-1')\nL28555:         'setup_tools-1.0+ubuntu.1'\nL28556:         \"\"\"\nL28557:         return \"{}-{}\".format(\nL28558:             canonicalize_name(name).replace('-', '_'),\nL28559:             canonicalize_version(version, strip_trailing_zero=False),\nL28560:         )\nL28561: \nL28562:     def get_author(self) -> str | None:\nL28563:         return self.author\nL28564: \nL28565:     def get_author_email(self) -> str | None:\nL28566:         return self.author_email\nL28567: \nL28568:     def get_maintainer(self) -> str | None:\nL28569:         return self.maintainer\nL28570: \nL28571:     def get_maintainer_email(self) -> str | None:\nL28572:         return self.maintainer_email\nL28573: \nL28574:     def get_contact(self) -> str | None:\nL28575:         return self.maintainer or self.author\nL28576: \nL28577:     def get_contact_email(self) -> str | None:\nL28578:         return self.maintainer_email or self.author_email\nL28579: \nL28580:     def get_url(self) -> str | None:\nL28581:         return self.url\nL28582: \nL28583:     def get_license(self) -> str | None:\nL28584:         return self.license\nL28585: \nL28586:     get_licence = get_license\nL28587: \nL28588:     def get_description(self) -> str | None:\nL28589:         return self.description\nL28590: \nL28591:     def get_long_description(self) -> str | None:\nL28592:         return self.long_description\nL28593: \nL28594:     def get_keywords(self) -> str | list[str]:\nL28595:         return self.keywords or []\nL28596: \nL28597:     def set_keywords(self, value: str | Iterable[str]) -> None:\nL28598:         self.keywords = _ensure_list(value, 'keywords')\nL28599: \nL28600:     def get_platforms(self) -> str | list[str] | None:\nL28601:         return self.platforms\nL28602: \nL28603:     def set_platforms(self, value: str | Iterable[str]) -> None:\nL28604:         self.platforms = _ensure_list(value, 'platforms')\nL28605: \nL28606:     def get_classifiers(self) -> str | list[str]:\nL28607:         return self.classifiers or []\nL28608: \nL28609:     def set_classifiers(self, value: str | Iterable[str]) -> None:\nL28610:         self.classifiers = _ensure_list(value, 'classifiers')\nL28611: \nL28612:     def get_download_url(self) -> str | None:\nL28613:         return self.download_url\nL28614: \nL28615:     # PEP 314\nL28616:     def get_requires(self) -> str | list[str]:\nL28617:         return self.requires or []\nL28618: \nL28619:     def set_requires(self, value: Iterable[str]) -> None:\nL28620:         import distutils.versionpredicate\nL28621: \nL28622:         for v in value:\nL28623:             distutils.versionpredicate.VersionPredicate(v)\nL28624:         self.requires = list(value)\nL28625: \nL28626:     def get_provides(self) -> str | list[str]:\nL28627:         return self.provides or []\nL28628: \nL28629:     def set_provides(self, value: Iterable[str]) -> None:\nL28630:         value = [v.strip() for v in value]\nL28631:         for v in value:\nL28632:             import distutils.versionpredicate\nL28633: \nL28634:             distutils.versionpredicate.split_provision(v)\nL28635:         self.provides = value\nL28636: \nL28637:     def get_obsoletes(self) -> str | list[str]:\nL28638:         return self.obsoletes or []\nL28639: \nL28640:     def set_obsoletes(self, value: Iterable[str]) -> None:\nL28641:         import distutils.versionpredicate\nL28642: \nL28643:         for v in value:\nL28644:             distutils.versionpredicate.VersionPredicate(v)\nL28645:         self.obsoletes = list(value)\nL28646: \nL28647: \nL28648: def fix_help_options(options):\nL28649:     \"\"\"Convert a 4-tuple 'help_options' list as found in various command\nL28650:     classes to the 3-tuple form required by FancyGetopt.\nL28651:     \"\"\"\nL28652:     return [opt[0:3] for opt in options]\nL28653: \nL28654: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/extension.py\nL28655: #!/usr/bin/env python3\nL28656: \"\"\"distutils.extension\nL28657: \nL28658: Provides the Extension class, used to describe C/C++ extension\nL28659: modules in setup scripts.\"\"\"\nL28660: \nL28661: from __future__ import annotations\nL28662: \nL28663: import os\nL28664: import warnings\nL28665: from collections.abc import Iterable\nL28666: \nL28667: # This class is really only used by the \"build_ext\" command, so it might\nL28668: # make sense to put it in distutils.command.build_ext.  However, that\nL28669: # module is already big enough, and I want to make this class a bit more\nL28670: # complex to simplify some common cases (\"foo\" module in \"foo.c\") and do\nL28671: # better error-checking (\"foo.c\" actually exists).\nL28672: #\nL28673: # Also, putting this in build_ext.py means every setup script would have to\nL28674: # import that large-ish module (indirectly, through distutils.core) in\nL28675: # order to do anything.\nL28676: \nL28677: \nL28678: class Extension:\nL28679:     \"\"\"Just a collection of attributes that describes an extension\nL28680:     module and everything needed to build it (hopefully in a portable\nL28681:     way, but there are hooks that let you be as unportable as you need).\nL28682: \nL28683:     Instance attributes:\nL28684:       name : string\nL28685:         the full name of the extension, including any packages -- ie.\nL28686:         *not* a filename or pathname, but Python dotted name\nL28687:       sources : Iterable[string | os.PathLike]\nL28688:         iterable of source filenames (except strings, which could be misinterpreted\nL28689:         as a single filename), relative to the distribution root (where the setup\nL28690:         script lives), in Unix form (slash-separated) for portability. Can be any\nL28691:         non-string iterable (list, tuple, set, etc.) containing strings or\nL28692:         PathLike objects. Source files may be C, C++, SWIG (.i), platform-specific\nL28693:         resource files, or whatever else is recognized by the \"build_ext\" command\nL28694:         as source for a Python extension.\nL28695:       include_dirs : [string]\nL28696:         list of directories to search for C/C++ header files (in Unix\nL28697:         form for portability)\nL28698:       define_macros : [(name : string, value : string|None)]\nL28699:         list of macros to define; each macro is defined using a 2-tuple,\nL28700:         where 'value' is either the string to define it to or None to\nL28701:         define it without a particular value (equivalent of \"#define\nL28702:         FOO\" in source or -DFOO on Unix C compiler command line)\nL28703:       undef_macros : [string]\nL28704:         list of macros to undefine explicitly\nL28705:       library_dirs : [string]\nL28706:         list of directories to search for C/C++ libraries at link time\nL28707:       libraries : [string]\nL28708:         list of library names (not filenames or paths) to link against\nL28709:       runtime_library_dirs : [string]\nL28710:         list of directories to search for C/C++ libraries at run time\nL28711:         (for shared extensions, this is when the extension is loaded)\nL28712:       extra_objects : [string]\nL28713:         list of extra files to link with (eg. object files not implied\nL28714:         by 'sources', static library that must be explicitly specified,\nL28715:         binary resource files, etc.)\nL28716:       extra_compile_args : [string]\nL28717:         any extra platform- and compiler-specific information to use\nL28718:         when compiling the source files in 'sources'.  For platforms and\nL28719:         compilers where \"command line\" makes sense, this is typically a\nL28720:         list of command-line arguments, but for other platforms it could\nL28721:         be anything.\nL28722:       extra_link_args : [string]\nL28723:         any extra platform- and compiler-specific information to use\nL28724:         when linking object files together to create the extension (or\nL28725:         to create a new static Python interpreter).  Similar\nL28726:         interpretation as for 'extra_compile_args'.\nL28727:       export_symbols : [string]\nL28728:         list of symbols to be exported from a shared extension.  Not\nL28729:         used on all platforms, and not generally necessary for Python\nL28730:         extensions, which typically export exactly one symbol: \"init\" +\nL28731:         extension_name.\nL28732:       swig_opts : [string]\nL28733:         any extra options to pass to SWIG if a source file has the .i\nL28734:         extension.\nL28735:       depends : [string]\nL28736:         list of files that the extension depends on\nL28737:       language : string\nL28738:         extension language (i.e. \"c\", \"c++\", \"objc\"). Will be detected\nL28739:         from the source extensions if not provided.\nL28740:       optional : boolean\nL28741:         specifies that a build failure in the extension should not abort the\nL28742:         build process, but simply not install the failing extension.\nL28743:     \"\"\"\nL28744: \nL28745:     # When adding arguments to this constructor, be sure to update\nL28746:     # setup_keywords in core.py.\nL28747:     def __init__(\nL28748:         self,\nL28749:         name: str,\nL28750:         sources: Iterable[str | os.PathLike[str]],\nL28751:         include_dirs: list[str] | None = None,\nL28752:         define_macros: list[tuple[str, str | None]] | None = None,\nL28753:         undef_macros: list[str] | None = None,\nL28754:         library_dirs: list[str] | None = None,\nL28755:         libraries: list[str] | None = None,\nL28756:         runtime_library_dirs: list[str] | None = None,\nL28757:         extra_objects: list[str] | None = None,\nL28758:         extra_compile_args: list[str] | None = None,\nL28759:         extra_link_args: list[str] | None = None,\nL28760:         export_symbols: list[str] | None = None,\nL28761:         swig_opts: list[str] | None = None,\nL28762:         depends: list[str] | None = None,\nL28763:         language: str | None = None,\nL28764:         optional: bool | None = None,\nL28765:         **kw,  # To catch unknown keywords\nL28766:     ):\nL28767:         if not isinstance(name, str):\nL28768:             raise TypeError(\"'name' must be a string\")\nL28769: \nL28770:         # handle the string case first; since strings are iterable, disallow them\nL28771:         if isinstance(sources, str):\nL28772:             raise TypeError(\nL28773:                 \"'sources' must be an iterable of strings or PathLike objects, not a string\"\nL28774:             )\nL28775: \nL28776:         # now we check if it's iterable and contains valid types\nL28777:         try:\nL28778:             self.sources = list(map(os.fspath, sources))\nL28779:         except TypeError:\nL28780:             raise TypeError(\nL28781:                 \"'sources' must be an iterable of strings or PathLike objects\"\nL28782:             )\nL28783: \nL28784:         self.name = name\nL28785:         self.include_dirs = include_dirs or []\nL28786:         self.define_macros = define_macros or []\nL28787:         self.undef_macros = undef_macros or []\nL28788:         self.library_dirs = library_dirs or []\nL28789:         self.libraries = libraries or []\nL28790:         self.runtime_library_dirs = runtime_library_dirs or []\nL28791:         self.extra_objects = extra_objects or []\nL28792:         self.extra_compile_args = extra_compile_args or []\nL28793:         self.extra_link_args = extra_link_args or []\nL28794:         self.export_symbols = export_symbols or []\nL28795:         self.swig_opts = swig_opts or []\nL28796:         self.depends = depends or []\nL28797:         self.language = language\nL28798:         self.optional = optional\nL28799: \nL28800:         # If there are unknown keyword options, warn about them\nL28801:         if len(kw) > 0:\nL28802:             options = [repr(option) for option in kw]\nL28803:             options = ', '.join(sorted(options))\nL28804:             msg = f\"Unknown Extension options: {options}\"\nL28805:             warnings.warn(msg)\nL28806: \nL28807:     def __repr__(self):\nL28808:         return f'<{self.__class__.__module__}.{self.__class__.__qualname__}({self.name!r}) at {id(self):#x}>'\nL28809: \nL28810: \nL28811: def read_setup_file(filename):  # noqa: C901\nL28812:     \"\"\"Reads a Setup file and returns Extension instances.\"\"\"\nL28813:     from distutils.sysconfig import _variable_rx, expand_makefile_vars, parse_makefile\nL28814:     from distutils.text_file import TextFile\nL28815:     from distutils.util import split_quoted\nL28816: \nL28817:     # First pass over the file to gather \"VAR = VALUE\" assignments.\nL28818:     vars = parse_makefile(filename)\nL28819: \nL28820:     # Second pass to gobble up the real content: lines of the form\nL28821:     #   <module> ... [<sourcefile> ...] [<cpparg> ...] [<library> ...]\nL28822:     file = TextFile(\nL28823:         filename,\nL28824:         strip_comments=True,\nL28825:         skip_blanks=True,\nL28826:         join_lines=True,\nL28827:         lstrip_ws=True,\nL28828:         rstrip_ws=True,\nL28829:     )\nL28830:     try:\nL28831:         extensions = []\nL28832: \nL28833:         while True:\nL28834:             line = file.readline()\nL28835:             if line is None:  # eof\nL28836:                 break\nL28837:             if _variable_rx.match(line):  # VAR=VALUE, handled in first pass\nL28838:                 continue\nL28839: \nL28840:             if line[0] == line[-1] == \"*\":\nL28841:                 file.warn(f\"'{line}' lines not handled yet\")\nL28842:                 continue\nL28843: \nL28844:             line = expand_makefile_vars(line, vars)\nL28845:             words = split_quoted(line)\nL28846: \nL28847:             # NB. this parses a slightly different syntax than the old\nL28848:             # makesetup script: here, there must be exactly one extension per\nL28849:             # line, and it must be the first word of the line.  I have no idea\nL28850:             # why the old syntax supported multiple extensions per line, as\nL28851:             # they all wind up being the same.\nL28852: \nL28853:             module = words[0]\nL28854:             ext = Extension(module, [])\nL28855:             append_next_word = None\nL28856: \nL28857:             for word in words[1:]:\nL28858:                 if append_next_word is not None:\nL28859:                     append_next_word.append(word)\nL28860:                     append_next_word = None\nL28861:                     continue\nL28862: \nL28863:                 suffix = os.path.splitext(word)[1]\nL28864:                 switch = word[0:2]\nL28865:                 value = word[2:]\nL28866: \nL28867:                 if suffix in (\".c\", \".cc\", \".cpp\", \".cxx\", \".c++\", \".m\", \".mm\"):\nL28868:                     # hmm, should we do something about C vs. C++ sources?\nL28869:                     # or leave it up to the CCompiler implementation to\nL28870:                     # worry about?\nL28871:                     ext.sources.append(word)\nL28872:                 elif switch == \"-I\":\nL28873:                     ext.include_dirs.append(value)\nL28874:                 elif switch == \"-D\":\nL28875:                     equals = value.find(\"=\")\nL28876:                     if equals == -1:  # bare \"-DFOO\" -- no value\nL28877:                         ext.define_macros.append((value, None))\nL28878:                     else:  # \"-DFOO=blah\"\nL28879:                         ext.define_macros.append((value[0:equals], value[equals + 2 :]))\nL28880:                 elif switch == \"-U\":\nL28881:                     ext.undef_macros.append(value)\nL28882:                 elif switch == \"-C\":  # only here 'cause makesetup has it!\nL28883:                     ext.extra_compile_args.append(word)\nL28884:                 elif switch == \"-l\":\nL28885:                     ext.libraries.append(value)\nL28886:                 elif switch == \"-L\":\nL28887:                     ext.library_dirs.append(value)\nL28888:                 elif switch == \"-R\":\nL28889:                     ext.runtime_library_dirs.append(value)\nL28890:                 elif word == \"-rpath\":\nL28891:                     append_next_word = ext.runtime_library_dirs\nL28892:                 elif word == \"-Xlinker\":\nL28893:                     append_next_word = ext.extra_link_args\nL28894:                 elif word == \"-Xcompiler\":\nL28895:                     append_next_word = ext.extra_compile_args\nL28896:                 elif switch == \"-u\":\nL28897:                     ext.extra_link_args.append(word)\nL28898:                     if not value:\nL28899:                         append_next_word = ext.extra_link_args\nL28900:                 elif suffix in (\".a\", \".so\", \".sl\", \".o\", \".dylib\"):\nL28901:                     # NB. a really faithful emulation of makesetup would\nL28902:                     # append a .o file to extra_objects only if it\nL28903:                     # had a slash in it; otherwise, it would s/.o/.c/\nL28904:                     # and append it to sources.  Hmmmm.\nL28905:                     ext.extra_objects.append(word)\nL28906:                 else:\nL28907:                     file.warn(f\"unrecognized argument '{word}'\")\nL28908: \nL28909:             extensions.append(ext)\nL28910:     finally:\nL28911:         file.close()\nL28912: \nL28913:     return extensions\nL28914: \nL28915: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/fancy_getopt.py\nL28916: #!/usr/bin/env python3\nL28917: \"\"\"distutils.fancy_getopt\nL28918: \nL28919: Wrapper around the standard getopt module that provides the following\nL28920: additional features:\nL28921:   * short and long options are tied together\nL28922:   * options have help strings, so fancy_getopt could potentially\nL28923:     create a complete usage summary\nL28924:   * options set attributes of a passed-in object\nL28925: \"\"\"\nL28926: \nL28927: from __future__ import annotations\nL28928: \nL28929: import getopt\nL28930: import re\nL28931: import string\nL28932: import sys\nL28933: from collections.abc import Sequence\nL28934: from typing import Any\nL28935: \nL28936: from .errors import DistutilsArgError, DistutilsGetoptError\nL28937: \nL28938: # Much like command_re in distutils.core, this is close to but not quite\nL28939: # the same as a Python NAME -- except, in the spirit of most GNU\nL28940: # utilities, we use '-' in place of '_'.  (The spirit of LISP lives on!)\nL28941: # The similarities to NAME are again not a coincidence...\nL28942: longopt_pat = r'[a-zA-Z](?:[a-zA-Z0-9-]*)'\nL28943: longopt_re = re.compile(rf'^{longopt_pat}$')\nL28944: \nL28945: # For recognizing \"negative alias\" options, eg. \"quiet=!verbose\"\nL28946: neg_alias_re = re.compile(f\"^({longopt_pat})=!({longopt_pat})$\")\nL28947: \nL28948: # This is used to translate long options to legitimate Python identifiers\nL28949: # (for use as attributes of some object).\nL28950: longopt_xlate = str.maketrans('-', '_')\nL28951: \nL28952: \nL28953: class FancyGetopt:\nL28954:     \"\"\"Wrapper around the standard 'getopt()' module that provides some\nL28955:     handy extra functionality:\nL28956:       * short and long options are tied together\nL28957:       * options have help strings, and help text can be assembled\nL28958:         from them\nL28959:       * options set attributes of a passed-in object\nL28960:       * boolean options can have \"negative aliases\" -- eg. if\nL28961:         --quiet is the \"negative alias\" of --verbose, then \"--quiet\"\nL28962:         on the command line sets 'verbose' to false\nL28963:     \"\"\"\nL28964: \nL28965:     def __init__(self, option_table=None):\nL28966:         # The option table is (currently) a list of tuples.  The\nL28967:         # tuples may have 3 or four values:\nL28968:         #   (long_option, short_option, help_string [, repeatable])\nL28969:         # if an option takes an argument, its long_option should have '='\nL28970:         # appended; short_option should just be a single character, no ':'\nL28971:         # in any case.  If a long_option doesn't have a corresponding\nL28972:         # short_option, short_option should be None.  All option tuples\nL28973:         # must have long options.\nL28974:         self.option_table = option_table\nL28975: \nL28976:         # 'option_index' maps long option names to entries in the option\nL28977:         # table (ie. those 3-tuples).\nL28978:         self.option_index = {}\nL28979:         if self.option_table:\nL28980:             self._build_index()\nL28981: \nL28982:         # 'alias' records (duh) alias options; {'foo': 'bar'} means\nL28983:         # --foo is an alias for --bar\nL28984:         self.alias = {}\nL28985: \nL28986:         # 'negative_alias' keeps track of options that are the boolean\nL28987:         # opposite of some other option\nL28988:         self.negative_alias = {}\nL28989: \nL28990:         # These keep track of the information in the option table.  We\nL28991:         # don't actually populate these structures until we're ready to\nL28992:         # parse the command-line, since the 'option_table' passed in here\nL28993:         # isn't necessarily the final word.\nL28994:         self.short_opts = []\nL28995:         self.long_opts = []\nL28996:         self.short2long = {}\nL28997:         self.attr_name = {}\nL28998:         self.takes_arg = {}\nL28999: \nL29000:         # And 'option_order' is filled up in 'getopt()'; it records the\nL29001:         # original order of options (and their values) on the command-line,\nL29002:         # but expands short options, converts aliases, etc.\nL29003:         self.option_order = []\nL29004: \nL29005:     def _build_index(self):\nL29006:         self.option_index.clear()\nL29007:         for option in self.option_table:\nL29008:             self.option_index[option[0]] = option\nL29009: \nL29010:     def set_option_table(self, option_table):\nL29011:         self.option_table = option_table\nL29012:         self._build_index()\nL29013: \nL29014:     def add_option(self, long_option, short_option=None, help_string=None):\nL29015:         if long_option in self.option_index:\nL29016:             raise DistutilsGetoptError(\nL29017:                 f\"option conflict: already an option '{long_option}'\"\nL29018:             )\nL29019:         else:\nL29020:             option = (long_option, short_option, help_string)\nL29021:             self.option_table.append(option)\nL29022:             self.option_index[long_option] = option\nL29023: \nL29024:     def has_option(self, long_option):\nL29025:         \"\"\"Return true if the option table for this parser has an\nL29026:         option with long name 'long_option'.\"\"\"\nL29027:         return long_option in self.option_index\nL29028: \nL29029:     def get_attr_name(self, long_option):\nL29030:         \"\"\"Translate long option name 'long_option' to the form it\nL29031:         has as an attribute of some object: ie., translate hyphens\nL29032:         to underscores.\"\"\"\nL29033:         return long_option.translate(longopt_xlate)\nL29034: \nL29035:     def _check_alias_dict(self, aliases, what):\nL29036:         assert isinstance(aliases, dict)\nL29037:         for alias, opt in aliases.items():\nL29038:             if alias not in self.option_index:\nL29039:                 raise DistutilsGetoptError(\nL29040:                     f\"invalid {what} '{alias}': option '{alias}' not defined\"\nL29041:                 )\nL29042:             if opt not in self.option_index:\nL29043:                 raise DistutilsGetoptError(\nL29044:                     f\"invalid {what} '{alias}': aliased option '{opt}' not defined\"\nL29045:                 )\nL29046: \nL29047:     def set_aliases(self, alias):\nL29048:         \"\"\"Set the aliases for this option parser.\"\"\"\nL29049:         self._check_alias_dict(alias, \"alias\")\nL29050:         self.alias = alias\nL29051: \nL29052:     def set_negative_aliases(self, negative_alias):\nL29053:         \"\"\"Set the negative aliases for this option parser.\nL29054:         'negative_alias' should be a dictionary mapping option names to\nL29055:         option names, both the key and value must already be defined\nL29056:         in the option table.\"\"\"\nL29057:         self._check_alias_dict(negative_alias, \"negative alias\")\nL29058:         self.negative_alias = negative_alias\nL29059: \nL29060:     def _grok_option_table(self):  # noqa: C901\nL29061:         \"\"\"Populate the various data structures that keep tabs on the\nL29062:         option table.  Called by 'getopt()' before it can do anything\nL29063:         worthwhile.\nL29064:         \"\"\"\nL29065:         self.long_opts = []\nL29066:         self.short_opts = []\nL29067:         self.short2long.clear()\nL29068:         self.repeat = {}\nL29069: \nL29070:         for option in self.option_table:\nL29071:             if len(option) == 3:\nL29072:                 long, short, help = option\nL29073:                 repeat = 0\nL29074:             elif len(option) == 4:\nL29075:                 long, short, help, repeat = option\nL29076:             else:\nL29077:                 # the option table is part of the code, so simply\nL29078:                 # assert that it is correct\nL29079:                 raise ValueError(f\"invalid option tuple: {option!r}\")\nL29080: \nL29081:             # Type- and value-check the option names\nL29082:             if not isinstance(long, str) or len(long) < 2:\nL29083:                 raise DistutilsGetoptError(\nL29084:                     f\"invalid long option '{long}': must be a string of length >= 2\"\nL29085:                 )\nL29086: \nL29087:             if not ((short is None) or (isinstance(short, str) and len(short) == 1)):\nL29088:                 raise DistutilsGetoptError(\nL29089:                     f\"invalid short option '{short}': must a single character or None\"\nL29090:                 )\nL29091: \nL29092:             self.repeat[long] = repeat\nL29093:             self.long_opts.append(long)\nL29094: \nL29095:             if long[-1] == '=':  # option takes an argument?\nL29096:                 if short:\nL29097:                     short = short + ':'\nL29098:                 long = long[0:-1]\nL29099:                 self.takes_arg[long] = True\nL29100:             else:\nL29101:                 # Is option is a \"negative alias\" for some other option (eg.\nL29102:                 # \"quiet\" == \"!verbose\")?\nL29103:                 alias_to = self.negative_alias.get(long)\nL29104:                 if alias_to is not None:\nL29105:                     if self.takes_arg[alias_to]:\nL29106:                         raise DistutilsGetoptError(\nL29107:                             f\"invalid negative alias '{long}': \"\nL29108:                             f\"aliased option '{alias_to}' takes a value\"\nL29109:                         )\nL29110: \nL29111:                     self.long_opts[-1] = long  # XXX redundant?!\nL29112:                 self.takes_arg[long] = False\nL29113: \nL29114:             # If this is an alias option, make sure its \"takes arg\" flag is\nL29115:             # the same as the option it's aliased to.\nL29116:             alias_to = self.alias.get(long)\nL29117:             if alias_to is not None:\nL29118:                 if self.takes_arg[long] != self.takes_arg[alias_to]:\nL29119:                     raise DistutilsGetoptError(\nL29120:                         f\"invalid alias '{long}': inconsistent with \"\nL29121:                         f\"aliased option '{alias_to}' (one of them takes a value, \"\nL29122:                         \"the other doesn't\"\nL29123:                     )\nL29124: \nL29125:             # Now enforce some bondage on the long option name, so we can\nL29126:             # later translate it to an attribute name on some object.  Have\nL29127:             # to do this a bit late to make sure we've removed any trailing\nL29128:             # '='.\nL29129:             if not longopt_re.match(long):\nL29130:                 raise DistutilsGetoptError(\nL29131:                     f\"invalid long option name '{long}' \"\nL29132:                     \"(must be letters, numbers, hyphens only\"\nL29133:                 )\nL29134: \nL29135:             self.attr_name[long] = self.get_attr_name(long)\nL29136:             if short:\nL29137:                 self.short_opts.append(short)\nL29138:                 self.short2long[short[0]] = long\nL29139: \nL29140:     def getopt(self, args: Sequence[str] | None = None, object=None):  # noqa: C901\nL29141:         \"\"\"Parse command-line options in args. Store as attributes on object.\nL29142: \nL29143:         If 'args' is None or not supplied, uses 'sys.argv[1:]'.  If\nL29144:         'object' is None or not supplied, creates a new OptionDummy\nL29145:         object, stores option values there, and returns a tuple (args,\nL29146:         object).  If 'object' is supplied, it is modified in place and\nL29147:         'getopt()' just returns 'args'; in both cases, the returned\nL29148:         'args' is a modified copy of the passed-in 'args' list, which\nL29149:         is left untouched.\nL29150:         \"\"\"\nL29151:         if args is None:\nL29152:             args = sys.argv[1:]\nL29153:         if object is None:\nL29154:             object = OptionDummy()\nL29155:             created_object = True\nL29156:         else:\nL29157:             created_object = False\nL29158: \nL29159:         self._grok_option_table()\nL29160: \nL29161:         short_opts = ' '.join(self.short_opts)\nL29162:         try:\nL29163:             opts, args = getopt.getopt(args, short_opts, self.long_opts)\nL29164:         except getopt.error as msg:\nL29165:             raise DistutilsArgError(msg)\nL29166: \nL29167:         for opt, val in opts:\nL29168:             if len(opt) == 2 and opt[0] == '-':  # it's a short option\nL29169:                 opt = self.short2long[opt[1]]\nL29170:             else:\nL29171:                 assert len(opt) > 2 and opt[:2] == '--'\nL29172:                 opt = opt[2:]\nL29173: \nL29174:             alias = self.alias.get(opt)\nL29175:             if alias:\nL29176:                 opt = alias\nL29177: \nL29178:             if not self.takes_arg[opt]:  # boolean option?\nL29179:                 assert val == '', \"boolean option can't have value\"\nL29180:                 alias = self.negative_alias.get(opt)\nL29181:                 if alias:\nL29182:                     opt = alias\nL29183:                     val = 0\nL29184:                 else:\nL29185:                     val = 1\nL29186: \nL29187:             attr = self.attr_name[opt]\nL29188:             # The only repeating option at the moment is 'verbose'.\nL29189:             # It has a negative option -q quiet, which should set verbose = False.\nL29190:             if val and self.repeat.get(attr) is not None:\nL29191:                 val = getattr(object, attr, 0) + 1\nL29192:             setattr(object, attr, val)\nL29193:             self.option_order.append((opt, val))\nL29194: \nL29195:         # for opts\nL29196:         if created_object:\nL29197:             return args, object\nL29198:         else:\nL29199:             return args\nL29200: \nL29201:     def get_option_order(self):\nL29202:         \"\"\"Returns the list of (option, value) tuples processed by the\nL29203:         previous run of 'getopt()'.  Raises RuntimeError if\nL29204:         'getopt()' hasn't been called yet.\nL29205:         \"\"\"\nL29206:         if self.option_order is None:\nL29207:             raise RuntimeError(\"'getopt()' hasn't been called yet\")\nL29208:         else:\nL29209:             return self.option_order\nL29210: \nL29211:     def generate_help(self, header=None):  # noqa: C901\nL29212:         \"\"\"Generate help text (a list of strings, one per suggested line of\nL29213:         output) from the option table for this FancyGetopt object.\nL29214:         \"\"\"\nL29215:         # Blithely assume the option table is good: probably wouldn't call\nL29216:         # 'generate_help()' unless you've already called 'getopt()'.\nL29217: \nL29218:         # First pass: determine maximum length of long option names\nL29219:         max_opt = 0\nL29220:         for option in self.option_table:\nL29221:             long = option[0]\nL29222:             short = option[1]\nL29223:             ell = len(long)\nL29224:             if long[-1] == '=':\nL29225:                 ell = ell - 1\nL29226:             if short is not None:\nL29227:                 ell = ell + 5  # \" (-x)\" where short == 'x'\nL29228:             if ell > max_opt:\nL29229:                 max_opt = ell\nL29230: \nL29231:         opt_width = max_opt + 2 + 2 + 2  # room for indent + dashes + gutter\nL29232: \nL29233:         # Typical help block looks like this:\nL29234:         #   --foo       controls foonabulation\nL29235:         # Help block for longest option looks like this:\nL29236:         #   --flimflam  set the flim-flam level\nL29237:         # and with wrapped text:\nL29238:         #   --flimflam  set the flim-flam level (must be between\nL29239:         #               0 and 100, except on Tuesdays)\nL29240:         # Options with short names will have the short name shown (but\nL29241:         # it doesn't contribute to max_opt):\nL29242:         #   --foo (-f)  controls foonabulation\nL29243:         # If adding the short option would make the left column too wide,\nL29244:         # we push the explanation off to the next line\nL29245:         #   --flimflam (-l)\nL29246:         #               set the flim-flam level\nL29247:         # Important parameters:\nL29248:         #   - 2 spaces before option block start lines\nL29249:         #   - 2 dashes for each long option name\nL29250:         #   - min. 2 spaces between option and explanation (gutter)\nL29251:         #   - 5 characters (incl. space) for short option name\nL29252: \nL29253:         # Now generate lines of help text.  (If 80 columns were good enough\nL29254:         # for Jesus, then 78 columns are good enough for me!)\nL29255:         line_width = 78\nL29256:         text_width = line_width - opt_width\nL29257:         big_indent = ' ' * opt_width\nL29258:         if header:\nL29259:             lines = [header]\nL29260:         else:\nL29261:             lines = ['Option summary:']\nL29262: \nL29263:         for option in self.option_table:\nL29264:             long, short, help = option[:3]\nL29265:             text = wrap_text(help, text_width)\nL29266:             if long[-1] == '=':\nL29267:                 long = long[0:-1]\nL29268: \nL29269:             # Case 1: no short option at all (makes life easy)\nL29270:             if short is None:\nL29271:                 if text:\nL29272:                     lines.append(f\"  --{long:<{max_opt}}  {text[0]}\")\nL29273:                 else:\nL29274:                     lines.append(f\"  --{long:<{max_opt}}\")\nL29275: \nL29276:             # Case 2: we have a short option, so we have to include it\nL29277:             # just after the long option\nL29278:             else:\nL29279:                 opt_names = f\"{long} (-{short})\"\nL29280:                 if text:\nL29281:                     lines.append(f\"  --{opt_names:<{max_opt}}  {text[0]}\")\nL29282:                 else:\nL29283:                     lines.append(f\"  --{opt_names:<{max_opt}}\")\nL29284: \nL29285:             for ell in text[1:]:\nL29286:                 lines.append(big_indent + ell)\nL29287:         return lines\nL29288: \nL29289:     def print_help(self, header=None, file=None):\nL29290:         if file is None:\nL29291:             file = sys.stdout\nL29292:         for line in self.generate_help(header):\nL29293:             file.write(line + \"\\n\")\nL29294: \nL29295: \nL29296: def fancy_getopt(options, negative_opt, object, args: Sequence[str] | None):\nL29297:     parser = FancyGetopt(options)\nL29298:     parser.set_negative_aliases(negative_opt)\nL29299:     return parser.getopt(args, object)\nL29300: \nL29301: \nL29302: WS_TRANS = {ord(_wschar): ' ' for _wschar in string.whitespace}\nL29303: \nL29304: \nL29305: def wrap_text(text, width):\nL29306:     \"\"\"wrap_text(text : string, width : int) -> [string]\nL29307: \nL29308:     Split 'text' into multiple lines of no more than 'width' characters\nL29309:     each, and return the list of strings that results.\nL29310:     \"\"\"\nL29311:     if text is None:\nL29312:         return []\nL29313:     if len(text) <= width:\nL29314:         return [text]\nL29315: \nL29316:     text = text.expandtabs()\nL29317:     text = text.translate(WS_TRANS)\nL29318:     chunks = re.split(r'( +|-+)', text)\nL29319:     chunks = [ch for ch in chunks if ch]  # ' - ' results in empty strings\nL29320:     lines = []\nL29321: \nL29322:     while chunks:\nL29323:         cur_line = []  # list of chunks (to-be-joined)\nL29324:         cur_len = 0  # length of current line\nL29325: \nL29326:         while chunks:\nL29327:             ell = len(chunks[0])\nL29328:             if cur_len + ell <= width:  # can squeeze (at least) this chunk in\nL29329:                 cur_line.append(chunks[0])\nL29330:                 del chunks[0]\nL29331:                 cur_len = cur_len + ell\nL29332:             else:  # this line is full\nL29333:                 # drop last chunk if all space\nL29334:                 if cur_line and cur_line[-1][0] == ' ':\nL29335:                     del cur_line[-1]\nL29336:                 break\nL29337: \nL29338:         if chunks:  # any chunks left to process?\nL29339:             # if the current line is still empty, then we had a single\nL29340:             # chunk that's too big too fit on a line -- so we break\nL29341:             # down and break it up at the line width\nL29342:             if cur_len == 0:\nL29343:                 cur_line.append(chunks[0][0:width])\nL29344:                 chunks[0] = chunks[0][width:]\nL29345: \nL29346:             # all-whitespace chunks at the end of a line can be discarded\nL29347:             # (and we know from the re.split above that if a chunk has\nL29348:             # *any* whitespace, it is *all* whitespace)\nL29349:             if chunks[0][0] == ' ':\nL29350:                 del chunks[0]\nL29351: \nL29352:         # and store this line in the list-of-all-lines -- as a single\nL29353:         # string, of course!\nL29354:         lines.append(''.join(cur_line))\nL29355: \nL29356:     return lines\nL29357: \nL29358: \nL29359: def translate_longopt(opt):\nL29360:     \"\"\"Convert a long option name to a valid Python identifier by\nL29361:     changing \"-\" to \"_\".\nL29362:     \"\"\"\nL29363:     return opt.translate(longopt_xlate)\nL29364: \nL29365: \nL29366: class OptionDummy:\nL29367:     \"\"\"Dummy class just used as a place to hold command-line option\nL29368:     values as instance attributes.\"\"\"\nL29369: \nL29370:     def __init__(self, options: Sequence[Any] = []):\nL29371:         \"\"\"Create a new OptionDummy instance.  The attributes listed in\nL29372:         'options' will be initialized to None.\"\"\"\nL29373:         for opt in options:\nL29374:             setattr(self, opt, None)\nL29375: \nL29376: \nL29377: if __name__ == \"__main__\":\nL29378:     text = \"\"\"\\\nL29379: Tra-la-la, supercalifragilisticexpialidocious.\nL29380: How *do* you spell that odd word, anyways?\nL29381: (Someone ask Mary -- she'll know [or she'll\nL29382: say, \"How should I know?\"].)\"\"\"\nL29383: \nL29384:     for w in (10, 20, 30, 40):\nL29385:         print(f\"width: {w}\")\nL29386:         print(\"\\n\".join(wrap_text(text, w)))\nL29387:         print()\nL29388: \nL29389: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/bdist.py\nL29390: #!/usr/bin/env python3\nL29391: \"\"\"distutils.command.bdist\nL29392: \nL29393: Implements the Distutils 'bdist' command (create a built [binary]\nL29394: distribution).\"\"\"\nL29395: \nL29396: from __future__ import annotations\nL29397: \nL29398: import os\nL29399: import warnings\nL29400: from collections.abc import Callable\nL29401: from typing import TYPE_CHECKING, ClassVar\nL29402: \nL29403: from ..core import Command\nL29404: from ..errors import DistutilsOptionError, DistutilsPlatformError\nL29405: from ..util import get_platform\nL29406: \nL29407: if TYPE_CHECKING:\nL29408:     from typing_extensions import deprecated\nL29409: else:\nL29410: \nL29411:     def deprecated(message):\nL29412:         return lambda fn: fn\nL29413: \nL29414: \nL29415: def show_formats():\nL29416:     \"\"\"Print list of available formats (arguments to \"--format\" option).\"\"\"\nL29417:     from ..fancy_getopt import FancyGetopt\nL29418: \nL29419:     formats = [\nL29420:         (\"formats=\" + format, None, bdist.format_commands[format][1])\nL29421:         for format in bdist.format_commands\nL29422:     ]\nL29423:     pretty_printer = FancyGetopt(formats)\nL29424:     pretty_printer.print_help(\"List of available distribution formats:\")\nL29425: \nL29426: \nL29427: class ListCompat(dict[str, tuple[str, str]]):\nL29428:     # adapter to allow for Setuptools compatibility in format_commands\nL29429:     @deprecated(\"format_commands is now a dict. append is deprecated.\")\nL29430:     def append(self, item: object) -> None:\nL29431:         warnings.warn(\nL29432:             \"format_commands is now a dict. append is deprecated.\",\nL29433:             DeprecationWarning,\nL29434:             stacklevel=2,\nL29435:         )\nL29436: \nL29437: \nL29438: class bdist(Command):\nL29439:     description = \"create a built (binary) distribution\"\nL29440: \nL29441:     user_options = [\nL29442:         ('bdist-base=', 'b', \"temporary directory for creating built distributions\"),\nL29443:         (\nL29444:             'plat-name=',\nL29445:             'p',\nL29446:             \"platform name to embed in generated filenames \"\nL29447:             f\"[default: {get_platform()}]\",\nL29448:         ),\nL29449:         ('formats=', None, \"formats for distribution (comma-separated list)\"),\nL29450:         (\nL29451:             'dist-dir=',\nL29452:             'd',\nL29453:             \"directory to put final built distributions in [default: dist]\",\nL29454:         ),\nL29455:         ('skip-build', None, \"skip rebuilding everything (for testing/debugging)\"),\nL29456:         (\nL29457:             'owner=',\nL29458:             'u',\nL29459:             \"Owner name used when creating a tar file [default: current user]\",\nL29460:         ),\nL29461:         (\nL29462:             'group=',\nL29463:             'g',\nL29464:             \"Group name used when creating a tar file [default: current group]\",\nL29465:         ),\nL29466:     ]\nL29467: \nL29468:     boolean_options: ClassVar[list[str]] = ['skip-build']\nL29469: \nL29470:     help_options: ClassVar[list[tuple[str, str | None, str, Callable[[], object]]]] = [\nL29471:         ('help-formats', None, \"lists available distribution formats\", show_formats),\nL29472:     ]\nL29473: \nL29474:     # The following commands do not take a format option from bdist\nL29475:     no_format_option: ClassVar[tuple[str, ...]] = ('bdist_rpm',)\nL29476: \nL29477:     # This won't do in reality: will need to distinguish RPM-ish Linux,\nL29478:     # Debian-ish Linux, Solaris, FreeBSD, ..., Windows, Mac OS.\nL29479:     default_format: ClassVar[dict[str, str]] = {'posix': 'gztar', 'nt': 'zip'}\nL29480: \nL29481:     # Define commands in preferred order for the --help-formats option\nL29482:     format_commands = ListCompat({\nL29483:         'rpm': ('bdist_rpm', \"RPM distribution\"),\nL29484:         'gztar': ('bdist_dumb', \"gzip'ed tar file\"),\nL29485:         'bztar': ('bdist_dumb', \"bzip2'ed tar file\"),\nL29486:         'xztar': ('bdist_dumb', \"xz'ed tar file\"),\nL29487:         'ztar': ('bdist_dumb', \"compressed tar file\"),\nL29488:         'tar': ('bdist_dumb', \"tar file\"),\nL29489:         'zip': ('bdist_dumb', \"ZIP file\"),\nL29490:     })\nL29491: \nL29492:     # for compatibility until consumers only reference format_commands\nL29493:     format_command = format_commands\nL29494: \nL29495:     def initialize_options(self):\nL29496:         self.bdist_base = None\nL29497:         self.plat_name = None\nL29498:         self.formats = None\nL29499:         self.dist_dir = None\nL29500:         self.skip_build = False\nL29501:         self.group = None\nL29502:         self.owner = None\nL29503: \nL29504:     def finalize_options(self) -> None:\nL29505:         # have to finalize 'plat_name' before 'bdist_base'\nL29506:         if self.plat_name is None:\nL29507:             if self.skip_build:\nL29508:                 self.plat_name = get_platform()\nL29509:             else:\nL29510:                 self.plat_name = self.get_finalized_command('build').plat_name\nL29511: \nL29512:         # 'bdist_base' -- parent of per-built-distribution-format\nL29513:         # temporary directories (eg. we'll probably have\nL29514:         # \"build/bdist.<plat>/dumb\", \"build/bdist.<plat>/rpm\", etc.)\nL29515:         if self.bdist_base is None:\nL29516:             build_base = self.get_finalized_command('build').build_base\nL29517:             self.bdist_base = os.path.join(build_base, 'bdist.' + self.plat_name)\nL29518: \nL29519:         self.ensure_string_list('formats')\nL29520:         if self.formats is None:\nL29521:             try:\nL29522:                 self.formats = [self.default_format[os.name]]\nL29523:             except KeyError:\nL29524:                 raise DistutilsPlatformError(\nL29525:                     \"don't know how to create built distributions \"\nL29526:                     f\"on platform {os.name}\"\nL29527:                 )\nL29528: \nL29529:         if self.dist_dir is None:\nL29530:             self.dist_dir = \"dist\"\nL29531: \nL29532:     def run(self) -> None:\nL29533:         # Figure out which sub-commands we need to run.\nL29534:         commands = []\nL29535:         for format in self.formats:\nL29536:             try:\nL29537:                 commands.append(self.format_commands[format][0])\nL29538:             except KeyError:\nL29539:                 raise DistutilsOptionError(f\"invalid format '{format}'\")\nL29540: \nL29541:         # Reinitialize and run each command.\nL29542:         for i in range(len(self.formats)):\nL29543:             cmd_name = commands[i]\nL29544:             sub_cmd = self.reinitialize_command(cmd_name)\nL29545:             if cmd_name not in self.no_format_option:\nL29546:                 sub_cmd.format = self.formats[i]\nL29547: \nL29548:             # passing the owner and group names for tar archiving\nL29549:             if cmd_name == 'bdist_dumb':\nL29550:                 sub_cmd.owner = self.owner\nL29551:                 sub_cmd.group = self.group\nL29552: \nL29553:             # If we're going to need to run this command again, tell it to\nL29554:             # keep its temporary files around so subsequent runs go faster.\nL29555:             if cmd_name in commands[i + 1 :]:\nL29556:                 sub_cmd.keep_temp = True\nL29557:             self.run_command(cmd_name)\nL29558: \nL29559: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/bdist_dumb.py\nL29560: #!/usr/bin/env python3\nL29561: \"\"\"distutils.command.bdist_dumb\nL29562: \nL29563: Implements the Distutils 'bdist_dumb' command (create a \"dumb\" built\nL29564: distribution -- i.e., just an archive to be unpacked under $prefix or\nL29565: $exec_prefix).\"\"\"\nL29566: \nL29567: import os\nL29568: from distutils._log import log\nL29569: from typing import ClassVar\nL29570: \nL29571: from ..core import Command\nL29572: from ..dir_util import ensure_relative, remove_tree\nL29573: from ..errors import DistutilsPlatformError\nL29574: from ..sysconfig import get_python_version\nL29575: from ..util import get_platform\nL29576: \nL29577: \nL29578: class bdist_dumb(Command):\nL29579:     description = \"create a \\\"dumb\\\" built distribution\"\nL29580: \nL29581:     user_options = [\nL29582:         ('bdist-dir=', 'd', \"temporary directory for creating the distribution\"),\nL29583:         (\nL29584:             'plat-name=',\nL29585:             'p',\nL29586:             \"platform name to embed in generated filenames \"\nL29587:             f\"[default: {get_platform()}]\",\nL29588:         ),\nL29589:         (\nL29590:             'format=',\nL29591:             'f',\nL29592:             \"archive format to create (tar, gztar, bztar, xztar, ztar, zip)\",\nL29593:         ),\nL29594:         (\nL29595:             'keep-temp',\nL29596:             'k',\nL29597:             \"keep the pseudo-installation tree around after creating the distribution archive\",\nL29598:         ),\nL29599:         ('dist-dir=', 'd', \"directory to put final built distributions in\"),\nL29600:         ('skip-build', None, \"skip rebuilding everything (for testing/debugging)\"),\nL29601:         (\nL29602:             'relative',\nL29603:             None,\nL29604:             \"build the archive using relative paths [default: false]\",\nL29605:         ),\nL29606:         (\nL29607:             'owner=',\nL29608:             'u',\nL29609:             \"Owner name used when creating a tar file [default: current user]\",\nL29610:         ),\nL29611:         (\nL29612:             'group=',\nL29613:             'g',\nL29614:             \"Group name used when creating a tar file [default: current group]\",\nL29615:         ),\nL29616:     ]\nL29617: \nL29618:     boolean_options: ClassVar[list[str]] = ['keep-temp', 'skip-build', 'relative']\nL29619: \nL29620:     default_format = {'posix': 'gztar', 'nt': 'zip'}\nL29621: \nL29622:     def initialize_options(self):\nL29623:         self.bdist_dir = None\nL29624:         self.plat_name = None\nL29625:         self.format = None\nL29626:         self.keep_temp = False\nL29627:         self.dist_dir = None\nL29628:         self.skip_build = None\nL29629:         self.relative = False\nL29630:         self.owner = None\nL29631:         self.group = None\nL29632: \nL29633:     def finalize_options(self):\nL29634:         if self.bdist_dir is None:\nL29635:             bdist_base = self.get_finalized_command('bdist').bdist_base\nL29636:             self.bdist_dir = os.path.join(bdist_base, 'dumb')\nL29637: \nL29638:         if self.format is None:\nL29639:             try:\nL29640:                 self.format = self.default_format[os.name]\nL29641:             except KeyError:\nL29642:                 raise DistutilsPlatformError(\nL29643:                     \"don't know how to create dumb built distributions \"\nL29644:                     f\"on platform {os.name}\"\nL29645:                 )\nL29646: \nL29647:         self.set_undefined_options(\nL29648:             'bdist',\nL29649:             ('dist_dir', 'dist_dir'),\nL29650:             ('plat_name', 'plat_name'),\nL29651:             ('skip_build', 'skip_build'),\nL29652:         )\nL29653: \nL29654:     def run(self):\nL29655:         if not self.skip_build:\nL29656:             self.run_command('build')\nL29657: \nL29658:         install = self.reinitialize_command('install', reinit_subcommands=True)\nL29659:         install.root = self.bdist_dir\nL29660:         install.skip_build = self.skip_build\nL29661:         install.warn_dir = False\nL29662: \nL29663:         log.info(\"installing to %s\", self.bdist_dir)\nL29664:         self.run_command('install')\nL29665: \nL29666:         # And make an archive relative to the root of the\nL29667:         # pseudo-installation tree.\nL29668:         archive_basename = f\"{self.distribution.get_fullname()}.{self.plat_name}\"\nL29669: \nL29670:         pseudoinstall_root = os.path.join(self.dist_dir, archive_basename)\nL29671:         if not self.relative:\nL29672:             archive_root = self.bdist_dir\nL29673:         else:\nL29674:             if self.distribution.has_ext_modules() and (\nL29675:                 install.install_base != install.install_platbase\nL29676:             ):\nL29677:                 raise DistutilsPlatformError(\nL29678:                     \"can't make a dumb built distribution where \"\nL29679:                     f\"base and platbase are different ({install.install_base!r}, {install.install_platbase!r})\"\nL29680:                 )\nL29681:             else:\nL29682:                 archive_root = os.path.join(\nL29683:                     self.bdist_dir, ensure_relative(install.install_base)\nL29684:                 )\nL29685: \nL29686:         # Make the archive\nL29687:         filename = self.make_archive(\nL29688:             pseudoinstall_root,\nL29689:             self.format,\nL29690:             root_dir=archive_root,\nL29691:             owner=self.owner,\nL29692:             group=self.group,\nL29693:         )\nL29694:         if self.distribution.has_ext_modules():\nL29695:             pyversion = get_python_version()\nL29696:         else:\nL29697:             pyversion = 'any'\nL29698:         self.distribution.dist_files.append(('bdist_dumb', pyversion, filename))\nL29699: \nL29700:         if not self.keep_temp:\nL29701:             remove_tree(self.bdist_dir, dry_run=self.dry_run)\nL29702: \nL29703: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/bdist_rpm.py\nL29704: #!/usr/bin/env python3\nL29705: \"\"\"distutils.command.bdist_rpm\nL29706: \nL29707: Implements the Distutils 'bdist_rpm' command (create RPM source and binary\nL29708: distributions).\"\"\"\nL29709: \nL29710: import os\nL29711: import subprocess\nL29712: import sys\nL29713: from distutils._log import log\nL29714: from typing import ClassVar\nL29715: \nL29716: from ..core import Command\nL29717: from ..debug import DEBUG\nL29718: from ..errors import (\nL29719:     DistutilsExecError,\nL29720:     DistutilsFileError,\nL29721:     DistutilsOptionError,\nL29722:     DistutilsPlatformError,\nL29723: )\nL29724: from ..file_util import write_file\nL29725: from ..sysconfig import get_python_version\nL29726: \nL29727: \nL29728: class bdist_rpm(Command):\nL29729:     description = \"create an RPM distribution\"\nL29730: \nL29731:     user_options = [\nL29732:         ('bdist-base=', None, \"base directory for creating built distributions\"),\nL29733:         (\nL29734:             'rpm-base=',\nL29735:             None,\nL29736:             \"base directory for creating RPMs (defaults to \\\"rpm\\\" under \"\nL29737:             \"--bdist-base; must be specified for RPM 2)\",\nL29738:         ),\nL29739:         (\nL29740:             'dist-dir=',\nL29741:             'd',\nL29742:             \"directory to put final RPM files in (and .spec files if --spec-only)\",\nL29743:         ),\nL29744:         (\nL29745:             'python=',\nL29746:             None,\nL29747:             \"path to Python interpreter to hard-code in the .spec file \"\nL29748:             \"[default: \\\"python\\\"]\",\nL29749:         ),\nL29750:         (\nL29751:             'fix-python',\nL29752:             None,\nL29753:             \"hard-code the exact path to the current Python interpreter in \"\nL29754:             \"the .spec file\",\nL29755:         ),\nL29756:         ('spec-only', None, \"only regenerate spec file\"),\nL29757:         ('source-only', None, \"only generate source RPM\"),\nL29758:         ('binary-only', None, \"only generate binary RPM\"),\nL29759:         ('use-bzip2', None, \"use bzip2 instead of gzip to create source distribution\"),\nL29760:         # More meta-data: too RPM-specific to put in the setup script,\nL29761:         # but needs to go in the .spec file -- so we make these options\nL29762:         # to \"bdist_rpm\".  The idea is that packagers would put this\nL29763:         # info in setup.cfg, although they are of course free to\nL29764:         # supply it on the command line.\nL29765:         (\nL29766:             'distribution-name=',\nL29767:             None,\nL29768:             \"name of the (Linux) distribution to which this \"\nL29769:             \"RPM applies (*not* the name of the module distribution!)\",\nL29770:         ),\nL29771:         ('group=', None, \"package classification [default: \\\"Development/Libraries\\\"]\"),\nL29772:         ('release=', None, \"RPM release number\"),\nL29773:         ('serial=', None, \"RPM serial number\"),\nL29774:         (\nL29775:             'vendor=',\nL29776:             None,\nL29777:             \"RPM \\\"vendor\\\" (eg. \\\"Joe Blow <joe@example.com>\\\") \"\nL29778:             \"[default: maintainer or author from setup script]\",\nL29779:         ),\nL29780:         (\nL29781:             'packager=',\nL29782:             None,\nL29783:             \"RPM packager (eg. \\\"Jane Doe <jane@example.net>\\\") [default: vendor]\",\nL29784:         ),\nL29785:         ('doc-files=', None, \"list of documentation files (space or comma-separated)\"),\nL29786:         ('changelog=', None, \"RPM changelog\"),\nL29787:         ('icon=', None, \"name of icon file\"),\nL29788:         ('provides=', None, \"capabilities provided by this package\"),\nL29789:         ('requires=', None, \"capabilities required by this package\"),\nL29790:         ('conflicts=', None, \"capabilities which conflict with this package\"),\nL29791:         ('build-requires=', None, \"capabilities required to build this package\"),\nL29792:         ('obsoletes=', None, \"capabilities made obsolete by this package\"),\nL29793:         ('no-autoreq', None, \"do not automatically calculate dependencies\"),\nL29794:         # Actions to take when building RPM\nL29795:         ('keep-temp', 'k', \"don't clean up RPM build directory\"),\nL29796:         ('no-keep-temp', None, \"clean up RPM build directory [default]\"),\nL29797:         (\nL29798:             'use-rpm-opt-flags',\nL29799:             None,\nL29800:             \"compile with RPM_OPT_FLAGS when building from source RPM\",\nL29801:         ),\nL29802:         ('no-rpm-opt-flags', None, \"do not pass any RPM CFLAGS to compiler\"),\nL29803:         ('rpm3-mode', None, \"RPM 3 compatibility mode (default)\"),\nL29804:         ('rpm2-mode', None, \"RPM 2 compatibility mode\"),\nL29805:         # Add the hooks necessary for specifying custom scripts\nL29806:         ('prep-script=', None, \"Specify a script for the PREP phase of RPM building\"),\nL29807:         ('build-script=', None, \"Specify a script for the BUILD phase of RPM building\"),\nL29808:         (\nL29809:             'pre-install=',\nL29810:             None,\nL29811:             \"Specify a script for the pre-INSTALL phase of RPM building\",\nL29812:         ),\nL29813:         (\nL29814:             'install-script=',\nL29815:             None,\nL29816:             \"Specify a script for the INSTALL phase of RPM building\",\nL29817:         ),\nL29818:         (\nL29819:             'post-install=',\nL29820:             None,\nL29821:             \"Specify a script for the post-INSTALL phase of RPM building\",\nL29822:         ),\nL29823:         (\nL29824:             'pre-uninstall=',\nL29825:             None,\nL29826:             \"Specify a script for the pre-UNINSTALL phase of RPM building\",\nL29827:         ),\nL29828:         (\nL29829:             'post-uninstall=',\nL29830:             None,\nL29831:             \"Specify a script for the post-UNINSTALL phase of RPM building\",\nL29832:         ),\nL29833:         ('clean-script=', None, \"Specify a script for the CLEAN phase of RPM building\"),\nL29834:         (\nL29835:             'verify-script=',\nL29836:             None,\nL29837:             \"Specify a script for the VERIFY phase of the RPM build\",\nL29838:         ),\nL29839:         # Allow a packager to explicitly force an architecture\nL29840:         ('force-arch=', None, \"Force an architecture onto the RPM build process\"),\nL29841:         ('quiet', 'q', \"Run the INSTALL phase of RPM building in quiet mode\"),\nL29842:     ]\nL29843: \nL29844:     boolean_options: ClassVar[list[str]] = [\nL29845:         'keep-temp',\nL29846:         'use-rpm-opt-flags',\nL29847:         'rpm3-mode',\nL29848:         'no-autoreq',\nL29849:         'quiet',\nL29850:     ]\nL29851: \nL29852:     negative_opt: ClassVar[dict[str, str]] = {\nL29853:         'no-keep-temp': 'keep-temp',\nL29854:         'no-rpm-opt-flags': 'use-rpm-opt-flags',\nL29855:         'rpm2-mode': 'rpm3-mode',\nL29856:     }\nL29857: \nL29858:     def initialize_options(self):\nL29859:         self.bdist_base = None\nL29860:         self.rpm_base = None\nL29861:         self.dist_dir = None\nL29862:         self.python = None\nL29863:         self.fix_python = None\nL29864:         self.spec_only = None\nL29865:         self.binary_only = None\nL29866:         self.source_only = None\nL29867:         self.use_bzip2 = None\nL29868: \nL29869:         self.distribution_name = None\nL29870:         self.group = None\nL29871:         self.release = None\nL29872:         self.serial = None\nL29873:         self.vendor = None\nL29874:         self.packager = None\nL29875:         self.doc_files = None\nL29876:         self.changelog = None\nL29877:         self.icon = None\nL29878: \nL29879:         self.prep_script = None\nL29880:         self.build_script = None\nL29881:         self.install_script = None\nL29882:         self.clean_script = None\nL29883:         self.verify_script = None\nL29884:         self.pre_install = None\nL29885:         self.post_install = None\nL29886:         self.pre_uninstall = None\nL29887:         self.post_uninstall = None\nL29888:         self.prep = None\nL29889:         self.provides = None\nL29890:         self.requires = None\nL29891:         self.conflicts = None\nL29892:         self.build_requires = None\nL29893:         self.obsoletes = None\nL29894: \nL29895:         self.keep_temp = False\nL29896:         self.use_rpm_opt_flags = True\nL29897:         self.rpm3_mode = True\nL29898:         self.no_autoreq = False\nL29899: \nL29900:         self.force_arch = None\nL29901:         self.quiet = False\nL29902: \nL29903:     def finalize_options(self) -> None:\nL29904:         self.set_undefined_options('bdist', ('bdist_base', 'bdist_base'))\nL29905:         if self.rpm_base is None:\nL29906:             if not self.rpm3_mode:\nL29907:                 raise DistutilsOptionError(\"you must specify --rpm-base in RPM 2 mode\")\nL29908:             self.rpm_base = os.path.join(self.bdist_base, \"rpm\")\nL29909: \nL29910:         if self.python is None:\nL29911:             if self.fix_python:\nL29912:                 self.python = sys.executable\nL29913:             else:\nL29914:                 self.python = \"python3\"\nL29915:         elif self.fix_python:\nL29916:             raise DistutilsOptionError(\nL29917:                 \"--python and --fix-python are mutually exclusive options\"\nL29918:             )\nL29919: \nL29920:         if os.name != 'posix':\nL29921:             raise DistutilsPlatformError(\nL29922:                 f\"don't know how to create RPM distributions on platform {os.name}\"\nL29923:             )\nL29924:         if self.binary_only and self.source_only:\nL29925:             raise DistutilsOptionError(\nL29926:                 \"cannot supply both '--source-only' and '--binary-only'\"\nL29927:             )\nL29928: \nL29929:         # don't pass CFLAGS to pure python distributions\nL29930:         if not self.distribution.has_ext_modules():\nL29931:             self.use_rpm_opt_flags = False\nL29932: \nL29933:         self.set_undefined_options('bdist', ('dist_dir', 'dist_dir'))\nL29934:         self.finalize_package_data()\nL29935: \nL29936:     def finalize_package_data(self) -> None:\nL29937:         self.ensure_string('group', \"Development/Libraries\")\nL29938:         self.ensure_string(\nL29939:             'vendor',\nL29940:             f\"{self.distribution.get_contact()} <{self.distribution.get_contact_email()}>\",\nL29941:         )\nL29942:         self.ensure_string('packager')\nL29943:         self.ensure_string_list('doc_files')\nL29944:         if isinstance(self.doc_files, list):\nL29945:             for readme in ('README', 'README.txt'):\nL29946:                 if os.path.exists(readme) and readme not in self.doc_files:\nL29947:                     self.doc_files.append(readme)\nL29948: \nL29949:         self.ensure_string('release', \"1\")\nL29950:         self.ensure_string('serial')  # should it be an int?\nL29951: \nL29952:         self.ensure_string('distribution_name')\nL29953: \nL29954:         self.ensure_string('changelog')\nL29955:         # Format changelog correctly\nL29956:         self.changelog = self._format_changelog(self.changelog)\nL29957: \nL29958:         self.ensure_filename('icon')\nL29959: \nL29960:         self.ensure_filename('prep_script')\nL29961:         self.ensure_filename('build_script')\nL29962:         self.ensure_filename('install_script')\nL29963:         self.ensure_filename('clean_script')\nL29964:         self.ensure_filename('verify_script')\nL29965:         self.ensure_filename('pre_install')\nL29966:         self.ensure_filename('post_install')\nL29967:         self.ensure_filename('pre_uninstall')\nL29968:         self.ensure_filename('post_uninstall')\nL29969: \nL29970:         # XXX don't forget we punted on summaries and descriptions -- they\nL29971:         # should be handled here eventually!\nL29972: \nL29973:         # Now *this* is some meta-data that belongs in the setup script...\nL29974:         self.ensure_string_list('provides')\nL29975:         self.ensure_string_list('requires')\nL29976:         self.ensure_string_list('conflicts')\nL29977:         self.ensure_string_list('build_requires')\nL29978:         self.ensure_string_list('obsoletes')\nL29979: \nL29980:         self.ensure_string('force_arch')\nL29981: \nL29982:     def run(self) -> None:  # noqa: C901\nL29983:         if DEBUG:\nL29984:             print(\"before _get_package_data():\")\nL29985:             print(\"vendor =\", self.vendor)\nL29986:             print(\"packager =\", self.packager)\nL29987:             print(\"doc_files =\", self.doc_files)\nL29988:             print(\"changelog =\", self.changelog)\nL29989: \nL29990:         # make directories\nL29991:         if self.spec_only:\nL29992:             spec_dir = self.dist_dir\nL29993:             self.mkpath(spec_dir)\nL29994:         else:\nL29995:             rpm_dir = {}\nL29996:             for d in ('SOURCES', 'SPECS', 'BUILD', 'RPMS', 'SRPMS'):\nL29997:                 rpm_dir[d] = os.path.join(self.rpm_base, d)\nL29998:                 self.mkpath(rpm_dir[d])\nL29999:             spec_dir = rpm_dir['SPECS']\nL30000: \nL30001:         # Spec file goes into 'dist_dir' if '--spec-only specified',\nL30002:         # build/rpm.<plat> otherwise.\nL30003:         spec_path = os.path.join(spec_dir, f\"{self.distribution.get_name()}.spec\")\nL30004:         self.execute(\nL30005:             write_file, (spec_path, self._make_spec_file()), f\"writing '{spec_path}'\"\nL30006:         )\nL30007: \nL30008:         if self.spec_only:  # stop if requested\nL30009:             return\nL30010: \nL30011:         # Make a source distribution and copy to SOURCES directory with\nL30012:         # optional icon.\nL30013:         saved_dist_files = self.distribution.dist_files[:]\nL30014:         sdist = self.reinitialize_command('sdist')\nL30015:         if self.use_bzip2:\nL30016:             sdist.formats = ['bztar']\nL30017:         else:\nL30018:             sdist.formats = ['gztar']\nL30019:         self.run_command('sdist')\nL30020:         self.distribution.dist_files = saved_dist_files\nL30021: \nL30022:         source = sdist.get_archive_files()[0]\nL30023:         source_dir = rpm_dir['SOURCES']\nL30024:         self.copy_file(source, source_dir)\nL30025: \nL30026:         if self.icon:\nL30027:             if os.path.exists(self.icon):\nL30028:                 self.copy_file(self.icon, source_dir)\nL30029:             else:\nL30030:                 raise DistutilsFileError(f\"icon file '{self.icon}' does not exist\")\nL30031: \nL30032:         # build package\nL30033:         log.info(\"building RPMs\")\nL30034:         rpm_cmd = ['rpmbuild']\nL30035: \nL30036:         if self.source_only:  # what kind of RPMs?\nL30037:             rpm_cmd.append('-bs')\nL30038:         elif self.binary_only:\nL30039:             rpm_cmd.append('-bb')\nL30040:         else:\nL30041:             rpm_cmd.append('-ba')\nL30042:         rpm_cmd.extend(['--define', f'__python {self.python}'])\nL30043:         if self.rpm3_mode:\nL30044:             rpm_cmd.extend(['--define', f'_topdir {os.path.abspath(self.rpm_base)}'])\nL30045:         if not self.keep_temp:\nL30046:             rpm_cmd.append('--clean')\nL30047: \nL30048:         if self.quiet:\nL30049:             rpm_cmd.append('--quiet')\nL30050: \nL30051:         rpm_cmd.append(spec_path)\nL30052:         # Determine the binary rpm names that should be built out of this spec\nL30053:         # file\nL30054:         # Note that some of these may not be really built (if the file\nL30055:         # list is empty)\nL30056:         nvr_string = \"%{name}-%{version}-%{release}\"\nL30057:         src_rpm = nvr_string + \".src.rpm\"\nL30058:         non_src_rpm = \"%{arch}/\" + nvr_string + \".%{arch}.rpm\"\nL30059:         q_cmd = rf\"rpm -q --qf '{src_rpm} {non_src_rpm}\\n' --specfile '{spec_path}'\"\nL30060: \nL30061:         out = os.popen(q_cmd)\nL30062:         try:\nL30063:             binary_rpms = []\nL30064:             source_rpm = None\nL30065:             while True:\nL30066:                 line = out.readline()\nL30067:                 if not line:\nL30068:                     break\nL30069:                 ell = line.strip().split()\nL30070:                 assert len(ell) == 2\nL30071:                 binary_rpms.append(ell[1])\nL30072:                 # The source rpm is named after the first entry in the spec file\nL30073:                 if source_rpm is None:\nL30074:                     source_rpm = ell[0]\nL30075: \nL30076:             status = out.close()\nL30077:             if status:\nL30078:                 raise DistutilsExecError(f\"Failed to execute: {q_cmd!r}\")\nL30079: \nL30080:         finally:\nL30081:             out.close()\nL30082: \nL30083:         self.spawn(rpm_cmd)\nL30084: \nL30085:         if not self.dry_run:\nL30086:             if self.distribution.has_ext_modules():\nL30087:                 pyversion = get_python_version()\nL30088:             else:\nL30089:                 pyversion = 'any'\nL30090: \nL30091:             if not self.binary_only:\nL30092:                 srpm = os.path.join(rpm_dir['SRPMS'], source_rpm)\nL30093:                 assert os.path.exists(srpm)\nL30094:                 self.move_file(srpm, self.dist_dir)\nL30095:                 filename = os.path.join(self.dist_dir, source_rpm)\nL30096:                 self.distribution.dist_files.append(('bdist_rpm', pyversion, filename))\nL30097: \nL30098:             if not self.source_only:\nL30099:                 for rpm in binary_rpms:\nL30100:                     rpm = os.path.join(rpm_dir['RPMS'], rpm)\nL30101:                     if os.path.exists(rpm):\nL30102:                         self.move_file(rpm, self.dist_dir)\nL30103:                         filename = os.path.join(self.dist_dir, os.path.basename(rpm))\nL30104:                         self.distribution.dist_files.append((\nL30105:                             'bdist_rpm',\nL30106:                             pyversion,\nL30107:                             filename,\nL30108:                         ))\nL30109: \nL30110:     def _dist_path(self, path):\nL30111:         return os.path.join(self.dist_dir, os.path.basename(path))\nL30112: \nL30113:     def _make_spec_file(self):  # noqa: C901\nL30114:         \"\"\"Generate the text of an RPM spec file and return it as a\nL30115:         list of strings (one per line).\nL30116:         \"\"\"\nL30117:         # definitions and headers\nL30118:         spec_file = [\nL30119:             '%define name ' + self.distribution.get_name(),\nL30120:             '%define version ' + self.distribution.get_version().replace('-', '_'),\nL30121:             '%define unmangled_version ' + self.distribution.get_version(),\nL30122:             '%define release ' + self.release.replace('-', '_'),\nL30123:             '',\nL30124:             'Summary: ' + (self.distribution.get_description() or \"UNKNOWN\"),\nL30125:         ]\nL30126: \nL30127:         # Workaround for #14443 which affects some RPM based systems such as\nL30128:         # RHEL6 (and probably derivatives)\nL30129:         vendor_hook = subprocess.getoutput('rpm --eval %{__os_install_post}')\nL30130:         # Generate a potential replacement value for __os_install_post (whilst\nL30131:         # normalizing the whitespace to simplify the test for whether the\nL30132:         # invocation of brp-python-bytecompile passes in __python):\nL30133:         vendor_hook = '\\n'.join([\nL30134:             f'  {line.strip()} \\\\' for line in vendor_hook.splitlines()\nL30135:         ])\nL30136:         problem = \"brp-python-bytecompile \\\\\\n\"\nL30137:         fixed = \"brp-python-bytecompile %{__python} \\\\\\n\"\nL30138:         fixed_hook = vendor_hook.replace(problem, fixed)\nL30139:         if fixed_hook != vendor_hook:\nL30140:             spec_file.append('# Workaround for https://bugs.python.org/issue14443')\nL30141:             spec_file.append('%define __os_install_post ' + fixed_hook + '\\n')\nL30142: \nL30143:         # put locale summaries into spec file\nL30144:         # XXX not supported for now (hard to put a dictionary\nL30145:         # in a config file -- arg!)\nL30146:         # for locale in self.summaries.keys():\nL30147:         #    spec_file.append('Summary(%s): %s' % (locale,\nL30148:         #                                          self.summaries[locale]))\nL30149: \nL30150:         spec_file.extend([\nL30151:             'Name: %{name}',\nL30152:             'Version: %{version}',\nL30153:             'Release: %{release}',\nL30154:         ])\nL30155: \nL30156:         # XXX yuck! this filename is available from the \"sdist\" command,\nL30157:         # but only after it has run: and we create the spec file before\nL30158:         # running \"sdist\", in case of --spec-only.\nL30159:         if self.use_bzip2:\nL30160:             spec_file.append('Source0: %{name}-%{unmangled_version}.tar.bz2')\nL30161:         else:\nL30162:             spec_file.append('Source0: %{name}-%{unmangled_version}.tar.gz')\nL30163: \nL30164:         spec_file.extend([\nL30165:             'License: ' + (self.distribution.get_license() or \"UNKNOWN\"),\nL30166:             'Group: ' + self.group,\nL30167:             'BuildRoot: %{_tmppath}/%{name}-%{version}-%{release}-buildroot',\nL30168:             'Prefix: %{_prefix}',\nL30169:         ])\nL30170: \nL30171:         if not self.force_arch:\nL30172:             # noarch if no extension modules\nL30173:             if not self.distribution.has_ext_modules():\nL30174:                 spec_file.append('BuildArch: noarch')\nL30175:         else:\nL30176:             spec_file.append(f'BuildArch: {self.force_arch}')\nL30177: \nL30178:         for field in (\nL30179:             'Vendor',\nL30180:             'Packager',\nL30181:             'Provides',\nL30182:             'Requires',\nL30183:             'Conflicts',\nL30184:             'Obsoletes',\nL30185:         ):\nL30186:             val = getattr(self, field.lower())\nL30187:             if isinstance(val, list):\nL30188:                 spec_file.append('{}: {}'.format(field, ' '.join(val)))\nL30189:             elif val is not None:\nL30190:                 spec_file.append(f'{field}: {val}')\nL30191: \nL30192:         if self.distribution.get_url():\nL30193:             spec_file.append('Url: ' + self.distribution.get_url())\nL30194: \nL30195:         if self.distribution_name:\nL30196:             spec_file.append('Distribution: ' + self.distribution_name)\nL30197: \nL30198:         if self.build_requires:\nL30199:             spec_file.append('BuildRequires: ' + ' '.join(self.build_requires))\nL30200: \nL30201:         if self.icon:\nL30202:             spec_file.append('Icon: ' + os.path.basename(self.icon))\nL30203: \nL30204:         if self.no_autoreq:\nL30205:             spec_file.append('AutoReq: 0')\nL30206: \nL30207:         spec_file.extend([\nL30208:             '',\nL30209:             '%description',\nL30210:             self.distribution.get_long_description() or \"\",\nL30211:         ])\nL30212: \nL30213:         # put locale descriptions into spec file\nL30214:         # XXX again, suppressed because config file syntax doesn't\nL30215:         # easily support this ;-(\nL30216:         # for locale in self.descriptions.keys():\nL30217:         #    spec_file.extend([\nL30218:         #        '',\nL30219:         #        '%description -l ' + locale,\nL30220:         #        self.descriptions[locale],\nL30221:         #        ])\nL30222: \nL30223:         # rpm scripts\nL30224:         # figure out default build script\nL30225:         def_setup_call = f\"{self.python} {os.path.basename(sys.argv[0])}\"\nL30226:         def_build = f\"{def_setup_call} build\"\nL30227:         if self.use_rpm_opt_flags:\nL30228:             def_build = 'env CFLAGS=\"$RPM_OPT_FLAGS\" ' + def_build\nL30229: \nL30230:         # insert contents of files\nL30231: \nL30232:         # XXX this is kind of misleading: user-supplied options are files\nL30233:         # that we open and interpolate into the spec file, but the defaults\nL30234:         # are just text that we drop in as-is.  Hmmm.\nL30235: \nL30236:         install_cmd = f'{def_setup_call} install -O1 --root=$RPM_BUILD_ROOT --record=INSTALLED_FILES'\nL30237: \nL30238:         script_options = [\nL30239:             ('prep', 'prep_script', \"%setup -n %{name}-%{unmangled_version}\"),\nL30240:             ('build', 'build_script', def_build),\nL30241:             ('install', 'install_script', install_cmd),\nL30242:             ('clean', 'clean_script', \"rm -rf $RPM_BUILD_ROOT\"),\nL30243:             ('verifyscript', 'verify_script', None),\nL30244:             ('pre', 'pre_install', None),\nL30245:             ('post', 'post_install', None),\nL30246:             ('preun', 'pre_uninstall', None),\nL30247:             ('postun', 'post_uninstall', None),\nL30248:         ]\nL30249: \nL30250:         for rpm_opt, attr, default in script_options:\nL30251:             # Insert contents of file referred to, if no file is referred to\nL30252:             # use 'default' as contents of script\nL30253:             val = getattr(self, attr)\nL30254:             if val or default:\nL30255:                 spec_file.extend([\nL30256:                     '',\nL30257:                     '%' + rpm_opt,\nL30258:                 ])\nL30259:                 if val:\nL30260:                     with open(val) as f:\nL30261:                         spec_file.extend(f.read().split('\\n'))\nL30262:                 else:\nL30263:                     spec_file.append(default)\nL30264: \nL30265:         # files section\nL30266:         spec_file.extend([\nL30267:             '',\nL30268:             '%files -f INSTALLED_FILES',\nL30269:             '%defattr(-,root,root)',\nL30270:         ])\nL30271: \nL30272:         if self.doc_files:\nL30273:             spec_file.append('%doc ' + ' '.join(self.doc_files))\nL30274: \nL30275:         if self.changelog:\nL30276:             spec_file.extend([\nL30277:                 '',\nL30278:                 '%changelog',\nL30279:             ])\nL30280:             spec_file.extend(self.changelog)\nL30281: \nL30282:         return spec_file\nL30283: \nL30284:     def _format_changelog(self, changelog):\nL30285:         \"\"\"Format the changelog correctly and convert it to a list of strings\"\"\"\nL30286:         if not changelog:\nL30287:             return changelog\nL30288:         new_changelog = []\nL30289:         for line in changelog.strip().split('\\n'):\nL30290:             line = line.strip()\nL30291:             if line[0] == '*':\nL30292:                 new_changelog.extend(['', line])\nL30293:             elif line[0] == '-':\nL30294:                 new_changelog.append(line)\nL30295:             else:\nL30296:                 new_changelog.append('  ' + line)\nL30297: \nL30298:         # strip trailing newline inserted by first changelog entry\nL30299:         if not new_changelog[0]:\nL30300:             del new_changelog[0]\nL30301: \nL30302:         return new_changelog\nL30303: \nL30304: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/build.py\nL30305: #!/usr/bin/env python3\nL30306: \"\"\"distutils.command.build\nL30307: \nL30308: Implements the Distutils 'build' command.\"\"\"\nL30309: \nL30310: from __future__ import annotations\nL30311: \nL30312: import os\nL30313: import sys\nL30314: import sysconfig\nL30315: from collections.abc import Callable\nL30316: from typing import ClassVar\nL30317: \nL30318: from ..ccompiler import show_compilers\nL30319: from ..core import Command\nL30320: from ..errors import DistutilsOptionError\nL30321: from ..util import get_platform\nL30322: \nL30323: \nL30324: class build(Command):\nL30325:     description = \"build everything needed to install\"\nL30326: \nL30327:     user_options = [\nL30328:         ('build-base=', 'b', \"base directory for build library\"),\nL30329:         ('build-purelib=', None, \"build directory for platform-neutral distributions\"),\nL30330:         ('build-platlib=', None, \"build directory for platform-specific distributions\"),\nL30331:         (\nL30332:             'build-lib=',\nL30333:             None,\nL30334:             \"build directory for all distribution (defaults to either build-purelib or build-platlib\",\nL30335:         ),\nL30336:         ('build-scripts=', None, \"build directory for scripts\"),\nL30337:         ('build-temp=', 't', \"temporary build directory\"),\nL30338:         (\nL30339:             'plat-name=',\nL30340:             'p',\nL30341:             f\"platform name to build for, if supported [default: {get_platform()}]\",\nL30342:         ),\nL30343:         ('compiler=', 'c', \"specify the compiler type\"),\nL30344:         ('parallel=', 'j', \"number of parallel build jobs\"),\nL30345:         ('debug', 'g', \"compile extensions and libraries with debugging information\"),\nL30346:         ('force', 'f', \"forcibly build everything (ignore file timestamps)\"),\nL30347:         ('executable=', 'e', \"specify final destination interpreter path (build.py)\"),\nL30348:     ]\nL30349: \nL30350:     boolean_options: ClassVar[list[str]] = ['debug', 'force']\nL30351: \nL30352:     help_options: ClassVar[list[tuple[str, str | None, str, Callable[[], object]]]] = [\nL30353:         ('help-compiler', None, \"list available compilers\", show_compilers),\nL30354:     ]\nL30355: \nL30356:     def initialize_options(self):\nL30357:         self.build_base = 'build'\nL30358:         # these are decided only after 'build_base' has its final value\nL30359:         # (unless overridden by the user or client)\nL30360:         self.build_purelib = None\nL30361:         self.build_platlib = None\nL30362:         self.build_lib = None\nL30363:         self.build_temp = None\nL30364:         self.build_scripts = None\nL30365:         self.compiler = None\nL30366:         self.plat_name = None\nL30367:         self.debug = None\nL30368:         self.force = False\nL30369:         self.executable = None\nL30370:         self.parallel = None\nL30371: \nL30372:     def finalize_options(self) -> None:  # noqa: C901\nL30373:         if self.plat_name is None:\nL30374:             self.plat_name = get_platform()\nL30375:         else:\nL30376:             # plat-name only supported for windows (other platforms are\nL30377:             # supported via ./configure flags, if at all).  Avoid misleading\nL30378:             # other platforms.\nL30379:             if os.name != 'nt':\nL30380:                 raise DistutilsOptionError(\nL30381:                     \"--plat-name only supported on Windows (try \"\nL30382:                     \"using './configure --help' on your platform)\"\nL30383:                 )\nL30384: \nL30385:         plat_specifier = f\".{self.plat_name}-{sys.implementation.cache_tag}\"\nL30386: \nL30387:         # Python 3.13+ with --disable-gil shouldn't share build directories\nL30388:         if sysconfig.get_config_var('Py_GIL_DISABLED'):\nL30389:             plat_specifier += 't'\nL30390: \nL30391:         # Make it so Python 2.x and Python 2.x with --with-pydebug don't\nL30392:         # share the same build directories. Doing so confuses the build\nL30393:         # process for C modules\nL30394:         if hasattr(sys, 'gettotalrefcount'):\nL30395:             plat_specifier += '-pydebug'\nL30396: \nL30397:         # 'build_purelib' and 'build_platlib' just default to 'lib' and\nL30398:         # 'lib.<plat>' under the base build directory.  We only use one of\nL30399:         # them for a given distribution, though --\nL30400:         if self.build_purelib is None:\nL30401:             self.build_purelib = os.path.join(self.build_base, 'lib')\nL30402:         if self.build_platlib is None:\nL30403:             self.build_platlib = os.path.join(self.build_base, 'lib' + plat_specifier)\nL30404: \nL30405:         # 'build_lib' is the actual directory that we will use for this\nL30406:         # particular module distribution -- if user didn't supply it, pick\nL30407:         # one of 'build_purelib' or 'build_platlib'.\nL30408:         if self.build_lib is None:\nL30409:             if self.distribution.has_ext_modules():\nL30410:                 self.build_lib = self.build_platlib\nL30411:             else:\nL30412:                 self.build_lib = self.build_purelib\nL30413: \nL30414:         # 'build_temp' -- temporary directory for compiler turds,\nL30415:         # \"build/temp.<plat>\"\nL30416:         if self.build_temp is None:\nL30417:             self.build_temp = os.path.join(self.build_base, 'temp' + plat_specifier)\nL30418:         if self.build_scripts is None:\nL30419:             self.build_scripts = os.path.join(\nL30420:                 self.build_base,\nL30421:                 f'scripts-{sys.version_info.major}.{sys.version_info.minor}',\nL30422:             )\nL30423: \nL30424:         if self.executable is None and sys.executable:\nL30425:             self.executable = os.path.normpath(sys.executable)\nL30426: \nL30427:         if isinstance(self.parallel, str):\nL30428:             try:\nL30429:                 self.parallel = int(self.parallel)\nL30430:             except ValueError:\nL30431:                 raise DistutilsOptionError(\"parallel should be an integer\")\nL30432: \nL30433:     def run(self) -> None:\nL30434:         # Run all relevant sub-commands.  This will be some subset of:\nL30435:         #  - build_py      - pure Python modules\nL30436:         #  - build_clib    - standalone C libraries\nL30437:         #  - build_ext     - Python extensions\nL30438:         #  - build_scripts - (Python) scripts\nL30439:         for cmd_name in self.get_sub_commands():\nL30440:             self.run_command(cmd_name)\nL30441: \nL30442:     # -- Predicates for the sub-command list ---------------------------\nL30443: \nL30444:     def has_pure_modules(self):\nL30445:         return self.distribution.has_pure_modules()\nL30446: \nL30447:     def has_c_libraries(self):\nL30448:         return self.distribution.has_c_libraries()\nL30449: \nL30450:     def has_ext_modules(self):\nL30451:         return self.distribution.has_ext_modules()\nL30452: \nL30453:     def has_scripts(self):\nL30454:         return self.distribution.has_scripts()\nL30455: \nL30456:     sub_commands = [\nL30457:         ('build_py', has_pure_modules),\nL30458:         ('build_clib', has_c_libraries),\nL30459:         ('build_ext', has_ext_modules),\nL30460:         ('build_scripts', has_scripts),\nL30461:     ]\nL30462: \nL30463: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/build_clib.py\nL30464: #!/usr/bin/env python3\nL30465: \"\"\"distutils.command.build_clib\nL30466: \nL30467: Implements the Distutils 'build_clib' command, to build a C/C++ library\nL30468: that is included in the module distribution and needed by an extension\nL30469: module.\"\"\"\nL30470: \nL30471: # XXX this module has *lots* of code ripped-off quite transparently from\nL30472: # build_ext.py -- not surprisingly really, as the work required to build\nL30473: # a static library from a collection of C source files is not really all\nL30474: # that different from what's required to build a shared object file from\nL30475: # a collection of C source files.  Nevertheless, I haven't done the\nL30476: # necessary refactoring to account for the overlap in code between the\nL30477: # two modules, mainly because a number of subtle details changed in the\nL30478: # cut 'n paste.  Sigh.\nL30479: from __future__ import annotations\nL30480: \nL30481: import os\nL30482: from collections.abc import Callable\nL30483: from distutils._log import log\nL30484: from typing import ClassVar\nL30485: \nL30486: from ..ccompiler import new_compiler, show_compilers\nL30487: from ..core import Command\nL30488: from ..errors import DistutilsSetupError\nL30489: from ..sysconfig import customize_compiler\nL30490: \nL30491: \nL30492: class build_clib(Command):\nL30493:     description = \"build C/C++ libraries used by Python extensions\"\nL30494: \nL30495:     user_options: ClassVar[list[tuple[str, str, str]]] = [\nL30496:         ('build-clib=', 'b', \"directory to build C/C++ libraries to\"),\nL30497:         ('build-temp=', 't', \"directory to put temporary build by-products\"),\nL30498:         ('debug', 'g', \"compile with debugging information\"),\nL30499:         ('force', 'f', \"forcibly build everything (ignore file timestamps)\"),\nL30500:         ('compiler=', 'c', \"specify the compiler type\"),\nL30501:     ]\nL30502: \nL30503:     boolean_options: ClassVar[list[str]] = ['debug', 'force']\nL30504: \nL30505:     help_options: ClassVar[list[tuple[str, str | None, str, Callable[[], object]]]] = [\nL30506:         ('help-compiler', None, \"list available compilers\", show_compilers),\nL30507:     ]\nL30508: \nL30509:     def initialize_options(self):\nL30510:         self.build_clib = None\nL30511:         self.build_temp = None\nL30512: \nL30513:         # List of libraries to build\nL30514:         self.libraries = None\nL30515: \nL30516:         # Compilation options for all libraries\nL30517:         self.include_dirs = None\nL30518:         self.define = None\nL30519:         self.undef = None\nL30520:         self.debug = None\nL30521:         self.force = False\nL30522:         self.compiler = None\nL30523: \nL30524:     def finalize_options(self) -> None:\nL30525:         # This might be confusing: both build-clib and build-temp default\nL30526:         # to build-temp as defined by the \"build\" command.  This is because\nL30527:         # I think that C libraries are really just temporary build\nL30528:         # by-products, at least from the point of view of building Python\nL30529:         # extensions -- but I want to keep my options open.\nL30530:         self.set_undefined_options(\nL30531:             'build',\nL30532:             ('build_temp', 'build_clib'),\nL30533:             ('build_temp', 'build_temp'),\nL30534:             ('compiler', 'compiler'),\nL30535:             ('debug', 'debug'),\nL30536:             ('force', 'force'),\nL30537:         )\nL30538: \nL30539:         self.libraries = self.distribution.libraries\nL30540:         if self.libraries:\nL30541:             self.check_library_list(self.libraries)\nL30542: \nL30543:         if self.include_dirs is None:\nL30544:             self.include_dirs = self.distribution.include_dirs or []\nL30545:         if isinstance(self.include_dirs, str):\nL30546:             self.include_dirs = self.include_dirs.split(os.pathsep)\nL30547: \nL30548:         # XXX same as for build_ext -- what about 'self.define' and\nL30549:         # 'self.undef' ?\nL30550: \nL30551:     def run(self) -> None:\nL30552:         if not self.libraries:\nL30553:             return\nL30554: \nL30555:         self.compiler = new_compiler(\nL30556:             compiler=self.compiler, dry_run=self.dry_run, force=self.force\nL30557:         )\nL30558:         customize_compiler(self.compiler)\nL30559: \nL30560:         if self.include_dirs is not None:\nL30561:             self.compiler.set_include_dirs(self.include_dirs)\nL30562:         if self.define is not None:\nL30563:             # 'define' option is a list of (name,value) tuples\nL30564:             for name, value in self.define:\nL30565:                 self.compiler.define_macro(name, value)\nL30566:         if self.undef is not None:\nL30567:             for macro in self.undef:\nL30568:                 self.compiler.undefine_macro(macro)\nL30569: \nL30570:         self.build_libraries(self.libraries)\nL30571: \nL30572:     def check_library_list(self, libraries) -> None:\nL30573:         \"\"\"Ensure that the list of libraries is valid.\nL30574: \nL30575:         `library` is presumably provided as a command option 'libraries'.\nL30576:         This method checks that it is a list of 2-tuples, where the tuples\nL30577:         are (library_name, build_info_dict).\nL30578: \nL30579:         Raise DistutilsSetupError if the structure is invalid anywhere;\nL30580:         just returns otherwise.\nL30581:         \"\"\"\nL30582:         if not isinstance(libraries, list):\nL30583:             raise DistutilsSetupError(\"'libraries' option must be a list of tuples\")\nL30584: \nL30585:         for lib in libraries:\nL30586:             if not isinstance(lib, tuple) and len(lib) != 2:\nL30587:                 raise DistutilsSetupError(\"each element of 'libraries' must a 2-tuple\")\nL30588: \nL30589:             name, build_info = lib\nL30590: \nL30591:             if not isinstance(name, str):\nL30592:                 raise DistutilsSetupError(\nL30593:                     \"first element of each tuple in 'libraries' \"\nL30594:                     \"must be a string (the library name)\"\nL30595:                 )\nL30596: \nL30597:             if '/' in name or (os.sep != '/' and os.sep in name):\nL30598:                 raise DistutilsSetupError(\nL30599:                     f\"bad library name '{lib[0]}': may not contain directory separators\"\nL30600:                 )\nL30601: \nL30602:             if not isinstance(build_info, dict):\nL30603:                 raise DistutilsSetupError(\nL30604:                     \"second element of each tuple in 'libraries' \"\nL30605:                     \"must be a dictionary (build info)\"\nL30606:                 )\nL30607: \nL30608:     def get_library_names(self):\nL30609:         # Assume the library list is valid -- 'check_library_list()' is\nL30610:         # called from 'finalize_options()', so it should be!\nL30611:         if not self.libraries:\nL30612:             return None\nL30613: \nL30614:         lib_names = []\nL30615:         for lib_name, _build_info in self.libraries:\nL30616:             lib_names.append(lib_name)\nL30617:         return lib_names\nL30618: \nL30619:     def get_source_files(self):\nL30620:         self.check_library_list(self.libraries)\nL30621:         filenames = []\nL30622:         for lib_name, build_info in self.libraries:\nL30623:             sources = build_info.get('sources')\nL30624:             if sources is None or not isinstance(sources, (list, tuple)):\nL30625:                 raise DistutilsSetupError(\nL30626:                     f\"in 'libraries' option (library '{lib_name}'), \"\nL30627:                     \"'sources' must be present and must be \"\nL30628:                     \"a list of source filenames\"\nL30629:                 )\nL30630: \nL30631:             filenames.extend(sources)\nL30632:         return filenames\nL30633: \nL30634:     def build_libraries(self, libraries) -> None:\nL30635:         for lib_name, build_info in libraries:\nL30636:             sources = build_info.get('sources')\nL30637:             if sources is None or not isinstance(sources, (list, tuple)):\nL30638:                 raise DistutilsSetupError(\nL30639:                     f\"in 'libraries' option (library '{lib_name}'), \"\nL30640:                     \"'sources' must be present and must be \"\nL30641:                     \"a list of source filenames\"\nL30642:                 )\nL30643:             sources = list(sources)\nL30644: \nL30645:             log.info(\"building '%s' library\", lib_name)\nL30646: \nL30647:             # First, compile the source code to object files in the library\nL30648:             # directory.  (This should probably change to putting object\nL30649:             # files in a temporary build directory.)\nL30650:             macros = build_info.get('macros')\nL30651:             include_dirs = build_info.get('include_dirs')\nL30652:             objects = self.compiler.compile(\nL30653:                 sources,\nL30654:                 output_dir=self.build_temp,\nL30655:                 macros=macros,\nL30656:                 include_dirs=include_dirs,\nL30657:                 debug=self.debug,\nL30658:             )\nL30659: \nL30660:             # Now \"link\" the object files together into a static library.\nL30661:             # (On Unix at least, this isn't really linking -- it just\nL30662:             # builds an archive.  Whatever.)\nL30663:             self.compiler.create_static_lib(\nL30664:                 objects, lib_name, output_dir=self.build_clib, debug=self.debug\nL30665:             )\nL30666: \nL30667: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/build_ext.py\nL30668: #!/usr/bin/env python3\nL30669: \"\"\"distutils.command.build_ext\nL30670: \nL30671: Implements the Distutils 'build_ext' command, for building extension\nL30672: modules (currently limited to C extensions, should accommodate C++\nL30673: extensions ASAP).\"\"\"\nL30674: \nL30675: from __future__ import annotations\nL30676: \nL30677: import contextlib\nL30678: import os\nL30679: import re\nL30680: import sys\nL30681: from collections.abc import Callable\nL30682: from distutils._log import log\nL30683: from site import USER_BASE\nL30684: from typing import ClassVar\nL30685: \nL30686: from .._modified import newer_group\nL30687: from ..ccompiler import new_compiler, show_compilers\nL30688: from ..core import Command\nL30689: from ..errors import (\nL30690:     CCompilerError,\nL30691:     CompileError,\nL30692:     DistutilsError,\nL30693:     DistutilsOptionError,\nL30694:     DistutilsPlatformError,\nL30695:     DistutilsSetupError,\nL30696: )\nL30697: from ..extension import Extension\nL30698: from ..sysconfig import customize_compiler, get_config_h_filename, get_python_version\nL30699: from ..util import get_platform, is_freethreaded, is_mingw\nL30700: \nL30701: # An extension name is just a dot-separated list of Python NAMEs (ie.\nL30702: # the same as a fully-qualified module name).\nL30703: extension_name_re = re.compile(r'^[a-zA-Z_][a-zA-Z_0-9]*(\\.[a-zA-Z_][a-zA-Z_0-9]*)*$')\nL30704: \nL30705: \nL30706: class build_ext(Command):\nL30707:     description = \"build C/C++ extensions (compile/link to build directory)\"\nL30708: \nL30709:     # XXX thoughts on how to deal with complex command-line options like\nL30710:     # these, i.e. how to make it so fancy_getopt can suck them off the\nL30711:     # command line and make it look like setup.py defined the appropriate\nL30712:     # lists of tuples of what-have-you.\nL30713:     #   - each command needs a callback to process its command-line options\nL30714:     #   - Command.__init__() needs access to its share of the whole\nL30715:     #     command line (must ultimately come from\nL30716:     #     Distribution.parse_command_line())\nL30717:     #   - it then calls the current command class' option-parsing\nL30718:     #     callback to deal with weird options like -D, which have to\nL30719:     #     parse the option text and churn out some custom data\nL30720:     #     structure\nL30721:     #   - that data structure (in this case, a list of 2-tuples)\nL30722:     #     will then be present in the command object by the time\nL30723:     #     we get to finalize_options() (i.e. the constructor\nL30724:     #     takes care of both command-line and client options\nL30725:     #     in between initialize_options() and finalize_options())\nL30726: \nL30727:     sep_by = f\" (separated by '{os.pathsep}')\"\nL30728:     user_options = [\nL30729:         ('build-lib=', 'b', \"directory for compiled extension modules\"),\nL30730:         ('build-temp=', 't', \"directory for temporary files (build by-products)\"),\nL30731:         (\nL30732:             'plat-name=',\nL30733:             'p',\nL30734:             \"platform name to cross-compile for, if supported \"\nL30735:             f\"[default: {get_platform()}]\",\nL30736:         ),\nL30737:         (\nL30738:             'inplace',\nL30739:             'i',\nL30740:             \"ignore build-lib and put compiled extensions into the source \"\nL30741:             \"directory alongside your pure Python modules\",\nL30742:         ),\nL30743:         (\nL30744:             'include-dirs=',\nL30745:             'I',\nL30746:             \"list of directories to search for header files\" + sep_by,\nL30747:         ),\nL30748:         ('define=', 'D', \"C preprocessor macros to define\"),\nL30749:         ('undef=', 'U', \"C preprocessor macros to undefine\"),\nL30750:         ('libraries=', 'l', \"external C libraries to link with\"),\nL30751:         (\nL30752:             'library-dirs=',\nL30753:             'L',\nL30754:             \"directories to search for external C libraries\" + sep_by,\nL30755:         ),\nL30756:         ('rpath=', 'R', \"directories to search for shared C libraries at runtime\"),\nL30757:         ('link-objects=', 'O', \"extra explicit link objects to include in the link\"),\nL30758:         ('debug', 'g', \"compile/link with debugging information\"),\nL30759:         ('force', 'f', \"forcibly build everything (ignore file timestamps)\"),\nL30760:         ('compiler=', 'c', \"specify the compiler type\"),\nL30761:         ('parallel=', 'j', \"number of parallel build jobs\"),\nL30762:         ('swig-cpp', None, \"make SWIG create C++ files (default is C)\"),\nL30763:         ('swig-opts=', None, \"list of SWIG command line options\"),\nL30764:         ('swig=', None, \"path to the SWIG executable\"),\nL30765:         ('user', None, \"add user include, library and rpath\"),\nL30766:     ]\nL30767: \nL30768:     boolean_options: ClassVar[list[str]] = [\nL30769:         'inplace',\nL30770:         'debug',\nL30771:         'force',\nL30772:         'swig-cpp',\nL30773:         'user',\nL30774:     ]\nL30775: \nL30776:     help_options: ClassVar[list[tuple[str, str | None, str, Callable[[], object]]]] = [\nL30777:         ('help-compiler', None, \"list available compilers\", show_compilers),\nL30778:     ]\nL30779: \nL30780:     def initialize_options(self):\nL30781:         self.extensions = None\nL30782:         self.build_lib = None\nL30783:         self.plat_name = None\nL30784:         self.build_temp = None\nL30785:         self.inplace = False\nL30786:         self.package = None\nL30787: \nL30788:         self.include_dirs = None\nL30789:         self.define = None\nL30790:         self.undef = None\nL30791:         self.libraries = None\nL30792:         self.library_dirs = None\nL30793:         self.rpath = None\nL30794:         self.link_objects = None\nL30795:         self.debug = None\nL30796:         self.force = None\nL30797:         self.compiler = None\nL30798:         self.swig = None\nL30799:         self.swig_cpp = None\nL30800:         self.swig_opts = None\nL30801:         self.user = None\nL30802:         self.parallel = None\nL30803: \nL30804:     @staticmethod\nL30805:     def _python_lib_dir(sysconfig):\nL30806:         \"\"\"\nL30807:         Resolve Python's library directory for building extensions\nL30808:         that rely on a shared Python library.\nL30809: \nL30810:         See python/cpython#44264 and python/cpython#48686\nL30811:         \"\"\"\nL30812:         if not sysconfig.get_config_var('Py_ENABLE_SHARED'):\nL30813:             return\nL30814: \nL30815:         if sysconfig.python_build:\nL30816:             yield '.'\nL30817:             return\nL30818: \nL30819:         if sys.platform == 'zos':\nL30820:             # On z/OS, a user is not required to install Python to\nL30821:             # a predetermined path, but can use Python portably\nL30822:             installed_dir = sysconfig.get_config_var('base')\nL30823:             lib_dir = sysconfig.get_config_var('platlibdir')\nL30824:             yield os.path.join(installed_dir, lib_dir)\nL30825:         else:\nL30826:             # building third party extensions\nL30827:             yield sysconfig.get_config_var('LIBDIR')\nL30828: \nL30829:     def finalize_options(self) -> None:  # noqa: C901\nL30830:         from distutils import sysconfig\nL30831: \nL30832:         self.set_undefined_options(\nL30833:             'build',\nL30834:             ('build_lib', 'build_lib'),\nL30835:             ('build_temp', 'build_temp'),\nL30836:             ('compiler', 'compiler'),\nL30837:             ('debug', 'debug'),\nL30838:             ('force', 'force'),\nL30839:             ('parallel', 'parallel'),\nL30840:             ('plat_name', 'plat_name'),\nL30841:         )\nL30842: \nL30843:         if self.package is None:\nL30844:             self.package = self.distribution.ext_package\nL30845: \nL30846:         self.extensions = self.distribution.ext_modules\nL30847: \nL30848:         # Make sure Python's include directories (for Python.h, pyconfig.h,\nL30849:         # etc.) are in the include search path.\nL30850:         py_include = sysconfig.get_python_inc()\nL30851:         plat_py_include = sysconfig.get_python_inc(plat_specific=True)\nL30852:         if self.include_dirs is None:\nL30853:             self.include_dirs = self.distribution.include_dirs or []\nL30854:         if isinstance(self.include_dirs, str):\nL30855:             self.include_dirs = self.include_dirs.split(os.pathsep)\nL30856: \nL30857:         # If in a virtualenv, add its include directory\nL30858:         # Issue 16116\nL30859:         if sys.exec_prefix != sys.base_exec_prefix:\nL30860:             self.include_dirs.append(os.path.join(sys.exec_prefix, 'include'))\nL30861: \nL30862:         # Put the Python \"system\" include dir at the end, so that\nL30863:         # any local include dirs take precedence.\nL30864:         self.include_dirs.extend(py_include.split(os.path.pathsep))\nL30865:         if plat_py_include != py_include:\nL30866:             self.include_dirs.extend(plat_py_include.split(os.path.pathsep))\nL30867: \nL30868:         self.ensure_string_list('libraries')\nL30869:         self.ensure_string_list('link_objects')\nL30870: \nL30871:         # Life is easier if we're not forever checking for None, so\nL30872:         # simplify these options to empty lists if unset\nL30873:         if self.libraries is None:\nL30874:             self.libraries = []\nL30875:         if self.library_dirs is None:\nL30876:             self.library_dirs = []\nL30877:         elif isinstance(self.library_dirs, str):\nL30878:             self.library_dirs = self.library_dirs.split(os.pathsep)\nL30879: \nL30880:         if self.rpath is None:\nL30881:             self.rpath = []\nL30882:         elif isinstance(self.rpath, str):\nL30883:             self.rpath = self.rpath.split(os.pathsep)\nL30884: \nL30885:         # for extensions under windows use different directories\nL30886:         # for Release and Debug builds.\nL30887:         # also Python's library directory must be appended to library_dirs\nL30888:         if os.name == 'nt' and not is_mingw():\nL30889:             # the 'libs' directory is for binary installs - we assume that\nL30890:             # must be the *native* platform.  But we don't really support\nL30891:             # cross-compiling via a binary install anyway, so we let it go.\nL30892:             self.library_dirs.append(os.path.join(sys.exec_prefix, 'libs'))\nL30893:             if sys.base_exec_prefix != sys.prefix:  # Issue 16116\nL30894:                 self.library_dirs.append(os.path.join(sys.base_exec_prefix, 'libs'))\nL30895:             if self.debug:\nL30896:                 self.build_temp = os.path.join(self.build_temp, \"Debug\")\nL30897:             else:\nL30898:                 self.build_temp = os.path.join(self.build_temp, \"Release\")\nL30899: \nL30900:             # Append the source distribution include and library directories,\nL30901:             # this allows distutils on windows to work in the source tree\nL30902:             self.include_dirs.append(os.path.dirname(get_config_h_filename()))\nL30903:             self.library_dirs.append(sys.base_exec_prefix)\nL30904: \nL30905:             # Use the .lib files for the correct architecture\nL30906:             if self.plat_name == 'win32':\nL30907:                 suffix = 'win32'\nL30908:             else:\nL30909:                 # win-amd64\nL30910:                 suffix = self.plat_name[4:]\nL30911:             new_lib = os.path.join(sys.exec_prefix, 'PCbuild')\nL30912:             if suffix:\nL30913:                 new_lib = os.path.join(new_lib, suffix)\nL30914:             self.library_dirs.append(new_lib)\nL30915: \nL30916:         # For extensions under Cygwin, Python's library directory must be\nL30917:         # appended to library_dirs\nL30918:         if sys.platform[:6] == 'cygwin':\nL30919:             if not sysconfig.python_build:\nL30920:                 # building third party extensions\nL30921:                 self.library_dirs.append(\nL30922:                     os.path.join(\nL30923:                         sys.prefix, \"lib\", \"python\" + get_python_version(), \"config\"\nL30924:                     )\nL30925:                 )\nL30926:             else:\nL30927:                 # building python standard extensions\nL30928:                 self.library_dirs.append('.')\nL30929: \nL30930:         self.library_dirs.extend(self._python_lib_dir(sysconfig))\nL30931: \nL30932:         # The argument parsing will result in self.define being a string, but\nL30933:         # it has to be a list of 2-tuples.  All the preprocessor symbols\nL30934:         # specified by the 'define' option will be set to '1'.  Multiple\nL30935:         # symbols can be separated with commas.\nL30936: \nL30937:         if self.define:\nL30938:             defines = self.define.split(',')\nL30939:             self.define = [(symbol, '1') for symbol in defines]\nL30940: \nL30941:         # The option for macros to undefine is also a string from the\nL30942:         # option parsing, but has to be a list.  Multiple symbols can also\nL30943:         # be separated with commas here.\nL30944:         if self.undef:\nL30945:             self.undef = self.undef.split(',')\nL30946: \nL30947:         if self.swig_opts is None:\nL30948:             self.swig_opts = []\nL30949:         else:\nL30950:             self.swig_opts = self.swig_opts.split(' ')\nL30951: \nL30952:         # Finally add the user include and library directories if requested\nL30953:         if self.user:\nL30954:             user_include = os.path.join(USER_BASE, \"include\")\nL30955:             user_lib = os.path.join(USER_BASE, \"lib\")\nL30956:             if os.path.isdir(user_include):\nL30957:                 self.include_dirs.append(user_include)\nL30958:             if os.path.isdir(user_lib):\nL30959:                 self.library_dirs.append(user_lib)\nL30960:                 self.rpath.append(user_lib)\nL30961: \nL30962:         if isinstance(self.parallel, str):\nL30963:             try:\nL30964:                 self.parallel = int(self.parallel)\nL30965:             except ValueError:\nL30966:                 raise DistutilsOptionError(\"parallel should be an integer\")\nL30967: \nL30968:     def run(self) -> None:  # noqa: C901\nL30969:         # 'self.extensions', as supplied by setup.py, is a list of\nL30970:         # Extension instances.  See the documentation for Extension (in\nL30971:         # distutils.extension) for details.\nL30972:         #\nL30973:         # For backwards compatibility with Distutils 0.8.2 and earlier, we\nL30974:         # also allow the 'extensions' list to be a list of tuples:\nL30975:         #    (ext_name, build_info)\nL30976:         # where build_info is a dictionary containing everything that\nL30977:         # Extension instances do except the name, with a few things being\nL30978:         # differently named.  We convert these 2-tuples to Extension\nL30979:         # instances as needed.\nL30980: \nL30981:         if not self.extensions:\nL30982:             return\nL30983: \nL30984:         # If we were asked to build any C/C++ libraries, make sure that the\nL30985:         # directory where we put them is in the library search path for\nL30986:         # linking extensions.\nL30987:         if self.distribution.has_c_libraries():\nL30988:             build_clib = self.get_finalized_command('build_clib')\nL30989:             self.libraries.extend(build_clib.get_library_names() or [])\nL30990:             self.library_dirs.append(build_clib.build_clib)\nL30991: \nL30992:         # Setup the CCompiler object that we'll use to do all the\nL30993:         # compiling and linking\nL30994:         self.compiler = new_compiler(\nL30995:             compiler=self.compiler,\nL30996:             verbose=self.verbose,\nL30997:             dry_run=self.dry_run,\nL30998:             force=self.force,\nL30999:         )\nL31000:         customize_compiler(self.compiler)\nL31001:         # If we are cross-compiling, init the compiler now (if we are not\nL31002:         # cross-compiling, init would not hurt, but people may rely on\nL31003:         # late initialization of compiler even if they shouldn't...)\nL31004:         if os.name == 'nt' and self.plat_name != get_platform():\nL31005:             self.compiler.initialize(self.plat_name)\nL31006: \nL31007:         # The official Windows free threaded Python installer doesn't set\nL31008:         # Py_GIL_DISABLED because its pyconfig.h is shared with the\nL31009:         # default build, so define it here (pypa/setuptools#4662).\nL31010:         if os.name == 'nt' and is_freethreaded():\nL31011:             self.compiler.define_macro('Py_GIL_DISABLED', '1')\nL31012: \nL31013:         # And make sure that any compile/link-related options (which might\nL31014:         # come from the command-line or from the setup script) are set in\nL31015:         # that CCompiler object -- that way, they automatically apply to\nL31016:         # all compiling and linking done here.\nL31017:         if self.include_dirs is not None:\nL31018:             self.compiler.set_include_dirs(self.include_dirs)\nL31019:         if self.define is not None:\nL31020:             # 'define' option is a list of (name,value) tuples\nL31021:             for name, value in self.define:\nL31022:                 self.compiler.define_macro(name, value)\nL31023:         if self.undef is not None:\nL31024:             for macro in self.undef:\nL31025:                 self.compiler.undefine_macro(macro)\nL31026:         if self.libraries is not None:\nL31027:             self.compiler.set_libraries(self.libraries)\nL31028:         if self.library_dirs is not None:\nL31029:             self.compiler.set_library_dirs(self.library_dirs)\nL31030:         if self.rpath is not None:\nL31031:             self.compiler.set_runtime_library_dirs(self.rpath)\nL31032:         if self.link_objects is not None:\nL31033:             self.compiler.set_link_objects(self.link_objects)\nL31034: \nL31035:         # Now actually compile and link everything.\nL31036:         self.build_extensions()\nL31037: \nL31038:     def check_extensions_list(self, extensions) -> None:  # noqa: C901\nL31039:         \"\"\"Ensure that the list of extensions (presumably provided as a\nL31040:         command option 'extensions') is valid, i.e. it is a list of\nL31041:         Extension objects.  We also support the old-style list of 2-tuples,\nL31042:         where the tuples are (ext_name, build_info), which are converted to\nL31043:         Extension instances here.\nL31044: \nL31045:         Raise DistutilsSetupError if the structure is invalid anywhere;\nL31046:         just returns otherwise.\nL31047:         \"\"\"\nL31048:         if not isinstance(extensions, list):\nL31049:             raise DistutilsSetupError(\nL31050:                 \"'ext_modules' option must be a list of Extension instances\"\nL31051:             )\nL31052: \nL31053:         for i, ext in enumerate(extensions):\nL31054:             if isinstance(ext, Extension):\nL31055:                 continue  # OK! (assume type-checking done\nL31056:                 # by Extension constructor)\nL31057: \nL31058:             if not isinstance(ext, tuple) or len(ext) != 2:\nL31059:                 raise DistutilsSetupError(\nL31060:                     \"each element of 'ext_modules' option must be an \"\nL31061:                     \"Extension instance or 2-tuple\"\nL31062:                 )\nL31063: \nL31064:             ext_name, build_info = ext\nL31065: \nL31066:             log.warning(\nL31067:                 \"old-style (ext_name, build_info) tuple found in \"\nL31068:                 \"ext_modules for extension '%s' \"\nL31069:                 \"-- please convert to Extension instance\",\nL31070:                 ext_name,\nL31071:             )\nL31072: \nL31073:             if not (isinstance(ext_name, str) and extension_name_re.match(ext_name)):\nL31074:                 raise DistutilsSetupError(\nL31075:                     \"first element of each tuple in 'ext_modules' \"\nL31076:                     \"must be the extension name (a string)\"\nL31077:                 )\nL31078: \nL31079:             if not isinstance(build_info, dict):\nL31080:                 raise DistutilsSetupError(\nL31081:                     \"second element of each tuple in 'ext_modules' \"\nL31082:                     \"must be a dictionary (build info)\"\nL31083:                 )\nL31084: \nL31085:             # OK, the (ext_name, build_info) dict is type-safe: convert it\nL31086:             # to an Extension instance.\nL31087:             ext = Extension(ext_name, build_info['sources'])\nL31088: \nL31089:             # Easy stuff: one-to-one mapping from dict elements to\nL31090:             # instance attributes.\nL31091:             for key in (\nL31092:                 'include_dirs',\nL31093:                 'library_dirs',\nL31094:                 'libraries',\nL31095:                 'extra_objects',\nL31096:                 'extra_compile_args',\nL31097:                 'extra_link_args',\nL31098:             ):\nL31099:                 val = build_info.get(key)\nL31100:                 if val is not None:\nL31101:                     setattr(ext, key, val)\nL31102: \nL31103:             # Medium-easy stuff: same syntax/semantics, different names.\nL31104:             ext.runtime_library_dirs = build_info.get('rpath')\nL31105:             if 'def_file' in build_info:\nL31106:                 log.warning(\"'def_file' element of build info dict no longer supported\")\nL31107: \nL31108:             # Non-trivial stuff: 'macros' split into 'define_macros'\nL31109:             # and 'undef_macros'.\nL31110:             macros = build_info.get('macros')\nL31111:             if macros:\nL31112:                 ext.define_macros = []\nL31113:                 ext.undef_macros = []\nL31114:                 for macro in macros:\nL31115:                     if not (isinstance(macro, tuple) and len(macro) in (1, 2)):\nL31116:                         raise DistutilsSetupError(\nL31117:                             \"'macros' element of build info dict must be 1- or 2-tuple\"\nL31118:                         )\nL31119:                     if len(macro) == 1:\nL31120:                         ext.undef_macros.append(macro[0])\nL31121:                     elif len(macro) == 2:\nL31122:                         ext.define_macros.append(macro)\nL31123: \nL31124:             extensions[i] = ext\nL31125: \nL31126:     def get_source_files(self):\nL31127:         self.check_extensions_list(self.extensions)\nL31128:         filenames = []\nL31129: \nL31130:         # Wouldn't it be neat if we knew the names of header files too...\nL31131:         for ext in self.extensions:\nL31132:             filenames.extend(ext.sources)\nL31133:         return filenames\nL31134: \nL31135:     def get_outputs(self):\nL31136:         # Sanity check the 'extensions' list -- can't assume this is being\nL31137:         # done in the same run as a 'build_extensions()' call (in fact, we\nL31138:         # can probably assume that it *isn't*!).\nL31139:         self.check_extensions_list(self.extensions)\nL31140: \nL31141:         # And build the list of output (built) filenames.  Note that this\nL31142:         # ignores the 'inplace' flag, and assumes everything goes in the\nL31143:         # \"build\" tree.\nL31144:         return [self.get_ext_fullpath(ext.name) for ext in self.extensions]\nL31145: \nL31146:     def build_extensions(self) -> None:\nL31147:         # First, sanity-check the 'extensions' list\nL31148:         self.check_extensions_list(self.extensions)\nL31149:         if self.parallel:\nL31150:             self._build_extensions_parallel()\nL31151:         else:\nL31152:             self._build_extensions_serial()\nL31153: \nL31154:     def _build_extensions_parallel(self):\nL31155:         workers = self.parallel\nL31156:         if self.parallel is True:\nL31157:             workers = os.cpu_count()  # may return None\nL31158:         try:\nL31159:             from concurrent.futures import ThreadPoolExecutor\nL31160:         except ImportError:\nL31161:             workers = None\nL31162: \nL31163:         if workers is None:\nL31164:             self._build_extensions_serial()\nL31165:             return\nL31166: \nL31167:         with ThreadPoolExecutor(max_workers=workers) as executor:\nL31168:             futures = [\nL31169:                 executor.submit(self.build_extension, ext) for ext in self.extensions\nL31170:             ]\nL31171:             for ext, fut in zip(self.extensions, futures):\nL31172:                 with self._filter_build_errors(ext):\nL31173:                     fut.result()\nL31174: \nL31175:     def _build_extensions_serial(self):\nL31176:         for ext in self.extensions:\nL31177:             with self._filter_build_errors(ext):\nL31178:                 self.build_extension(ext)\nL31179: \nL31180:     @contextlib.contextmanager\nL31181:     def _filter_build_errors(self, ext):\nL31182:         try:\nL31183:             yield\nL31184:         except (CCompilerError, DistutilsError, CompileError) as e:\nL31185:             if not ext.optional:\nL31186:                 raise\nL31187:             self.warn(f'building extension \"{ext.name}\" failed: {e}')\nL31188: \nL31189:     def build_extension(self, ext) -> None:\nL31190:         sources = ext.sources\nL31191:         if sources is None or not isinstance(sources, (list, tuple)):\nL31192:             raise DistutilsSetupError(\nL31193:                 f\"in 'ext_modules' option (extension '{ext.name}'), \"\nL31194:                 \"'sources' must be present and must be \"\nL31195:                 \"a list of source filenames\"\nL31196:             )\nL31197:         # sort to make the resulting .so file build reproducible\nL31198:         sources = sorted(sources)\nL31199: \nL31200:         ext_path = self.get_ext_fullpath(ext.name)\nL31201:         depends = sources + ext.depends\nL31202:         if not (self.force or newer_group(depends, ext_path, 'newer')):\nL31203:             log.debug(\"skipping '%s' extension (up-to-date)\", ext.name)\nL31204:             return\nL31205:         else:\nL31206:             log.info(\"building '%s' extension\", ext.name)\nL31207: \nL31208:         # First, scan the sources for SWIG definition files (.i), run\nL31209:         # SWIG on 'em to create .c files, and modify the sources list\nL31210:         # accordingly.\nL31211:         sources = self.swig_sources(sources, ext)\nL31212: \nL31213:         # Next, compile the source code to object files.\nL31214: \nL31215:         # XXX not honouring 'define_macros' or 'undef_macros' -- the\nL31216:         # CCompiler API needs to change to accommodate this, and I\nL31217:         # want to do one thing at a time!\nL31218: \nL31219:         # Two possible sources for extra compiler arguments:\nL31220:         #   - 'extra_compile_args' in Extension object\nL31221:         #   - CFLAGS environment variable (not particularly\nL31222:         #     elegant, but people seem to expect it and I\nL31223:         #     guess it's useful)\nL31224:         # The environment variable should take precedence, and\nL31225:         # any sensible compiler will give precedence to later\nL31226:         # command line args.  Hence we combine them in order:\nL31227:         extra_args = ext.extra_compile_args or []\nL31228: \nL31229:         macros = ext.define_macros[:]\nL31230:         for undef in ext.undef_macros:\nL31231:             macros.append((undef,))\nL31232: \nL31233:         objects = self.compiler.compile(\nL31234:             sources,\nL31235:             output_dir=self.build_temp,\nL31236:             macros=macros,\nL31237:             include_dirs=ext.include_dirs,\nL31238:             debug=self.debug,\nL31239:             extra_postargs=extra_args,\nL31240:             depends=ext.depends,\nL31241:         )\nL31242: \nL31243:         # XXX outdated variable, kept here in case third-part code\nL31244:         # needs it.\nL31245:         self._built_objects = objects[:]\nL31246: \nL31247:         # Now link the object files together into a \"shared object\" --\nL31248:         # of course, first we have to figure out all the other things\nL31249:         # that go into the mix.\nL31250:         if ext.extra_objects:\nL31251:             objects.extend(ext.extra_objects)\nL31252:         extra_args = ext.extra_link_args or []\nL31253: \nL31254:         # Detect target language, if not provided\nL31255:         language = ext.language or self.compiler.detect_language(sources)\nL31256: \nL31257:         self.compiler.link_shared_object(\nL31258:             objects,\nL31259:             ext_path,\nL31260:             libraries=self.get_libraries(ext),\nL31261:             library_dirs=ext.library_dirs,\nL31262:             runtime_library_dirs=ext.runtime_library_dirs,\nL31263:             extra_postargs=extra_args,\nL31264:             export_symbols=self.get_export_symbols(ext),\nL31265:             debug=self.debug,\nL31266:             build_temp=self.build_temp,\nL31267:             target_lang=language,\nL31268:         )\nL31269: \nL31270:     def swig_sources(self, sources, extension):\nL31271:         \"\"\"Walk the list of source files in 'sources', looking for SWIG\nL31272:         interface (.i) files.  Run SWIG on all that are found, and\nL31273:         return a modified 'sources' list with SWIG source files replaced\nL31274:         by the generated C (or C++) files.\nL31275:         \"\"\"\nL31276:         new_sources = []\nL31277:         swig_sources = []\nL31278:         swig_targets = {}\nL31279: \nL31280:         # XXX this drops generated C/C++ files into the source tree, which\nL31281:         # is fine for developers who want to distribute the generated\nL31282:         # source -- but there should be an option to put SWIG output in\nL31283:         # the temp dir.\nL31284: \nL31285:         if self.swig_cpp:\nL31286:             log.warning(\"--swig-cpp is deprecated - use --swig-opts=-c++\")\nL31287: \nL31288:         if (\nL31289:             self.swig_cpp\nL31290:             or ('-c++' in self.swig_opts)\nL31291:             or ('-c++' in extension.swig_opts)\nL31292:         ):\nL31293:             target_ext = '.cpp'\nL31294:         else:\nL31295:             target_ext = '.c'\nL31296: \nL31297:         for source in sources:\nL31298:             (base, ext) = os.path.splitext(source)\nL31299:             if ext == \".i\":  # SWIG interface file\nL31300:                 new_sources.append(base + '_wrap' + target_ext)\nL31301:                 swig_sources.append(source)\nL31302:                 swig_targets[source] = new_sources[-1]\nL31303:             else:\nL31304:                 new_sources.append(source)\nL31305: \nL31306:         if not swig_sources:\nL31307:             return new_sources\nL31308: \nL31309:         swig = self.swig or self.find_swig()\nL31310:         swig_cmd = [swig, \"-python\"]\nL31311:         swig_cmd.extend(self.swig_opts)\nL31312:         if self.swig_cpp:\nL31313:             swig_cmd.append(\"-c++\")\nL31314: \nL31315:         # Do not override commandline arguments\nL31316:         if not self.swig_opts:\nL31317:             swig_cmd.extend(extension.swig_opts)\nL31318: \nL31319:         for source in swig_sources:\nL31320:             target = swig_targets[source]\nL31321:             log.info(\"swigging %s to %s\", source, target)\nL31322:             self.spawn(swig_cmd + [\"-o\", target, source])\nL31323: \nL31324:         return new_sources\nL31325: \nL31326:     def find_swig(self):\nL31327:         \"\"\"Return the name of the SWIG executable.  On Unix, this is\nL31328:         just \"swig\" -- it should be in the PATH.  Tries a bit harder on\nL31329:         Windows.\nL31330:         \"\"\"\nL31331:         if os.name == \"posix\":\nL31332:             return \"swig\"\nL31333:         elif os.name == \"nt\":\nL31334:             # Look for SWIG in its standard installation directory on\nL31335:             # Windows (or so I presume!).  If we find it there, great;\nL31336:             # if not, act like Unix and assume it's in the PATH.\nL31337:             for vers in (\"1.3\", \"1.2\", \"1.1\"):\nL31338:                 fn = os.path.join(f\"c:\\\\swig{vers}\", \"swig.exe\")\nL31339:                 if os.path.isfile(fn):\nL31340:                     return fn\nL31341:             else:\nL31342:                 return \"swig.exe\"\nL31343:         else:\nL31344:             raise DistutilsPlatformError(\nL31345:                 f\"I don't know how to find (much less run) SWIG on platform '{os.name}'\"\nL31346:             )\nL31347: \nL31348:     # -- Name generators -----------------------------------------------\nL31349:     # (extension names, filenames, whatever)\nL31350:     def get_ext_fullpath(self, ext_name: str) -> str:\nL31351:         \"\"\"Returns the path of the filename for a given extension.\nL31352: \nL31353:         The file is located in `build_lib` or directly in the package\nL31354:         (inplace option).\nL31355:         \"\"\"\nL31356:         fullname = self.get_ext_fullname(ext_name)\nL31357:         modpath = fullname.split('.')\nL31358:         filename = self.get_ext_filename(modpath[-1])\nL31359: \nL31360:         if not self.inplace:\nL31361:             # no further work needed\nL31362:             # returning :\nL31363:             #   build_dir/package/path/filename\nL31364:             filename = os.path.join(*modpath[:-1] + [filename])\nL31365:             return os.path.join(self.build_lib, filename)\nL31366: \nL31367:         # the inplace option requires to find the package directory\nL31368:         # using the build_py command for that\nL31369:         package = '.'.join(modpath[0:-1])\nL31370:         build_py = self.get_finalized_command('build_py')\nL31371:         package_dir = os.path.abspath(build_py.get_package_dir(package))\nL31372: \nL31373:         # returning\nL31374:         #   package_dir/filename\nL31375:         return os.path.join(package_dir, filename)\nL31376: \nL31377:     def get_ext_fullname(self, ext_name: str) -> str:\nL31378:         \"\"\"Returns the fullname of a given extension name.\nL31379: \nL31380:         Adds the `package.` prefix\"\"\"\nL31381:         if self.package is None:\nL31382:             return ext_name\nL31383:         else:\nL31384:             return self.package + '.' + ext_name\nL31385: \nL31386:     def get_ext_filename(self, ext_name: str) -> str:\nL31387:         r\"\"\"Convert the name of an extension (eg. \"foo.bar\") into the name\nL31388:         of the file from which it will be loaded (eg. \"foo/bar.so\", or\nL31389:         \"foo\\bar.pyd\").\nL31390:         \"\"\"\nL31391:         from ..sysconfig import get_config_var\nL31392: \nL31393:         ext_path = ext_name.split('.')\nL31394:         ext_suffix = get_config_var('EXT_SUFFIX')\nL31395:         return os.path.join(*ext_path) + ext_suffix\nL31396: \nL31397:     def get_export_symbols(self, ext: Extension) -> list[str]:\nL31398:         \"\"\"Return the list of symbols that a shared extension has to\nL31399:         export.  This either uses 'ext.export_symbols' or, if it's not\nL31400:         provided, \"PyInit_\" + module_name.  Only relevant on Windows, where\nL31401:         the .pyd file (DLL) must export the module \"PyInit_\" function.\nL31402:         \"\"\"\nL31403:         name = self._get_module_name_for_symbol(ext)\nL31404:         try:\nL31405:             # Unicode module name support as defined in PEP-489\nL31406:             # https://peps.python.org/pep-0489/#export-hook-name\nL31407:             name.encode('ascii')\nL31408:         except UnicodeEncodeError:\nL31409:             suffix = 'U_' + name.encode('punycode').replace(b'-', b'_').decode('ascii')\nL31410:         else:\nL31411:             suffix = \"_\" + name\nL31412: \nL31413:         initfunc_name = \"PyInit\" + suffix\nL31414:         if initfunc_name not in ext.export_symbols:\nL31415:             ext.export_symbols.append(initfunc_name)\nL31416:         return ext.export_symbols\nL31417: \nL31418:     def _get_module_name_for_symbol(self, ext):\nL31419:         # Package name should be used for `__init__` modules\nL31420:         # https://github.com/python/cpython/issues/80074\nL31421:         # https://github.com/pypa/setuptools/issues/4826\nL31422:         parts = ext.name.split(\".\")\nL31423:         if parts[-1] == \"__init__\" and len(parts) >= 2:\nL31424:             return parts[-2]\nL31425:         return parts[-1]\nL31426: \nL31427:     def get_libraries(self, ext: Extension) -> list[str]:  # noqa: C901\nL31428:         \"\"\"Return the list of libraries to link against when building a\nL31429:         shared extension.  On most platforms, this is just 'ext.libraries';\nL31430:         on Windows, we add the Python library (eg. python20.dll).\nL31431:         \"\"\"\nL31432:         # The python library is always needed on Windows.  For MSVC, this\nL31433:         # is redundant, since the library is mentioned in a pragma in\nL31434:         # pyconfig.h that MSVC groks.  The other Windows compilers all seem\nL31435:         # to need it mentioned explicitly, though, so that's what we do.\nL31436:         # Append '_d' to the python import library on debug builds.\nL31437:         if sys.platform == \"win32\" and not is_mingw():\nL31438:             from .._msvccompiler import MSVCCompiler\nL31439: \nL31440:             if not isinstance(self.compiler, MSVCCompiler):\nL31441:                 template = \"python%d%d\"\nL31442:                 if self.debug:\nL31443:                     template = template + '_d'\nL31444:                 pythonlib = template % (\nL31445:                     sys.hexversion >> 24,\nL31446:                     (sys.hexversion >> 16) & 0xFF,\nL31447:                 )\nL31448:                 # don't extend ext.libraries, it may be shared with other\nL31449:                 # extensions, it is a reference to the original list\nL31450:                 return ext.libraries + [pythonlib]\nL31451:         else:\nL31452:             # On Android only the main executable and LD_PRELOADs are considered\nL31453:             # to be RTLD_GLOBAL, all the dependencies of the main executable\nL31454:             # remain RTLD_LOCAL and so the shared libraries must be linked with\nL31455:             # libpython when python is built with a shared python library (issue\nL31456:             # bpo-21536).\nL31457:             # On Cygwin (and if required, other POSIX-like platforms based on\nL31458:             # Windows like MinGW) it is simply necessary that all symbols in\nL31459:             # shared libraries are resolved at link time.\nL31460:             from ..sysconfig import get_config_var\nL31461: \nL31462:             link_libpython = False\nL31463:             if get_config_var('Py_ENABLE_SHARED'):\nL31464:                 # A native build on an Android device or on Cygwin\nL31465:                 if hasattr(sys, 'getandroidapilevel'):\nL31466:                     link_libpython = True\nL31467:                 elif sys.platform == 'cygwin' or is_mingw():\nL31468:                     link_libpython = True\nL31469:                 elif '_PYTHON_HOST_PLATFORM' in os.environ:\nL31470:                     # We are cross-compiling for one of the relevant platforms\nL31471:                     if get_config_var('ANDROID_API_LEVEL') != 0:\nL31472:                         link_libpython = True\nL31473:                     elif get_config_var('MACHDEP') == 'cygwin':\nL31474:                         link_libpython = True\nL31475: \nL31476:             if link_libpython:\nL31477:                 ldversion = get_config_var('LDVERSION')\nL31478:                 return ext.libraries + ['python' + ldversion]\nL31479: \nL31480:         return ext.libraries\nL31481: \nL31482: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/build_py.py\nL31483: #!/usr/bin/env python3\nL31484: \"\"\"distutils.command.build_py\nL31485: \nL31486: Implements the Distutils 'build_py' command.\"\"\"\nL31487: \nL31488: import glob\nL31489: import importlib.util\nL31490: import os\nL31491: import sys\nL31492: from distutils._log import log\nL31493: from typing import ClassVar\nL31494: \nL31495: from ..core import Command\nL31496: from ..errors import DistutilsFileError, DistutilsOptionError\nL31497: from ..util import convert_path\nL31498: \nL31499: \nL31500: class build_py(Command):\nL31501:     description = \"\\\"build\\\" pure Python modules (copy to build directory)\"\nL31502: \nL31503:     user_options = [\nL31504:         ('build-lib=', 'd', \"directory to \\\"build\\\" (copy) to\"),\nL31505:         ('compile', 'c', \"compile .py to .pyc\"),\nL31506:         ('no-compile', None, \"don't compile .py files [default]\"),\nL31507:         (\nL31508:             'optimize=',\nL31509:             'O',\nL31510:             \"also compile with optimization: -O1 for \\\"python -O\\\", \"\nL31511:             \"-O2 for \\\"python -OO\\\", and -O0 to disable [default: -O0]\",\nL31512:         ),\nL31513:         ('force', 'f', \"forcibly build everything (ignore file timestamps)\"),\nL31514:     ]\nL31515: \nL31516:     boolean_options: ClassVar[list[str]] = ['compile', 'force']\nL31517:     negative_opt: ClassVar[dict[str, str]] = {'no-compile': 'compile'}\nL31518: \nL31519:     def initialize_options(self):\nL31520:         self.build_lib = None\nL31521:         self.py_modules = None\nL31522:         self.package = None\nL31523:         self.package_data = None\nL31524:         self.package_dir = None\nL31525:         self.compile = False\nL31526:         self.optimize = 0\nL31527:         self.force = None\nL31528: \nL31529:     def finalize_options(self) -> None:\nL31530:         self.set_undefined_options(\nL31531:             'build', ('build_lib', 'build_lib'), ('force', 'force')\nL31532:         )\nL31533: \nL31534:         # Get the distribution options that are aliases for build_py\nL31535:         # options -- list of packages and list of modules.\nL31536:         self.packages = self.distribution.packages\nL31537:         self.py_modules = self.distribution.py_modules\nL31538:         self.package_data = self.distribution.package_data\nL31539:         self.package_dir = {}\nL31540:         if self.distribution.package_dir:\nL31541:             for name, path in self.distribution.package_dir.items():\nL31542:                 self.package_dir[name] = convert_path(path)\nL31543:         self.data_files = self.get_data_files()\nL31544: \nL31545:         # Ick, copied straight from install_lib.py (fancy_getopt needs a\nL31546:         # type system!  Hell, *everything* needs a type system!!!)\nL31547:         if not isinstance(self.optimize, int):\nL31548:             try:\nL31549:                 self.optimize = int(self.optimize)\nL31550:                 assert 0 <= self.optimize <= 2\nL31551:             except (ValueError, AssertionError):\nL31552:                 raise DistutilsOptionError(\"optimize must be 0, 1, or 2\")\nL31553: \nL31554:     def run(self) -> None:\nL31555:         # XXX copy_file by default preserves atime and mtime.  IMHO this is\nL31556:         # the right thing to do, but perhaps it should be an option -- in\nL31557:         # particular, a site administrator might want installed files to\nL31558:         # reflect the time of installation rather than the last\nL31559:         # modification time before the installed release.\nL31560: \nL31561:         # XXX copy_file by default preserves mode, which appears to be the\nL31562:         # wrong thing to do: if a file is read-only in the working\nL31563:         # directory, we want it to be installed read/write so that the next\nL31564:         # installation of the same module distribution can overwrite it\nL31565:         # without problems.  (This might be a Unix-specific issue.)  Thus\nL31566:         # we turn off 'preserve_mode' when copying to the build directory,\nL31567:         # since the build directory is supposed to be exactly what the\nL31568:         # installation will look like (ie. we preserve mode when\nL31569:         # installing).\nL31570: \nL31571:         # Two options control which modules will be installed: 'packages'\nL31572:         # and 'py_modules'.  The former lets us work with whole packages, not\nL31573:         # specifying individual modules at all; the latter is for\nL31574:         # specifying modules one-at-a-time.\nL31575: \nL31576:         if self.py_modules:\nL31577:             self.build_modules()\nL31578:         if self.packages:\nL31579:             self.build_packages()\nL31580:             self.build_package_data()\nL31581: \nL31582:         self.byte_compile(self.get_outputs(include_bytecode=False))\nL31583: \nL31584:     def get_data_files(self):\nL31585:         \"\"\"Generate list of '(package,src_dir,build_dir,filenames)' tuples\"\"\"\nL31586:         data = []\nL31587:         if not self.packages:\nL31588:             return data\nL31589:         for package in self.packages:\nL31590:             # Locate package source directory\nL31591:             src_dir = self.get_package_dir(package)\nL31592: \nL31593:             # Compute package build directory\nL31594:             build_dir = os.path.join(*([self.build_lib] + package.split('.')))\nL31595: \nL31596:             # Length of path to strip from found files\nL31597:             plen = 0\nL31598:             if src_dir:\nL31599:                 plen = len(src_dir) + 1\nL31600: \nL31601:             # Strip directory from globbed filenames\nL31602:             filenames = [file[plen:] for file in self.find_data_files(package, src_dir)]\nL31603:             data.append((package, src_dir, build_dir, filenames))\nL31604:         return data\nL31605: \nL31606:     def find_data_files(self, package, src_dir):\nL31607:         \"\"\"Return filenames for package's data files in 'src_dir'\"\"\"\nL31608:         globs = self.package_data.get('', []) + self.package_data.get(package, [])\nL31609:         files = []\nL31610:         for pattern in globs:\nL31611:             # Each pattern has to be converted to a platform-specific path\nL31612:             filelist = glob.glob(\nL31613:                 os.path.join(glob.escape(src_dir), convert_path(pattern))\nL31614:             )\nL31615:             # Files that match more than one pattern are only added once\nL31616:             files.extend([\nL31617:                 fn for fn in filelist if fn not in files and os.path.isfile(fn)\nL31618:             ])\nL31619:         return files\nL31620: \nL31621:     def build_package_data(self) -> None:\nL31622:         \"\"\"Copy data files into build directory\"\"\"\nL31623:         for _package, src_dir, build_dir, filenames in self.data_files:\nL31624:             for filename in filenames:\nL31625:                 target = os.path.join(build_dir, filename)\nL31626:                 self.mkpath(os.path.dirname(target))\nL31627:                 self.copy_file(\nL31628:                     os.path.join(src_dir, filename), target, preserve_mode=False\nL31629:                 )\nL31630: \nL31631:     def get_package_dir(self, package):\nL31632:         \"\"\"Return the directory, relative to the top of the source\nL31633:         distribution, where package 'package' should be found\nL31634:         (at least according to the 'package_dir' option, if any).\"\"\"\nL31635:         path = package.split('.')\nL31636: \nL31637:         if not self.package_dir:\nL31638:             if path:\nL31639:                 return os.path.join(*path)\nL31640:             else:\nL31641:                 return ''\nL31642:         else:\nL31643:             tail = []\nL31644:             while path:\nL31645:                 try:\nL31646:                     pdir = self.package_dir['.'.join(path)]\nL31647:                 except KeyError:\nL31648:                     tail.insert(0, path[-1])\nL31649:                     del path[-1]\nL31650:                 else:\nL31651:                     tail.insert(0, pdir)\nL31652:                     return os.path.join(*tail)\nL31653:             else:\nL31654:                 # Oops, got all the way through 'path' without finding a\nL31655:                 # match in package_dir.  If package_dir defines a directory\nL31656:                 # for the root (nameless) package, then fallback on it;\nL31657:                 # otherwise, we might as well have not consulted\nL31658:                 # package_dir at all, as we just use the directory implied\nL31659:                 # by 'tail' (which should be the same as the original value\nL31660:                 # of 'path' at this point).\nL31661:                 pdir = self.package_dir.get('')\nL31662:                 if pdir is not None:\nL31663:                     tail.insert(0, pdir)\nL31664: \nL31665:                 if tail:\nL31666:                     return os.path.join(*tail)\nL31667:                 else:\nL31668:                     return ''\nL31669: \nL31670:     def check_package(self, package, package_dir):\nL31671:         # Empty dir name means current directory, which we can probably\nL31672:         # assume exists.  Also, os.path.exists and isdir don't know about\nL31673:         # my \"empty string means current dir\" convention, so we have to\nL31674:         # circumvent them.\nL31675:         if package_dir != \"\":\nL31676:             if not os.path.exists(package_dir):\nL31677:                 raise DistutilsFileError(\nL31678:                     f\"package directory '{package_dir}' does not exist\"\nL31679:                 )\nL31680:             if not os.path.isdir(package_dir):\nL31681:                 raise DistutilsFileError(\nL31682:                     f\"supposed package directory '{package_dir}' exists, \"\nL31683:                     \"but is not a directory\"\nL31684:                 )\nL31685: \nL31686:         # Directories without __init__.py are namespace packages (PEP 420).\nL31687:         if package:\nL31688:             init_py = os.path.join(package_dir, \"__init__.py\")\nL31689:             if os.path.isfile(init_py):\nL31690:                 return init_py\nL31691: \nL31692:         # Either not in a package at all (__init__.py not expected), or\nL31693:         # __init__.py doesn't exist -- so don't return the filename.\nL31694:         return None\nL31695: \nL31696:     def check_module(self, module, module_file):\nL31697:         if not os.path.isfile(module_file):\nL31698:             log.warning(\"file %s (for module %s) not found\", module_file, module)\nL31699:             return False\nL31700:         else:\nL31701:             return True\nL31702: \nL31703:     def find_package_modules(self, package, package_dir):\nL31704:         self.check_package(package, package_dir)\nL31705:         module_files = glob.glob(os.path.join(glob.escape(package_dir), \"*.py\"))\nL31706:         modules = []\nL31707:         setup_script = os.path.abspath(self.distribution.script_name)\nL31708: \nL31709:         for f in module_files:\nL31710:             abs_f = os.path.abspath(f)\nL31711:             if abs_f != setup_script:\nL31712:                 module = os.path.splitext(os.path.basename(f))[0]\nL31713:                 modules.append((package, module, f))\nL31714:             else:\nL31715:                 self.debug_print(f\"excluding {setup_script}\")\nL31716:         return modules\nL31717: \nL31718:     def find_modules(self):\nL31719:         \"\"\"Finds individually-specified Python modules, ie. those listed by\nL31720:         module name in 'self.py_modules'.  Returns a list of tuples (package,\nL31721:         module_base, filename): 'package' is a tuple of the path through\nL31722:         package-space to the module; 'module_base' is the bare (no\nL31723:         packages, no dots) module name, and 'filename' is the path to the\nL31724:         \".py\" file (relative to the distribution root) that implements the\nL31725:         module.\nL31726:         \"\"\"\nL31727:         # Map package names to tuples of useful info about the package:\nL31728:         #    (package_dir, checked)\nL31729:         # package_dir - the directory where we'll find source files for\nL31730:         #   this package\nL31731:         # checked - true if we have checked that the package directory\nL31732:         #   is valid (exists, contains __init__.py, ... ?)\nL31733:         packages = {}\nL31734: \nL31735:         # List of (package, module, filename) tuples to return\nL31736:         modules = []\nL31737: \nL31738:         # We treat modules-in-packages almost the same as toplevel modules,\nL31739:         # just the \"package\" for a toplevel is empty (either an empty\nL31740:         # string or empty list, depending on context).  Differences:\nL31741:         #   - don't check for __init__.py in directory for empty package\nL31742:         for module in self.py_modules:\nL31743:             path = module.split('.')\nL31744:             package = '.'.join(path[0:-1])\nL31745:             module_base = path[-1]\nL31746: \nL31747:             try:\nL31748:                 (package_dir, checked) = packages[package]\nL31749:             except KeyError:\nL31750:                 package_dir = self.get_package_dir(package)\nL31751:                 checked = False\nL31752: \nL31753:             if not checked:\nL31754:                 init_py = self.check_package(package, package_dir)\nL31755:                 packages[package] = (package_dir, 1)\nL31756:                 if init_py:\nL31757:                     modules.append((package, \"__init__\", init_py))\nL31758: \nL31759:             # XXX perhaps we should also check for just .pyc files\nL31760:             # (so greedy closed-source bastards can distribute Python\nL31761:             # modules too)\nL31762:             module_file = os.path.join(package_dir, module_base + \".py\")\nL31763:             if not self.check_module(module, module_file):\nL31764:                 continue\nL31765: \nL31766:             modules.append((package, module_base, module_file))\nL31767: \nL31768:         return modules\nL31769: \nL31770:     def find_all_modules(self):\nL31771:         \"\"\"Compute the list of all modules that will be built, whether\nL31772:         they are specified one-module-at-a-time ('self.py_modules') or\nL31773:         by whole packages ('self.packages').  Return a list of tuples\nL31774:         (package, module, module_file), just like 'find_modules()' and\nL31775:         'find_package_modules()' do.\"\"\"\nL31776:         modules = []\nL31777:         if self.py_modules:\nL31778:             modules.extend(self.find_modules())\nL31779:         if self.packages:\nL31780:             for package in self.packages:\nL31781:                 package_dir = self.get_package_dir(package)\nL31782:                 m = self.find_package_modules(package, package_dir)\nL31783:                 modules.extend(m)\nL31784:         return modules\nL31785: \nL31786:     def get_source_files(self):\nL31787:         return [module[-1] for module in self.find_all_modules()]\nL31788: \nL31789:     def get_module_outfile(self, build_dir, package, module):\nL31790:         outfile_path = [build_dir] + list(package) + [module + \".py\"]\nL31791:         return os.path.join(*outfile_path)\nL31792: \nL31793:     def get_outputs(self, include_bytecode: bool = True) -> list[str]:\nL31794:         modules = self.find_all_modules()\nL31795:         outputs = []\nL31796:         for package, module, _module_file in modules:\nL31797:             package = package.split('.')\nL31798:             filename = self.get_module_outfile(self.build_lib, package, module)\nL31799:             outputs.append(filename)\nL31800:             if include_bytecode:\nL31801:                 if self.compile:\nL31802:                     outputs.append(\nL31803:                         importlib.util.cache_from_source(filename, optimization='')\nL31804:                     )\nL31805:                 if self.optimize > 0:\nL31806:                     outputs.append(\nL31807:                         importlib.util.cache_from_source(\nL31808:                             filename, optimization=self.optimize\nL31809:                         )\nL31810:                     )\nL31811: \nL31812:         outputs += [\nL31813:             os.path.join(build_dir, filename)\nL31814:             for package, src_dir, build_dir, filenames in self.data_files\nL31815:             for filename in filenames\nL31816:         ]\nL31817: \nL31818:         return outputs\nL31819: \nL31820:     def build_module(self, module, module_file, package):\nL31821:         if isinstance(package, str):\nL31822:             package = package.split('.')\nL31823:         elif not isinstance(package, (list, tuple)):\nL31824:             raise TypeError(\nL31825:                 \"'package' must be a string (dot-separated), list, or tuple\"\nL31826:             )\nL31827: \nL31828:         # Now put the module source file into the \"build\" area -- this is\nL31829:         # easy, we just copy it somewhere under self.build_lib (the build\nL31830:         # directory for Python source).\nL31831:         outfile = self.get_module_outfile(self.build_lib, package, module)\nL31832:         dir = os.path.dirname(outfile)\nL31833:         self.mkpath(dir)\nL31834:         return self.copy_file(module_file, outfile, preserve_mode=False)\nL31835: \nL31836:     def build_modules(self) -> None:\nL31837:         modules = self.find_modules()\nL31838:         for package, module, module_file in modules:\nL31839:             # Now \"build\" the module -- ie. copy the source file to\nL31840:             # self.build_lib (the build directory for Python source).\nL31841:             # (Actually, it gets copied to the directory for this package\nL31842:             # under self.build_lib.)\nL31843:             self.build_module(module, module_file, package)\nL31844: \nL31845:     def build_packages(self) -> None:\nL31846:         for package in self.packages:\nL31847:             # Get list of (package, module, module_file) tuples based on\nL31848:             # scanning the package directory.  'package' is only included\nL31849:             # in the tuple so that 'find_modules()' and\nL31850:             # 'find_package_tuples()' have a consistent interface; it's\nL31851:             # ignored here (apart from a sanity check).  Also, 'module' is\nL31852:             # the *unqualified* module name (ie. no dots, no package -- we\nL31853:             # already know its package!), and 'module_file' is the path to\nL31854:             # the .py file, relative to the current directory\nL31855:             # (ie. including 'package_dir').\nL31856:             package_dir = self.get_package_dir(package)\nL31857:             modules = self.find_package_modules(package, package_dir)\nL31858: \nL31859:             # Now loop over the modules we found, \"building\" each one (just\nL31860:             # copy it to self.build_lib).\nL31861:             for package_, module, module_file in modules:\nL31862:                 assert package == package_\nL31863:                 self.build_module(module, module_file, package)\nL31864: \nL31865:     def byte_compile(self, files) -> None:\nL31866:         if sys.dont_write_bytecode:\nL31867:             self.warn('byte-compiling is disabled, skipping.')\nL31868:             return\nL31869: \nL31870:         from ..util import byte_compile\nL31871: \nL31872:         prefix = self.build_lib\nL31873:         if prefix[-1] != os.sep:\nL31874:             prefix = prefix + os.sep\nL31875: \nL31876:         # XXX this code is essentially the same as the 'byte_compile()\nL31877:         # method of the \"install_lib\" command, except for the determination\nL31878:         # of the 'prefix' string.  Hmmm.\nL31879:         if self.compile:\nL31880:             byte_compile(\nL31881:                 files, optimize=0, force=self.force, prefix=prefix, dry_run=self.dry_run\nL31882:             )\nL31883:         if self.optimize > 0:\nL31884:             byte_compile(\nL31885:                 files,\nL31886:                 optimize=self.optimize,\nL31887:                 force=self.force,\nL31888:                 prefix=prefix,\nL31889:                 dry_run=self.dry_run,\nL31890:             )\nL31891: \nL31892: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/build_scripts.py\nL31893: #!/usr/bin/env python3\nL31894: \"\"\"distutils.command.build_scripts\nL31895: \nL31896: Implements the Distutils 'build_scripts' command.\"\"\"\nL31897: \nL31898: import os\nL31899: import re\nL31900: import tokenize\nL31901: from distutils._log import log\nL31902: from stat import ST_MODE\nL31903: from typing import ClassVar\nL31904: \nL31905: from .._modified import newer\nL31906: from ..core import Command\nL31907: from ..util import convert_path\nL31908: \nL31909: shebang_pattern = re.compile('^#!.*python[0-9.]*([ \\t].*)?$')\nL31910: \"\"\"\nL31911: Pattern matching a Python interpreter indicated in first line of a script.\nL31912: \"\"\"\nL31913: \nL31914: # for Setuptools compatibility\nL31915: first_line_re = shebang_pattern\nL31916: \nL31917: \nL31918: class build_scripts(Command):\nL31919:     description = \"\\\"build\\\" scripts (copy and fixup #! line)\"\nL31920: \nL31921:     user_options: ClassVar[list[tuple[str, str, str]]] = [\nL31922:         ('build-dir=', 'd', \"directory to \\\"build\\\" (copy) to\"),\nL31923:         ('force', 'f', \"forcibly build everything (ignore file timestamps\"),\nL31924:         ('executable=', 'e', \"specify final destination interpreter path\"),\nL31925:     ]\nL31926: \nL31927:     boolean_options: ClassVar[list[str]] = ['force']\nL31928: \nL31929:     def initialize_options(self):\nL31930:         self.build_dir = None\nL31931:         self.scripts = None\nL31932:         self.force = None\nL31933:         self.executable = None\nL31934: \nL31935:     def finalize_options(self):\nL31936:         self.set_undefined_options(\nL31937:             'build',\nL31938:             ('build_scripts', 'build_dir'),\nL31939:             ('force', 'force'),\nL31940:             ('executable', 'executable'),\nL31941:         )\nL31942:         self.scripts = self.distribution.scripts\nL31943: \nL31944:     def get_source_files(self):\nL31945:         return self.scripts\nL31946: \nL31947:     def run(self):\nL31948:         if not self.scripts:\nL31949:             return\nL31950:         self.copy_scripts()\nL31951: \nL31952:     def copy_scripts(self):\nL31953:         \"\"\"\nL31954:         Copy each script listed in ``self.scripts``.\nL31955: \nL31956:         If a script is marked as a Python script (first line matches\nL31957:         'shebang_pattern', i.e. starts with ``#!`` and contains\nL31958:         \"python\"), then adjust in the copy the first line to refer to\nL31959:         the current Python interpreter.\nL31960:         \"\"\"\nL31961:         self.mkpath(self.build_dir)\nL31962:         outfiles = []\nL31963:         updated_files = []\nL31964:         for script in self.scripts:\nL31965:             self._copy_script(script, outfiles, updated_files)\nL31966: \nL31967:         self._change_modes(outfiles)\nL31968: \nL31969:         return outfiles, updated_files\nL31970: \nL31971:     def _copy_script(self, script, outfiles, updated_files):\nL31972:         shebang_match = None\nL31973:         script = convert_path(script)\nL31974:         outfile = os.path.join(self.build_dir, os.path.basename(script))\nL31975:         outfiles.append(outfile)\nL31976: \nL31977:         if not self.force and not newer(script, outfile):\nL31978:             log.debug(\"not copying %s (up-to-date)\", script)\nL31979:             return\nL31980: \nL31981:         # Always open the file, but ignore failures in dry-run mode\nL31982:         # in order to attempt to copy directly.\nL31983:         try:\nL31984:             f = tokenize.open(script)\nL31985:         except OSError:\nL31986:             if not self.dry_run:\nL31987:                 raise\nL31988:             f = None\nL31989:         else:\nL31990:             first_line = f.readline()\nL31991:             if not first_line:\nL31992:                 self.warn(f\"{script} is an empty file (skipping)\")\nL31993:                 return\nL31994: \nL31995:             shebang_match = shebang_pattern.match(first_line)\nL31996: \nL31997:         updated_files.append(outfile)\nL31998:         if shebang_match:\nL31999:             log.info(\"copying and adjusting %s -> %s\", script, self.build_dir)\nL32000:             if not self.dry_run:\nL32001:                 post_interp = shebang_match.group(1) or ''\nL32002:                 shebang = \"#!\" + self.executable + post_interp + \"\\n\"\nL32003:                 self._validate_shebang(shebang, f.encoding)\nL32004:                 with open(outfile, \"w\", encoding=f.encoding) as outf:\nL32005:                     outf.write(shebang)\nL32006:                     outf.writelines(f.readlines())\nL32007:             if f:\nL32008:                 f.close()\nL32009:         else:\nL32010:             if f:\nL32011:                 f.close()\nL32012:             self.copy_file(script, outfile)\nL32013: \nL32014:     def _change_modes(self, outfiles):\nL32015:         if os.name != 'posix':\nL32016:             return\nL32017: \nL32018:         for file in outfiles:\nL32019:             self._change_mode(file)\nL32020: \nL32021:     def _change_mode(self, file):\nL32022:         if self.dry_run:\nL32023:             log.info(\"changing mode of %s\", file)\nL32024:             return\nL32025: \nL32026:         oldmode = os.stat(file)[ST_MODE] & 0o7777\nL32027:         newmode = (oldmode | 0o555) & 0o7777\nL32028:         if newmode != oldmode:\nL32029:             log.info(\"changing mode of %s from %o to %o\", file, oldmode, newmode)\nL32030:             os.chmod(file, newmode)\nL32031: \nL32032:     @staticmethod\nL32033:     def _validate_shebang(shebang, encoding):\nL32034:         # Python parser starts to read a script using UTF-8 until\nL32035:         # it gets a #coding:xxx cookie. The shebang has to be the\nL32036:         # first line of a file, the #coding:xxx cookie cannot be\nL32037:         # written before. So the shebang has to be encodable to\nL32038:         # UTF-8.\nL32039:         try:\nL32040:             shebang.encode('utf-8')\nL32041:         except UnicodeEncodeError:\nL32042:             raise ValueError(f\"The shebang ({shebang!r}) is not encodable to utf-8\")\nL32043: \nL32044:         # If the script is encoded to a custom encoding (use a\nL32045:         # #coding:xxx cookie), the shebang has to be encodable to\nL32046:         # the script encoding too.\nL32047:         try:\nL32048:             shebang.encode(encoding)\nL32049:         except UnicodeEncodeError:\nL32050:             raise ValueError(\nL32051:                 f\"The shebang ({shebang!r}) is not encodable \"\nL32052:                 f\"to the script encoding ({encoding})\"\nL32053:             )\nL32054: \nL32055: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/check.py\nL32056: #!/usr/bin/env python3\nL32057: \"\"\"distutils.command.check\nL32058: \nL32059: Implements the Distutils 'check' command.\nL32060: \"\"\"\nL32061: \nL32062: import contextlib\nL32063: from typing import ClassVar\nL32064: \nL32065: from ..core import Command\nL32066: from ..errors import DistutilsSetupError\nL32067: \nL32068: with contextlib.suppress(ImportError):\nL32069:     import docutils.frontend\nL32070:     import docutils.nodes\nL32071:     import docutils.parsers.rst\nL32072:     import docutils.utils\nL32073: \nL32074:     class SilentReporter(docutils.utils.Reporter):\nL32075:         def __init__(\nL32076:             self,\nL32077:             source,\nL32078:             report_level,\nL32079:             halt_level,\nL32080:             stream=None,\nL32081:             debug=False,\nL32082:             encoding='ascii',\nL32083:             error_handler='replace',\nL32084:         ):\nL32085:             self.messages = []\nL32086:             super().__init__(\nL32087:                 source, report_level, halt_level, stream, debug, encoding, error_handler\nL32088:             )\nL32089: \nL32090:         def system_message(self, level, message, *children, **kwargs):\nL32091:             self.messages.append((level, message, children, kwargs))\nL32092:             return docutils.nodes.system_message(\nL32093:                 message, *children, level=level, type=self.levels[level], **kwargs\nL32094:             )\nL32095: \nL32096: \nL32097: class check(Command):\nL32098:     \"\"\"This command checks the meta-data of the package.\"\"\"\nL32099: \nL32100:     description = \"perform some checks on the package\"\nL32101:     user_options: ClassVar[list[tuple[str, str, str]]] = [\nL32102:         ('metadata', 'm', 'Verify meta-data'),\nL32103:         (\nL32104:             'restructuredtext',\nL32105:             'r',\nL32106:             'Checks if long string meta-data syntax are reStructuredText-compliant',\nL32107:         ),\nL32108:         ('strict', 's', 'Will exit with an error if a check fails'),\nL32109:     ]\nL32110: \nL32111:     boolean_options: ClassVar[list[str]] = ['metadata', 'restructuredtext', 'strict']\nL32112: \nL32113:     def initialize_options(self):\nL32114:         \"\"\"Sets default values for options.\"\"\"\nL32115:         self.restructuredtext = False\nL32116:         self.metadata = 1\nL32117:         self.strict = False\nL32118:         self._warnings = 0\nL32119: \nL32120:     def finalize_options(self):\nL32121:         pass\nL32122: \nL32123:     def warn(self, msg):\nL32124:         \"\"\"Counts the number of warnings that occurs.\"\"\"\nL32125:         self._warnings += 1\nL32126:         return Command.warn(self, msg)\nL32127: \nL32128:     def run(self):\nL32129:         \"\"\"Runs the command.\"\"\"\nL32130:         # perform the various tests\nL32131:         if self.metadata:\nL32132:             self.check_metadata()\nL32133:         if self.restructuredtext:\nL32134:             if 'docutils' in globals():\nL32135:                 try:\nL32136:                     self.check_restructuredtext()\nL32137:                 except TypeError as exc:\nL32138:                     raise DistutilsSetupError(str(exc))\nL32139:             elif self.strict:\nL32140:                 raise DistutilsSetupError('The docutils package is needed.')\nL32141: \nL32142:         # let's raise an error in strict mode, if we have at least\nL32143:         # one warning\nL32144:         if self.strict and self._warnings > 0:\nL32145:             raise DistutilsSetupError('Please correct your package.')\nL32146: \nL32147:     def check_metadata(self):\nL32148:         \"\"\"Ensures that all required elements of meta-data are supplied.\nL32149: \nL32150:         Required fields:\nL32151:             name, version\nL32152: \nL32153:         Warns if any are missing.\nL32154:         \"\"\"\nL32155:         metadata = self.distribution.metadata\nL32156: \nL32157:         missing = [\nL32158:             attr for attr in ('name', 'version') if not getattr(metadata, attr, None)\nL32159:         ]\nL32160: \nL32161:         if missing:\nL32162:             self.warn(\"missing required meta-data: {}\".format(', '.join(missing)))\nL32163: \nL32164:     def check_restructuredtext(self):\nL32165:         \"\"\"Checks if the long string fields are reST-compliant.\"\"\"\nL32166:         data = self.distribution.get_long_description()\nL32167:         for warning in self._check_rst_data(data):\nL32168:             line = warning[-1].get('line')\nL32169:             if line is None:\nL32170:                 warning = warning[1]\nL32171:             else:\nL32172:                 warning = f'{warning[1]} (line {line})'\nL32173:             self.warn(warning)\nL32174: \nL32175:     def _check_rst_data(self, data):\nL32176:         \"\"\"Returns warnings when the provided data doesn't compile.\"\"\"\nL32177:         # the include and csv_table directives need this to be a path\nL32178:         source_path = self.distribution.script_name or 'setup.py'\nL32179:         parser = docutils.parsers.rst.Parser()\nL32180:         settings = docutils.frontend.OptionParser(\nL32181:             components=(docutils.parsers.rst.Parser,)\nL32182:         ).get_default_values()\nL32183:         settings.tab_width = 4\nL32184:         settings.pep_references = None\nL32185:         settings.rfc_references = None\nL32186:         reporter = SilentReporter(\nL32187:             source_path,\nL32188:             settings.report_level,\nL32189:             settings.halt_level,\nL32190:             stream=settings.warning_stream,\nL32191:             debug=settings.debug,\nL32192:             encoding=settings.error_encoding,\nL32193:             error_handler=settings.error_encoding_error_handler,\nL32194:         )\nL32195: \nL32196:         document = docutils.nodes.document(settings, reporter, source=source_path)\nL32197:         document.note_source(source_path, -1)\nL32198:         try:\nL32199:             parser.parse(data, document)\nL32200:         except (AttributeError, TypeError) as e:\nL32201:             reporter.messages.append((\nL32202:                 -1,\nL32203:                 f'Could not finish the parsing: {e}.',\nL32204:                 '',\nL32205:                 {},\nL32206:             ))\nL32207: \nL32208:         return reporter.messages\nL32209: \nL32210: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/clean.py\nL32211: #!/usr/bin/env python3\nL32212: \"\"\"distutils.command.clean\nL32213: \nL32214: Implements the Distutils 'clean' command.\"\"\"\nL32215: \nL32216: # contributed by Bastian Kleineidam <calvin@cs.uni-sb.de>, added 2000-03-18\nL32217: \nL32218: import os\nL32219: from distutils._log import log\nL32220: from typing import ClassVar\nL32221: \nL32222: from ..core import Command\nL32223: from ..dir_util import remove_tree\nL32224: \nL32225: \nL32226: class clean(Command):\nL32227:     description = \"clean up temporary files from 'build' command\"\nL32228:     user_options = [\nL32229:         ('build-base=', 'b', \"base build directory [default: 'build.build-base']\"),\nL32230:         (\nL32231:             'build-lib=',\nL32232:             None,\nL32233:             \"build directory for all modules [default: 'build.build-lib']\",\nL32234:         ),\nL32235:         ('build-temp=', 't', \"temporary build directory [default: 'build.build-temp']\"),\nL32236:         (\nL32237:             'build-scripts=',\nL32238:             None,\nL32239:             \"build directory for scripts [default: 'build.build-scripts']\",\nL32240:         ),\nL32241:         ('bdist-base=', None, \"temporary directory for built distributions\"),\nL32242:         ('all', 'a', \"remove all build output, not just temporary by-products\"),\nL32243:     ]\nL32244: \nL32245:     boolean_options: ClassVar[list[str]] = ['all']\nL32246: \nL32247:     def initialize_options(self):\nL32248:         self.build_base = None\nL32249:         self.build_lib = None\nL32250:         self.build_temp = None\nL32251:         self.build_scripts = None\nL32252:         self.bdist_base = None\nL32253:         self.all = None\nL32254: \nL32255:     def finalize_options(self):\nL32256:         self.set_undefined_options(\nL32257:             'build',\nL32258:             ('build_base', 'build_base'),\nL32259:             ('build_lib', 'build_lib'),\nL32260:             ('build_scripts', 'build_scripts'),\nL32261:             ('build_temp', 'build_temp'),\nL32262:         )\nL32263:         self.set_undefined_options('bdist', ('bdist_base', 'bdist_base'))\nL32264: \nL32265:     def run(self):\nL32266:         # remove the build/temp.<plat> directory (unless it's already\nL32267:         # gone)\nL32268:         if os.path.exists(self.build_temp):\nL32269:             remove_tree(self.build_temp, dry_run=self.dry_run)\nL32270:         else:\nL32271:             log.debug(\"'%s' does not exist -- can't clean it\", self.build_temp)\nL32272: \nL32273:         if self.all:\nL32274:             # remove build directories\nL32275:             for directory in (self.build_lib, self.bdist_base, self.build_scripts):\nL32276:                 if os.path.exists(directory):\nL32277:                     remove_tree(directory, dry_run=self.dry_run)\nL32278:                 else:\nL32279:                     log.warning(\"'%s' does not exist -- can't clean it\", directory)\nL32280: \nL32281:         # just for the heck of it, try to remove the base build directory:\nL32282:         # we might have emptied it right now, but if not we don't care\nL32283:         if not self.dry_run:\nL32284:             try:\nL32285:                 os.rmdir(self.build_base)\nL32286:                 log.info(\"removing '%s'\", self.build_base)\nL32287:             except OSError:\nL32288:                 pass\nL32289: \nL32290: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/config.py\nL32291: #!/usr/bin/env python3\nL32292: \"\"\"distutils.command.config\nL32293: \nL32294: Implements the Distutils 'config' command, a (mostly) empty command class\nL32295: that exists mainly to be sub-classed by specific module distributions and\nL32296: applications.  The idea is that while every \"config\" command is different,\nL32297: at least they're all named the same, and users always see \"config\" in the\nL32298: list of standard commands.  Also, this is a good place to put common\nL32299: configure-like tasks: \"try to compile this C code\", or \"figure out where\nL32300: this header file lives\".\nL32301: \"\"\"\nL32302: \nL32303: from __future__ import annotations\nL32304: \nL32305: import os\nL32306: import pathlib\nL32307: import re\nL32308: from collections.abc import Sequence\nL32309: from distutils._log import log\nL32310: \nL32311: from ..ccompiler import CCompiler, CompileError, LinkError, new_compiler\nL32312: from ..core import Command\nL32313: from ..errors import DistutilsExecError\nL32314: from ..sysconfig import customize_compiler\nL32315: \nL32316: LANG_EXT = {\"c\": \".c\", \"c++\": \".cxx\"}\nL32317: \nL32318: \nL32319: class config(Command):\nL32320:     description = \"prepare to build\"\nL32321: \nL32322:     user_options = [\nL32323:         ('compiler=', None, \"specify the compiler type\"),\nL32324:         ('cc=', None, \"specify the compiler executable\"),\nL32325:         ('include-dirs=', 'I', \"list of directories to search for header files\"),\nL32326:         ('define=', 'D', \"C preprocessor macros to define\"),\nL32327:         ('undef=', 'U', \"C preprocessor macros to undefine\"),\nL32328:         ('libraries=', 'l', \"external C libraries to link with\"),\nL32329:         ('library-dirs=', 'L', \"directories to search for external C libraries\"),\nL32330:         ('noisy', None, \"show every action (compile, link, run, ...) taken\"),\nL32331:         (\nL32332:             'dump-source',\nL32333:             None,\nL32334:             \"dump generated source files before attempting to compile them\",\nL32335:         ),\nL32336:     ]\nL32337: \nL32338:     # The three standard command methods: since the \"config\" command\nL32339:     # does nothing by default, these are empty.\nL32340: \nL32341:     def initialize_options(self):\nL32342:         self.compiler = None\nL32343:         self.cc = None\nL32344:         self.include_dirs = None\nL32345:         self.libraries = None\nL32346:         self.library_dirs = None\nL32347: \nL32348:         # maximal output for now\nL32349:         self.noisy = 1\nL32350:         self.dump_source = 1\nL32351: \nL32352:         # list of temporary files generated along-the-way that we have\nL32353:         # to clean at some point\nL32354:         self.temp_files = []\nL32355: \nL32356:     def finalize_options(self):\nL32357:         if self.include_dirs is None:\nL32358:             self.include_dirs = self.distribution.include_dirs or []\nL32359:         elif isinstance(self.include_dirs, str):\nL32360:             self.include_dirs = self.include_dirs.split(os.pathsep)\nL32361: \nL32362:         if self.libraries is None:\nL32363:             self.libraries = []\nL32364:         elif isinstance(self.libraries, str):\nL32365:             self.libraries = [self.libraries]\nL32366: \nL32367:         if self.library_dirs is None:\nL32368:             self.library_dirs = []\nL32369:         elif isinstance(self.library_dirs, str):\nL32370:             self.library_dirs = self.library_dirs.split(os.pathsep)\nL32371: \nL32372:     def run(self):\nL32373:         pass\nL32374: \nL32375:     # Utility methods for actual \"config\" commands.  The interfaces are\nL32376:     # loosely based on Autoconf macros of similar names.  Sub-classes\nL32377:     # may use these freely.\nL32378: \nL32379:     def _check_compiler(self):\nL32380:         \"\"\"Check that 'self.compiler' really is a CCompiler object;\nL32381:         if not, make it one.\nL32382:         \"\"\"\nL32383:         if not isinstance(self.compiler, CCompiler):\nL32384:             self.compiler = new_compiler(\nL32385:                 compiler=self.compiler, dry_run=self.dry_run, force=True\nL32386:             )\nL32387:             customize_compiler(self.compiler)\nL32388:             if self.include_dirs:\nL32389:                 self.compiler.set_include_dirs(self.include_dirs)\nL32390:             if self.libraries:\nL32391:                 self.compiler.set_libraries(self.libraries)\nL32392:             if self.library_dirs:\nL32393:                 self.compiler.set_library_dirs(self.library_dirs)\nL32394: \nL32395:     def _gen_temp_sourcefile(self, body, headers, lang):\nL32396:         filename = \"_configtest\" + LANG_EXT[lang]\nL32397:         with open(filename, \"w\", encoding='utf-8') as file:\nL32398:             if headers:\nL32399:                 for header in headers:\nL32400:                     file.write(f\"#include <{header}>\\n\")\nL32401:                 file.write(\"\\n\")\nL32402:             file.write(body)\nL32403:             if body[-1] != \"\\n\":\nL32404:                 file.write(\"\\n\")\nL32405:         return filename\nL32406: \nL32407:     def _preprocess(self, body, headers, include_dirs, lang):\nL32408:         src = self._gen_temp_sourcefile(body, headers, lang)\nL32409:         out = \"_configtest.i\"\nL32410:         self.temp_files.extend([src, out])\nL32411:         self.compiler.preprocess(src, out, include_dirs=include_dirs)\nL32412:         return (src, out)\nL32413: \nL32414:     def _compile(self, body, headers, include_dirs, lang):\nL32415:         src = self._gen_temp_sourcefile(body, headers, lang)\nL32416:         if self.dump_source:\nL32417:             dump_file(src, f\"compiling '{src}':\")\nL32418:         (obj,) = self.compiler.object_filenames([src])\nL32419:         self.temp_files.extend([src, obj])\nL32420:         self.compiler.compile([src], include_dirs=include_dirs)\nL32421:         return (src, obj)\nL32422: \nL32423:     def _link(self, body, headers, include_dirs, libraries, library_dirs, lang):\nL32424:         (src, obj) = self._compile(body, headers, include_dirs, lang)\nL32425:         prog = os.path.splitext(os.path.basename(src))[0]\nL32426:         self.compiler.link_executable(\nL32427:             [obj],\nL32428:             prog,\nL32429:             libraries=libraries,\nL32430:             library_dirs=library_dirs,\nL32431:             target_lang=lang,\nL32432:         )\nL32433: \nL32434:         if self.compiler.exe_extension is not None:\nL32435:             prog = prog + self.compiler.exe_extension\nL32436:         self.temp_files.append(prog)\nL32437: \nL32438:         return (src, obj, prog)\nL32439: \nL32440:     def _clean(self, *filenames):\nL32441:         if not filenames:\nL32442:             filenames = self.temp_files\nL32443:             self.temp_files = []\nL32444:         log.info(\"removing: %s\", ' '.join(filenames))\nL32445:         for filename in filenames:\nL32446:             try:\nL32447:                 os.remove(filename)\nL32448:             except OSError:\nL32449:                 pass\nL32450: \nL32451:     # XXX these ignore the dry-run flag: what to do, what to do? even if\nL32452:     # you want a dry-run build, you still need some sort of configuration\nL32453:     # info.  My inclination is to make it up to the real config command to\nL32454:     # consult 'dry_run', and assume a default (minimal) configuration if\nL32455:     # true.  The problem with trying to do it here is that you'd have to\nL32456:     # return either true or false from all the 'try' methods, neither of\nL32457:     # which is correct.\nL32458: \nL32459:     # XXX need access to the header search path and maybe default macros.\nL32460: \nL32461:     def try_cpp(self, body=None, headers=None, include_dirs=None, lang=\"c\"):\nL32462:         \"\"\"Construct a source file from 'body' (a string containing lines\nL32463:         of C/C++ code) and 'headers' (a list of header files to include)\nL32464:         and run it through the preprocessor.  Return true if the\nL32465:         preprocessor succeeded, false if there were any errors.\nL32466:         ('body' probably isn't of much use, but what the heck.)\nL32467:         \"\"\"\nL32468:         self._check_compiler()\nL32469:         ok = True\nL32470:         try:\nL32471:             self._preprocess(body, headers, include_dirs, lang)\nL32472:         except CompileError:\nL32473:             ok = False\nL32474: \nL32475:         self._clean()\nL32476:         return ok\nL32477: \nL32478:     def search_cpp(self, pattern, body=None, headers=None, include_dirs=None, lang=\"c\"):\nL32479:         \"\"\"Construct a source file (just like 'try_cpp()'), run it through\nL32480:         the preprocessor, and return true if any line of the output matches\nL32481:         'pattern'.  'pattern' should either be a compiled regex object or a\nL32482:         string containing a regex.  If both 'body' and 'headers' are None,\nL32483:         preprocesses an empty file -- which can be useful to determine the\nL32484:         symbols the preprocessor and compiler set by default.\nL32485:         \"\"\"\nL32486:         self._check_compiler()\nL32487:         src, out = self._preprocess(body, headers, include_dirs, lang)\nL32488: \nL32489:         if isinstance(pattern, str):\nL32490:             pattern = re.compile(pattern)\nL32491: \nL32492:         with open(out, encoding='utf-8') as file:\nL32493:             match = any(pattern.search(line) for line in file)\nL32494: \nL32495:         self._clean()\nL32496:         return match\nL32497: \nL32498:     def try_compile(self, body, headers=None, include_dirs=None, lang=\"c\"):\nL32499:         \"\"\"Try to compile a source file built from 'body' and 'headers'.\nL32500:         Return true on success, false otherwise.\nL32501:         \"\"\"\nL32502:         self._check_compiler()\nL32503:         try:\nL32504:             self._compile(body, headers, include_dirs, lang)\nL32505:             ok = True\nL32506:         except CompileError:\nL32507:             ok = False\nL32508: \nL32509:         log.info(ok and \"success!\" or \"failure.\")\nL32510:         self._clean()\nL32511:         return ok\nL32512: \nL32513:     def try_link(\nL32514:         self,\nL32515:         body,\nL32516:         headers=None,\nL32517:         include_dirs=None,\nL32518:         libraries=None,\nL32519:         library_dirs=None,\nL32520:         lang=\"c\",\nL32521:     ):\nL32522:         \"\"\"Try to compile and link a source file, built from 'body' and\nL32523:         'headers', to executable form.  Return true on success, false\nL32524:         otherwise.\nL32525:         \"\"\"\nL32526:         self._check_compiler()\nL32527:         try:\nL32528:             self._link(body, headers, include_dirs, libraries, library_dirs, lang)\nL32529:             ok = True\nL32530:         except (CompileError, LinkError):\nL32531:             ok = False\nL32532: \nL32533:         log.info(ok and \"success!\" or \"failure.\")\nL32534:         self._clean()\nL32535:         return ok\nL32536: \nL32537:     def try_run(\nL32538:         self,\nL32539:         body,\nL32540:         headers=None,\nL32541:         include_dirs=None,\nL32542:         libraries=None,\nL32543:         library_dirs=None,\nL32544:         lang=\"c\",\nL32545:     ):\nL32546:         \"\"\"Try to compile, link to an executable, and run a program\nL32547:         built from 'body' and 'headers'.  Return true on success, false\nL32548:         otherwise.\nL32549:         \"\"\"\nL32550:         self._check_compiler()\nL32551:         try:\nL32552:             src, obj, exe = self._link(\nL32553:                 body, headers, include_dirs, libraries, library_dirs, lang\nL32554:             )\nL32555:             self.spawn([exe])\nL32556:             ok = True\nL32557:         except (CompileError, LinkError, DistutilsExecError):\nL32558:             ok = False\nL32559: \nL32560:         log.info(ok and \"success!\" or \"failure.\")\nL32561:         self._clean()\nL32562:         return ok\nL32563: \nL32564:     # -- High-level methods --------------------------------------------\nL32565:     # (these are the ones that are actually likely to be useful\nL32566:     # when implementing a real-world config command!)\nL32567: \nL32568:     def check_func(\nL32569:         self,\nL32570:         func,\nL32571:         headers=None,\nL32572:         include_dirs=None,\nL32573:         libraries=None,\nL32574:         library_dirs=None,\nL32575:         decl=False,\nL32576:         call=False,\nL32577:     ):\nL32578:         \"\"\"Determine if function 'func' is available by constructing a\nL32579:         source file that refers to 'func', and compiles and links it.\nL32580:         If everything succeeds, returns true; otherwise returns false.\nL32581: \nL32582:         The constructed source file starts out by including the header\nL32583:         files listed in 'headers'.  If 'decl' is true, it then declares\nL32584:         'func' (as \"int func()\"); you probably shouldn't supply 'headers'\nL32585:         and set 'decl' true in the same call, or you might get errors about\nL32586:         a conflicting declarations for 'func'.  Finally, the constructed\nL32587:         'main()' function either references 'func' or (if 'call' is true)\nL32588:         calls it.  'libraries' and 'library_dirs' are used when\nL32589:         linking.\nL32590:         \"\"\"\nL32591:         self._check_compiler()\nL32592:         body = []\nL32593:         if decl:\nL32594:             body.append(f\"int {func} ();\")\nL32595:         body.append(\"int main () {\")\nL32596:         if call:\nL32597:             body.append(f\"  {func}();\")\nL32598:         else:\nL32599:             body.append(f\"  {func};\")\nL32600:         body.append(\"}\")\nL32601:         body = \"\\n\".join(body) + \"\\n\"\nL32602: \nL32603:         return self.try_link(body, headers, include_dirs, libraries, library_dirs)\nL32604: \nL32605:     def check_lib(\nL32606:         self,\nL32607:         library,\nL32608:         library_dirs=None,\nL32609:         headers=None,\nL32610:         include_dirs=None,\nL32611:         other_libraries: Sequence[str] = [],\nL32612:     ):\nL32613:         \"\"\"Determine if 'library' is available to be linked against,\nL32614:         without actually checking that any particular symbols are provided\nL32615:         by it.  'headers' will be used in constructing the source file to\nL32616:         be compiled, but the only effect of this is to check if all the\nL32617:         header files listed are available.  Any libraries listed in\nL32618:         'other_libraries' will be included in the link, in case 'library'\nL32619:         has symbols that depend on other libraries.\nL32620:         \"\"\"\nL32621:         self._check_compiler()\nL32622:         return self.try_link(\nL32623:             \"int main (void) { }\",\nL32624:             headers,\nL32625:             include_dirs,\nL32626:             [library] + list(other_libraries),\nL32627:             library_dirs,\nL32628:         )\nL32629: \nL32630:     def check_header(self, header, include_dirs=None, library_dirs=None, lang=\"c\"):\nL32631:         \"\"\"Determine if the system header file named by 'header_file'\nL32632:         exists and can be found by the preprocessor; return true if so,\nL32633:         false otherwise.\nL32634:         \"\"\"\nL32635:         return self.try_cpp(\nL32636:             body=\"/* No body */\", headers=[header], include_dirs=include_dirs\nL32637:         )\nL32638: \nL32639: \nL32640: def dump_file(filename, head=None):\nL32641:     \"\"\"Dumps a file content into log.info.\nL32642: \nL32643:     If head is not None, will be dumped before the file content.\nL32644:     \"\"\"\nL32645:     if head is None:\nL32646:         log.info('%s', filename)\nL32647:     else:\nL32648:         log.info(head)\nL32649:     log.info(pathlib.Path(filename).read_text(encoding='utf-8'))\nL32650: \nL32651: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/install.py\nL32652: #!/usr/bin/env python3\nL32653: \"\"\"distutils.command.install\nL32654: \nL32655: Implements the Distutils 'install' command.\"\"\"\nL32656: \nL32657: from __future__ import annotations\nL32658: \nL32659: import collections\nL32660: import contextlib\nL32661: import itertools\nL32662: import os\nL32663: import sys\nL32664: import sysconfig\nL32665: from distutils._log import log\nL32666: from site import USER_BASE, USER_SITE\nL32667: from typing import ClassVar\nL32668: \nL32669: from ..core import Command\nL32670: from ..debug import DEBUG\nL32671: from ..errors import DistutilsOptionError, DistutilsPlatformError\nL32672: from ..file_util import write_file\nL32673: from ..sysconfig import get_config_vars\nL32674: from ..util import change_root, convert_path, get_platform, subst_vars\nL32675: from . import _framework_compat as fw\nL32676: \nL32677: HAS_USER_SITE = True\nL32678: \nL32679: WINDOWS_SCHEME = {\nL32680:     'purelib': '{base}/Lib/site-packages',\nL32681:     'platlib': '{base}/Lib/site-packages',\nL32682:     'headers': '{base}/Include/{dist_name}',\nL32683:     'scripts': '{base}/Scripts',\nL32684:     'data': '{base}',\nL32685: }\nL32686: \nL32687: INSTALL_SCHEMES = {\nL32688:     'posix_prefix': {\nL32689:         'purelib': '{base}/lib/{implementation_lower}{py_version_short}/site-packages',\nL32690:         'platlib': '{platbase}/{platlibdir}/{implementation_lower}'\nL32691:         '{py_version_short}/site-packages',\nL32692:         'headers': '{base}/include/{implementation_lower}'\nL32693:         '{py_version_short}{abiflags}/{dist_name}',\nL32694:         'scripts': '{base}/bin',\nL32695:         'data': '{base}',\nL32696:     },\nL32697:     'posix_home': {\nL32698:         'purelib': '{base}/lib/{implementation_lower}',\nL32699:         'platlib': '{base}/{platlibdir}/{implementation_lower}',\nL32700:         'headers': '{base}/include/{implementation_lower}/{dist_name}',\nL32701:         'scripts': '{base}/bin',\nL32702:         'data': '{base}',\nL32703:     },\nL32704:     'nt': WINDOWS_SCHEME,\nL32705:     'pypy': {\nL32706:         'purelib': '{base}/site-packages',\nL32707:         'platlib': '{base}/site-packages',\nL32708:         'headers': '{base}/include/{dist_name}',\nL32709:         'scripts': '{base}/bin',\nL32710:         'data': '{base}',\nL32711:     },\nL32712:     'pypy_nt': {\nL32713:         'purelib': '{base}/site-packages',\nL32714:         'platlib': '{base}/site-packages',\nL32715:         'headers': '{base}/include/{dist_name}',\nL32716:         'scripts': '{base}/Scripts',\nL32717:         'data': '{base}',\nL32718:     },\nL32719: }\nL32720: \nL32721: # user site schemes\nL32722: if HAS_USER_SITE:\nL32723:     INSTALL_SCHEMES['nt_user'] = {\nL32724:         'purelib': '{usersite}',\nL32725:         'platlib': '{usersite}',\nL32726:         'headers': '{userbase}/{implementation}{py_version_nodot_plat}'\nL32727:         '/Include/{dist_name}',\nL32728:         'scripts': '{userbase}/{implementation}{py_version_nodot_plat}/Scripts',\nL32729:         'data': '{userbase}',\nL32730:     }\nL32731: \nL32732:     INSTALL_SCHEMES['posix_user'] = {\nL32733:         'purelib': '{usersite}',\nL32734:         'platlib': '{usersite}',\nL32735:         'headers': '{userbase}/include/{implementation_lower}'\nL32736:         '{py_version_short}{abiflags}/{dist_name}',\nL32737:         'scripts': '{userbase}/bin',\nL32738:         'data': '{userbase}',\nL32739:     }\nL32740: \nL32741: \nL32742: INSTALL_SCHEMES.update(fw.schemes)\nL32743: \nL32744: \nL32745: # The keys to an installation scheme; if any new types of files are to be\nL32746: # installed, be sure to add an entry to every installation scheme above,\nL32747: # and to SCHEME_KEYS here.\nL32748: SCHEME_KEYS = ('purelib', 'platlib', 'headers', 'scripts', 'data')\nL32749: \nL32750: \nL32751: def _load_sysconfig_schemes():\nL32752:     with contextlib.suppress(AttributeError):\nL32753:         return {\nL32754:             scheme: sysconfig.get_paths(scheme, expand=False)\nL32755:             for scheme in sysconfig.get_scheme_names()\nL32756:         }\nL32757: \nL32758: \nL32759: def _load_schemes():\nL32760:     \"\"\"\nL32761:     Extend default schemes with schemes from sysconfig.\nL32762:     \"\"\"\nL32763: \nL32764:     sysconfig_schemes = _load_sysconfig_schemes() or {}\nL32765: \nL32766:     return {\nL32767:         scheme: {\nL32768:             **INSTALL_SCHEMES.get(scheme, {}),\nL32769:             **sysconfig_schemes.get(scheme, {}),\nL32770:         }\nL32771:         for scheme in set(itertools.chain(INSTALL_SCHEMES, sysconfig_schemes))\nL32772:     }\nL32773: \nL32774: \nL32775: def _get_implementation():\nL32776:     if hasattr(sys, 'pypy_version_info'):\nL32777:         return 'PyPy'\nL32778:     else:\nL32779:         return 'Python'\nL32780: \nL32781: \nL32782: def _select_scheme(ob, name):\nL32783:     scheme = _inject_headers(name, _load_scheme(_resolve_scheme(name)))\nL32784:     vars(ob).update(_remove_set(ob, _scheme_attrs(scheme)))\nL32785: \nL32786: \nL32787: def _remove_set(ob, attrs):\nL32788:     \"\"\"\nL32789:     Include only attrs that are None in ob.\nL32790:     \"\"\"\nL32791:     return {key: value for key, value in attrs.items() if getattr(ob, key) is None}\nL32792: \nL32793: \nL32794: def _resolve_scheme(name):\nL32795:     os_name, sep, key = name.partition('_')\nL32796:     try:\nL32797:         resolved = sysconfig.get_preferred_scheme(key)\nL32798:     except Exception:\nL32799:         resolved = fw.scheme(name)\nL32800:     return resolved\nL32801: \nL32802: \nL32803: def _load_scheme(name):\nL32804:     return _load_schemes()[name]\nL32805: \nL32806: \nL32807: def _inject_headers(name, scheme):\nL32808:     \"\"\"\nL32809:     Given a scheme name and the resolved scheme,\nL32810:     if the scheme does not include headers, resolve\nL32811:     the fallback scheme for the name and use headers\nL32812:     from it. pypa/distutils#88\nL32813:     \"\"\"\nL32814:     # Bypass the preferred scheme, which may not\nL32815:     # have defined headers.\nL32816:     fallback = _load_scheme(name)\nL32817:     scheme.setdefault('headers', fallback['headers'])\nL32818:     return scheme\nL32819: \nL32820: \nL32821: def _scheme_attrs(scheme):\nL32822:     \"\"\"Resolve install directories by applying the install schemes.\"\"\"\nL32823:     return {f'install_{key}': scheme[key] for key in SCHEME_KEYS}\nL32824: \nL32825: \nL32826: class install(Command):\nL32827:     description = \"install everything from build directory\"\nL32828: \nL32829:     user_options = [\nL32830:         # Select installation scheme and set base director(y|ies)\nL32831:         ('prefix=', None, \"installation prefix\"),\nL32832:         ('exec-prefix=', None, \"(Unix only) prefix for platform-specific files\"),\nL32833:         ('home=', None, \"(Unix only) home directory to install under\"),\nL32834:         # Or, just set the base director(y|ies)\nL32835:         (\nL32836:             'install-base=',\nL32837:             None,\nL32838:             \"base installation directory (instead of --prefix or --home)\",\nL32839:         ),\nL32840:         (\nL32841:             'install-platbase=',\nL32842:             None,\nL32843:             \"base installation directory for platform-specific files (instead of --exec-prefix or --home)\",\nL32844:         ),\nL32845:         ('root=', None, \"install everything relative to this alternate root directory\"),\nL32846:         # Or, explicitly set the installation scheme\nL32847:         (\nL32848:             'install-purelib=',\nL32849:             None,\nL32850:             \"installation directory for pure Python module distributions\",\nL32851:         ),\nL32852:         (\nL32853:             'install-platlib=',\nL32854:             None,\nL32855:             \"installation directory for non-pure module distributions\",\nL32856:         ),\nL32857:         (\nL32858:             'install-lib=',\nL32859:             None,\nL32860:             \"installation directory for all module distributions (overrides --install-purelib and --install-platlib)\",\nL32861:         ),\nL32862:         ('install-headers=', None, \"installation directory for C/C++ headers\"),\nL32863:         ('install-scripts=', None, \"installation directory for Python scripts\"),\nL32864:         ('install-data=', None, \"installation directory for data files\"),\nL32865:         # Byte-compilation options -- see install_lib.py for details, as\nL32866:         # these are duplicated from there (but only install_lib does\nL32867:         # anything with them).\nL32868:         ('compile', 'c', \"compile .py to .pyc [default]\"),\nL32869:         ('no-compile', None, \"don't compile .py files\"),\nL32870:         (\nL32871:             'optimize=',\nL32872:             'O',\nL32873:             \"also compile with optimization: -O1 for \\\"python -O\\\", \"\nL32874:             \"-O2 for \\\"python -OO\\\", and -O0 to disable [default: -O0]\",\nL32875:         ),\nL32876:         # Miscellaneous control options\nL32877:         ('force', 'f', \"force installation (overwrite any existing files)\"),\nL32878:         ('skip-build', None, \"skip rebuilding everything (for testing/debugging)\"),\nL32879:         # Where to install documentation (eventually!)\nL32880:         # ('doc-format=', None, \"format of documentation to generate\"),\nL32881:         # ('install-man=', None, \"directory for Unix man pages\"),\nL32882:         # ('install-html=', None, \"directory for HTML documentation\"),\nL32883:         # ('install-info=', None, \"directory for GNU info files\"),\nL32884:         ('record=', None, \"filename in which to record list of installed files\"),\nL32885:     ]\nL32886: \nL32887:     boolean_options: ClassVar[list[str]] = ['compile', 'force', 'skip-build']\nL32888: \nL32889:     if HAS_USER_SITE:\nL32890:         user_options.append((\nL32891:             'user',\nL32892:             None,\nL32893:             f\"install in user site-package '{USER_SITE}'\",\nL32894:         ))\nL32895:         boolean_options.append('user')\nL32896: \nL32897:     negative_opt: ClassVar[dict[str, str]] = {'no-compile': 'compile'}\nL32898: \nL32899:     def initialize_options(self) -> None:\nL32900:         \"\"\"Initializes options.\"\"\"\nL32901:         # High-level options: these select both an installation base\nL32902:         # and scheme.\nL32903:         self.prefix: str | None = None\nL32904:         self.exec_prefix: str | None = None\nL32905:         self.home: str | None = None\nL32906:         self.user = False\nL32907: \nL32908:         # These select only the installation base; it's up to the user to\nL32909:         # specify the installation scheme (currently, that means supplying\nL32910:         # the --install-{platlib,purelib,scripts,data} options).\nL32911:         self.install_base = None\nL32912:         self.install_platbase = None\nL32913:         self.root: str | None = None\nL32914: \nL32915:         # These options are the actual installation directories; if not\nL32916:         # supplied by the user, they are filled in using the installation\nL32917:         # scheme implied by prefix/exec-prefix/home and the contents of\nL32918:         # that installation scheme.\nL32919:         self.install_purelib = None  # for pure module distributions\nL32920:         self.install_platlib = None  # non-pure (dists w/ extensions)\nL32921:         self.install_headers = None  # for C/C++ headers\nL32922:         self.install_lib: str | None = None  # set to either purelib or platlib\nL32923:         self.install_scripts = None\nL32924:         self.install_data = None\nL32925:         self.install_userbase = USER_BASE\nL32926:         self.install_usersite = USER_SITE\nL32927: \nL32928:         self.compile = None\nL32929:         self.optimize = None\nL32930: \nL32931:         # Deprecated\nL32932:         # These two are for putting non-packagized distributions into their\nL32933:         # own directory and creating a .pth file if it makes sense.\nL32934:         # 'extra_path' comes from the setup file; 'install_path_file' can\nL32935:         # be turned off if it makes no sense to install a .pth file.  (But\nL32936:         # better to install it uselessly than to guess wrong and not\nL32937:         # install it when it's necessary and would be used!)  Currently,\nL32938:         # 'install_path_file' is always true unless some outsider meddles\nL32939:         # with it.\nL32940:         self.extra_path = None\nL32941:         self.install_path_file = True\nL32942: \nL32943:         # 'force' forces installation, even if target files are not\nL32944:         # out-of-date.  'skip_build' skips running the \"build\" command,\nL32945:         # handy if you know it's not necessary.  'warn_dir' (which is *not*\nL32946:         # a user option, it's just there so the bdist_* commands can turn\nL32947:         # it off) determines whether we warn about installing to a\nL32948:         # directory not in sys.path.\nL32949:         self.force = False\nL32950:         self.skip_build = False\nL32951:         self.warn_dir = True\nL32952: \nL32953:         # These are only here as a conduit from the 'build' command to the\nL32954:         # 'install_*' commands that do the real work.  ('build_base' isn't\nL32955:         # actually used anywhere, but it might be useful in future.)  They\nL32956:         # are not user options, because if the user told the install\nL32957:         # command where the build directory is, that wouldn't affect the\nL32958:         # build command.\nL32959:         self.build_base = None\nL32960:         self.build_lib = None\nL32961: \nL32962:         # Not defined yet because we don't know anything about\nL32963:         # documentation yet.\nL32964:         # self.install_man = None\nL32965:         # self.install_html = None\nL32966:         # self.install_info = None\nL32967: \nL32968:         self.record = None\nL32969: \nL32970:     # -- Option finalizing methods -------------------------------------\nL32971:     # (This is rather more involved than for most commands,\nL32972:     # because this is where the policy for installing third-\nL32973:     # party Python modules on various platforms given a wide\nL32974:     # array of user input is decided.  Yes, it's quite complex!)\nL32975: \nL32976:     def finalize_options(self) -> None:  # noqa: C901\nL32977:         \"\"\"Finalizes options.\"\"\"\nL32978:         # This method (and its helpers, like 'finalize_unix()',\nL32979:         # 'finalize_other()', and 'select_scheme()') is where the default\nL32980:         # installation directories for modules, extension modules, and\nL32981:         # anything else we care to install from a Python module\nL32982:         # distribution.  Thus, this code makes a pretty important policy\nL32983:         # statement about how third-party stuff is added to a Python\nL32984:         # installation!  Note that the actual work of installation is done\nL32985:         # by the relatively simple 'install_*' commands; they just take\nL32986:         # their orders from the installation directory options determined\nL32987:         # here.\nL32988: \nL32989:         # Check for errors/inconsistencies in the options; first, stuff\nL32990:         # that's wrong on any platform.\nL32991: \nL32992:         if (self.prefix or self.exec_prefix or self.home) and (\nL32993:             self.install_base or self.install_platbase\nL32994:         ):\nL32995:             raise DistutilsOptionError(\nL32996:                 \"must supply either prefix/exec-prefix/home or install-base/install-platbase -- not both\"\nL32997:             )\nL32998: \nL32999:         if self.home and (self.prefix or self.exec_prefix):\nL33000:             raise DistutilsOptionError(\nL33001:                 \"must supply either home or prefix/exec-prefix -- not both\"\nL33002:             )\nL33003: \nL33004:         if self.user and (\nL33005:             self.prefix\nL33006:             or self.exec_prefix\nL33007:             or self.home\nL33008:             or self.install_base\nL33009:             or self.install_platbase\nL33010:         ):\nL33011:             raise DistutilsOptionError(\nL33012:                 \"can't combine user with prefix, \"\nL33013:                 \"exec_prefix/home, or install_(plat)base\"\nL33014:             )\nL33015: \nL33016:         # Next, stuff that's wrong (or dubious) only on certain platforms.\nL33017:         if os.name != \"posix\":\nL33018:             if self.exec_prefix:\nL33019:                 self.warn(\"exec-prefix option ignored on this platform\")\nL33020:                 self.exec_prefix = None\nL33021: \nL33022:         # Now the interesting logic -- so interesting that we farm it out\nL33023:         # to other methods.  The goal of these methods is to set the final\nL33024:         # values for the install_{lib,scripts,data,...}  options, using as\nL33025:         # input a heady brew of prefix, exec_prefix, home, install_base,\nL33026:         # install_platbase, user-supplied versions of\nL33027:         # install_{purelib,platlib,lib,scripts,data,...}, and the\nL33028:         # install schemes.  Phew!\nL33029: \nL33030:         self.dump_dirs(\"pre-finalize_{unix,other}\")\nL33031: \nL33032:         if os.name == 'posix':\nL33033:             self.finalize_unix()\nL33034:         else:\nL33035:             self.finalize_other()\nL33036: \nL33037:         self.dump_dirs(\"post-finalize_{unix,other}()\")\nL33038: \nL33039:         # Expand configuration variables, tilde, etc. in self.install_base\nL33040:         # and self.install_platbase -- that way, we can use $base or\nL33041:         # $platbase in the other installation directories and not worry\nL33042:         # about needing recursive variable expansion (shudder).\nL33043: \nL33044:         py_version = sys.version.split()[0]\nL33045:         (prefix, exec_prefix) = get_config_vars('prefix', 'exec_prefix')\nL33046:         try:\nL33047:             abiflags = sys.abiflags\nL33048:         except AttributeError:\nL33049:             # sys.abiflags may not be defined on all platforms.\nL33050:             abiflags = ''\nL33051:         local_vars = {\nL33052:             'dist_name': self.distribution.get_name(),\nL33053:             'dist_version': self.distribution.get_version(),\nL33054:             'dist_fullname': self.distribution.get_fullname(),\nL33055:             'py_version': py_version,\nL33056:             'py_version_short': f'{sys.version_info.major}.{sys.version_info.minor}',\nL33057:             'py_version_nodot': f'{sys.version_info.major}{sys.version_info.minor}',\nL33058:             'sys_prefix': prefix,\nL33059:             'prefix': prefix,\nL33060:             'sys_exec_prefix': exec_prefix,\nL33061:             'exec_prefix': exec_prefix,\nL33062:             'abiflags': abiflags,\nL33063:             'platlibdir': getattr(sys, 'platlibdir', 'lib'),\nL33064:             'implementation_lower': _get_implementation().lower(),\nL33065:             'implementation': _get_implementation(),\nL33066:         }\nL33067: \nL33068:         # vars for compatibility on older Pythons\nL33069:         compat_vars = dict(\nL33070:             # Python 3.9 and earlier\nL33071:             py_version_nodot_plat=getattr(sys, 'winver', '').replace('.', ''),\nL33072:         )\nL33073: \nL33074:         if HAS_USER_SITE:\nL33075:             local_vars['userbase'] = self.install_userbase\nL33076:             local_vars['usersite'] = self.install_usersite\nL33077: \nL33078:         self.config_vars = collections.ChainMap(\nL33079:             local_vars,\nL33080:             sysconfig.get_config_vars(),\nL33081:             compat_vars,\nL33082:             fw.vars(),\nL33083:         )\nL33084: \nL33085:         self.expand_basedirs()\nL33086: \nL33087:         self.dump_dirs(\"post-expand_basedirs()\")\nL33088: \nL33089:         # Now define config vars for the base directories so we can expand\nL33090:         # everything else.\nL33091:         local_vars['base'] = self.install_base\nL33092:         local_vars['platbase'] = self.install_platbase\nL33093: \nL33094:         if DEBUG:\nL33095:             from pprint import pprint\nL33096: \nL33097:             print(\"config vars:\")\nL33098:             pprint(dict(self.config_vars))\nL33099: \nL33100:         # Expand \"~\" and configuration variables in the installation\nL33101:         # directories.\nL33102:         self.expand_dirs()\nL33103: \nL33104:         self.dump_dirs(\"post-expand_dirs()\")\nL33105: \nL33106:         # Create directories in the home dir:\nL33107:         if self.user:\nL33108:             self.create_home_path()\nL33109: \nL33110:         # Pick the actual directory to install all modules to: either\nL33111:         # install_purelib or install_platlib, depending on whether this\nL33112:         # module distribution is pure or not.  Of course, if the user\nL33113:         # already specified install_lib, use their selection.\nL33114:         if self.install_lib is None:\nL33115:             if self.distribution.has_ext_modules():  # has extensions: non-pure\nL33116:                 self.install_lib = self.install_platlib\nL33117:             else:\nL33118:                 self.install_lib = self.install_purelib\nL33119: \nL33120:         # Convert directories from Unix /-separated syntax to the local\nL33121:         # convention.\nL33122:         self.convert_paths(\nL33123:             'lib',\nL33124:             'purelib',\nL33125:             'platlib',\nL33126:             'scripts',\nL33127:             'data',\nL33128:             'headers',\nL33129:             'userbase',\nL33130:             'usersite',\nL33131:         )\nL33132: \nL33133:         # Deprecated\nL33134:         # Well, we're not actually fully completely finalized yet: we still\nL33135:         # have to deal with 'extra_path', which is the hack for allowing\nL33136:         # non-packagized module distributions (hello, Numerical Python!) to\nL33137:         # get their own directories.\nL33138:         self.handle_extra_path()\nL33139:         self.install_libbase = self.install_lib  # needed for .pth file\nL33140:         self.install_lib = os.path.join(self.install_lib, self.extra_dirs)\nL33141: \nL33142:         # If a new root directory was supplied, make all the installation\nL33143:         # dirs relative to it.\nL33144:         if self.root is not None:\nL33145:             self.change_roots(\nL33146:                 'libbase', 'lib', 'purelib', 'platlib', 'scripts', 'data', 'headers'\nL33147:             )\nL33148: \nL33149:         self.dump_dirs(\"after prepending root\")\nL33150: \nL33151:         # Find out the build directories, ie. where to install from.\nL33152:         self.set_undefined_options(\nL33153:             'build', ('build_base', 'build_base'), ('build_lib', 'build_lib')\nL33154:         )\nL33155: \nL33156:         # Punt on doc directories for now -- after all, we're punting on\nL33157:         # documentation completely!\nL33158: \nL33159:     def dump_dirs(self, msg) -> None:\nL33160:         \"\"\"Dumps the list of user options.\"\"\"\nL33161:         if not DEBUG:\nL33162:             return\nL33163:         from ..fancy_getopt import longopt_xlate\nL33164: \nL33165:         log.debug(msg + \":\")\nL33166:         for opt in self.user_options:\nL33167:             opt_name = opt[0]\nL33168:             if opt_name[-1] == \"=\":\nL33169:                 opt_name = opt_name[0:-1]\nL33170:             if opt_name in self.negative_opt:\nL33171:                 opt_name = self.negative_opt[opt_name]\nL33172:                 opt_name = opt_name.translate(longopt_xlate)\nL33173:                 val = not getattr(self, opt_name)\nL33174:             else:\nL33175:                 opt_name = opt_name.translate(longopt_xlate)\nL33176:                 val = getattr(self, opt_name)\nL33177:             log.debug(\"  %s: %s\", opt_name, val)\nL33178: \nL33179:     def finalize_unix(self) -> None:\nL33180:         \"\"\"Finalizes options for posix platforms.\"\"\"\nL33181:         if self.install_base is not None or self.install_platbase is not None:\nL33182:             incomplete_scheme = (\nL33183:                 (\nL33184:                     self.install_lib is None\nL33185:                     and self.install_purelib is None\nL33186:                     and self.install_platlib is None\nL33187:                 )\nL33188:                 or self.install_headers is None\nL33189:                 or self.install_scripts is None\nL33190:                 or self.install_data is None\nL33191:             )\nL33192:             if incomplete_scheme:\nL33193:                 raise DistutilsOptionError(\nL33194:                     \"install-base or install-platbase supplied, but \"\nL33195:                     \"installation scheme is incomplete\"\nL33196:                 )\nL33197:             return\nL33198: \nL33199:         if self.user:\nL33200:             if self.install_userbase is None:\nL33201:                 raise DistutilsPlatformError(\"User base directory is not specified\")\nL33202:             self.install_base = self.install_platbase = self.install_userbase\nL33203:             self.select_scheme(\"posix_user\")\nL33204:         elif self.home is not None:\nL33205:             self.install_base = self.install_platbase = self.home\nL33206:             self.select_scheme(\"posix_home\")\nL33207:         else:\nL33208:             if self.prefix is None:\nL33209:                 if self.exec_prefix is not None:\nL33210:                     raise DistutilsOptionError(\nL33211:                         \"must not supply exec-prefix without prefix\"\nL33212:                     )\nL33213: \nL33214:                 # Allow Fedora to add components to the prefix\nL33215:                 _prefix_addition = getattr(sysconfig, '_prefix_addition', \"\")\nL33216: \nL33217:                 self.prefix = os.path.normpath(sys.prefix) + _prefix_addition\nL33218:                 self.exec_prefix = os.path.normpath(sys.exec_prefix) + _prefix_addition\nL33219: \nL33220:             else:\nL33221:                 if self.exec_prefix is None:\nL33222:                     self.exec_prefix = self.prefix\nL33223: \nL33224:             self.install_base = self.prefix\nL33225:             self.install_platbase = self.exec_prefix\nL33226:             self.select_scheme(\"posix_prefix\")\nL33227: \nL33228:     def finalize_other(self) -> None:\nL33229:         \"\"\"Finalizes options for non-posix platforms\"\"\"\nL33230:         if self.user:\nL33231:             if self.install_userbase is None:\nL33232:                 raise DistutilsPlatformError(\"User base directory is not specified\")\nL33233:             self.install_base = self.install_platbase = self.install_userbase\nL33234:             self.select_scheme(os.name + \"_user\")\nL33235:         elif self.home is not None:\nL33236:             self.install_base = self.install_platbase = self.home\nL33237:             self.select_scheme(\"posix_home\")\nL33238:         else:\nL33239:             if self.prefix is None:\nL33240:                 self.prefix = os.path.normpath(sys.prefix)\nL33241: \nL33242:             self.install_base = self.install_platbase = self.prefix\nL33243:             try:\nL33244:                 self.select_scheme(os.name)\nL33245:             except KeyError:\nL33246:                 raise DistutilsPlatformError(\nL33247:                     f\"I don't know how to install stuff on '{os.name}'\"\nL33248:                 )\nL33249: \nL33250:     def select_scheme(self, name) -> None:\nL33251:         _select_scheme(self, name)\nL33252: \nL33253:     def _expand_attrs(self, attrs):\nL33254:         for attr in attrs:\nL33255:             val = getattr(self, attr)\nL33256:             if val is not None:\nL33257:                 if os.name in ('posix', 'nt'):\nL33258:                     val = os.path.expanduser(val)\nL33259:                 val = subst_vars(val, self.config_vars)\nL33260:                 setattr(self, attr, val)\nL33261: \nL33262:     def expand_basedirs(self) -> None:\nL33263:         \"\"\"Calls `os.path.expanduser` on install_base, install_platbase and\nL33264:         root.\"\"\"\nL33265:         self._expand_attrs(['install_base', 'install_platbase', 'root'])\nL33266: \nL33267:     def expand_dirs(self) -> None:\nL33268:         \"\"\"Calls `os.path.expanduser` on install dirs.\"\"\"\nL33269:         self._expand_attrs([\nL33270:             'install_purelib',\nL33271:             'install_platlib',\nL33272:             'install_lib',\nL33273:             'install_headers',\nL33274:             'install_scripts',\nL33275:             'install_data',\nL33276:         ])\nL33277: \nL33278:     def convert_paths(self, *names) -> None:\nL33279:         \"\"\"Call `convert_path` over `names`.\"\"\"\nL33280:         for name in names:\nL33281:             attr = \"install_\" + name\nL33282:             setattr(self, attr, convert_path(getattr(self, attr)))\nL33283: \nL33284:     def handle_extra_path(self) -> None:\nL33285:         \"\"\"Set `path_file` and `extra_dirs` using `extra_path`.\"\"\"\nL33286:         if self.extra_path is None:\nL33287:             self.extra_path = self.distribution.extra_path\nL33288: \nL33289:         if self.extra_path is not None:\nL33290:             log.warning(\nL33291:                 \"Distribution option extra_path is deprecated. \"\nL33292:                 \"See issue27919 for details.\"\nL33293:             )\nL33294:             if isinstance(self.extra_path, str):\nL33295:                 self.extra_path = self.extra_path.split(',')\nL33296: \nL33297:             if len(self.extra_path) == 1:\nL33298:                 path_file = extra_dirs = self.extra_path[0]\nL33299:             elif len(self.extra_path) == 2:\nL33300:                 path_file, extra_dirs = self.extra_path\nL33301:             else:\nL33302:                 raise DistutilsOptionError(\nL33303:                     \"'extra_path' option must be a list, tuple, or \"\nL33304:                     \"comma-separated string with 1 or 2 elements\"\nL33305:                 )\nL33306: \nL33307:             # convert to local form in case Unix notation used (as it\nL33308:             # should be in setup scripts)\nL33309:             extra_dirs = convert_path(extra_dirs)\nL33310:         else:\nL33311:             path_file = None\nL33312:             extra_dirs = ''\nL33313: \nL33314:         # XXX should we warn if path_file and not extra_dirs? (in which\nL33315:         # case the path file would be harmless but pointless)\nL33316:         self.path_file = path_file\nL33317:         self.extra_dirs = extra_dirs\nL33318: \nL33319:     def change_roots(self, *names) -> None:\nL33320:         \"\"\"Change the install directories pointed by name using root.\"\"\"\nL33321:         for name in names:\nL33322:             attr = \"install_\" + name\nL33323:             setattr(self, attr, change_root(self.root, getattr(self, attr)))\nL33324: \nL33325:     def create_home_path(self) -> None:\nL33326:         \"\"\"Create directories under ~.\"\"\"\nL33327:         if not self.user:\nL33328:             return\nL33329:         home = convert_path(os.path.expanduser(\"~\"))\nL33330:         for path in self.config_vars.values():\nL33331:             if str(path).startswith(home) and not os.path.isdir(path):\nL33332:                 self.debug_print(f\"os.makedirs('{path}', 0o700)\")\nL33333:                 os.makedirs(path, 0o700)\nL33334: \nL33335:     # -- Command execution methods -------------------------------------\nL33336: \nL33337:     def run(self):\nL33338:         \"\"\"Runs the command.\"\"\"\nL33339:         # Obviously have to build before we can install\nL33340:         if not self.skip_build:\nL33341:             self.run_command('build')\nL33342:             # If we built for any other platform, we can't install.\nL33343:             build_plat = self.distribution.get_command_obj('build').plat_name\nL33344:             # check warn_dir - it is a clue that the 'install' is happening\nL33345:             # internally, and not to sys.path, so we don't check the platform\nL33346:             # matches what we are running.\nL33347:             if self.warn_dir and build_plat != get_platform():\nL33348:                 raise DistutilsPlatformError(\"Can't install when cross-compiling\")\nL33349: \nL33350:         # Run all sub-commands (at least those that need to be run)\nL33351:         for cmd_name in self.get_sub_commands():\nL33352:             self.run_command(cmd_name)\nL33353: \nL33354:         if self.path_file:\nL33355:             self.create_path_file()\nL33356: \nL33357:         # write list of installed files, if requested.\nL33358:         if self.record:\nL33359:             outputs = self.get_outputs()\nL33360:             if self.root:  # strip any package prefix\nL33361:                 root_len = len(self.root)\nL33362:                 for counter in range(len(outputs)):\nL33363:                     outputs[counter] = outputs[counter][root_len:]\nL33364:             self.execute(\nL33365:                 write_file,\nL33366:                 (self.record, outputs),\nL33367:                 f\"writing list of installed files to '{self.record}'\",\nL33368:             )\nL33369: \nL33370:         sys_path = map(os.path.normpath, sys.path)\nL33371:         sys_path = map(os.path.normcase, sys_path)\nL33372:         install_lib = os.path.normcase(os.path.normpath(self.install_lib))\nL33373:         if (\nL33374:             self.warn_dir\nL33375:             and not (self.path_file and self.install_path_file)\nL33376:             and install_lib not in sys_path\nL33377:         ):\nL33378:             log.debug(\nL33379:                 (\nL33380:                     \"modules installed to '%s', which is not in \"\nL33381:                     \"Python's module search path (sys.path) -- \"\nL33382:                     \"you'll have to change the search path yourself\"\nL33383:                 ),\nL33384:                 self.install_lib,\nL33385:             )\nL33386: \nL33387:     def create_path_file(self):\nL33388:         \"\"\"Creates the .pth file\"\"\"\nL33389:         filename = os.path.join(self.install_libbase, self.path_file + \".pth\")\nL33390:         if self.install_path_file:\nL33391:             self.execute(\nL33392:                 write_file, (filename, [self.extra_dirs]), f\"creating {filename}\"\nL33393:             )\nL33394:         else:\nL33395:             self.warn(f\"path file '{filename}' not created\")\nL33396: \nL33397:     # -- Reporting methods ---------------------------------------------\nL33398: \nL33399:     def get_outputs(self):\nL33400:         \"\"\"Assembles the outputs of all the sub-commands.\"\"\"\nL33401:         outputs = []\nL33402:         for cmd_name in self.get_sub_commands():\nL33403:             cmd = self.get_finalized_command(cmd_name)\nL33404:             # Add the contents of cmd.get_outputs(), ensuring\nL33405:             # that outputs doesn't contain duplicate entries\nL33406:             for filename in cmd.get_outputs():\nL33407:                 if filename not in outputs:\nL33408:                     outputs.append(filename)\nL33409: \nL33410:         if self.path_file and self.install_path_file:\nL33411:             outputs.append(os.path.join(self.install_libbase, self.path_file + \".pth\"))\nL33412: \nL33413:         return outputs\nL33414: \nL33415:     def get_inputs(self):\nL33416:         \"\"\"Returns the inputs of all the sub-commands\"\"\"\nL33417:         # XXX gee, this looks familiar ;-(\nL33418:         inputs = []\nL33419:         for cmd_name in self.get_sub_commands():\nL33420:             cmd = self.get_finalized_command(cmd_name)\nL33421:             inputs.extend(cmd.get_inputs())\nL33422: \nL33423:         return inputs\nL33424: \nL33425:     # -- Predicates for sub-command list -------------------------------\nL33426: \nL33427:     def has_lib(self):\nL33428:         \"\"\"Returns true if the current distribution has any Python\nL33429:         modules to install.\"\"\"\nL33430:         return (\nL33431:             self.distribution.has_pure_modules() or self.distribution.has_ext_modules()\nL33432:         )\nL33433: \nL33434:     def has_headers(self):\nL33435:         \"\"\"Returns true if the current distribution has any headers to\nL33436:         install.\"\"\"\nL33437:         return self.distribution.has_headers()\nL33438: \nL33439:     def has_scripts(self):\nL33440:         \"\"\"Returns true if the current distribution has any scripts to.\nL33441:         install.\"\"\"\nL33442:         return self.distribution.has_scripts()\nL33443: \nL33444:     def has_data(self):\nL33445:         \"\"\"Returns true if the current distribution has any data to.\nL33446:         install.\"\"\"\nL33447:         return self.distribution.has_data_files()\nL33448: \nL33449:     # 'sub_commands': a list of commands this command might have to run to\nL33450:     # get its work done.  See cmd.py for more info.\nL33451:     sub_commands = [\nL33452:         ('install_lib', has_lib),\nL33453:         ('install_headers', has_headers),\nL33454:         ('install_scripts', has_scripts),\nL33455:         ('install_data', has_data),\nL33456:         ('install_egg_info', lambda self: True),\nL33457:     ]\nL33458: \nL33459: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/install_data.py\nL33460: #!/usr/bin/env python3\nL33461: \"\"\"distutils.command.install_data\nL33462: \nL33463: Implements the Distutils 'install_data' command, for installing\nL33464: platform-independent data files.\"\"\"\nL33465: \nL33466: # contributed by Bastian Kleineidam\nL33467: \nL33468: from __future__ import annotations\nL33469: \nL33470: import functools\nL33471: import os\nL33472: from collections.abc import Iterable\nL33473: from typing import ClassVar\nL33474: \nL33475: from ..core import Command\nL33476: from ..util import change_root, convert_path\nL33477: \nL33478: \nL33479: class install_data(Command):\nL33480:     description = \"install data files\"\nL33481: \nL33482:     user_options = [\nL33483:         (\nL33484:             'install-dir=',\nL33485:             'd',\nL33486:             \"base directory for installing data files [default: installation base dir]\",\nL33487:         ),\nL33488:         ('root=', None, \"install everything relative to this alternate root directory\"),\nL33489:         ('force', 'f', \"force installation (overwrite existing files)\"),\nL33490:     ]\nL33491: \nL33492:     boolean_options: ClassVar[list[str]] = ['force']\nL33493: \nL33494:     def initialize_options(self):\nL33495:         self.install_dir = None\nL33496:         self.outfiles = []\nL33497:         self.root = None\nL33498:         self.force = False\nL33499:         self.data_files = self.distribution.data_files\nL33500:         self.warn_dir = True\nL33501: \nL33502:     def finalize_options(self) -> None:\nL33503:         self.set_undefined_options(\nL33504:             'install',\nL33505:             ('install_data', 'install_dir'),\nL33506:             ('root', 'root'),\nL33507:             ('force', 'force'),\nL33508:         )\nL33509: \nL33510:     def run(self) -> None:\nL33511:         self.mkpath(self.install_dir)\nL33512:         for f in self.data_files:\nL33513:             self._copy(f)\nL33514: \nL33515:     @functools.singledispatchmethod\nL33516:     def _copy(self, f: tuple[str | os.PathLike, Iterable[str | os.PathLike]]):\nL33517:         # it's a tuple with path to install to and a list of files\nL33518:         dir = convert_path(f[0])\nL33519:         if not os.path.isabs(dir):\nL33520:             dir = os.path.join(self.install_dir, dir)\nL33521:         elif self.root:\nL33522:             dir = change_root(self.root, dir)\nL33523:         self.mkpath(dir)\nL33524: \nL33525:         if f[1] == []:\nL33526:             # If there are no files listed, the user must be\nL33527:             # trying to create an empty directory, so add the\nL33528:             # directory to the list of output files.\nL33529:             self.outfiles.append(dir)\nL33530:         else:\nL33531:             # Copy files, adding them to the list of output files.\nL33532:             for data in f[1]:\nL33533:                 data = convert_path(data)\nL33534:                 (out, _) = self.copy_file(data, dir)\nL33535:                 self.outfiles.append(out)\nL33536: \nL33537:     @_copy.register(str)\nL33538:     @_copy.register(os.PathLike)\nL33539:     def _(self, f: str | os.PathLike):\nL33540:         # it's a simple file, so copy it\nL33541:         f = convert_path(f)\nL33542:         if self.warn_dir:\nL33543:             self.warn(\nL33544:                 \"setup script did not provide a directory for \"\nL33545:                 f\"'{f}' -- installing right in '{self.install_dir}'\"\nL33546:             )\nL33547:         (out, _) = self.copy_file(f, self.install_dir)\nL33548:         self.outfiles.append(out)\nL33549: \nL33550:     def get_inputs(self):\nL33551:         return self.data_files or []\nL33552: \nL33553:     def get_outputs(self):\nL33554:         return self.outfiles\nL33555: \nL33556: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/install_headers.py\nL33557: #!/usr/bin/env python3\nL33558: \"\"\"distutils.command.install_headers\nL33559: \nL33560: Implements the Distutils 'install_headers' command, to install C/C++ header\nL33561: files to the Python include directory.\"\"\"\nL33562: \nL33563: from typing import ClassVar\nL33564: \nL33565: from ..core import Command\nL33566: \nL33567: \nL33568: # XXX force is never used\nL33569: class install_headers(Command):\nL33570:     description = \"install C/C++ header files\"\nL33571: \nL33572:     user_options: ClassVar[list[tuple[str, str, str]]] = [\nL33573:         ('install-dir=', 'd', \"directory to install header files to\"),\nL33574:         ('force', 'f', \"force installation (overwrite existing files)\"),\nL33575:     ]\nL33576: \nL33577:     boolean_options: ClassVar[list[str]] = ['force']\nL33578: \nL33579:     def initialize_options(self):\nL33580:         self.install_dir = None\nL33581:         self.force = False\nL33582:         self.outfiles = []\nL33583: \nL33584:     def finalize_options(self):\nL33585:         self.set_undefined_options(\nL33586:             'install', ('install_headers', 'install_dir'), ('force', 'force')\nL33587:         )\nL33588: \nL33589:     def run(self):\nL33590:         headers = self.distribution.headers\nL33591:         if not headers:\nL33592:             return\nL33593: \nL33594:         self.mkpath(self.install_dir)\nL33595:         for header in headers:\nL33596:             (out, _) = self.copy_file(header, self.install_dir)\nL33597:             self.outfiles.append(out)\nL33598: \nL33599:     def get_inputs(self):\nL33600:         return self.distribution.headers or []\nL33601: \nL33602:     def get_outputs(self):\nL33603:         return self.outfiles\nL33604: \nL33605: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/install_lib.py\nL33606: #!/usr/bin/env python3\nL33607: \"\"\"distutils.command.install_lib\nL33608: \nL33609: Implements the Distutils 'install_lib' command\nL33610: (install all Python modules).\"\"\"\nL33611: \nL33612: from __future__ import annotations\nL33613: \nL33614: import importlib.util\nL33615: import os\nL33616: import sys\nL33617: from typing import Any, ClassVar\nL33618: \nL33619: from ..core import Command\nL33620: from ..errors import DistutilsOptionError\nL33621: \nL33622: # Extension for Python source files.\nL33623: PYTHON_SOURCE_EXTENSION = \".py\"\nL33624: \nL33625: \nL33626: class install_lib(Command):\nL33627:     description = \"install all Python modules (extensions and pure Python)\"\nL33628: \nL33629:     # The byte-compilation options are a tad confusing.  Here are the\nL33630:     # possible scenarios:\nL33631:     #   1) no compilation at all (--no-compile --no-optimize)\nL33632:     #   2) compile .pyc only (--compile --no-optimize; default)\nL33633:     #   3) compile .pyc and \"opt-1\" .pyc (--compile --optimize)\nL33634:     #   4) compile \"opt-1\" .pyc only (--no-compile --optimize)\nL33635:     #   5) compile .pyc and \"opt-2\" .pyc (--compile --optimize-more)\nL33636:     #   6) compile \"opt-2\" .pyc only (--no-compile --optimize-more)\nL33637:     #\nL33638:     # The UI for this is two options, 'compile' and 'optimize'.\nL33639:     # 'compile' is strictly boolean, and only decides whether to\nL33640:     # generate .pyc files.  'optimize' is three-way (0, 1, or 2), and\nL33641:     # decides both whether to generate .pyc files and what level of\nL33642:     # optimization to use.\nL33643: \nL33644:     user_options = [\nL33645:         ('install-dir=', 'd', \"directory to install to\"),\nL33646:         ('build-dir=', 'b', \"build directory (where to install from)\"),\nL33647:         ('force', 'f', \"force installation (overwrite existing files)\"),\nL33648:         ('compile', 'c', \"compile .py to .pyc [default]\"),\nL33649:         ('no-compile', None, \"don't compile .py files\"),\nL33650:         (\nL33651:             'optimize=',\nL33652:             'O',\nL33653:             \"also compile with optimization: -O1 for \\\"python -O\\\", \"\nL33654:             \"-O2 for \\\"python -OO\\\", and -O0 to disable [default: -O0]\",\nL33655:         ),\nL33656:         ('skip-build', None, \"skip the build steps\"),\nL33657:     ]\nL33658: \nL33659:     boolean_options: ClassVar[list[str]] = ['force', 'compile', 'skip-build']\nL33660:     negative_opt: ClassVar[dict[str, str]] = {'no-compile': 'compile'}\nL33661: \nL33662:     def initialize_options(self):\nL33663:         # let the 'install' command dictate our installation directory\nL33664:         self.install_dir = None\nL33665:         self.build_dir = None\nL33666:         self.force = False\nL33667:         self.compile = None\nL33668:         self.optimize = None\nL33669:         self.skip_build = None\nL33670: \nL33671:     def finalize_options(self) -> None:\nL33672:         # Get all the information we need to install pure Python modules\nL33673:         # from the umbrella 'install' command -- build (source) directory,\nL33674:         # install (target) directory, and whether to compile .py files.\nL33675:         self.set_undefined_options(\nL33676:             'install',\nL33677:             ('build_lib', 'build_dir'),\nL33678:             ('install_lib', 'install_dir'),\nL33679:             ('force', 'force'),\nL33680:             ('compile', 'compile'),\nL33681:             ('optimize', 'optimize'),\nL33682:             ('skip_build', 'skip_build'),\nL33683:         )\nL33684: \nL33685:         if self.compile is None:\nL33686:             self.compile = True\nL33687:         if self.optimize is None:\nL33688:             self.optimize = False\nL33689: \nL33690:         if not isinstance(self.optimize, int):\nL33691:             try:\nL33692:                 self.optimize = int(self.optimize)\nL33693:             except ValueError:\nL33694:                 pass\nL33695:             if self.optimize not in (0, 1, 2):\nL33696:                 raise DistutilsOptionError(\"optimize must be 0, 1, or 2\")\nL33697: \nL33698:     def run(self) -> None:\nL33699:         # Make sure we have built everything we need first\nL33700:         self.build()\nL33701: \nL33702:         # Install everything: simply dump the entire contents of the build\nL33703:         # directory to the installation directory (that's the beauty of\nL33704:         # having a build directory!)\nL33705:         outfiles = self.install()\nL33706: \nL33707:         # (Optionally) compile .py to .pyc\nL33708:         if outfiles is not None and self.distribution.has_pure_modules():\nL33709:             self.byte_compile(outfiles)\nL33710: \nL33711:     # -- Top-level worker functions ------------------------------------\nL33712:     # (called from 'run()')\nL33713: \nL33714:     def build(self) -> None:\nL33715:         if not self.skip_build:\nL33716:             if self.distribution.has_pure_modules():\nL33717:                 self.run_command('build_py')\nL33718:             if self.distribution.has_ext_modules():\nL33719:                 self.run_command('build_ext')\nL33720: \nL33721:     # Any: https://typing.readthedocs.io/en/latest/guides/writing_stubs.html#the-any-trick\nL33722:     def install(self) -> list[str] | Any:\nL33723:         if os.path.isdir(self.build_dir):\nL33724:             outfiles = self.copy_tree(self.build_dir, self.install_dir)\nL33725:         else:\nL33726:             self.warn(\nL33727:                 f\"'{self.build_dir}' does not exist -- no Python modules to install\"\nL33728:             )\nL33729:             return\nL33730:         return outfiles\nL33731: \nL33732:     def byte_compile(self, files) -> None:\nL33733:         if sys.dont_write_bytecode:\nL33734:             self.warn('byte-compiling is disabled, skipping.')\nL33735:             return\nL33736: \nL33737:         from ..util import byte_compile\nL33738: \nL33739:         # Get the \"--root\" directory supplied to the \"install\" command,\nL33740:         # and use it as a prefix to strip off the purported filename\nL33741:         # encoded in bytecode files.  This is far from complete, but it\nL33742:         # should at least generate usable bytecode in RPM distributions.\nL33743:         install_root = self.get_finalized_command('install').root\nL33744: \nL33745:         if self.compile:\nL33746:             byte_compile(\nL33747:                 files,\nL33748:                 optimize=0,\nL33749:                 force=self.force,\nL33750:                 prefix=install_root,\nL33751:                 dry_run=self.dry_run,\nL33752:             )\nL33753:         if self.optimize > 0:\nL33754:             byte_compile(\nL33755:                 files,\nL33756:                 optimize=self.optimize,\nL33757:                 force=self.force,\nL33758:                 prefix=install_root,\nL33759:                 verbose=self.verbose,\nL33760:                 dry_run=self.dry_run,\nL33761:             )\nL33762: \nL33763:     # -- Utility methods -----------------------------------------------\nL33764: \nL33765:     def _mutate_outputs(self, has_any, build_cmd, cmd_option, output_dir):\nL33766:         if not has_any:\nL33767:             return []\nL33768: \nL33769:         build_cmd = self.get_finalized_command(build_cmd)\nL33770:         build_files = build_cmd.get_outputs()\nL33771:         build_dir = getattr(build_cmd, cmd_option)\nL33772: \nL33773:         prefix_len = len(build_dir) + len(os.sep)\nL33774:         outputs = [os.path.join(output_dir, file[prefix_len:]) for file in build_files]\nL33775: \nL33776:         return outputs\nL33777: \nL33778:     def _bytecode_filenames(self, py_filenames):\nL33779:         bytecode_files = []\nL33780:         for py_file in py_filenames:\nL33781:             # Since build_py handles package data installation, the\nL33782:             # list of outputs can contain more than just .py files.\nL33783:             # Make sure we only report bytecode for the .py files.\nL33784:             ext = os.path.splitext(os.path.normcase(py_file))[1]\nL33785:             if ext != PYTHON_SOURCE_EXTENSION:\nL33786:                 continue\nL33787:             if self.compile:\nL33788:                 bytecode_files.append(\nL33789:                     importlib.util.cache_from_source(py_file, optimization='')\nL33790:                 )\nL33791:             if self.optimize > 0:\nL33792:                 bytecode_files.append(\nL33793:                     importlib.util.cache_from_source(\nL33794:                         py_file, optimization=self.optimize\nL33795:                     )\nL33796:                 )\nL33797: \nL33798:         return bytecode_files\nL33799: \nL33800:     # -- External interface --------------------------------------------\nL33801:     # (called by outsiders)\nL33802: \nL33803:     def get_outputs(self):\nL33804:         \"\"\"Return the list of files that would be installed if this command\nL33805:         were actually run.  Not affected by the \"dry-run\" flag or whether\nL33806:         modules have actually been built yet.\nL33807:         \"\"\"\nL33808:         pure_outputs = self._mutate_outputs(\nL33809:             self.distribution.has_pure_modules(),\nL33810:             'build_py',\nL33811:             'build_lib',\nL33812:             self.install_dir,\nL33813:         )\nL33814:         if self.compile:\nL33815:             bytecode_outputs = self._bytecode_filenames(pure_outputs)\nL33816:         else:\nL33817:             bytecode_outputs = []\nL33818: \nL33819:         ext_outputs = self._mutate_outputs(\nL33820:             self.distribution.has_ext_modules(),\nL33821:             'build_ext',\nL33822:             'build_lib',\nL33823:             self.install_dir,\nL33824:         )\nL33825: \nL33826:         return pure_outputs + bytecode_outputs + ext_outputs\nL33827: \nL33828:     def get_inputs(self):\nL33829:         \"\"\"Get the list of files that are input to this command, ie. the\nL33830:         files that get installed as they are named in the build tree.\nL33831:         The files in this list correspond one-to-one to the output\nL33832:         filenames returned by 'get_outputs()'.\nL33833:         \"\"\"\nL33834:         inputs = []\nL33835: \nL33836:         if self.distribution.has_pure_modules():\nL33837:             build_py = self.get_finalized_command('build_py')\nL33838:             inputs.extend(build_py.get_outputs())\nL33839: \nL33840:         if self.distribution.has_ext_modules():\nL33841:             build_ext = self.get_finalized_command('build_ext')\nL33842:             inputs.extend(build_ext.get_outputs())\nL33843: \nL33844:         return inputs\nL33845: \nL33846: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/install_scripts.py\nL33847: #!/usr/bin/env python3\nL33848: \"\"\"distutils.command.install_scripts\nL33849: \nL33850: Implements the Distutils 'install_scripts' command, for installing\nL33851: Python scripts.\"\"\"\nL33852: \nL33853: # contributed by Bastian Kleineidam\nL33854: \nL33855: import os\nL33856: from distutils._log import log\nL33857: from stat import ST_MODE\nL33858: from typing import ClassVar\nL33859: \nL33860: from ..core import Command\nL33861: \nL33862: \nL33863: class install_scripts(Command):\nL33864:     description = \"install scripts (Python or otherwise)\"\nL33865: \nL33866:     user_options = [\nL33867:         ('install-dir=', 'd', \"directory to install scripts to\"),\nL33868:         ('build-dir=', 'b', \"build directory (where to install from)\"),\nL33869:         ('force', 'f', \"force installation (overwrite existing files)\"),\nL33870:         ('skip-build', None, \"skip the build steps\"),\nL33871:     ]\nL33872: \nL33873:     boolean_options: ClassVar[list[str]] = ['force', 'skip-build']\nL33874: \nL33875:     def initialize_options(self):\nL33876:         self.install_dir = None\nL33877:         self.force = False\nL33878:         self.build_dir = None\nL33879:         self.skip_build = None\nL33880: \nL33881:     def finalize_options(self) -> None:\nL33882:         self.set_undefined_options('build', ('build_scripts', 'build_dir'))\nL33883:         self.set_undefined_options(\nL33884:             'install',\nL33885:             ('install_scripts', 'install_dir'),\nL33886:             ('force', 'force'),\nL33887:             ('skip_build', 'skip_build'),\nL33888:         )\nL33889: \nL33890:     def run(self) -> None:\nL33891:         if not self.skip_build:\nL33892:             self.run_command('build_scripts')\nL33893:         self.outfiles = self.copy_tree(self.build_dir, self.install_dir)\nL33894:         if os.name == 'posix':\nL33895:             # Set the executable bits (owner, group, and world) on\nL33896:             # all the scripts we just installed.\nL33897:             for file in self.get_outputs():\nL33898:                 if self.dry_run:\nL33899:                     log.info(\"changing mode of %s\", file)\nL33900:                 else:\nL33901:                     mode = ((os.stat(file)[ST_MODE]) | 0o555) & 0o7777\nL33902:                     log.info(\"changing mode of %s to %o\", file, mode)\nL33903:                     os.chmod(file, mode)\nL33904: \nL33905:     def get_inputs(self):\nL33906:         return self.distribution.scripts or []\nL33907: \nL33908:     def get_outputs(self):\nL33909:         return self.outfiles or []\nL33910: \nL33911: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/command/sdist.py\nL33912: #!/usr/bin/env python3\nL33913: \"\"\"distutils.command.sdist\nL33914: \nL33915: Implements the Distutils 'sdist' command (create a source distribution).\"\"\"\nL33916: \nL33917: from __future__ import annotations\nL33918: \nL33919: import os\nL33920: import sys\nL33921: from collections.abc import Callable\nL33922: from distutils import archive_util, dir_util, file_util\nL33923: from distutils._log import log\nL33924: from glob import glob\nL33925: from itertools import filterfalse\nL33926: from typing import ClassVar\nL33927: \nL33928: from ..core import Command\nL33929: from ..errors import DistutilsOptionError, DistutilsTemplateError\nL33930: from ..filelist import FileList\nL33931: from ..text_file import TextFile\nL33932: from ..util import convert_path\nL33933: \nL33934: \nL33935: def show_formats():\nL33936:     \"\"\"Print all possible values for the 'formats' option (used by\nL33937:     the \"--help-formats\" command-line option).\nL33938:     \"\"\"\nL33939:     from ..archive_util import ARCHIVE_FORMATS\nL33940:     from ..fancy_getopt import FancyGetopt\nL33941: \nL33942:     formats = sorted(\nL33943:         (\"formats=\" + format, None, ARCHIVE_FORMATS[format][2])\nL33944:         for format in ARCHIVE_FORMATS.keys()\nL33945:     )\nL33946:     FancyGetopt(formats).print_help(\"List of available source distribution formats:\")\nL33947: \nL33948: \nL33949: class sdist(Command):\nL33950:     description = \"create a source distribution (tarball, zip file, etc.)\"\nL33951: \nL33952:     def checking_metadata(self) -> bool:\nL33953:         \"\"\"Callable used for the check sub-command.\nL33954: \nL33955:         Placed here so user_options can view it\"\"\"\nL33956:         return self.metadata_check\nL33957: \nL33958:     user_options = [\nL33959:         ('template=', 't', \"name of manifest template file [default: MANIFEST.in]\"),\nL33960:         ('manifest=', 'm', \"name of manifest file [default: MANIFEST]\"),\nL33961:         (\nL33962:             'use-defaults',\nL33963:             None,\nL33964:             \"include the default file set in the manifest \"\nL33965:             \"[default; disable with --no-defaults]\",\nL33966:         ),\nL33967:         ('no-defaults', None, \"don't include the default file set\"),\nL33968:         (\nL33969:             'prune',\nL33970:             None,\nL33971:             \"specifically exclude files/directories that should not be \"\nL33972:             \"distributed (build tree, RCS/CVS dirs, etc.) \"\nL33973:             \"[default; disable with --no-prune]\",\nL33974:         ),\nL33975:         ('no-prune', None, \"don't automatically exclude anything\"),\nL33976:         (\nL33977:             'manifest-only',\nL33978:             'o',\nL33979:             \"just regenerate the manifest and then stop (implies --force-manifest)\",\nL33980:         ),\nL33981:         (\nL33982:             'force-manifest',\nL33983:             'f',\nL33984:             \"forcibly regenerate the manifest and carry on as usual. \"\nL33985:             \"Deprecated: now the manifest is always regenerated.\",\nL33986:         ),\nL33987:         ('formats=', None, \"formats for source distribution (comma-separated list)\"),\nL33988:         (\nL33989:             'keep-temp',\nL33990:             'k',\nL33991:             \"keep the distribution tree around after creating \" + \"archive file(s)\",\nL33992:         ),\nL33993:         (\nL33994:             'dist-dir=',\nL33995:             'd',\nL33996:             \"directory to put the source distribution archive(s) in [default: dist]\",\nL33997:         ),\nL33998:         (\nL33999:             'metadata-check',\nL34000:             None,\nL34001:             \"Ensure that all required elements of meta-data \"\nL34002:             \"are supplied. Warn if any missing. [default]\",\nL34003:         ),\nL34004:         (\nL34005:             'owner=',\nL34006:             'u',\nL34007:             \"Owner name used when creating a tar file [default: current user]\",\nL34008:         ),\nL34009:         (\nL34010:             'group=',\nL34011:             'g',\nL34012:             \"Group name used when creating a tar file [default: current group]\",\nL34013:         ),\nL34014:     ]\nL34015: \nL34016:     boolean_options: ClassVar[list[str]] = [\nL34017:         'use-defaults',\nL34018:         'prune',\nL34019:         'manifest-only',\nL34020:         'force-manifest',\nL34021:         'keep-temp',\nL34022:         'metadata-check',\nL34023:     ]\nL34024: \nL34025:     help_options: ClassVar[list[tuple[str, str | None, str, Callable[[], object]]]] = [\nL34026:         ('help-formats', None, \"list available distribution formats\", show_formats),\nL34027:     ]\nL34028: \nL34029:     negative_opt: ClassVar[dict[str, str]] = {\nL34030:         'no-defaults': 'use-defaults',\nL34031:         'no-prune': 'prune',\nL34032:     }\nL34033: \nL34034:     sub_commands = [('check', checking_metadata)]\nL34035: \nL34036:     READMES: ClassVar[tuple[str, ...]] = ('README', 'README.txt', 'README.rst')\nL34037: \nL34038:     def initialize_options(self):\nL34039:         # 'template' and 'manifest' are, respectively, the names of\nL34040:         # the manifest template and manifest file.\nL34041:         self.template = None\nL34042:         self.manifest = None\nL34043: \nL34044:         # 'use_defaults': if true, we will include the default file set\nL34045:         # in the manifest\nL34046:         self.use_defaults = True\nL34047:         self.prune = True\nL34048: \nL34049:         self.manifest_only = False\nL34050:         self.force_manifest = False\nL34051: \nL34052:         self.formats = ['gztar']\nL34053:         self.keep_temp = False\nL34054:         self.dist_dir = None\nL34055: \nL34056:         self.archive_files = None\nL34057:         self.metadata_check = True\nL34058:         self.owner = None\nL34059:         self.group = None\nL34060: \nL34061:     def finalize_options(self) -> None:\nL34062:         if self.manifest is None:\nL34063:             self.manifest = \"MANIFEST\"\nL34064:         if self.template is None:\nL34065:             self.template = \"MANIFEST.in\"\nL34066: \nL34067:         self.ensure_string_list('formats')\nL34068: \nL34069:         bad_format = archive_util.check_archive_formats(self.formats)\nL34070:         if bad_format:\nL34071:             raise DistutilsOptionError(f\"unknown archive format '{bad_format}'\")\nL34072: \nL34073:         if self.dist_dir is None:\nL34074:             self.dist_dir = \"dist\"\nL34075: \nL34076:     def run(self) -> None:\nL34077:         # 'filelist' contains the list of files that will make up the\nL34078:         # manifest\nL34079:         self.filelist = FileList()\nL34080: \nL34081:         # Run sub commands\nL34082:         for cmd_name in self.get_sub_commands():\nL34083:             self.run_command(cmd_name)\nL34084: \nL34085:         # Do whatever it takes to get the list of files to process\nL34086:         # (process the manifest template, read an existing manifest,\nL34087:         # whatever).  File list is accumulated in 'self.filelist'.\nL34088:         self.get_file_list()\nL34089: \nL34090:         # If user just wanted us to regenerate the manifest, stop now.\nL34091:         if self.manifest_only:\nL34092:             return\nL34093: \nL34094:         # Otherwise, go ahead and create the source distribution tarball,\nL34095:         # or zipfile, or whatever.\nL34096:         self.make_distribution()\nL34097: \nL34098:     def get_file_list(self) -> None:\nL34099:         \"\"\"Figure out the list of files to include in the source\nL34100:         distribution, and put it in 'self.filelist'.  This might involve\nL34101:         reading the manifest template (and writing the manifest), or just\nL34102:         reading the manifest, or just using the default file set -- it all\nL34103:         depends on the user's options.\nL34104:         \"\"\"\nL34105:         # new behavior when using a template:\nL34106:         # the file list is recalculated every time because\nL34107:         # even if MANIFEST.in or setup.py are not changed\nL34108:         # the user might have added some files in the tree that\nL34109:         # need to be included.\nL34110:         #\nL34111:         #  This makes --force the default and only behavior with templates.\nL34112:         template_exists = os.path.isfile(self.template)\nL34113:         if not template_exists and self._manifest_is_not_generated():\nL34114:             self.read_manifest()\nL34115:             self.filelist.sort()\nL34116:             self.filelist.remove_duplicates()\nL34117:             return\nL34118: \nL34119:         if not template_exists:\nL34120:             self.warn(\nL34121:                 (\"manifest template '%s' does not exist \" + \"(using default file list)\")\nL34122:                 % self.template\nL34123:             )\nL34124:         self.filelist.findall()\nL34125: \nL34126:         if self.use_defaults:\nL34127:             self.add_defaults()\nL34128: \nL34129:         if template_exists:\nL34130:             self.read_template()\nL34131: \nL34132:         if self.prune:\nL34133:             self.prune_file_list()\nL34134: \nL34135:         self.filelist.sort()\nL34136:         self.filelist.remove_duplicates()\nL34137:         self.write_manifest()\nL34138: \nL34139:     def add_defaults(self) -> None:\nL34140:         \"\"\"Add all the default files to self.filelist:\nL34141:           - README or README.txt\nL34142:           - setup.py\nL34143:           - tests/test*.py and test/test*.py\nL34144:           - all pure Python modules mentioned in setup script\nL34145:           - all files pointed by package_data (build_py)\nL34146:           - all files defined in data_files.\nL34147:           - all files defined as scripts.\nL34148:           - all C sources listed as part of extensions or C libraries\nL34149:             in the setup script (doesn't catch C headers!)\nL34150:         Warns if (README or README.txt) or setup.py are missing; everything\nL34151:         else is optional.\nL34152:         \"\"\"\nL34153:         self._add_defaults_standards()\nL34154:         self._add_defaults_optional()\nL34155:         self._add_defaults_python()\nL34156:         self._add_defaults_data_files()\nL34157:         self._add_defaults_ext()\nL34158:         self._add_defaults_c_libs()\nL34159:         self._add_defaults_scripts()\nL34160: \nL34161:     @staticmethod\nL34162:     def _cs_path_exists(fspath):\nL34163:         \"\"\"\nL34164:         Case-sensitive path existence check\nL34165: \nL34166:         >>> sdist._cs_path_exists(__file__)\nL34167:         True\nL34168:         >>> sdist._cs_path_exists(__file__.upper())\nL34169:         False\nL34170:         \"\"\"\nL34171:         if not os.path.exists(fspath):\nL34172:             return False\nL34173:         # make absolute so we always have a directory\nL34174:         abspath = os.path.abspath(fspath)\nL34175:         directory, filename = os.path.split(abspath)\nL34176:         return filename in os.listdir(directory)\nL34177: \nL34178:     def _add_defaults_standards(self):\nL34179:         standards = [self.READMES, self.distribution.script_name]\nL34180:         for fn in standards:\nL34181:             if isinstance(fn, tuple):\nL34182:                 alts = fn\nL34183:                 got_it = False\nL34184:                 for fn in alts:\nL34185:                     if self._cs_path_exists(fn):\nL34186:                         got_it = True\nL34187:                         self.filelist.append(fn)\nL34188:                         break\nL34189: \nL34190:                 if not got_it:\nL34191:                     self.warn(\nL34192:                         \"standard file not found: should have one of \" + ', '.join(alts)\nL34193:                     )\nL34194:             else:\nL34195:                 if self._cs_path_exists(fn):\nL34196:                     self.filelist.append(fn)\nL34197:                 else:\nL34198:                     self.warn(f\"standard file '{fn}' not found\")\nL34199: \nL34200:     def _add_defaults_optional(self):\nL34201:         optional = ['tests/test*.py', 'test/test*.py', 'setup.cfg']\nL34202:         for pattern in optional:\nL34203:             files = filter(os.path.isfile, glob(pattern))\nL34204:             self.filelist.extend(files)\nL34205: \nL34206:     def _add_defaults_python(self):\nL34207:         # build_py is used to get:\nL34208:         #  - python modules\nL34209:         #  - files defined in package_data\nL34210:         build_py = self.get_finalized_command('build_py')\nL34211: \nL34212:         # getting python files\nL34213:         if self.distribution.has_pure_modules():\nL34214:             self.filelist.extend(build_py.get_source_files())\nL34215: \nL34216:         # getting package_data files\nL34217:         # (computed in build_py.data_files by build_py.finalize_options)\nL34218:         for _pkg, src_dir, _build_dir, filenames in build_py.data_files:\nL34219:             for filename in filenames:\nL34220:                 self.filelist.append(os.path.join(src_dir, filename))\nL34221: \nL34222:     def _add_defaults_data_files(self):\nL34223:         # getting distribution.data_files\nL34224:         if self.distribution.has_data_files():\nL34225:             for item in self.distribution.data_files:\nL34226:                 if isinstance(item, str):\nL34227:                     # plain file\nL34228:                     item = convert_path(item)\nL34229:                     if os.path.isfile(item):\nL34230:                         self.filelist.append(item)\nL34231:                 else:\nL34232:                     # a (dirname, filenames) tuple\nL34233:                     dirname, filenames = item\nL34234:                     for f in filenames:\nL34235:                         f = convert_path(f)\nL34236:                         if os.path.isfile(f):\nL34237:                             self.filelist.append(f)\nL34238: \nL34239:     def _add_defaults_ext(self):\nL34240:         if self.distribution.has_ext_modules():\nL34241:             build_ext = self.get_finalized_command('build_ext')\nL34242:             self.filelist.extend(build_ext.get_source_files())\nL34243: \nL34244:     def _add_defaults_c_libs(self):\nL34245:         if self.distribution.has_c_libraries():\nL34246:             build_clib = self.get_finalized_command('build_clib')\nL34247:             self.filelist.extend(build_clib.get_source_files())\nL34248: \nL34249:     def _add_defaults_scripts(self):\nL34250:         if self.distribution.has_scripts():\nL34251:             build_scripts = self.get_finalized_command('build_scripts')\nL34252:             self.filelist.extend(build_scripts.get_source_files())\nL34253: \nL34254:     def read_template(self) -> None:\nL34255:         \"\"\"Read and parse manifest template file named by self.template.\nL34256: \nL34257:         (usually \"MANIFEST.in\") The parsing and processing is done by\nL34258:         'self.filelist', which updates itself accordingly.\nL34259:         \"\"\"\nL34260:         log.info(\"reading manifest template '%s'\", self.template)\nL34261:         template = TextFile(\nL34262:             self.template,\nL34263:             strip_comments=True,\nL34264:             skip_blanks=True,\nL34265:             join_lines=True,\nL34266:             lstrip_ws=True,\nL34267:             rstrip_ws=True,\nL34268:             collapse_join=True,\nL34269:         )\nL34270: \nL34271:         try:\nL34272:             while True:\nL34273:                 line = template.readline()\nL34274:                 if line is None:  # end of file\nL34275:                     break\nL34276: \nL34277:                 try:\nL34278:                     self.filelist.process_template_line(line)\nL34279:                 # the call above can raise a DistutilsTemplateError for\nL34280:                 # malformed lines, or a ValueError from the lower-level\nL34281:                 # convert_path function\nL34282:                 except (DistutilsTemplateError, ValueError) as msg:\nL34283:                     self.warn(\nL34284:                         f\"{template.filename}, line {int(template.current_line)}: {msg}\"\nL34285:                     )\nL34286:         finally:\nL34287:             template.close()\nL34288: \nL34289:     def prune_file_list(self) -> None:\nL34290:         \"\"\"Prune off branches that might slip into the file list as created\nL34291:         by 'read_template()', but really don't belong there:\nL34292:           * the build tree (typically \"build\")\nL34293:           * the release tree itself (only an issue if we ran \"sdist\"\nL34294:             previously with --keep-temp, or it aborted)\nL34295:           * any RCS, CVS, .svn, .hg, .git, .bzr, _darcs directories\nL34296:         \"\"\"\nL34297:         build = self.get_finalized_command('build')\nL34298:         base_dir = self.distribution.get_fullname()\nL34299: \nL34300:         self.filelist.exclude_pattern(None, prefix=os.fspath(build.build_base))\nL34301:         self.filelist.exclude_pattern(None, prefix=base_dir)\nL34302: \nL34303:         if sys.platform == 'win32':\nL34304:             seps = r'/|\\\\'\nL34305:         else:\nL34306:             seps = '/'\nL34307: \nL34308:         vcs_dirs = ['RCS', 'CVS', r'\\.svn', r'\\.hg', r'\\.git', r'\\.bzr', '_darcs']\nL34309:         vcs_ptrn = r'(^|{})({})({}).*'.format(seps, '|'.join(vcs_dirs), seps)\nL34310:         self.filelist.exclude_pattern(vcs_ptrn, is_regex=True)\nL34311: \nL34312:     def write_manifest(self) -> None:\nL34313:         \"\"\"Write the file list in 'self.filelist' (presumably as filled in\nL34314:         by 'add_defaults()' and 'read_template()') to the manifest file\nL34315:         named by 'self.manifest'.\nL34316:         \"\"\"\nL34317:         if self._manifest_is_not_generated():\nL34318:             log.info(\nL34319:                 f\"not writing to manually maintained manifest file '{self.manifest}'\"\nL34320:             )\nL34321:             return\nL34322: \nL34323:         content = self.filelist.files[:]\nL34324:         content.insert(0, '# file GENERATED by distutils, do NOT edit')\nL34325:         self.execute(\nL34326:             file_util.write_file,\nL34327:             (self.manifest, content),\nL34328:             f\"writing manifest file '{self.manifest}'\",\nL34329:         )\nL34330: \nL34331:     def _manifest_is_not_generated(self):\nL34332:         # check for special comment used in 3.1.3 and higher\nL34333:         if not os.path.isfile(self.manifest):\nL34334:             return False\nL34335: \nL34336:         with open(self.manifest, encoding='utf-8') as fp:\nL34337:             first_line = next(fp)\nL34338:         return first_line != '# file GENERATED by distutils, do NOT edit\\n'\nL34339: \nL34340:     def read_manifest(self) -> None:\nL34341:         \"\"\"Read the manifest file (named by 'self.manifest') and use it to\nL34342:         fill in 'self.filelist', the list of files to include in the source\nL34343:         distribution.\nL34344:         \"\"\"\nL34345:         log.info(\"reading manifest file '%s'\", self.manifest)\nL34346:         with open(self.manifest, encoding='utf-8') as lines:\nL34347:             self.filelist.extend(\nL34348:                 # ignore comments and blank lines\nL34349:                 filter(None, filterfalse(is_comment, map(str.strip, lines)))\nL34350:             )\nL34351: \nL34352:     def make_release_tree(self, base_dir, files) -> None:\nL34353:         \"\"\"Create the directory tree that will become the source\nL34354:         distribution archive.  All directories implied by the filenames in\nL34355:         'files' are created under 'base_dir', and then we hard link or copy\nL34356:         (if hard linking is unavailable) those files into place.\nL34357:         Essentially, this duplicates the developer's source tree, but in a\nL34358:         directory named after the distribution, containing only the files\nL34359:         to be distributed.\nL34360:         \"\"\"\nL34361:         # Create all the directories under 'base_dir' necessary to\nL34362:         # put 'files' there; the 'mkpath()' is just so we don't die\nL34363:         # if the manifest happens to be empty.\nL34364:         self.mkpath(base_dir)\nL34365:         dir_util.create_tree(base_dir, files, dry_run=self.dry_run)\nL34366: \nL34367:         # And walk over the list of files, either making a hard link (if\nL34368:         # os.link exists) to each one that doesn't already exist in its\nL34369:         # corresponding location under 'base_dir', or copying each file\nL34370:         # that's out-of-date in 'base_dir'.  (Usually, all files will be\nL34371:         # out-of-date, because by default we blow away 'base_dir' when\nL34372:         # we're done making the distribution archives.)\nL34373: \nL34374:         if hasattr(os, 'link'):  # can make hard links on this system\nL34375:             link = 'hard'\nL34376:             msg = f\"making hard links in {base_dir}...\"\nL34377:         else:  # nope, have to copy\nL34378:             link = None\nL34379:             msg = f\"copying files to {base_dir}...\"\nL34380: \nL34381:         if not files:\nL34382:             log.warning(\"no files to distribute -- empty manifest?\")\nL34383:         else:\nL34384:             log.info(msg)\nL34385:         for file in files:\nL34386:             if not os.path.isfile(file):\nL34387:                 log.warning(\"'%s' not a regular file -- skipping\", file)\nL34388:             else:\nL34389:                 dest = os.path.join(base_dir, file)\nL34390:                 self.copy_file(file, dest, link=link)\nL34391: \nL34392:         self.distribution.metadata.write_pkg_info(base_dir)\nL34393: \nL34394:     def make_distribution(self) -> None:\nL34395:         \"\"\"Create the source distribution(s).  First, we create the release\nL34396:         tree with 'make_release_tree()'; then, we create all required\nL34397:         archive files (according to 'self.formats') from the release tree.\nL34398:         Finally, we clean up by blowing away the release tree (unless\nL34399:         'self.keep_temp' is true).  The list of archive files created is\nL34400:         stored so it can be retrieved later by 'get_archive_files()'.\nL34401:         \"\"\"\nL34402:         # Don't warn about missing meta-data here -- should be (and is!)\nL34403:         # done elsewhere.\nL34404:         base_dir = self.distribution.get_fullname()\nL34405:         base_name = os.path.join(self.dist_dir, base_dir)\nL34406: \nL34407:         self.make_release_tree(base_dir, self.filelist.files)\nL34408:         archive_files = []  # remember names of files we create\nL34409:         # tar archive must be created last to avoid overwrite and remove\nL34410:         if 'tar' in self.formats:\nL34411:             self.formats.append(self.formats.pop(self.formats.index('tar')))\nL34412: \nL34413:         for fmt in self.formats:\nL34414:             file = self.make_archive(\nL34415:                 base_name, fmt, base_dir=base_dir, owner=self.owner, group=self.group\nL34416:             )\nL34417:             archive_files.append(file)\nL34418:             self.distribution.dist_files.append(('sdist', '', file))\nL34419: \nL34420:         self.archive_files = archive_files\nL34421: \nL34422:         if not self.keep_temp:\nL34423:             dir_util.remove_tree(base_dir, dry_run=self.dry_run)\nL34424: \nL34425:     def get_archive_files(self):\nL34426:         \"\"\"Return the list of archive files created when the command\nL34427:         was run, or None if the command hasn't run yet.\nL34428:         \"\"\"\nL34429:         return self.archive_files\nL34430: \nL34431: \nL34432: def is_comment(line: str) -> bool:\nL34433:     return line.startswith('#')\nL34434: \nL34435: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/support.py\nL34436: #!/usr/bin/env python3\nL34437: \"\"\"Support code for distutils test cases.\"\"\"\nL34438: \nL34439: import itertools\nL34440: import os\nL34441: import pathlib\nL34442: import shutil\nL34443: import sys\nL34444: import sysconfig\nL34445: import tempfile\nL34446: from distutils.core import Distribution\nL34447: \nL34448: import pytest\nL34449: from more_itertools import always_iterable\nL34450: \nL34451: \nL34452: @pytest.mark.usefixtures('distutils_managed_tempdir')\nL34453: class TempdirManager:\nL34454:     \"\"\"\nL34455:     Mix-in class that handles temporary directories for test cases.\nL34456:     \"\"\"\nL34457: \nL34458:     def mkdtemp(self):\nL34459:         \"\"\"Create a temporary directory that will be cleaned up.\nL34460: \nL34461:         Returns the path of the directory.\nL34462:         \"\"\"\nL34463:         d = tempfile.mkdtemp()\nL34464:         self.tempdirs.append(d)\nL34465:         return d\nL34466: \nL34467:     def write_file(self, path, content='xxx'):\nL34468:         \"\"\"Writes a file in the given path.\nL34469: \nL34470:         path can be a string or a sequence.\nL34471:         \"\"\"\nL34472:         pathlib.Path(*always_iterable(path)).write_text(content, encoding='utf-8')\nL34473: \nL34474:     def create_dist(self, pkg_name='foo', **kw):\nL34475:         \"\"\"Will generate a test environment.\nL34476: \nL34477:         This function creates:\nL34478:          - a Distribution instance using keywords\nL34479:          - a temporary directory with a package structure\nL34480: \nL34481:         It returns the package directory and the distribution\nL34482:         instance.\nL34483:         \"\"\"\nL34484:         tmp_dir = self.mkdtemp()\nL34485:         pkg_dir = os.path.join(tmp_dir, pkg_name)\nL34486:         os.mkdir(pkg_dir)\nL34487:         dist = Distribution(attrs=kw)\nL34488: \nL34489:         return pkg_dir, dist\nL34490: \nL34491: \nL34492: class DummyCommand:\nL34493:     \"\"\"Class to store options for retrieval via set_undefined_options().\"\"\"\nL34494: \nL34495:     def __init__(self, **kwargs):\nL34496:         vars(self).update(kwargs)\nL34497: \nL34498:     def ensure_finalized(self):\nL34499:         pass\nL34500: \nL34501: \nL34502: def copy_xxmodule_c(directory):\nL34503:     \"\"\"Helper for tests that need the xxmodule.c source file.\nL34504: \nL34505:     Example use:\nL34506: \nL34507:         def test_compile(self):\nL34508:             copy_xxmodule_c(self.tmpdir)\nL34509:             self.assertIn('xxmodule.c', os.listdir(self.tmpdir))\nL34510: \nL34511:     If the source file can be found, it will be copied to *directory*.  If not,\nL34512:     the test will be skipped.  Errors during copy are not caught.\nL34513:     \"\"\"\nL34514:     shutil.copy(_get_xxmodule_path(), os.path.join(directory, 'xxmodule.c'))\nL34515: \nL34516: \nL34517: def _get_xxmodule_path():\nL34518:     source_name = 'xxmodule.c' if sys.version_info > (3, 9) else 'xxmodule-3.8.c'\nL34519:     return os.path.join(os.path.dirname(__file__), source_name)\nL34520: \nL34521: \nL34522: def fixup_build_ext(cmd):\nL34523:     \"\"\"Function needed to make build_ext tests pass.\nL34524: \nL34525:     When Python was built with --enable-shared on Unix, -L. is not enough to\nL34526:     find libpython<blah>.so, because regrtest runs in a tempdir, not in the\nL34527:     source directory where the .so lives.\nL34528: \nL34529:     When Python was built with in debug mode on Windows, build_ext commands\nL34530:     need their debug attribute set, and it is not done automatically for\nL34531:     some reason.\nL34532: \nL34533:     This function handles both of these things.  Example use:\nL34534: \nL34535:         cmd = build_ext(dist)\nL34536:         support.fixup_build_ext(cmd)\nL34537:         cmd.ensure_finalized()\nL34538: \nL34539:     Unlike most other Unix platforms, Mac OS X embeds absolute paths\nL34540:     to shared libraries into executables, so the fixup is not needed there.\nL34541:     \"\"\"\nL34542:     if os.name == 'nt':\nL34543:         cmd.debug = sys.executable.endswith('_d.exe')\nL34544:     elif sysconfig.get_config_var('Py_ENABLE_SHARED'):\nL34545:         # To further add to the shared builds fun on Unix, we can't just add\nL34546:         # library_dirs to the Extension() instance because that doesn't get\nL34547:         # plumbed through to the final compiler command.\nL34548:         runshared = sysconfig.get_config_var('RUNSHARED')\nL34549:         if runshared is None:\nL34550:             cmd.library_dirs = ['.']\nL34551:         else:\nL34552:             if sys.platform == 'darwin':\nL34553:                 cmd.library_dirs = []\nL34554:             else:\nL34555:                 name, equals, value = runshared.partition('=')\nL34556:                 cmd.library_dirs = [d for d in value.split(os.pathsep) if d]\nL34557: \nL34558: \nL34559: def combine_markers(cls):\nL34560:     \"\"\"\nL34561:     pytest will honor markers as found on the class, but when\nL34562:     markers are on multiple subclasses, only one appears. Use\nL34563:     this decorator to combine those markers.\nL34564:     \"\"\"\nL34565:     cls.pytestmark = [\nL34566:         mark\nL34567:         for base in itertools.chain([cls], cls.__bases__)\nL34568:         for mark in getattr(base, 'pytestmark', [])\nL34569:     ]\nL34570:     return cls\nL34571: \nL34572: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_bdist_dumb.py\nL34573: #!/usr/bin/env python3\nL34574: \"\"\"Tests for distutils.command.bdist_dumb.\"\"\"\nL34575: \nL34576: import os\nL34577: import sys\nL34578: import zipfile\nL34579: from distutils.command.bdist_dumb import bdist_dumb\nL34580: from distutils.core import Distribution\nL34581: from distutils.tests import support\nL34582: \nL34583: import pytest\nL34584: \nL34585: SETUP_PY = \"\"\"\\\nL34586: from distutils.core import setup\nL34587: import foo\nL34588: \nL34589: setup(name='foo', version='0.1', py_modules=['foo'],\nL34590:       url='xxx', author='xxx', author_email='xxx')\nL34591: \nL34592: \"\"\"\nL34593: \nL34594: \nL34595: @support.combine_markers\nL34596: @pytest.mark.usefixtures('save_env')\nL34597: @pytest.mark.usefixtures('save_argv')\nL34598: @pytest.mark.usefixtures('save_cwd')\nL34599: class TestBuildDumb(\nL34600:     support.TempdirManager,\nL34601: ):\nL34602:     @pytest.mark.usefixtures('needs_zlib')\nL34603:     def test_simple_built(self):\nL34604:         # let's create a simple package\nL34605:         tmp_dir = self.mkdtemp()\nL34606:         pkg_dir = os.path.join(tmp_dir, 'foo')\nL34607:         os.mkdir(pkg_dir)\nL34608:         self.write_file((pkg_dir, 'setup.py'), SETUP_PY)\nL34609:         self.write_file((pkg_dir, 'foo.py'), '#')\nL34610:         self.write_file((pkg_dir, 'MANIFEST.in'), 'include foo.py')\nL34611:         self.write_file((pkg_dir, 'README'), '')\nL34612: \nL34613:         dist = Distribution({\nL34614:             'name': 'foo',\nL34615:             'version': '0.1',\nL34616:             'py_modules': ['foo'],\nL34617:             'url': 'xxx',\nL34618:             'author': 'xxx',\nL34619:             'author_email': 'xxx',\nL34620:         })\nL34621:         dist.script_name = 'setup.py'\nL34622:         os.chdir(pkg_dir)\nL34623: \nL34624:         sys.argv = ['setup.py']\nL34625:         cmd = bdist_dumb(dist)\nL34626: \nL34627:         # so the output is the same no matter\nL34628:         # what is the platform\nL34629:         cmd.format = 'zip'\nL34630: \nL34631:         cmd.ensure_finalized()\nL34632:         cmd.run()\nL34633: \nL34634:         # see what we have\nL34635:         dist_created = os.listdir(os.path.join(pkg_dir, 'dist'))\nL34636:         base = f\"{dist.get_fullname()}.{cmd.plat_name}.zip\"\nL34637: \nL34638:         assert dist_created == [base]\nL34639: \nL34640:         # now let's check what we have in the zip file\nL34641:         fp = zipfile.ZipFile(os.path.join('dist', base))\nL34642:         try:\nL34643:             contents = fp.namelist()\nL34644:         finally:\nL34645:             fp.close()\nL34646: \nL34647:         contents = sorted(filter(None, map(os.path.basename, contents)))\nL34648:         wanted = ['foo-0.1-py{}.{}.egg-info'.format(*sys.version_info[:2]), 'foo.py']\nL34649:         if not sys.dont_write_bytecode:\nL34650:             wanted.append(f'foo.{sys.implementation.cache_tag}.pyc')\nL34651:         assert contents == sorted(wanted)\nL34652: \nL34653: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_bdist_rpm.py\nL34654: #!/usr/bin/env python3\nL34655: \"\"\"Tests for distutils.command.bdist_rpm.\"\"\"\nL34656: \nL34657: import os\nL34658: import shutil  # noqa: F401\nL34659: import sys\nL34660: from distutils.command.bdist_rpm import bdist_rpm\nL34661: from distutils.core import Distribution\nL34662: from distutils.tests import support\nL34663: \nL34664: import pytest\nL34665: from test.support import requires_zlib\nL34666: \nL34667: SETUP_PY = \"\"\"\\\nL34668: from distutils.core import setup\nL34669: import foo\nL34670: \nL34671: setup(name='foo', version='0.1', py_modules=['foo'],\nL34672:       url='xxx', author='xxx', author_email='xxx')\nL34673: \nL34674: \"\"\"\nL34675: \nL34676: \nL34677: @pytest.fixture(autouse=True)\nL34678: def sys_executable_encodable():\nL34679:     try:\nL34680:         sys.executable.encode('UTF-8')\nL34681:     except UnicodeEncodeError:\nL34682:         pytest.skip(\"sys.executable is not encodable to UTF-8\")\nL34683: \nL34684: \nL34685: mac_woes = pytest.mark.skipif(\nL34686:     \"not sys.platform.startswith('linux')\",\nL34687:     reason='spurious sdtout/stderr output under macOS',\nL34688: )\nL34689: \nL34690: \nL34691: @pytest.mark.usefixtures('save_env')\nL34692: @pytest.mark.usefixtures('save_argv')\nL34693: @pytest.mark.usefixtures('save_cwd')\nL34694: class TestBuildRpm(\nL34695:     support.TempdirManager,\nL34696: ):\nL34697:     @mac_woes\nL34698:     @requires_zlib()\nL34699:     @pytest.mark.skipif(\"not shutil.which('rpm')\")\nL34700:     @pytest.mark.skipif(\"not shutil.which('rpmbuild')\")\nL34701:     def test_quiet(self):\nL34702:         # let's create a package\nL34703:         tmp_dir = self.mkdtemp()\nL34704:         os.environ['HOME'] = tmp_dir  # to confine dir '.rpmdb' creation\nL34705:         pkg_dir = os.path.join(tmp_dir, 'foo')\nL34706:         os.mkdir(pkg_dir)\nL34707:         self.write_file((pkg_dir, 'setup.py'), SETUP_PY)\nL34708:         self.write_file((pkg_dir, 'foo.py'), '#')\nL34709:         self.write_file((pkg_dir, 'MANIFEST.in'), 'include foo.py')\nL34710:         self.write_file((pkg_dir, 'README'), '')\nL34711: \nL34712:         dist = Distribution({\nL34713:             'name': 'foo',\nL34714:             'version': '0.1',\nL34715:             'py_modules': ['foo'],\nL34716:             'url': 'xxx',\nL34717:             'author': 'xxx',\nL34718:             'author_email': 'xxx',\nL34719:         })\nL34720:         dist.script_name = 'setup.py'\nL34721:         os.chdir(pkg_dir)\nL34722: \nL34723:         sys.argv = ['setup.py']\nL34724:         cmd = bdist_rpm(dist)\nL34725:         cmd.fix_python = True\nL34726: \nL34727:         # running in quiet mode\nL34728:         cmd.quiet = True\nL34729:         cmd.ensure_finalized()\nL34730:         cmd.run()\nL34731: \nL34732:         dist_created = os.listdir(os.path.join(pkg_dir, 'dist'))\nL34733:         assert 'foo-0.1-1.noarch.rpm' in dist_created\nL34734: \nL34735:         # bug #2945: upload ignores bdist_rpm files\nL34736:         assert ('bdist_rpm', 'any', 'dist/foo-0.1-1.src.rpm') in dist.dist_files\nL34737:         assert ('bdist_rpm', 'any', 'dist/foo-0.1-1.noarch.rpm') in dist.dist_files\nL34738: \nL34739:     @mac_woes\nL34740:     @requires_zlib()\nL34741:     # https://bugs.python.org/issue1533164\nL34742:     @pytest.mark.skipif(\"not shutil.which('rpm')\")\nL34743:     @pytest.mark.skipif(\"not shutil.which('rpmbuild')\")\nL34744:     def test_no_optimize_flag(self):\nL34745:         # let's create a package that breaks bdist_rpm\nL34746:         tmp_dir = self.mkdtemp()\nL34747:         os.environ['HOME'] = tmp_dir  # to confine dir '.rpmdb' creation\nL34748:         pkg_dir = os.path.join(tmp_dir, 'foo')\nL34749:         os.mkdir(pkg_dir)\nL34750:         self.write_file((pkg_dir, 'setup.py'), SETUP_PY)\nL34751:         self.write_file((pkg_dir, 'foo.py'), '#')\nL34752:         self.write_file((pkg_dir, 'MANIFEST.in'), 'include foo.py')\nL34753:         self.write_file((pkg_dir, 'README'), '')\nL34754: \nL34755:         dist = Distribution({\nL34756:             'name': 'foo',\nL34757:             'version': '0.1',\nL34758:             'py_modules': ['foo'],\nL34759:             'url': 'xxx',\nL34760:             'author': 'xxx',\nL34761:             'author_email': 'xxx',\nL34762:         })\nL34763:         dist.script_name = 'setup.py'\nL34764:         os.chdir(pkg_dir)\nL34765: \nL34766:         sys.argv = ['setup.py']\nL34767:         cmd = bdist_rpm(dist)\nL34768:         cmd.fix_python = True\nL34769: \nL34770:         cmd.quiet = True\nL34771:         cmd.ensure_finalized()\nL34772:         cmd.run()\nL34773: \nL34774:         dist_created = os.listdir(os.path.join(pkg_dir, 'dist'))\nL34775:         assert 'foo-0.1-1.noarch.rpm' in dist_created\nL34776: \nL34777:         # bug #2945: upload ignores bdist_rpm files\nL34778:         assert ('bdist_rpm', 'any', 'dist/foo-0.1-1.src.rpm') in dist.dist_files\nL34779:         assert ('bdist_rpm', 'any', 'dist/foo-0.1-1.noarch.rpm') in dist.dist_files\nL34780: \nL34781:         os.remove(os.path.join(pkg_dir, 'dist', 'foo-0.1-1.noarch.rpm'))\nL34782: \nL34783: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_build_ext.py\nL34784: #!/usr/bin/env python3\nL34785: import contextlib\nL34786: import glob\nL34787: import importlib\nL34788: import os.path\nL34789: import platform\nL34790: import re\nL34791: import shutil\nL34792: import site\nL34793: import subprocess\nL34794: import sys\nL34795: import tempfile\nL34796: import textwrap\nL34797: import time\nL34798: from distutils import sysconfig\nL34799: from distutils.command.build_ext import build_ext\nL34800: from distutils.core import Distribution\nL34801: from distutils.errors import (\nL34802:     CompileError,\nL34803:     DistutilsPlatformError,\nL34804:     DistutilsSetupError,\nL34805:     UnknownFileError,\nL34806: )\nL34807: from distutils.extension import Extension\nL34808: from distutils.tests import missing_compiler_executable\nL34809: from distutils.tests.support import TempdirManager, copy_xxmodule_c, fixup_build_ext\nL34810: from io import StringIO\nL34811: \nL34812: import jaraco.path\nL34813: import path\nL34814: import pytest\nL34815: from test import support\nL34816: \nL34817: from .compat import py39 as import_helper\nL34818: \nL34819: \nL34820: @pytest.fixture()\nL34821: def user_site_dir(request):\nL34822:     self = request.instance\nL34823:     self.tmp_dir = self.mkdtemp()\nL34824:     self.tmp_path = path.Path(self.tmp_dir)\nL34825:     from distutils.command import build_ext\nL34826: \nL34827:     orig_user_base = site.USER_BASE\nL34828: \nL34829:     site.USER_BASE = self.mkdtemp()\nL34830:     build_ext.USER_BASE = site.USER_BASE\nL34831: \nL34832:     # bpo-30132: On Windows, a .pdb file may be created in the current\nL34833:     # working directory. Create a temporary working directory to cleanup\nL34834:     # everything at the end of the test.\nL34835:     with self.tmp_path:\nL34836:         yield\nL34837: \nL34838:     site.USER_BASE = orig_user_base\nL34839:     build_ext.USER_BASE = orig_user_base\nL34840: \nL34841:     if sys.platform == 'cygwin':\nL34842:         time.sleep(1)\nL34843: \nL34844: \nL34845: @contextlib.contextmanager\nL34846: def safe_extension_import(name, path):\nL34847:     with import_helper.CleanImport(name):\nL34848:         with extension_redirect(name, path) as new_path:\nL34849:             with import_helper.DirsOnSysPath(new_path):\nL34850:                 yield\nL34851: \nL34852: \nL34853: @contextlib.contextmanager\nL34854: def extension_redirect(mod, path):\nL34855:     \"\"\"\nL34856:     Tests will fail to tear down an extension module if it's been imported.\nL34857: \nL34858:     Before importing, copy the file to a temporary directory that won't\nL34859:     be cleaned up. Yield the new path.\nL34860:     \"\"\"\nL34861:     if platform.system() != \"Windows\" and sys.platform != \"cygwin\":\nL34862:         yield path\nL34863:         return\nL34864:     with import_helper.DirsOnSysPath(path):\nL34865:         spec = importlib.util.find_spec(mod)\nL34866:     filename = os.path.basename(spec.origin)\nL34867:     trash_dir = tempfile.mkdtemp(prefix='deleteme')\nL34868:     dest = os.path.join(trash_dir, os.path.basename(filename))\nL34869:     shutil.copy(spec.origin, dest)\nL34870:     yield trash_dir\nL34871:     # TODO: can the file be scheduled for deletion?\nL34872: \nL34873: \nL34874: @pytest.mark.usefixtures('user_site_dir')\nL34875: class TestBuildExt(TempdirManager):\nL34876:     def build_ext(self, *args, **kwargs):\nL34877:         return build_ext(*args, **kwargs)\nL34878: \nL34879:     @pytest.mark.parametrize(\"copy_so\", [False])\nL34880:     def test_build_ext(self, copy_so):\nL34881:         missing_compiler_executable()\nL34882:         copy_xxmodule_c(self.tmp_dir)\nL34883:         xx_c = os.path.join(self.tmp_dir, 'xxmodule.c')\nL34884:         xx_ext = Extension('xx', [xx_c])\nL34885:         if sys.platform != \"win32\":\nL34886:             if not copy_so:\nL34887:                 xx_ext = Extension(\nL34888:                     'xx',\nL34889:                     [xx_c],\nL34890:                     library_dirs=['/usr/lib'],\nL34891:                     libraries=['z'],\nL34892:                     runtime_library_dirs=['/usr/lib'],\nL34893:                 )\nL34894:             elif sys.platform == 'linux':\nL34895:                 libz_so = {\nL34896:                     os.path.realpath(name) for name in glob.iglob('/usr/lib*/libz.so*')\nL34897:                 }\nL34898:                 libz_so = sorted(libz_so, key=lambda lib_path: len(lib_path))\nL34899:                 shutil.copyfile(libz_so[-1], '/tmp/libxx_z.so')\nL34900: \nL34901:                 xx_ext = Extension(\nL34902:                     'xx',\nL34903:                     [xx_c],\nL34904:                     library_dirs=['/tmp'],\nL34905:                     libraries=['xx_z'],\nL34906:                     runtime_library_dirs=['/tmp'],\nL34907:                 )\nL34908:         dist = Distribution({'name': 'xx', 'ext_modules': [xx_ext]})\nL34909:         dist.package_dir = self.tmp_dir\nL34910:         cmd = self.build_ext(dist)\nL34911:         fixup_build_ext(cmd)\nL34912:         cmd.build_lib = self.tmp_dir\nL34913:         cmd.build_temp = self.tmp_dir\nL34914: \nL34915:         old_stdout = sys.stdout\nL34916:         if not support.verbose:\nL34917:             # silence compiler output\nL34918:             sys.stdout = StringIO()\nL34919:         try:\nL34920:             cmd.ensure_finalized()\nL34921:             cmd.run()\nL34922:         finally:\nL34923:             sys.stdout = old_stdout\nL34924: \nL34925:         with safe_extension_import('xx', self.tmp_dir):\nL34926:             self._test_xx(copy_so)\nL34927: \nL34928:         if sys.platform == 'linux' and copy_so:\nL34929:             os.unlink('/tmp/libxx_z.so')\nL34930: \nL34931:     @staticmethod\nL34932:     def _test_xx(copy_so):\nL34933:         import xx  # type: ignore[import-not-found] # Module generated for tests\nL34934: \nL34935:         for attr in ('error', 'foo', 'new', 'roj'):\nL34936:             assert hasattr(xx, attr)\nL34937: \nL34938:         assert xx.foo(2, 5) == 7\nL34939:         assert xx.foo(13, 15) == 28\nL34940:         assert xx.new().demo() is None\nL34941:         if support.HAVE_DOCSTRINGS:\nL34942:             doc = 'This is a template module just for instruction.'\nL34943:             assert xx.__doc__ == doc\nL34944:         assert isinstance(xx.Null(), xx.Null)\nL34945:         assert isinstance(xx.Str(), xx.Str)\nL34946: \nL34947:         if sys.platform == 'linux':\nL34948:             so_headers = subprocess.check_output(\nL34949:                 [\"readelf\", \"-d\", xx.__file__], universal_newlines=True\nL34950:             )\nL34951:             import pprint\nL34952: \nL34953:             pprint.pprint(so_headers)\nL34954:             rpaths = [\nL34955:                 rpath\nL34956:                 for line in so_headers.split(\"\\n\")\nL34957:                 if \"RPATH\" in line or \"RUNPATH\" in line\nL34958:                 for rpath in line.split()[2][1:-1].split(\":\")\nL34959:             ]\nL34960:             if not copy_so:\nL34961:                 pprint.pprint(rpaths)\nL34962:                 # Linked against a library in /usr/lib{,64}\nL34963:                 assert \"/usr/lib\" not in rpaths and \"/usr/lib64\" not in rpaths\nL34964:             else:\nL34965:                 # Linked against a library in /tmp\nL34966:                 assert \"/tmp\" in rpaths\nL34967:                 # The import is the real test here\nL34968: \nL34969:     def test_solaris_enable_shared(self):\nL34970:         dist = Distribution({'name': 'xx'})\nL34971:         cmd = self.build_ext(dist)\nL34972:         old = sys.platform\nL34973: \nL34974:         sys.platform = 'sunos'  # fooling finalize_options\nL34975:         from distutils.sysconfig import _config_vars\nL34976: \nL34977:         old_var = _config_vars.get('Py_ENABLE_SHARED')\nL34978:         _config_vars['Py_ENABLE_SHARED'] = True\nL34979:         try:\nL34980:             cmd.ensure_finalized()\nL34981:         finally:\nL34982:             sys.platform = old\nL34983:             if old_var is None:\nL34984:                 del _config_vars['Py_ENABLE_SHARED']\nL34985:             else:\nL34986:                 _config_vars['Py_ENABLE_SHARED'] = old_var\nL34987: \nL34988:         # make sure we get some library dirs under solaris\nL34989:         assert len(cmd.library_dirs) > 0\nL34990: \nL34991:     def test_user_site(self):\nL34992:         import site\nL34993: \nL34994:         dist = Distribution({'name': 'xx'})\nL34995:         cmd = self.build_ext(dist)\nL34996: \nL34997:         # making sure the user option is there\nL34998:         options = [name for name, short, label in cmd.user_options]\nL34999:         assert 'user' in options\nL35000: \nL35001:         # setting a value\nL35002:         cmd.user = True\nL35003: \nL35004:         # setting user based lib and include\nL35005:         lib = os.path.join(site.USER_BASE, 'lib')\nL35006:         incl = os.path.join(site.USER_BASE, 'include')\nL35007:         os.mkdir(lib)\nL35008:         os.mkdir(incl)\nL35009: \nL35010:         # let's run finalize\nL35011:         cmd.ensure_finalized()\nL35012: \nL35013:         # see if include_dirs and library_dirs\nL35014:         # were set\nL35015:         assert lib in cmd.library_dirs\nL35016:         assert lib in cmd.rpath\nL35017:         assert incl in cmd.include_dirs\nL35018: \nL35019:     def test_optional_extension(self):\nL35020:         # this extension will fail, but let's ignore this failure\nL35021:         # with the optional argument.\nL35022:         modules = [Extension('foo', ['xxx'], optional=False)]\nL35023:         dist = Distribution({'name': 'xx', 'ext_modules': modules})\nL35024:         cmd = self.build_ext(dist)\nL35025:         cmd.ensure_finalized()\nL35026:         with pytest.raises((UnknownFileError, CompileError)):\nL35027:             cmd.run()  # should raise an error\nL35028: \nL35029:         modules = [Extension('foo', ['xxx'], optional=True)]\nL35030:         dist = Distribution({'name': 'xx', 'ext_modules': modules})\nL35031:         cmd = self.build_ext(dist)\nL35032:         cmd.ensure_finalized()\nL35033:         cmd.run()  # should pass\nL35034: \nL35035:     def test_finalize_options(self):\nL35036:         # Make sure Python's include directories (for Python.h, pyconfig.h,\nL35037:         # etc.) are in the include search path.\nL35038:         modules = [Extension('foo', ['xxx'], optional=False)]\nL35039:         dist = Distribution({'name': 'xx', 'ext_modules': modules})\nL35040:         cmd = self.build_ext(dist)\nL35041:         cmd.finalize_options()\nL35042: \nL35043:         py_include = sysconfig.get_python_inc()\nL35044:         for p in py_include.split(os.path.pathsep):\nL35045:             assert p in cmd.include_dirs\nL35046: \nL35047:         plat_py_include = sysconfig.get_python_inc(plat_specific=True)\nL35048:         for p in plat_py_include.split(os.path.pathsep):\nL35049:             assert p in cmd.include_dirs\nL35050: \nL35051:         # make sure cmd.libraries is turned into a list\nL35052:         # if it's a string\nL35053:         cmd = self.build_ext(dist)\nL35054:         cmd.libraries = 'my_lib, other_lib lastlib'\nL35055:         cmd.finalize_options()\nL35056:         assert cmd.libraries == ['my_lib', 'other_lib', 'lastlib']\nL35057: \nL35058:         # make sure cmd.library_dirs is turned into a list\nL35059:         # if it's a string\nL35060:         cmd = self.build_ext(dist)\nL35061:         cmd.library_dirs = f'my_lib_dir{os.pathsep}other_lib_dir'\nL35062:         cmd.finalize_options()\nL35063:         assert 'my_lib_dir' in cmd.library_dirs\nL35064:         assert 'other_lib_dir' in cmd.library_dirs\nL35065: \nL35066:         # make sure rpath is turned into a list\nL35067:         # if it's a string\nL35068:         cmd = self.build_ext(dist)\nL35069:         cmd.rpath = f'one{os.pathsep}two'\nL35070:         cmd.finalize_options()\nL35071:         assert cmd.rpath == ['one', 'two']\nL35072: \nL35073:         # make sure cmd.link_objects is turned into a list\nL35074:         # if it's a string\nL35075:         cmd = build_ext(dist)\nL35076:         cmd.link_objects = 'one two,three'\nL35077:         cmd.finalize_options()\nL35078:         assert cmd.link_objects == ['one', 'two', 'three']\nL35079: \nL35080:         # XXX more tests to perform for win32\nL35081: \nL35082:         # make sure define is turned into 2-tuples\nL35083:         # strings if they are ','-separated strings\nL35084:         cmd = self.build_ext(dist)\nL35085:         cmd.define = 'one,two'\nL35086:         cmd.finalize_options()\nL35087:         assert cmd.define == [('one', '1'), ('two', '1')]\nL35088: \nL35089:         # make sure undef is turned into a list of\nL35090:         # strings if they are ','-separated strings\nL35091:         cmd = self.build_ext(dist)\nL35092:         cmd.undef = 'one,two'\nL35093:         cmd.finalize_options()\nL35094:         assert cmd.undef == ['one', 'two']\nL35095: \nL35096:         # make sure swig_opts is turned into a list\nL35097:         cmd = self.build_ext(dist)\nL35098:         cmd.swig_opts = None\nL35099:         cmd.finalize_options()\nL35100:         assert cmd.swig_opts == []\nL35101: \nL35102:         cmd = self.build_ext(dist)\nL35103:         cmd.swig_opts = '1 2'\nL35104:         cmd.finalize_options()\nL35105:         assert cmd.swig_opts == ['1', '2']\nL35106: \nL35107:     def test_check_extensions_list(self):\nL35108:         dist = Distribution()\nL35109:         cmd = self.build_ext(dist)\nL35110:         cmd.finalize_options()\nL35111: \nL35112:         # 'extensions' option must be a list of Extension instances\nL35113:         with pytest.raises(DistutilsSetupError):\nL35114:             cmd.check_extensions_list('foo')\nL35115: \nL35116:         # each element of 'ext_modules' option must be an\nL35117:         # Extension instance or 2-tuple\nL35118:         exts = [('bar', 'foo', 'bar'), 'foo']\nL35119:         with pytest.raises(DistutilsSetupError):\nL35120:             cmd.check_extensions_list(exts)\nL35121: \nL35122:         # first element of each tuple in 'ext_modules'\nL35123:         # must be the extension name (a string) and match\nL35124:         # a python dotted-separated name\nL35125:         exts = [('foo-bar', '')]\nL35126:         with pytest.raises(DistutilsSetupError):\nL35127:             cmd.check_extensions_list(exts)\nL35128: \nL35129:         # second element of each tuple in 'ext_modules'\nL35130:         # must be a dictionary (build info)\nL35131:         exts = [('foo.bar', '')]\nL35132:         with pytest.raises(DistutilsSetupError):\nL35133:             cmd.check_extensions_list(exts)\nL35134: \nL35135:         # ok this one should pass\nL35136:         exts = [('foo.bar', {'sources': [''], 'libraries': 'foo', 'some': 'bar'})]\nL35137:         cmd.check_extensions_list(exts)\nL35138:         ext = exts[0]\nL35139:         assert isinstance(ext, Extension)\nL35140: \nL35141:         # check_extensions_list adds in ext the values passed\nL35142:         # when they are in ('include_dirs', 'library_dirs', 'libraries'\nL35143:         # 'extra_objects', 'extra_compile_args', 'extra_link_args')\nL35144:         assert ext.libraries == 'foo'\nL35145:         assert not hasattr(ext, 'some')\nL35146: \nL35147:         # 'macros' element of build info dict must be 1- or 2-tuple\nL35148:         exts = [\nL35149:             (\nL35150:                 'foo.bar',\nL35151:                 {\nL35152:                     'sources': [''],\nL35153:                     'libraries': 'foo',\nL35154:                     'some': 'bar',\nL35155:                     'macros': [('1', '2', '3'), 'foo'],\nL35156:                 },\nL35157:             )\nL35158:         ]\nL35159:         with pytest.raises(DistutilsSetupError):\nL35160:             cmd.check_extensions_list(exts)\nL35161: \nL35162:         exts[0][1]['macros'] = [('1', '2'), ('3',)]\nL35163:         cmd.check_extensions_list(exts)\nL35164:         assert exts[0].undef_macros == ['3']\nL35165:         assert exts[0].define_macros == [('1', '2')]\nL35166: \nL35167:     def test_get_source_files(self):\nL35168:         modules = [Extension('foo', ['xxx'], optional=False)]\nL35169:         dist = Distribution({'name': 'xx', 'ext_modules': modules})\nL35170:         cmd = self.build_ext(dist)\nL35171:         cmd.ensure_finalized()\nL35172:         assert cmd.get_source_files() == ['xxx']\nL35173: \nL35174:     def test_unicode_module_names(self):\nL35175:         modules = [\nL35176:             Extension('foo', ['aaa'], optional=False),\nL35177:             Extension('f\u00f6\u00f6', ['uuu'], optional=False),\nL35178:         ]\nL35179:         dist = Distribution({'name': 'xx', 'ext_modules': modules})\nL35180:         cmd = self.build_ext(dist)\nL35181:         cmd.ensure_finalized()\nL35182:         assert re.search(r'foo(_d)?\\..*', cmd.get_ext_filename(modules[0].name))\nL35183:         assert re.search(r'f\u00f6\u00f6(_d)?\\..*', cmd.get_ext_filename(modules[1].name))\nL35184:         assert cmd.get_export_symbols(modules[0]) == ['PyInit_foo']\nL35185:         assert cmd.get_export_symbols(modules[1]) == ['PyInitU_f_1gaa']\nL35186: \nL35187:     def test_export_symbols__init__(self):\nL35188:         # https://github.com/python/cpython/issues/80074\nL35189:         # https://github.com/pypa/setuptools/issues/4826\nL35190:         modules = [\nL35191:             Extension('foo.__init__', ['aaa']),\nL35192:             Extension('f\u00f6\u00f6.__init__', ['uuu']),\nL35193:         ]\nL35194:         dist = Distribution({'name': 'xx', 'ext_modules': modules})\nL35195:         cmd = self.build_ext(dist)\nL35196:         cmd.ensure_finalized()\nL35197:         assert cmd.get_export_symbols(modules[0]) == ['PyInit_foo']\nL35198:         assert cmd.get_export_symbols(modules[1]) == ['PyInitU_f_1gaa']\nL35199: \nL35200:     def test_compiler_option(self):\nL35201:         # cmd.compiler is an option and\nL35202:         # should not be overridden by a compiler instance\nL35203:         # when the command is run\nL35204:         dist = Distribution()\nL35205:         cmd = self.build_ext(dist)\nL35206:         cmd.compiler = 'unix'\nL35207:         cmd.ensure_finalized()\nL35208:         cmd.run()\nL35209:         assert cmd.compiler == 'unix'\nL35210: \nL35211:     def test_get_outputs(self):\nL35212:         missing_compiler_executable()\nL35213:         tmp_dir = self.mkdtemp()\nL35214:         c_file = os.path.join(tmp_dir, 'foo.c')\nL35215:         self.write_file(c_file, 'void PyInit_foo(void) {}\\n')\nL35216:         ext = Extension('foo', [c_file], optional=False)\nL35217:         dist = Distribution({'name': 'xx', 'ext_modules': [ext]})\nL35218:         cmd = self.build_ext(dist)\nL35219:         fixup_build_ext(cmd)\nL35220:         cmd.ensure_finalized()\nL35221:         assert len(cmd.get_outputs()) == 1\nL35222: \nL35223:         cmd.build_lib = os.path.join(self.tmp_dir, 'build')\nL35224:         cmd.build_temp = os.path.join(self.tmp_dir, 'tempt')\nL35225: \nL35226:         # issue #5977 : distutils build_ext.get_outputs\nL35227:         # returns wrong result with --inplace\nL35228:         other_tmp_dir = os.path.realpath(self.mkdtemp())\nL35229:         old_wd = os.getcwd()\nL35230:         os.chdir(other_tmp_dir)\nL35231:         try:\nL35232:             cmd.inplace = True\nL35233:             cmd.run()\nL35234:             so_file = cmd.get_outputs()[0]\nL35235:         finally:\nL35236:             os.chdir(old_wd)\nL35237:         assert os.path.exists(so_file)\nL35238:         ext_suffix = sysconfig.get_config_var('EXT_SUFFIX')\nL35239:         assert so_file.endswith(ext_suffix)\nL35240:         so_dir = os.path.dirname(so_file)\nL35241:         assert so_dir == other_tmp_dir\nL35242: \nL35243:         cmd.inplace = False\nL35244:         cmd.compiler = None\nL35245:         cmd.run()\nL35246:         so_file = cmd.get_outputs()[0]\nL35247:         assert os.path.exists(so_file)\nL35248:         assert so_file.endswith(ext_suffix)\nL35249:         so_dir = os.path.dirname(so_file)\nL35250:         assert so_dir == cmd.build_lib\nL35251: \nL35252:         # inplace = False, cmd.package = 'bar'\nL35253:         build_py = cmd.get_finalized_command('build_py')\nL35254:         build_py.package_dir = {'': 'bar'}\nL35255:         path = cmd.get_ext_fullpath('foo')\nL35256:         # checking that the last directory is the build_dir\nL35257:         path = os.path.split(path)[0]\nL35258:         assert path == cmd.build_lib\nL35259: \nL35260:         # inplace = True, cmd.package = 'bar'\nL35261:         cmd.inplace = True\nL35262:         other_tmp_dir = os.path.realpath(self.mkdtemp())\nL35263:         old_wd = os.getcwd()\nL35264:         os.chdir(other_tmp_dir)\nL35265:         try:\nL35266:             path = cmd.get_ext_fullpath('foo')\nL35267:         finally:\nL35268:             os.chdir(old_wd)\nL35269:         # checking that the last directory is bar\nL35270:         path = os.path.split(path)[0]\nL35271:         lastdir = os.path.split(path)[-1]\nL35272:         assert lastdir == 'bar'\nL35273: \nL35274:     def test_ext_fullpath(self):\nL35275:         ext = sysconfig.get_config_var('EXT_SUFFIX')\nL35276:         # building lxml.etree inplace\nL35277:         # etree_c = os.path.join(self.tmp_dir, 'lxml.etree.c')\nL35278:         # etree_ext = Extension('lxml.etree', [etree_c])\nL35279:         # dist = Distribution({'name': 'lxml', 'ext_modules': [etree_ext]})\nL35280:         dist = Distribution()\nL35281:         cmd = self.build_ext(dist)\nL35282:         cmd.inplace = True\nL35283:         cmd.distribution.package_dir = {'': 'src'}\nL35284:         cmd.distribution.packages = ['lxml', 'lxml.html']\nL35285:         curdir = os.getcwd()\nL35286:         wanted = os.path.join(curdir, 'src', 'lxml', 'etree' + ext)\nL35287:         path = cmd.get_ext_fullpath('lxml.etree')\nL35288:         assert wanted == path\nL35289: \nL35290:         # building lxml.etree not inplace\nL35291:         cmd.inplace = False\nL35292:         cmd.build_lib = os.path.join(curdir, 'tmpdir')\nL35293:         wanted = os.path.join(curdir, 'tmpdir', 'lxml', 'etree' + ext)\nL35294:         path = cmd.get_ext_fullpath('lxml.etree')\nL35295:         assert wanted == path\nL35296: \nL35297:         # building twisted.runner.portmap not inplace\nL35298:         build_py = cmd.get_finalized_command('build_py')\nL35299:         build_py.package_dir = {}\nL35300:         cmd.distribution.packages = ['twisted', 'twisted.runner.portmap']\nL35301:         path = cmd.get_ext_fullpath('twisted.runner.portmap')\nL35302:         wanted = os.path.join(curdir, 'tmpdir', 'twisted', 'runner', 'portmap' + ext)\nL35303:         assert wanted == path\nL35304: \nL35305:         # building twisted.runner.portmap inplace\nL35306:         cmd.inplace = True\nL35307:         path = cmd.get_ext_fullpath('twisted.runner.portmap')\nL35308:         wanted = os.path.join(curdir, 'twisted', 'runner', 'portmap' + ext)\nL35309:         assert wanted == path\nL35310: \nL35311:     @pytest.mark.skipif('platform.system() != \"Darwin\"')\nL35312:     @pytest.mark.usefixtures('save_env')\nL35313:     def test_deployment_target_default(self):\nL35314:         # Issue 9516: Test that, in the absence of the environment variable,\nL35315:         # an extension module is compiled with the same deployment target as\nL35316:         #  the interpreter.\nL35317:         self._try_compile_deployment_target('==', None)\nL35318: \nL35319:     @pytest.mark.skipif('platform.system() != \"Darwin\"')\nL35320:     @pytest.mark.usefixtures('save_env')\nL35321:     def test_deployment_target_too_low(self):\nL35322:         # Issue 9516: Test that an extension module is not allowed to be\nL35323:         # compiled with a deployment target less than that of the interpreter.\nL35324:         with pytest.raises(DistutilsPlatformError):\nL35325:             self._try_compile_deployment_target('>', '10.1')\nL35326: \nL35327:     @pytest.mark.skipif('platform.system() != \"Darwin\"')\nL35328:     @pytest.mark.usefixtures('save_env')\nL35329:     def test_deployment_target_higher_ok(self):  # pragma: no cover\nL35330:         # Issue 9516: Test that an extension module can be compiled with a\nL35331:         # deployment target higher than that of the interpreter: the ext\nL35332:         # module may depend on some newer OS feature.\nL35333:         deptarget = sysconfig.get_config_var('MACOSX_DEPLOYMENT_TARGET')\nL35334:         if deptarget:\nL35335:             # increment the minor version number (i.e. 10.6 -> 10.7)\nL35336:             deptarget = [int(x) for x in deptarget.split('.')]\nL35337:             deptarget[-1] += 1\nL35338:             deptarget = '.'.join(str(i) for i in deptarget)\nL35339:             self._try_compile_deployment_target('<', deptarget)\nL35340: \nL35341:     def _try_compile_deployment_target(self, operator, target):  # pragma: no cover\nL35342:         if target is None:\nL35343:             if os.environ.get('MACOSX_DEPLOYMENT_TARGET'):\nL35344:                 del os.environ['MACOSX_DEPLOYMENT_TARGET']\nL35345:         else:\nL35346:             os.environ['MACOSX_DEPLOYMENT_TARGET'] = target\nL35347: \nL35348:         jaraco.path.build(\nL35349:             {\nL35350:                 'deptargetmodule.c': textwrap.dedent(f\"\"\"\\\nL35351:                     #include <AvailabilityMacros.h>\nL35352: \nL35353:                     int dummy;\nL35354: \nL35355:                     #if TARGET {operator} MAC_OS_X_VERSION_MIN_REQUIRED\nL35356:                     #else\nL35357:                     #error \"Unexpected target\"\nL35358:                     #endif\nL35359: \nL35360:                     \"\"\"),\nL35361:             },\nL35362:             self.tmp_path,\nL35363:         )\nL35364: \nL35365:         # get the deployment target that the interpreter was built with\nL35366:         target = sysconfig.get_config_var('MACOSX_DEPLOYMENT_TARGET')\nL35367:         target = tuple(map(int, target.split('.')[0:2]))\nL35368:         # format the target value as defined in the Apple\nL35369:         # Availability Macros.  We can't use the macro names since\nL35370:         # at least one value we test with will not exist yet.\nL35371:         if target[:2] < (10, 10):\nL35372:             # for 10.1 through 10.9.x -> \"10n0\"\nL35373:             tmpl = '{:02}{:01}0'\nL35374:         else:\nL35375:             # for 10.10 and beyond -> \"10nn00\"\nL35376:             if len(target) >= 2:\nL35377:                 tmpl = '{:02}{:02}00'\nL35378:             else:\nL35379:                 # 11 and later can have no minor version (11 instead of 11.0)\nL35380:                 tmpl = '{:02}0000'\nL35381:         target = tmpl.format(*target)\nL35382:         deptarget_ext = Extension(\nL35383:             'deptarget',\nL35384:             [self.tmp_path / 'deptargetmodule.c'],\nL35385:             extra_compile_args=[f'-DTARGET={target}'],\nL35386:         )\nL35387:         dist = Distribution({'name': 'deptarget', 'ext_modules': [deptarget_ext]})\nL35388:         dist.package_dir = self.tmp_dir\nL35389:         cmd = self.build_ext(dist)\nL35390:         cmd.build_lib = self.tmp_dir\nL35391:         cmd.build_temp = self.tmp_dir\nL35392: \nL35393:         try:\nL35394:             old_stdout = sys.stdout\nL35395:             if not support.verbose:\nL35396:                 # silence compiler output\nL35397:                 sys.stdout = StringIO()\nL35398:             try:\nL35399:                 cmd.ensure_finalized()\nL35400:                 cmd.run()\nL35401:             finally:\nL35402:                 sys.stdout = old_stdout\nL35403: \nL35404:         except CompileError:\nL35405:             self.fail(\"Wrong deployment target during compilation\")\nL35406: \nL35407: \nL35408: class TestParallelBuildExt(TestBuildExt):\nL35409:     def build_ext(self, *args, **kwargs):\nL35410:         build_ext = super().build_ext(*args, **kwargs)\nL35411:         build_ext.parallel = True\nL35412:         return build_ext\nL35413: \nL35414: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_build_py.py\nL35415: #!/usr/bin/env python3\nL35416: \"\"\"Tests for distutils.command.build_py.\"\"\"\nL35417: \nL35418: import os\nL35419: import sys\nL35420: from distutils.command.build_py import build_py\nL35421: from distutils.core import Distribution\nL35422: from distutils.errors import DistutilsFileError\nL35423: from distutils.tests import support\nL35424: \nL35425: import jaraco.path\nL35426: import pytest\nL35427: \nL35428: \nL35429: @support.combine_markers\nL35430: class TestBuildPy(support.TempdirManager):\nL35431:     def test_package_data(self):\nL35432:         sources = self.mkdtemp()\nL35433:         jaraco.path.build(\nL35434:             {\nL35435:                 '__init__.py': \"# Pretend this is a package.\",\nL35436:                 'README.txt': 'Info about this package',\nL35437:             },\nL35438:             sources,\nL35439:         )\nL35440: \nL35441:         destination = self.mkdtemp()\nL35442: \nL35443:         dist = Distribution({\"packages\": [\"pkg\"], \"package_dir\": {\"pkg\": sources}})\nL35444:         # script_name need not exist, it just need to be initialized\nL35445:         dist.script_name = os.path.join(sources, \"setup.py\")\nL35446:         dist.command_obj[\"build\"] = support.DummyCommand(\nL35447:             force=False, build_lib=destination\nL35448:         )\nL35449:         dist.packages = [\"pkg\"]\nL35450:         dist.package_data = {\"pkg\": [\"README.txt\"]}\nL35451:         dist.package_dir = {\"pkg\": sources}\nL35452: \nL35453:         cmd = build_py(dist)\nL35454:         cmd.compile = True\nL35455:         cmd.ensure_finalized()\nL35456:         assert cmd.package_data == dist.package_data\nL35457: \nL35458:         cmd.run()\nL35459: \nL35460:         # This makes sure the list of outputs includes byte-compiled\nL35461:         # files for Python modules but not for package data files\nL35462:         # (there shouldn't *be* byte-code files for those!).\nL35463:         assert len(cmd.get_outputs()) == 3\nL35464:         pkgdest = os.path.join(destination, \"pkg\")\nL35465:         files = os.listdir(pkgdest)\nL35466:         pycache_dir = os.path.join(pkgdest, \"__pycache__\")\nL35467:         assert \"__init__.py\" in files\nL35468:         assert \"README.txt\" in files\nL35469:         if sys.dont_write_bytecode:\nL35470:             assert not os.path.exists(pycache_dir)\nL35471:         else:\nL35472:             pyc_files = os.listdir(pycache_dir)\nL35473:             assert f\"__init__.{sys.implementation.cache_tag}.pyc\" in pyc_files\nL35474: \nL35475:     def test_empty_package_dir(self):\nL35476:         # See bugs #1668596/#1720897\nL35477:         sources = self.mkdtemp()\nL35478:         jaraco.path.build({'__init__.py': '', 'doc': {'testfile': ''}}, sources)\nL35479: \nL35480:         os.chdir(sources)\nL35481:         dist = Distribution({\nL35482:             \"packages\": [\"pkg\"],\nL35483:             \"package_dir\": {\"pkg\": \"\"},\nL35484:             \"package_data\": {\"pkg\": [\"doc/*\"]},\nL35485:         })\nL35486:         # script_name need not exist, it just need to be initialized\nL35487:         dist.script_name = os.path.join(sources, \"setup.py\")\nL35488:         dist.script_args = [\"build\"]\nL35489:         dist.parse_command_line()\nL35490: \nL35491:         try:\nL35492:             dist.run_commands()\nL35493:         except DistutilsFileError:\nL35494:             self.fail(\"failed package_data test when package_dir is ''\")\nL35495: \nL35496:     @pytest.mark.skipif('sys.dont_write_bytecode')\nL35497:     def test_byte_compile(self):\nL35498:         project_dir, dist = self.create_dist(py_modules=['boiledeggs'])\nL35499:         os.chdir(project_dir)\nL35500:         self.write_file('boiledeggs.py', 'import antigravity')\nL35501:         cmd = build_py(dist)\nL35502:         cmd.compile = True\nL35503:         cmd.build_lib = 'here'\nL35504:         cmd.finalize_options()\nL35505:         cmd.run()\nL35506: \nL35507:         found = os.listdir(cmd.build_lib)\nL35508:         assert sorted(found) == ['__pycache__', 'boiledeggs.py']\nL35509:         found = os.listdir(os.path.join(cmd.build_lib, '__pycache__'))\nL35510:         assert found == [f'boiledeggs.{sys.implementation.cache_tag}.pyc']\nL35511: \nL35512:     @pytest.mark.skipif('sys.dont_write_bytecode')\nL35513:     def test_byte_compile_optimized(self):\nL35514:         project_dir, dist = self.create_dist(py_modules=['boiledeggs'])\nL35515:         os.chdir(project_dir)\nL35516:         self.write_file('boiledeggs.py', 'import antigravity')\nL35517:         cmd = build_py(dist)\nL35518:         cmd.compile = False\nL35519:         cmd.optimize = 1\nL35520:         cmd.build_lib = 'here'\nL35521:         cmd.finalize_options()\nL35522:         cmd.run()\nL35523: \nL35524:         found = os.listdir(cmd.build_lib)\nL35525:         assert sorted(found) == ['__pycache__', 'boiledeggs.py']\nL35526:         found = os.listdir(os.path.join(cmd.build_lib, '__pycache__'))\nL35527:         expect = f'boiledeggs.{sys.implementation.cache_tag}.opt-1.pyc'\nL35528:         assert sorted(found) == [expect]\nL35529: \nL35530:     def test_dir_in_package_data(self):\nL35531:         \"\"\"\nL35532:         A directory in package_data should not be added to the filelist.\nL35533:         \"\"\"\nL35534:         # See bug 19286\nL35535:         sources = self.mkdtemp()\nL35536:         jaraco.path.build(\nL35537:             {\nL35538:                 'pkg': {\nL35539:                     '__init__.py': '',\nL35540:                     'doc': {\nL35541:                         'testfile': '',\nL35542:                         # create a directory that could be incorrectly detected as a file\nL35543:                         'otherdir': {},\nL35544:                     },\nL35545:                 }\nL35546:             },\nL35547:             sources,\nL35548:         )\nL35549: \nL35550:         os.chdir(sources)\nL35551:         dist = Distribution({\"packages\": [\"pkg\"], \"package_data\": {\"pkg\": [\"doc/*\"]}})\nL35552:         # script_name need not exist, it just need to be initialized\nL35553:         dist.script_name = os.path.join(sources, \"setup.py\")\nL35554:         dist.script_args = [\"build\"]\nL35555:         dist.parse_command_line()\nL35556: \nL35557:         try:\nL35558:             dist.run_commands()\nL35559:         except DistutilsFileError:\nL35560:             self.fail(\"failed package_data when data dir includes a dir\")\nL35561: \nL35562:     def test_dont_write_bytecode(self, caplog):\nL35563:         # makes sure byte_compile is not used\nL35564:         dist = self.create_dist()[1]\nL35565:         cmd = build_py(dist)\nL35566:         cmd.compile = True\nL35567:         cmd.optimize = 1\nL35568: \nL35569:         old_dont_write_bytecode = sys.dont_write_bytecode\nL35570:         sys.dont_write_bytecode = True\nL35571:         try:\nL35572:             cmd.byte_compile([])\nL35573:         finally:\nL35574:             sys.dont_write_bytecode = old_dont_write_bytecode\nL35575: \nL35576:         assert 'byte-compiling is disabled' in caplog.records[0].message\nL35577: \nL35578:     def test_namespace_package_does_not_warn(self, caplog):\nL35579:         \"\"\"\nL35580:         Originally distutils implementation did not account for PEP 420\nL35581:         and included warns for package directories that did not contain\nL35582:         ``__init__.py`` files.\nL35583:         After the acceptance of PEP 420, these warnings don't make more sense\nL35584:         so we want to ensure there are not displayed to not confuse the users.\nL35585:         \"\"\"\nL35586:         # Create a fake project structure with a package namespace:\nL35587:         tmp = self.mkdtemp()\nL35588:         jaraco.path.build({'ns': {'pkg': {'module.py': ''}}}, tmp)\nL35589:         os.chdir(tmp)\nL35590: \nL35591:         # Configure the package:\nL35592:         attrs = {\nL35593:             \"name\": \"ns.pkg\",\nL35594:             \"packages\": [\"ns\", \"ns.pkg\"],\nL35595:             \"script_name\": \"setup.py\",\nL35596:         }\nL35597:         dist = Distribution(attrs)\nL35598: \nL35599:         # Run code paths that would trigger the trap:\nL35600:         cmd = dist.get_command_obj(\"build_py\")\nL35601:         cmd.finalize_options()\nL35602:         modules = cmd.find_all_modules()\nL35603:         assert len(modules) == 1\nL35604:         module_path = modules[0][-1]\nL35605:         assert module_path.replace(os.sep, \"/\") == \"ns/pkg/module.py\"\nL35606: \nL35607:         cmd.run()\nL35608: \nL35609:         assert not any(\nL35610:             \"package init file\" in msg and \"not found\" in msg for msg in caplog.messages\nL35611:         )\nL35612: \nL35613: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_build_scripts.py\nL35614: #!/usr/bin/env python3\nL35615: \"\"\"Tests for distutils.command.build_scripts.\"\"\"\nL35616: \nL35617: import os\nL35618: import textwrap\nL35619: from distutils import sysconfig\nL35620: from distutils.command.build_scripts import build_scripts\nL35621: from distutils.core import Distribution\nL35622: from distutils.tests import support\nL35623: \nL35624: import jaraco.path\nL35625: \nL35626: \nL35627: class TestBuildScripts(support.TempdirManager):\nL35628:     def test_default_settings(self):\nL35629:         cmd = self.get_build_scripts_cmd(\"/foo/bar\", [])\nL35630:         assert not cmd.force\nL35631:         assert cmd.build_dir is None\nL35632: \nL35633:         cmd.finalize_options()\nL35634: \nL35635:         assert cmd.force\nL35636:         assert cmd.build_dir == \"/foo/bar\"\nL35637: \nL35638:     def test_build(self):\nL35639:         source = self.mkdtemp()\nL35640:         target = self.mkdtemp()\nL35641:         expected = self.write_sample_scripts(source)\nL35642: \nL35643:         cmd = self.get_build_scripts_cmd(\nL35644:             target, [os.path.join(source, fn) for fn in expected]\nL35645:         )\nL35646:         cmd.finalize_options()\nL35647:         cmd.run()\nL35648: \nL35649:         built = os.listdir(target)\nL35650:         for name in expected:\nL35651:             assert name in built\nL35652: \nL35653:     def get_build_scripts_cmd(self, target, scripts):\nL35654:         import sys\nL35655: \nL35656:         dist = Distribution()\nL35657:         dist.scripts = scripts\nL35658:         dist.command_obj[\"build\"] = support.DummyCommand(\nL35659:             build_scripts=target, force=True, executable=sys.executable\nL35660:         )\nL35661:         return build_scripts(dist)\nL35662: \nL35663:     @staticmethod\nL35664:     def write_sample_scripts(dir):\nL35665:         spec = {\nL35666:             'script1.py': textwrap.dedent(\"\"\"\nL35667:                 #! /usr/bin/env python2.3\nL35668:                 # bogus script w/ Python sh-bang\nL35669:                 pass\nL35670:                 \"\"\").lstrip(),\nL35671:             'script2.py': textwrap.dedent(\"\"\"\nL35672:                 #!/usr/bin/python\nL35673:                 # bogus script w/ Python sh-bang\nL35674:                 pass\nL35675:                 \"\"\").lstrip(),\nL35676:             'shell.sh': textwrap.dedent(\"\"\"\nL35677:                 #!/bin/sh\nL35678:                 # bogus shell script w/ sh-bang\nL35679:                 exit 0\nL35680:                 \"\"\").lstrip(),\nL35681:         }\nL35682:         jaraco.path.build(spec, dir)\nL35683:         return list(spec)\nL35684: \nL35685:     def test_version_int(self):\nL35686:         source = self.mkdtemp()\nL35687:         target = self.mkdtemp()\nL35688:         expected = self.write_sample_scripts(source)\nL35689: \nL35690:         cmd = self.get_build_scripts_cmd(\nL35691:             target, [os.path.join(source, fn) for fn in expected]\nL35692:         )\nL35693:         cmd.finalize_options()\nL35694: \nL35695:         # https://bugs.python.org/issue4524\nL35696:         #\nL35697:         # On linux-g++-32 with command line `./configure --enable-ipv6\nL35698:         # --with-suffix=3`, python is compiled okay but the build scripts\nL35699:         # failed when writing the name of the executable\nL35700:         old = sysconfig.get_config_vars().get('VERSION')\nL35701:         sysconfig._config_vars['VERSION'] = 4\nL35702:         try:\nL35703:             cmd.run()\nL35704:         finally:\nL35705:             if old is not None:\nL35706:                 sysconfig._config_vars['VERSION'] = old\nL35707: \nL35708:         built = os.listdir(target)\nL35709:         for name in expected:\nL35710:             assert name in built\nL35711: \nL35712: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_core.py\nL35713: #!/usr/bin/env python3\nL35714: \"\"\"Tests for distutils.core.\"\"\"\nL35715: \nL35716: import distutils.core\nL35717: import io\nL35718: import os\nL35719: import sys\nL35720: from distutils.dist import Distribution\nL35721: \nL35722: import pytest\nL35723: \nL35724: # setup script that uses __file__\nL35725: setup_using___file__ = \"\"\"\\\nL35726: \nL35727: __file__\nL35728: \nL35729: from distutils.core import setup\nL35730: setup()\nL35731: \"\"\"\nL35732: \nL35733: setup_prints_cwd = \"\"\"\\\nL35734: \nL35735: import os\nL35736: print(os.getcwd())\nL35737: \nL35738: from distutils.core import setup\nL35739: setup()\nL35740: \"\"\"\nL35741: \nL35742: setup_does_nothing = \"\"\"\\\nL35743: from distutils.core import setup\nL35744: setup()\nL35745: \"\"\"\nL35746: \nL35747: \nL35748: setup_defines_subclass = \"\"\"\\\nL35749: from distutils.core import setup\nL35750: from distutils.command.install import install as _install\nL35751: \nL35752: class install(_install):\nL35753:     sub_commands = _install.sub_commands + ['cmd']\nL35754: \nL35755: setup(cmdclass={'install': install})\nL35756: \"\"\"\nL35757: \nL35758: setup_within_if_main = \"\"\"\\\nL35759: from distutils.core import setup\nL35760: \nL35761: def main():\nL35762:     return setup(name=\"setup_within_if_main\")\nL35763: \nL35764: if __name__ == \"__main__\":\nL35765:     main()\nL35766: \"\"\"\nL35767: \nL35768: \nL35769: @pytest.fixture(autouse=True)\nL35770: def save_stdout(monkeypatch):\nL35771:     monkeypatch.setattr(sys, 'stdout', sys.stdout)\nL35772: \nL35773: \nL35774: @pytest.fixture\nL35775: def temp_file(tmp_path):\nL35776:     return tmp_path / 'file'\nL35777: \nL35778: \nL35779: @pytest.mark.usefixtures('save_env')\nL35780: @pytest.mark.usefixtures('save_argv')\nL35781: class TestCore:\nL35782:     def test_run_setup_provides_file(self, temp_file):\nL35783:         # Make sure the script can use __file__; if that's missing, the test\nL35784:         # setup.py script will raise NameError.\nL35785:         temp_file.write_text(setup_using___file__, encoding='utf-8')\nL35786:         distutils.core.run_setup(temp_file)\nL35787: \nL35788:     def test_run_setup_preserves_sys_argv(self, temp_file):\nL35789:         # Make sure run_setup does not clobber sys.argv\nL35790:         argv_copy = sys.argv.copy()\nL35791:         temp_file.write_text(setup_does_nothing, encoding='utf-8')\nL35792:         distutils.core.run_setup(temp_file)\nL35793:         assert sys.argv == argv_copy\nL35794: \nL35795:     def test_run_setup_defines_subclass(self, temp_file):\nL35796:         # Make sure the script can use __file__; if that's missing, the test\nL35797:         # setup.py script will raise NameError.\nL35798:         temp_file.write_text(setup_defines_subclass, encoding='utf-8')\nL35799:         dist = distutils.core.run_setup(temp_file)\nL35800:         install = dist.get_command_obj('install')\nL35801:         assert 'cmd' in install.sub_commands\nL35802: \nL35803:     def test_run_setup_uses_current_dir(self, tmp_path):\nL35804:         \"\"\"\nL35805:         Test that the setup script is run with the current directory\nL35806:         as its own current directory.\nL35807:         \"\"\"\nL35808:         sys.stdout = io.StringIO()\nL35809:         cwd = os.getcwd()\nL35810: \nL35811:         # Create a directory and write the setup.py file there:\nL35812:         setup_py = tmp_path / 'setup.py'\nL35813:         setup_py.write_text(setup_prints_cwd, encoding='utf-8')\nL35814:         distutils.core.run_setup(setup_py)\nL35815: \nL35816:         output = sys.stdout.getvalue()\nL35817:         if output.endswith(\"\\n\"):\nL35818:             output = output[:-1]\nL35819:         assert cwd == output\nL35820: \nL35821:     def test_run_setup_within_if_main(self, temp_file):\nL35822:         temp_file.write_text(setup_within_if_main, encoding='utf-8')\nL35823:         dist = distutils.core.run_setup(temp_file, stop_after=\"config\")\nL35824:         assert isinstance(dist, Distribution)\nL35825:         assert dist.get_name() == \"setup_within_if_main\"\nL35826: \nL35827:     def test_run_commands(self, temp_file):\nL35828:         sys.argv = ['setup.py', 'build']\nL35829:         temp_file.write_text(setup_within_if_main, encoding='utf-8')\nL35830:         dist = distutils.core.run_setup(temp_file, stop_after=\"commandline\")\nL35831:         assert 'build' not in dist.have_run\nL35832:         distutils.core.run_commands(dist)\nL35833:         assert 'build' in dist.have_run\nL35834: \nL35835:     def test_debug_mode(self, capsys, monkeypatch):\nL35836:         # this covers the code called when DEBUG is set\nL35837:         sys.argv = ['setup.py', '--name']\nL35838:         distutils.core.setup(name='bar')\nL35839:         assert capsys.readouterr().out == 'bar\\n'\nL35840:         monkeypatch.setattr(distutils.core, 'DEBUG', True)\nL35841:         distutils.core.setup(name='bar')\nL35842:         wanted = \"options (after parsing config files):\\n\"\nL35843:         assert capsys.readouterr().out.startswith(wanted)\nL35844: \nL35845: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_install.py\nL35846: #!/usr/bin/env python3\nL35847: \"\"\"Tests for distutils.command.install.\"\"\"\nL35848: \nL35849: import logging\nL35850: import os\nL35851: import pathlib\nL35852: import site\nL35853: import sys\nL35854: from distutils import sysconfig\nL35855: from distutils.command import install as install_module\nL35856: from distutils.command.build_ext import build_ext\nL35857: from distutils.command.install import INSTALL_SCHEMES, install\nL35858: from distutils.core import Distribution\nL35859: from distutils.errors import DistutilsOptionError\nL35860: from distutils.extension import Extension\nL35861: from distutils.tests import missing_compiler_executable, support\nL35862: from distutils.util import is_mingw\nL35863: \nL35864: import pytest\nL35865: \nL35866: \nL35867: def _make_ext_name(modname):\nL35868:     return modname + sysconfig.get_config_var('EXT_SUFFIX')\nL35869: \nL35870: \nL35871: @support.combine_markers\nL35872: @pytest.mark.usefixtures('save_env')\nL35873: class TestInstall(\nL35874:     support.TempdirManager,\nL35875: ):\nL35876:     @pytest.mark.xfail(\nL35877:         'platform.system() == \"Windows\" and sys.version_info > (3, 11)',\nL35878:         reason=\"pypa/distutils#148\",\nL35879:     )\nL35880:     def test_home_installation_scheme(self):\nL35881:         # This ensure two things:\nL35882:         # - that --home generates the desired set of directory names\nL35883:         # - test --home is supported on all platforms\nL35884:         builddir = self.mkdtemp()\nL35885:         destination = os.path.join(builddir, \"installation\")\nL35886: \nL35887:         dist = Distribution({\"name\": \"foopkg\"})\nL35888:         # script_name need not exist, it just need to be initialized\nL35889:         dist.script_name = os.path.join(builddir, \"setup.py\")\nL35890:         dist.command_obj[\"build\"] = support.DummyCommand(\nL35891:             build_base=builddir,\nL35892:             build_lib=os.path.join(builddir, \"lib\"),\nL35893:         )\nL35894: \nL35895:         cmd = install(dist)\nL35896:         cmd.home = destination\nL35897:         cmd.ensure_finalized()\nL35898: \nL35899:         assert cmd.install_base == destination\nL35900:         assert cmd.install_platbase == destination\nL35901: \nL35902:         def check_path(got, expected):\nL35903:             got = os.path.normpath(got)\nL35904:             expected = os.path.normpath(expected)\nL35905:             assert got == expected\nL35906: \nL35907:         impl_name = sys.implementation.name.replace(\"cpython\", \"python\")\nL35908:         libdir = os.path.join(destination, \"lib\", impl_name)\nL35909:         check_path(cmd.install_lib, libdir)\nL35910:         _platlibdir = getattr(sys, \"platlibdir\", \"lib\")\nL35911:         platlibdir = os.path.join(destination, _platlibdir, impl_name)\nL35912:         check_path(cmd.install_platlib, platlibdir)\nL35913:         check_path(cmd.install_purelib, libdir)\nL35914:         check_path(\nL35915:             cmd.install_headers,\nL35916:             os.path.join(destination, \"include\", impl_name, \"foopkg\"),\nL35917:         )\nL35918:         check_path(cmd.install_scripts, os.path.join(destination, \"bin\"))\nL35919:         check_path(cmd.install_data, destination)\nL35920: \nL35921:     def test_user_site(self, monkeypatch):\nL35922:         # test install with --user\nL35923:         # preparing the environment for the test\nL35924:         self.tmpdir = self.mkdtemp()\nL35925:         orig_site = site.USER_SITE\nL35926:         orig_base = site.USER_BASE\nL35927:         monkeypatch.setattr(site, 'USER_BASE', os.path.join(self.tmpdir, 'B'))\nL35928:         monkeypatch.setattr(site, 'USER_SITE', os.path.join(self.tmpdir, 'S'))\nL35929:         monkeypatch.setattr(install_module, 'USER_BASE', site.USER_BASE)\nL35930:         monkeypatch.setattr(install_module, 'USER_SITE', site.USER_SITE)\nL35931: \nL35932:         def _expanduser(path):\nL35933:             if path.startswith('~'):\nL35934:                 return os.path.normpath(self.tmpdir + path[1:])\nL35935:             return path\nL35936: \nL35937:         monkeypatch.setattr(os.path, 'expanduser', _expanduser)\nL35938: \nL35939:         for key in ('nt_user', 'posix_user'):\nL35940:             assert key in INSTALL_SCHEMES\nL35941: \nL35942:         dist = Distribution({'name': 'xx'})\nL35943:         cmd = install(dist)\nL35944: \nL35945:         # making sure the user option is there\nL35946:         options = [name for name, short, label in cmd.user_options]\nL35947:         assert 'user' in options\nL35948: \nL35949:         # setting a value\nL35950:         cmd.user = True\nL35951: \nL35952:         # user base and site shouldn't be created yet\nL35953:         assert not os.path.exists(site.USER_BASE)\nL35954:         assert not os.path.exists(site.USER_SITE)\nL35955: \nL35956:         # let's run finalize\nL35957:         cmd.ensure_finalized()\nL35958: \nL35959:         # now they should\nL35960:         assert os.path.exists(site.USER_BASE)\nL35961:         assert os.path.exists(site.USER_SITE)\nL35962: \nL35963:         assert 'userbase' in cmd.config_vars\nL35964:         assert 'usersite' in cmd.config_vars\nL35965: \nL35966:         actual_headers = os.path.relpath(cmd.install_headers, site.USER_BASE)\nL35967:         if os.name == 'nt' and not is_mingw():\nL35968:             site_path = os.path.relpath(os.path.dirname(orig_site), orig_base)\nL35969:             include = os.path.join(site_path, 'Include')\nL35970:         else:\nL35971:             include = sysconfig.get_python_inc(0, '')\nL35972:         expect_headers = os.path.join(include, 'xx')\nL35973: \nL35974:         assert os.path.normcase(actual_headers) == os.path.normcase(expect_headers)\nL35975: \nL35976:     def test_handle_extra_path(self):\nL35977:         dist = Distribution({'name': 'xx', 'extra_path': 'path,dirs'})\nL35978:         cmd = install(dist)\nL35979: \nL35980:         # two elements\nL35981:         cmd.handle_extra_path()\nL35982:         assert cmd.extra_path == ['path', 'dirs']\nL35983:         assert cmd.extra_dirs == 'dirs'\nL35984:         assert cmd.path_file == 'path'\nL35985: \nL35986:         # one element\nL35987:         cmd.extra_path = ['path']\nL35988:         cmd.handle_extra_path()\nL35989:         assert cmd.extra_path == ['path']\nL35990:         assert cmd.extra_dirs == 'path'\nL35991:         assert cmd.path_file == 'path'\nL35992: \nL35993:         # none\nL35994:         dist.extra_path = cmd.extra_path = None\nL35995:         cmd.handle_extra_path()\nL35996:         assert cmd.extra_path is None\nL35997:         assert cmd.extra_dirs == ''\nL35998:         assert cmd.path_file is None\nL35999: \nL36000:         # three elements (no way !)\nL36001:         cmd.extra_path = 'path,dirs,again'\nL36002:         with pytest.raises(DistutilsOptionError):\nL36003:             cmd.handle_extra_path()\nL36004: \nL36005:     def test_finalize_options(self):\nL36006:         dist = Distribution({'name': 'xx'})\nL36007:         cmd = install(dist)\nL36008: \nL36009:         # must supply either prefix/exec-prefix/home or\nL36010:         # install-base/install-platbase -- not both\nL36011:         cmd.prefix = 'prefix'\nL36012:         cmd.install_base = 'base'\nL36013:         with pytest.raises(DistutilsOptionError):\nL36014:             cmd.finalize_options()\nL36015: \nL36016:         # must supply either home or prefix/exec-prefix -- not both\nL36017:         cmd.install_base = None\nL36018:         cmd.home = 'home'\nL36019:         with pytest.raises(DistutilsOptionError):\nL36020:             cmd.finalize_options()\nL36021: \nL36022:         # can't combine user with prefix/exec_prefix/home or\nL36023:         # install_(plat)base\nL36024:         cmd.prefix = None\nL36025:         cmd.user = 'user'\nL36026:         with pytest.raises(DistutilsOptionError):\nL36027:             cmd.finalize_options()\nL36028: \nL36029:     def test_record(self):\nL36030:         install_dir = self.mkdtemp()\nL36031:         project_dir, dist = self.create_dist(py_modules=['hello'], scripts=['sayhi'])\nL36032:         os.chdir(project_dir)\nL36033:         self.write_file('hello.py', \"def main(): print('o hai')\")\nL36034:         self.write_file('sayhi', 'from hello import main; main()')\nL36035: \nL36036:         cmd = install(dist)\nL36037:         dist.command_obj['install'] = cmd\nL36038:         cmd.root = install_dir\nL36039:         cmd.record = os.path.join(project_dir, 'filelist')\nL36040:         cmd.ensure_finalized()\nL36041:         cmd.run()\nL36042: \nL36043:         content = pathlib.Path(cmd.record).read_text(encoding='utf-8')\nL36044: \nL36045:         found = [pathlib.Path(line).name for line in content.splitlines()]\nL36046:         expected = [\nL36047:             'hello.py',\nL36048:             f'hello.{sys.implementation.cache_tag}.pyc',\nL36049:             'sayhi',\nL36050:             'UNKNOWN-0.0.0-py{}.{}.egg-info'.format(*sys.version_info[:2]),\nL36051:         ]\nL36052:         assert found == expected\nL36053: \nL36054:     def test_record_extensions(self):\nL36055:         cmd = missing_compiler_executable()\nL36056:         if cmd is not None:\nL36057:             pytest.skip(f'The {cmd!r} command is not found')\nL36058:         install_dir = self.mkdtemp()\nL36059:         project_dir, dist = self.create_dist(\nL36060:             ext_modules=[Extension('xx', ['xxmodule.c'])]\nL36061:         )\nL36062:         os.chdir(project_dir)\nL36063:         support.copy_xxmodule_c(project_dir)\nL36064: \nL36065:         buildextcmd = build_ext(dist)\nL36066:         support.fixup_build_ext(buildextcmd)\nL36067:         buildextcmd.ensure_finalized()\nL36068: \nL36069:         cmd = install(dist)\nL36070:         dist.command_obj['install'] = cmd\nL36071:         dist.command_obj['build_ext'] = buildextcmd\nL36072:         cmd.root = install_dir\nL36073:         cmd.record = os.path.join(project_dir, 'filelist')\nL36074:         cmd.ensure_finalized()\nL36075:         cmd.run()\nL36076: \nL36077:         content = pathlib.Path(cmd.record).read_text(encoding='utf-8')\nL36078: \nL36079:         found = [pathlib.Path(line).name for line in content.splitlines()]\nL36080:         expected = [\nL36081:             _make_ext_name('xx'),\nL36082:             'UNKNOWN-0.0.0-py{}.{}.egg-info'.format(*sys.version_info[:2]),\nL36083:         ]\nL36084:         assert found == expected\nL36085: \nL36086:     def test_debug_mode(self, caplog, monkeypatch):\nL36087:         # this covers the code called when DEBUG is set\nL36088:         monkeypatch.setattr(install_module, 'DEBUG', True)\nL36089:         caplog.set_level(logging.DEBUG)\nL36090:         self.test_record()\nL36091:         assert any(rec for rec in caplog.records if rec.levelno == logging.DEBUG)\nL36092: \nL36093: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_install_scripts.py\nL36094: #!/usr/bin/env python3\nL36095: \"\"\"Tests for distutils.command.install_scripts.\"\"\"\nL36096: \nL36097: import os\nL36098: from distutils.command.install_scripts import install_scripts\nL36099: from distutils.core import Distribution\nL36100: from distutils.tests import support\nL36101: \nL36102: from . import test_build_scripts\nL36103: \nL36104: \nL36105: class TestInstallScripts(support.TempdirManager):\nL36106:     def test_default_settings(self):\nL36107:         dist = Distribution()\nL36108:         dist.command_obj[\"build\"] = support.DummyCommand(build_scripts=\"/foo/bar\")\nL36109:         dist.command_obj[\"install\"] = support.DummyCommand(\nL36110:             install_scripts=\"/splat/funk\",\nL36111:             force=True,\nL36112:             skip_build=True,\nL36113:         )\nL36114:         cmd = install_scripts(dist)\nL36115:         assert not cmd.force\nL36116:         assert not cmd.skip_build\nL36117:         assert cmd.build_dir is None\nL36118:         assert cmd.install_dir is None\nL36119: \nL36120:         cmd.finalize_options()\nL36121: \nL36122:         assert cmd.force\nL36123:         assert cmd.skip_build\nL36124:         assert cmd.build_dir == \"/foo/bar\"\nL36125:         assert cmd.install_dir == \"/splat/funk\"\nL36126: \nL36127:     def test_installation(self):\nL36128:         source = self.mkdtemp()\nL36129: \nL36130:         expected = test_build_scripts.TestBuildScripts.write_sample_scripts(source)\nL36131: \nL36132:         target = self.mkdtemp()\nL36133:         dist = Distribution()\nL36134:         dist.command_obj[\"build\"] = support.DummyCommand(build_scripts=source)\nL36135:         dist.command_obj[\"install\"] = support.DummyCommand(\nL36136:             install_scripts=target,\nL36137:             force=True,\nL36138:             skip_build=True,\nL36139:         )\nL36140:         cmd = install_scripts(dist)\nL36141:         cmd.finalize_options()\nL36142:         cmd.run()\nL36143: \nL36144:         installed = os.listdir(target)\nL36145:         for name in expected:\nL36146:             assert name in installed\nL36147: \nL36148: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_sdist.py\nL36149: #!/usr/bin/env python3\nL36150: \"\"\"Tests for distutils.command.sdist.\"\"\"\nL36151: \nL36152: import os\nL36153: import pathlib\nL36154: import shutil  # noqa: F401\nL36155: import tarfile\nL36156: import zipfile\nL36157: from distutils.archive_util import ARCHIVE_FORMATS\nL36158: from distutils.command.sdist import sdist, show_formats\nL36159: from distutils.core import Distribution\nL36160: from distutils.errors import DistutilsOptionError\nL36161: from distutils.filelist import FileList\nL36162: from os.path import join\nL36163: from textwrap import dedent\nL36164: \nL36165: import jaraco.path\nL36166: import path\nL36167: import pytest\nL36168: from more_itertools import ilen\nL36169: \nL36170: from . import support\nL36171: from .unix_compat import grp, pwd, require_uid_0, require_unix_id\nL36172: \nL36173: SETUP_PY = \"\"\"\nL36174: from distutils.core import setup\nL36175: import somecode\nL36176: \nL36177: setup(name='fake')\nL36178: \"\"\"\nL36179: \nL36180: MANIFEST = \"\"\"\\\nL36181: # file GENERATED by distutils, do NOT edit\nL36182: README\nL36183: buildout.cfg\nL36184: inroot.txt\nL36185: setup.py\nL36186: data%(sep)sdata.dt\nL36187: scripts%(sep)sscript.py\nL36188: some%(sep)sfile.txt\nL36189: some%(sep)sother_file.txt\nL36190: somecode%(sep)s__init__.py\nL36191: somecode%(sep)sdoc.dat\nL36192: somecode%(sep)sdoc.txt\nL36193: \"\"\"\nL36194: \nL36195: \nL36196: @pytest.fixture(autouse=True)\nL36197: def project_dir(request, distutils_managed_tempdir):\nL36198:     self = request.instance\nL36199:     self.tmp_dir = self.mkdtemp()\nL36200:     jaraco.path.build(\nL36201:         {\nL36202:             'somecode': {\nL36203:                 '__init__.py': '#',\nL36204:             },\nL36205:             'README': 'xxx',\nL36206:             'setup.py': SETUP_PY,\nL36207:         },\nL36208:         self.tmp_dir,\nL36209:     )\nL36210:     with path.Path(self.tmp_dir):\nL36211:         yield\nL36212: \nL36213: \nL36214: def clean_lines(filepath):\nL36215:     with pathlib.Path(filepath).open(encoding='utf-8') as f:\nL36216:         yield from filter(None, map(str.strip, f))\nL36217: \nL36218: \nL36219: class TestSDist(support.TempdirManager):\nL36220:     def get_cmd(self, metadata=None):\nL36221:         \"\"\"Returns a cmd\"\"\"\nL36222:         if metadata is None:\nL36223:             metadata = {\nL36224:                 'name': 'ns.fake--pkg',\nL36225:                 'version': '1.0',\nL36226:                 'url': 'xxx',\nL36227:                 'author': 'xxx',\nL36228:                 'author_email': 'xxx',\nL36229:             }\nL36230:         dist = Distribution(metadata)\nL36231:         dist.script_name = 'setup.py'\nL36232:         dist.packages = ['somecode']\nL36233:         dist.include_package_data = True\nL36234:         cmd = sdist(dist)\nL36235:         cmd.dist_dir = 'dist'\nL36236:         return dist, cmd\nL36237: \nL36238:     @pytest.mark.usefixtures('needs_zlib')\nL36239:     def test_prune_file_list(self):\nL36240:         # this test creates a project with some VCS dirs and an NFS rename\nL36241:         # file, then launches sdist to check they get pruned on all systems\nL36242: \nL36243:         # creating VCS directories with some files in them\nL36244:         os.mkdir(join(self.tmp_dir, 'somecode', '.svn'))\nL36245:         self.write_file((self.tmp_dir, 'somecode', '.svn', 'ok.py'), 'xxx')\nL36246: \nL36247:         os.mkdir(join(self.tmp_dir, 'somecode', '.hg'))\nL36248:         self.write_file((self.tmp_dir, 'somecode', '.hg', 'ok'), 'xxx')\nL36249: \nL36250:         os.mkdir(join(self.tmp_dir, 'somecode', '.git'))\nL36251:         self.write_file((self.tmp_dir, 'somecode', '.git', 'ok'), 'xxx')\nL36252: \nL36253:         self.write_file((self.tmp_dir, 'somecode', '.nfs0001'), 'xxx')\nL36254: \nL36255:         # now building a sdist\nL36256:         dist, cmd = self.get_cmd()\nL36257: \nL36258:         # zip is available universally\nL36259:         # (tar might not be installed under win32)\nL36260:         cmd.formats = ['zip']\nL36261: \nL36262:         cmd.ensure_finalized()\nL36263:         cmd.run()\nL36264: \nL36265:         # now let's check what we have\nL36266:         dist_folder = join(self.tmp_dir, 'dist')\nL36267:         files = os.listdir(dist_folder)\nL36268:         assert files == ['ns_fake_pkg-1.0.zip']\nL36269: \nL36270:         zip_file = zipfile.ZipFile(join(dist_folder, 'ns_fake_pkg-1.0.zip'))\nL36271:         try:\nL36272:             content = zip_file.namelist()\nL36273:         finally:\nL36274:             zip_file.close()\nL36275: \nL36276:         # making sure everything has been pruned correctly\nL36277:         expected = [\nL36278:             '',\nL36279:             'PKG-INFO',\nL36280:             'README',\nL36281:             'setup.py',\nL36282:             'somecode/',\nL36283:             'somecode/__init__.py',\nL36284:         ]\nL36285:         assert sorted(content) == ['ns_fake_pkg-1.0/' + x for x in expected]\nL36286: \nL36287:     @pytest.mark.usefixtures('needs_zlib')\nL36288:     @pytest.mark.skipif(\"not shutil.which('tar')\")\nL36289:     @pytest.mark.skipif(\"not shutil.which('gzip')\")\nL36290:     def test_make_distribution(self):\nL36291:         # now building a sdist\nL36292:         dist, cmd = self.get_cmd()\nL36293: \nL36294:         # creating a gztar then a tar\nL36295:         cmd.formats = ['gztar', 'tar']\nL36296:         cmd.ensure_finalized()\nL36297:         cmd.run()\nL36298: \nL36299:         # making sure we have two files\nL36300:         dist_folder = join(self.tmp_dir, 'dist')\nL36301:         result = os.listdir(dist_folder)\nL36302:         result.sort()\nL36303:         assert result == ['ns_fake_pkg-1.0.tar', 'ns_fake_pkg-1.0.tar.gz']\nL36304: \nL36305:         os.remove(join(dist_folder, 'ns_fake_pkg-1.0.tar'))\nL36306:         os.remove(join(dist_folder, 'ns_fake_pkg-1.0.tar.gz'))\nL36307: \nL36308:         # now trying a tar then a gztar\nL36309:         cmd.formats = ['tar', 'gztar']\nL36310: \nL36311:         cmd.ensure_finalized()\nL36312:         cmd.run()\nL36313: \nL36314:         result = os.listdir(dist_folder)\nL36315:         result.sort()\nL36316:         assert result == ['ns_fake_pkg-1.0.tar', 'ns_fake_pkg-1.0.tar.gz']\nL36317: \nL36318:     @pytest.mark.usefixtures('needs_zlib')\nL36319:     def test_add_defaults(self):\nL36320:         # https://bugs.python.org/issue2279\nL36321: \nL36322:         # add_default should also include\nL36323:         # data_files and package_data\nL36324:         dist, cmd = self.get_cmd()\nL36325: \nL36326:         # filling data_files by pointing files\nL36327:         # in package_data\nL36328:         dist.package_data = {'': ['*.cfg', '*.dat'], 'somecode': ['*.txt']}\nL36329:         self.write_file((self.tmp_dir, 'somecode', 'doc.txt'), '#')\nL36330:         self.write_file((self.tmp_dir, 'somecode', 'doc.dat'), '#')\nL36331: \nL36332:         # adding some data in data_files\nL36333:         data_dir = join(self.tmp_dir, 'data')\nL36334:         os.mkdir(data_dir)\nL36335:         self.write_file((data_dir, 'data.dt'), '#')\nL36336:         some_dir = join(self.tmp_dir, 'some')\nL36337:         os.mkdir(some_dir)\nL36338:         # make sure VCS directories are pruned (#14004)\nL36339:         hg_dir = join(self.tmp_dir, '.hg')\nL36340:         os.mkdir(hg_dir)\nL36341:         self.write_file((hg_dir, 'last-message.txt'), '#')\nL36342:         # a buggy regex used to prevent this from working on windows (#6884)\nL36343:         self.write_file((self.tmp_dir, 'buildout.cfg'), '#')\nL36344:         self.write_file((self.tmp_dir, 'inroot.txt'), '#')\nL36345:         self.write_file((some_dir, 'file.txt'), '#')\nL36346:         self.write_file((some_dir, 'other_file.txt'), '#')\nL36347: \nL36348:         dist.data_files = [\nL36349:             ('data', ['data/data.dt', 'buildout.cfg', 'inroot.txt', 'notexisting']),\nL36350:             'some/file.txt',\nL36351:             'some/other_file.txt',\nL36352:         ]\nL36353: \nL36354:         # adding a script\nL36355:         script_dir = join(self.tmp_dir, 'scripts')\nL36356:         os.mkdir(script_dir)\nL36357:         self.write_file((script_dir, 'script.py'), '#')\nL36358:         dist.scripts = [join('scripts', 'script.py')]\nL36359: \nL36360:         cmd.formats = ['zip']\nL36361:         cmd.use_defaults = True\nL36362: \nL36363:         cmd.ensure_finalized()\nL36364:         cmd.run()\nL36365: \nL36366:         # now let's check what we have\nL36367:         dist_folder = join(self.tmp_dir, 'dist')\nL36368:         files = os.listdir(dist_folder)\nL36369:         assert files == ['ns_fake_pkg-1.0.zip']\nL36370: \nL36371:         zip_file = zipfile.ZipFile(join(dist_folder, 'ns_fake_pkg-1.0.zip'))\nL36372:         try:\nL36373:             content = zip_file.namelist()\nL36374:         finally:\nL36375:             zip_file.close()\nL36376: \nL36377:         # making sure everything was added\nL36378:         expected = [\nL36379:             '',\nL36380:             'PKG-INFO',\nL36381:             'README',\nL36382:             'buildout.cfg',\nL36383:             'data/',\nL36384:             'data/data.dt',\nL36385:             'inroot.txt',\nL36386:             'scripts/',\nL36387:             'scripts/script.py',\nL36388:             'setup.py',\nL36389:             'some/',\nL36390:             'some/file.txt',\nL36391:             'some/other_file.txt',\nL36392:             'somecode/',\nL36393:             'somecode/__init__.py',\nL36394:             'somecode/doc.dat',\nL36395:             'somecode/doc.txt',\nL36396:         ]\nL36397:         assert sorted(content) == ['ns_fake_pkg-1.0/' + x for x in expected]\nL36398: \nL36399:         # checking the MANIFEST\nL36400:         manifest = pathlib.Path(self.tmp_dir, 'MANIFEST').read_text(encoding='utf-8')\nL36401:         assert manifest == MANIFEST % {'sep': os.sep}\nL36402: \nL36403:     @staticmethod\nL36404:     def warnings(messages, prefix='warning: '):\nL36405:         return [msg for msg in messages if msg.startswith(prefix)]\nL36406: \nL36407:     @pytest.mark.usefixtures('needs_zlib')\nL36408:     def test_metadata_check_option(self, caplog):\nL36409:         # testing the `medata-check` option\nL36410:         dist, cmd = self.get_cmd(metadata={})\nL36411: \nL36412:         # this should raise some warnings !\nL36413:         # with the `check` subcommand\nL36414:         cmd.ensure_finalized()\nL36415:         cmd.run()\nL36416:         assert len(self.warnings(caplog.messages, 'warning: check: ')) == 1\nL36417: \nL36418:         # trying with a complete set of metadata\nL36419:         caplog.clear()\nL36420:         dist, cmd = self.get_cmd()\nL36421:         cmd.ensure_finalized()\nL36422:         cmd.metadata_check = False\nL36423:         cmd.run()\nL36424:         assert len(self.warnings(caplog.messages, 'warning: check: ')) == 0\nL36425: \nL36426:     def test_show_formats(self, capsys):\nL36427:         show_formats()\nL36428: \nL36429:         # the output should be a header line + one line per format\nL36430:         num_formats = len(ARCHIVE_FORMATS.keys())\nL36431:         output = [\nL36432:             line\nL36433:             for line in capsys.readouterr().out.split('\\n')\nL36434:             if line.strip().startswith('--formats=')\nL36435:         ]\nL36436:         assert len(output) == num_formats\nL36437: \nL36438:     def test_finalize_options(self):\nL36439:         dist, cmd = self.get_cmd()\nL36440:         cmd.finalize_options()\nL36441: \nL36442:         # default options set by finalize\nL36443:         assert cmd.manifest == 'MANIFEST'\nL36444:         assert cmd.template == 'MANIFEST.in'\nL36445:         assert cmd.dist_dir == 'dist'\nL36446: \nL36447:         # formats has to be a string splitable on (' ', ',') or\nL36448:         # a stringlist\nL36449:         cmd.formats = 1\nL36450:         with pytest.raises(DistutilsOptionError):\nL36451:             cmd.finalize_options()\nL36452:         cmd.formats = ['zip']\nL36453:         cmd.finalize_options()\nL36454: \nL36455:         # formats has to be known\nL36456:         cmd.formats = 'supazipa'\nL36457:         with pytest.raises(DistutilsOptionError):\nL36458:             cmd.finalize_options()\nL36459: \nL36460:     # the following tests make sure there is a nice error message instead\nL36461:     # of a traceback when parsing an invalid manifest template\nL36462: \nL36463:     def _check_template(self, content, caplog):\nL36464:         dist, cmd = self.get_cmd()\nL36465:         os.chdir(self.tmp_dir)\nL36466:         self.write_file('MANIFEST.in', content)\nL36467:         cmd.ensure_finalized()\nL36468:         cmd.filelist = FileList()\nL36469:         cmd.read_template()\nL36470:         assert len(self.warnings(caplog.messages)) == 1\nL36471: \nL36472:     def test_invalid_template_unknown_command(self, caplog):\nL36473:         self._check_template('taunt knights *', caplog)\nL36474: \nL36475:     def test_invalid_template_wrong_arguments(self, caplog):\nL36476:         # this manifest command takes one argument\nL36477:         self._check_template('prune', caplog)\nL36478: \nL36479:     @pytest.mark.skipif(\"platform.system() != 'Windows'\")\nL36480:     def test_invalid_template_wrong_path(self, caplog):\nL36481:         # on Windows, trailing slashes are not allowed\nL36482:         # this used to crash instead of raising a warning: #8286\nL36483:         self._check_template('include examples/', caplog)\nL36484: \nL36485:     @pytest.mark.usefixtures('needs_zlib')\nL36486:     def test_get_file_list(self):\nL36487:         # make sure MANIFEST is recalculated\nL36488:         dist, cmd = self.get_cmd()\nL36489: \nL36490:         # filling data_files by pointing files in package_data\nL36491:         dist.package_data = {'somecode': ['*.txt']}\nL36492:         self.write_file((self.tmp_dir, 'somecode', 'doc.txt'), '#')\nL36493:         cmd.formats = ['gztar']\nL36494:         cmd.ensure_finalized()\nL36495:         cmd.run()\nL36496: \nL36497:         assert ilen(clean_lines(cmd.manifest)) == 5\nL36498: \nL36499:         # adding a file\nL36500:         self.write_file((self.tmp_dir, 'somecode', 'doc2.txt'), '#')\nL36501: \nL36502:         # make sure build_py is reinitialized, like a fresh run\nL36503:         build_py = dist.get_command_obj('build_py')\nL36504:         build_py.finalized = False\nL36505:         build_py.ensure_finalized()\nL36506: \nL36507:         cmd.run()\nL36508: \nL36509:         manifest2 = list(clean_lines(cmd.manifest))\nL36510: \nL36511:         # do we have the new file in MANIFEST ?\nL36512:         assert len(manifest2) == 6\nL36513:         assert 'doc2.txt' in manifest2[-1]\nL36514: \nL36515:     @pytest.mark.usefixtures('needs_zlib')\nL36516:     def test_manifest_marker(self):\nL36517:         # check that autogenerated MANIFESTs have a marker\nL36518:         dist, cmd = self.get_cmd()\nL36519:         cmd.ensure_finalized()\nL36520:         cmd.run()\nL36521: \nL36522:         assert (\nL36523:             next(clean_lines(cmd.manifest))\nL36524:             == '# file GENERATED by distutils, do NOT edit'\nL36525:         )\nL36526: \nL36527:     @pytest.mark.usefixtures('needs_zlib')\nL36528:     def test_manifest_comments(self):\nL36529:         # make sure comments don't cause exceptions or wrong includes\nL36530:         contents = dedent(\nL36531:             \"\"\"\\\nL36532:             # bad.py\nL36533:             #bad.py\nL36534:             good.py\nL36535:             \"\"\"\nL36536:         )\nL36537:         dist, cmd = self.get_cmd()\nL36538:         cmd.ensure_finalized()\nL36539:         self.write_file((self.tmp_dir, cmd.manifest), contents)\nL36540:         self.write_file((self.tmp_dir, 'good.py'), '# pick me!')\nL36541:         self.write_file((self.tmp_dir, 'bad.py'), \"# don't pick me!\")\nL36542:         self.write_file((self.tmp_dir, '#bad.py'), \"# don't pick me!\")\nL36543:         cmd.run()\nL36544:         assert cmd.filelist.files == ['good.py']\nL36545: \nL36546:     @pytest.mark.usefixtures('needs_zlib')\nL36547:     def test_manual_manifest(self):\nL36548:         # check that a MANIFEST without a marker is left alone\nL36549:         dist, cmd = self.get_cmd()\nL36550:         cmd.formats = ['gztar']\nL36551:         cmd.ensure_finalized()\nL36552:         self.write_file((self.tmp_dir, cmd.manifest), 'README.manual')\nL36553:         self.write_file(\nL36554:             (self.tmp_dir, 'README.manual'),\nL36555:             'This project maintains its MANIFEST file itself.',\nL36556:         )\nL36557:         cmd.run()\nL36558:         assert cmd.filelist.files == ['README.manual']\nL36559: \nL36560:         assert list(clean_lines(cmd.manifest)) == ['README.manual']\nL36561: \nL36562:         archive_name = join(self.tmp_dir, 'dist', 'ns_fake_pkg-1.0.tar.gz')\nL36563:         archive = tarfile.open(archive_name)\nL36564:         try:\nL36565:             filenames = [tarinfo.name for tarinfo in archive]\nL36566:         finally:\nL36567:             archive.close()\nL36568:         assert sorted(filenames) == [\nL36569:             'ns_fake_pkg-1.0',\nL36570:             'ns_fake_pkg-1.0/PKG-INFO',\nL36571:             'ns_fake_pkg-1.0/README.manual',\nL36572:         ]\nL36573: \nL36574:     @pytest.mark.usefixtures('needs_zlib')\nL36575:     @require_unix_id\nL36576:     @require_uid_0\nL36577:     @pytest.mark.skipif(\"not shutil.which('tar')\")\nL36578:     @pytest.mark.skipif(\"not shutil.which('gzip')\")\nL36579:     def test_make_distribution_owner_group(self):\nL36580:         # now building a sdist\nL36581:         dist, cmd = self.get_cmd()\nL36582: \nL36583:         # creating a gztar and specifying the owner+group\nL36584:         cmd.formats = ['gztar']\nL36585:         cmd.owner = pwd.getpwuid(0)[0]\nL36586:         cmd.group = grp.getgrgid(0)[0]\nL36587:         cmd.ensure_finalized()\nL36588:         cmd.run()\nL36589: \nL36590:         # making sure we have the good rights\nL36591:         archive_name = join(self.tmp_dir, 'dist', 'ns_fake_pkg-1.0.tar.gz')\nL36592:         archive = tarfile.open(archive_name)\nL36593:         try:\nL36594:             for member in archive.getmembers():\nL36595:                 assert member.uid == 0\nL36596:                 assert member.gid == 0\nL36597:         finally:\nL36598:             archive.close()\nL36599: \nL36600:         # building a sdist again\nL36601:         dist, cmd = self.get_cmd()\nL36602: \nL36603:         # creating a gztar\nL36604:         cmd.formats = ['gztar']\nL36605:         cmd.ensure_finalized()\nL36606:         cmd.run()\nL36607: \nL36608:         # making sure we have the good rights\nL36609:         archive_name = join(self.tmp_dir, 'dist', 'ns_fake_pkg-1.0.tar.gz')\nL36610:         archive = tarfile.open(archive_name)\nL36611: \nL36612:         # note that we are not testing the group ownership here\nL36613:         # because, depending on the platforms and the container\nL36614:         # rights (see #7408)\nL36615:         try:\nL36616:             for member in archive.getmembers():\nL36617:                 assert member.uid == os.getuid()\nL36618:         finally:\nL36619:             archive.close()\nL36620: \nL36621: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_distutils/tests/test_sysconfig.py\nL36622: #!/usr/bin/env python3\nL36623: \"\"\"Tests for distutils.sysconfig.\"\"\"\nL36624: \nL36625: import contextlib\nL36626: import distutils\nL36627: import os\nL36628: import pathlib\nL36629: import subprocess\nL36630: import sys\nL36631: from distutils import sysconfig\nL36632: from distutils.ccompiler import new_compiler  # noqa: F401\nL36633: from distutils.unixccompiler import UnixCCompiler\nL36634: \nL36635: import jaraco.envs\nL36636: import path\nL36637: import pytest\nL36638: from jaraco.text import trim\nL36639: from test.support import swap_item\nL36640: \nL36641: \nL36642: def _gen_makefile(root, contents):\nL36643:     jaraco.path.build({'Makefile': trim(contents)}, root)\nL36644:     return root / 'Makefile'\nL36645: \nL36646: \nL36647: @pytest.mark.usefixtures('save_env')\nL36648: class TestSysconfig:\nL36649:     def test_get_config_h_filename(self):\nL36650:         config_h = sysconfig.get_config_h_filename()\nL36651:         assert os.path.isfile(config_h)\nL36652: \nL36653:     @pytest.mark.skipif(\"platform.system() == 'Windows'\")\nL36654:     @pytest.mark.skipif(\"sys.implementation.name != 'cpython'\")\nL36655:     def test_get_makefile_filename(self):\nL36656:         makefile = sysconfig.get_makefile_filename()\nL36657:         assert os.path.isfile(makefile)\nL36658: \nL36659:     def test_get_python_lib(self, tmp_path):\nL36660:         assert sysconfig.get_python_lib() != sysconfig.get_python_lib(prefix=tmp_path)\nL36661: \nL36662:     def test_get_config_vars(self):\nL36663:         cvars = sysconfig.get_config_vars()\nL36664:         assert isinstance(cvars, dict)\nL36665:         assert cvars\nL36666: \nL36667:     @pytest.mark.skipif('sysconfig.IS_PYPY')\nL36668:     @pytest.mark.skipif('sysconfig.python_build')\nL36669:     @pytest.mark.xfail('platform.system() == \"Windows\"')\nL36670:     def test_srcdir_simple(self):\nL36671:         # See #15364.\nL36672:         srcdir = pathlib.Path(sysconfig.get_config_var('srcdir'))\nL36673: \nL36674:         assert srcdir.absolute()\nL36675:         assert srcdir.is_dir()\nL36676: \nL36677:         makefile = pathlib.Path(sysconfig.get_makefile_filename())\nL36678:         assert makefile.parent.samefile(srcdir)\nL36679: \nL36680:     @pytest.mark.skipif('sysconfig.IS_PYPY')\nL36681:     @pytest.mark.skipif('not sysconfig.python_build')\nL36682:     def test_srcdir_python_build(self):\nL36683:         # See #15364.\nL36684:         srcdir = pathlib.Path(sysconfig.get_config_var('srcdir'))\nL36685: \nL36686:         # The python executable has not been installed so srcdir\nL36687:         # should be a full source checkout.\nL36688:         Python_h = srcdir.joinpath('Include', 'Python.h')\nL36689:         assert Python_h.is_file()\nL36690:         assert sysconfig._is_python_source_dir(srcdir)\nL36691:         assert sysconfig._is_python_source_dir(str(srcdir))\nL36692: \nL36693:     def test_srcdir_independent_of_cwd(self):\nL36694:         \"\"\"\nL36695:         srcdir should be independent of the current working directory\nL36696:         \"\"\"\nL36697:         # See #15364.\nL36698:         srcdir = sysconfig.get_config_var('srcdir')\nL36699:         with path.Path('..'):\nL36700:             srcdir2 = sysconfig.get_config_var('srcdir')\nL36701:         assert srcdir == srcdir2\nL36702: \nL36703:     def customize_compiler(self):\nL36704:         # make sure AR gets caught\nL36705:         class compiler:\nL36706:             compiler_type = 'unix'\nL36707:             executables = UnixCCompiler.executables\nL36708: \nL36709:             def __init__(self):\nL36710:                 self.exes = {}\nL36711: \nL36712:             def set_executables(self, **kw):\nL36713:                 for k, v in kw.items():\nL36714:                     self.exes[k] = v\nL36715: \nL36716:         sysconfig_vars = {\nL36717:             'AR': 'sc_ar',\nL36718:             'CC': 'sc_cc',\nL36719:             'CXX': 'sc_cxx',\nL36720:             'ARFLAGS': '--sc-arflags',\nL36721:             'CFLAGS': '--sc-cflags',\nL36722:             'CCSHARED': '--sc-ccshared',\nL36723:             'LDSHARED': 'sc_ldshared',\nL36724:             'SHLIB_SUFFIX': 'sc_shutil_suffix',\nL36725:         }\nL36726: \nL36727:         comp = compiler()\nL36728:         with contextlib.ExitStack() as cm:\nL36729:             for key, value in sysconfig_vars.items():\nL36730:                 cm.enter_context(swap_item(sysconfig._config_vars, key, value))\nL36731:             sysconfig.customize_compiler(comp)\nL36732: \nL36733:         return comp\nL36734: \nL36735:     @pytest.mark.skipif(\"not isinstance(new_compiler(), UnixCCompiler)\")\nL36736:     @pytest.mark.usefixtures('disable_macos_customization')\nL36737:     def test_customize_compiler(self):\nL36738:         # Make sure that sysconfig._config_vars is initialized\nL36739:         sysconfig.get_config_vars()\nL36740: \nL36741:         os.environ['AR'] = 'env_ar'\nL36742:         os.environ['CC'] = 'env_cc'\nL36743:         os.environ['CPP'] = 'env_cpp'\nL36744:         os.environ['CXX'] = 'env_cxx --env-cxx-flags'\nL36745:         os.environ['LDSHARED'] = 'env_ldshared'\nL36746:         os.environ['LDFLAGS'] = '--env-ldflags'\nL36747:         os.environ['ARFLAGS'] = '--env-arflags'\nL36748:         os.environ['CFLAGS'] = '--env-cflags'\nL36749:         os.environ['CPPFLAGS'] = '--env-cppflags'\nL36750:         os.environ['RANLIB'] = 'env_ranlib'\nL36751: \nL36752:         comp = self.customize_compiler()\nL36753:         assert comp.exes['archiver'] == 'env_ar --env-arflags'\nL36754:         assert comp.exes['preprocessor'] == 'env_cpp --env-cppflags'\nL36755:         assert comp.exes['compiler'] == 'env_cc --env-cflags --env-cppflags'\nL36756:         assert comp.exes['compiler_so'] == (\nL36757:             'env_cc --env-cflags --env-cppflags --sc-ccshared'\nL36758:         )\nL36759:         assert (\nL36760:             comp.exes['compiler_cxx']\nL36761:             == 'env_cxx --env-cxx-flags --sc-cflags --env-cppflags'\nL36762:         )\nL36763:         assert comp.exes['linker_exe'] == 'env_cc'\nL36764:         assert comp.exes['linker_so'] == (\nL36765:             'env_ldshared --env-ldflags --env-cflags --env-cppflags'\nL36766:         )\nL36767:         assert comp.shared_lib_extension == 'sc_shutil_suffix'\nL36768: \nL36769:         if sys.platform == \"darwin\":\nL36770:             assert comp.exes['ranlib'] == 'env_ranlib'\nL36771:         else:\nL36772:             assert 'ranlib' not in comp.exes\nL36773: \nL36774:         del os.environ['AR']\nL36775:         del os.environ['CC']\nL36776:         del os.environ['CPP']\nL36777:         del os.environ['CXX']\nL36778:         del os.environ['LDSHARED']\nL36779:         del os.environ['LDFLAGS']\nL36780:         del os.environ['ARFLAGS']\nL36781:         del os.environ['CFLAGS']\nL36782:         del os.environ['CPPFLAGS']\nL36783:         del os.environ['RANLIB']\nL36784: \nL36785:         comp = self.customize_compiler()\nL36786:         assert comp.exes['archiver'] == 'sc_ar --sc-arflags'\nL36787:         assert comp.exes['preprocessor'] == 'sc_cc -E'\nL36788:         assert comp.exes['compiler'] == 'sc_cc --sc-cflags'\nL36789:         assert comp.exes['compiler_so'] == 'sc_cc --sc-cflags --sc-ccshared'\nL36790:         assert comp.exes['compiler_cxx'] == 'sc_cxx --sc-cflags'\nL36791:         assert comp.exes['linker_exe'] == 'sc_cc'\nL36792:         assert comp.exes['linker_so'] == 'sc_ldshared'\nL36793:         assert comp.shared_lib_extension == 'sc_shutil_suffix'\nL36794:         assert 'ranlib' not in comp.exes\nL36795: \nL36796:     def test_parse_makefile_base(self, tmp_path):\nL36797:         makefile = _gen_makefile(\nL36798:             tmp_path,\nL36799:             \"\"\"\nL36800:             CONFIG_ARGS=  '--arg1=optarg1' 'ENV=LIB'\nL36801:             VAR=$OTHER\nL36802:             OTHER=foo\nL36803:             \"\"\",\nL36804:         )\nL36805:         d = sysconfig.parse_makefile(makefile)\nL36806:         assert d == {'CONFIG_ARGS': \"'--arg1=optarg1' 'ENV=LIB'\", 'OTHER': 'foo'}\nL36807: \nL36808:     def test_parse_makefile_literal_dollar(self, tmp_path):\nL36809:         makefile = _gen_makefile(\nL36810:             tmp_path,\nL36811:             \"\"\"\nL36812:             CONFIG_ARGS=  '--arg1=optarg1' 'ENV=\\\\$$LIB'\nL36813:             VAR=$OTHER\nL36814:             OTHER=foo\nL36815:             \"\"\",\nL36816:         )\nL36817:         d = sysconfig.parse_makefile(makefile)\nL36818:         assert d == {'CONFIG_ARGS': r\"'--arg1=optarg1' 'ENV=\\$LIB'\", 'OTHER': 'foo'}\nL36819: \nL36820:     def test_sysconfig_module(self):\nL36821:         import sysconfig as global_sysconfig\nL36822: \nL36823:         assert global_sysconfig.get_config_var('CFLAGS') == sysconfig.get_config_var(\nL36824:             'CFLAGS'\nL36825:         )\nL36826:         assert global_sysconfig.get_config_var('LDFLAGS') == sysconfig.get_config_var(\nL36827:             'LDFLAGS'\nL36828:         )\nL36829: \nL36830:     # On macOS, binary installers support extension module building on\nL36831:     # various levels of the operating system with differing Xcode\nL36832:     # configurations, requiring customization of some of the\nL36833:     # compiler configuration directives to suit the environment on\nL36834:     # the installed machine. Some of these customizations may require\nL36835:     # running external programs and are thus deferred until needed by\nL36836:     # the first extension module build. Only\nL36837:     # the Distutils version of sysconfig is used for extension module\nL36838:     # builds, which happens earlier in the Distutils tests. This may\nL36839:     # cause the following tests to fail since no tests have caused\nL36840:     # the global version of sysconfig to call the customization yet.\nL36841:     # The solution for now is to simply skip this test in this case.\nL36842:     # The longer-term solution is to only have one version of sysconfig.\nL36843:     @pytest.mark.skipif(\"sysconfig.get_config_var('CUSTOMIZED_OSX_COMPILER')\")\nL36844:     def test_sysconfig_compiler_vars(self):\nL36845:         import sysconfig as global_sysconfig\nL36846: \nL36847:         if sysconfig.get_config_var('CUSTOMIZED_OSX_COMPILER'):\nL36848:             pytest.skip('compiler flags customized')\nL36849:         assert global_sysconfig.get_config_var('LDSHARED') == sysconfig.get_config_var(\nL36850:             'LDSHARED'\nL36851:         )\nL36852:         assert global_sysconfig.get_config_var('CC') == sysconfig.get_config_var('CC')\nL36853: \nL36854:     @pytest.mark.skipif(\"not sysconfig.get_config_var('EXT_SUFFIX')\")\nL36855:     def test_SO_deprecation(self):\nL36856:         with pytest.warns(DeprecationWarning):\nL36857:             sysconfig.get_config_var('SO')\nL36858: \nL36859:     def test_customize_compiler_before_get_config_vars(self, tmp_path):\nL36860:         # Issue #21923: test that a Distribution compiler\nL36861:         # instance can be called without an explicit call to\nL36862:         # get_config_vars().\nL36863:         jaraco.path.build(\nL36864:             {\nL36865:                 'file': trim(\"\"\"\nL36866:                     from distutils.core import Distribution\nL36867:                     config = Distribution().get_command_obj('config')\nL36868:                     # try_compile may pass or it may fail if no compiler\nL36869:                     # is found but it should not raise an exception.\nL36870:                     rc = config.try_compile('int x;')\nL36871:                     \"\"\")\nL36872:             },\nL36873:             tmp_path,\nL36874:         )\nL36875:         p = subprocess.Popen(\nL36876:             [sys.executable, tmp_path / 'file'],\nL36877:             stdout=subprocess.PIPE,\nL36878:             stderr=subprocess.STDOUT,\nL36879:             universal_newlines=True,\nL36880:             encoding='utf-8',\nL36881:         )\nL36882:         outs, errs = p.communicate()\nL36883:         assert 0 == p.returncode, \"Subprocess failed: \" + outs\nL36884: \nL36885:     def test_parse_config_h(self):\nL36886:         config_h = sysconfig.get_config_h_filename()\nL36887:         input = {}\nL36888:         with open(config_h, encoding=\"utf-8\") as f:\nL36889:             result = sysconfig.parse_config_h(f, g=input)\nL36890:         assert input is result\nL36891:         with open(config_h, encoding=\"utf-8\") as f:\nL36892:             result = sysconfig.parse_config_h(f)\nL36893:         assert isinstance(result, dict)\nL36894: \nL36895:     @pytest.mark.skipif(\"platform.system() != 'Windows'\")\nL36896:     @pytest.mark.skipif(\"sys.implementation.name != 'cpython'\")\nL36897:     def test_win_ext_suffix(self):\nL36898:         assert sysconfig.get_config_var(\"EXT_SUFFIX\").endswith(\".pyd\")\nL36899:         assert sysconfig.get_config_var(\"EXT_SUFFIX\") != \".pyd\"\nL36900: \nL36901:     @pytest.mark.skipif(\"platform.system() != 'Windows'\")\nL36902:     @pytest.mark.skipif(\"sys.implementation.name != 'cpython'\")\nL36903:     @pytest.mark.skipif(\nL36904:         '\\\\PCbuild\\\\'.casefold() not in sys.executable.casefold(),\nL36905:         reason='Need sys.executable to be in a source tree',\nL36906:     )\nL36907:     def test_win_build_venv_from_source_tree(self, tmp_path):\nL36908:         \"\"\"Ensure distutils.sysconfig detects venvs from source tree builds.\"\"\"\nL36909:         env = jaraco.envs.VEnv()\nL36910:         env.create_opts = env.clean_opts\nL36911:         env.root = tmp_path\nL36912:         env.ensure_env()\nL36913:         cmd = [\nL36914:             env.exe(),\nL36915:             \"-c\",\nL36916:             \"import distutils.sysconfig; print(distutils.sysconfig.python_build)\",\nL36917:         ]\nL36918:         distutils_path = os.path.dirname(os.path.dirname(distutils.__file__))\nL36919:         out = subprocess.check_output(\nL36920:             cmd, env={**os.environ, \"PYTHONPATH\": distutils_path}\nL36921:         )\nL36922:         assert out == \"True\"\nL36923: \nL36924:     def test_get_python_inc_missing_config_dir(self, monkeypatch):\nL36925:         \"\"\"\nL36926:         In portable Python installations, the sysconfig will be broken,\nL36927:         pointing to the directories where the installation was built and\nL36928:         not where it currently is. In this case, ensure that the missing\nL36929:         directory isn't used for get_python_inc.\nL36930: \nL36931:         See pypa/distutils#178.\nL36932:         \"\"\"\nL36933: \nL36934:         def override(name):\nL36935:             if name == 'INCLUDEPY':\nL36936:                 return '/does-not-exist'\nL36937:             return sysconfig.get_config_var(name)\nL36938: \nL36939:         monkeypatch.setattr(sysconfig, 'get_config_var', override)\nL36940: \nL36941:         assert os.path.exists(sysconfig.get_python_inc())\nL36942: \nL36943: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/setuptools/_vendor/typing_extensions.py\nL36944: #!/usr/bin/env python3\nL36945: import abc\nL36946: import collections\nL36947: import collections.abc\nL36948: import contextlib\nL36949: import functools\nL36950: import inspect\nL36951: import operator\nL36952: import sys\nL36953: import types as _types\nL36954: import typing\nL36955: import warnings\nL36956: \nL36957: __all__ = [\nL36958:     # Super-special typing primitives.\nL36959:     'Any',\nL36960:     'ClassVar',\nL36961:     'Concatenate',\nL36962:     'Final',\nL36963:     'LiteralString',\nL36964:     'ParamSpec',\nL36965:     'ParamSpecArgs',\nL36966:     'ParamSpecKwargs',\nL36967:     'Self',\nL36968:     'Type',\nL36969:     'TypeVar',\nL36970:     'TypeVarTuple',\nL36971:     'Unpack',\nL36972: \nL36973:     # ABCs (from collections.abc).\nL36974:     'Awaitable',\nL36975:     'AsyncIterator',\nL36976:     'AsyncIterable',\nL36977:     'Coroutine',\nL36978:     'AsyncGenerator',\nL36979:     'AsyncContextManager',\nL36980:     'Buffer',\nL36981:     'ChainMap',\nL36982: \nL36983:     # Concrete collection types.\nL36984:     'ContextManager',\nL36985:     'Counter',\nL36986:     'Deque',\nL36987:     'DefaultDict',\nL36988:     'NamedTuple',\nL36989:     'OrderedDict',\nL36990:     'TypedDict',\nL36991: \nL36992:     # Structural checks, a.k.a. protocols.\nL36993:     'SupportsAbs',\nL36994:     'SupportsBytes',\nL36995:     'SupportsComplex',\nL36996:     'SupportsFloat',\nL36997:     'SupportsIndex',\nL36998:     'SupportsInt',\nL36999:     'SupportsRound',\nL37000: \nL37001:     # One-off things.\nL37002:     'Annotated',\nL37003:     'assert_never',\nL37004:     'assert_type',\nL37005:     'clear_overloads',\nL37006:     'dataclass_transform',\nL37007:     'deprecated',\nL37008:     'Doc',\nL37009:     'get_overloads',\nL37010:     'final',\nL37011:     'get_args',\nL37012:     'get_origin',\nL37013:     'get_original_bases',\nL37014:     'get_protocol_members',\nL37015:     'get_type_hints',\nL37016:     'IntVar',\nL37017:     'is_protocol',\nL37018:     'is_typeddict',\nL37019:     'Literal',\nL37020:     'NewType',\nL37021:     'overload',\nL37022:     'override',\nL37023:     'Protocol',\nL37024:     'reveal_type',\nL37025:     'runtime',\nL37026:     'runtime_checkable',\nL37027:     'Text',\nL37028:     'TypeAlias',\nL37029:     'TypeAliasType',\nL37030:     'TypeGuard',\nL37031:     'TypeIs',\nL37032:     'TYPE_CHECKING',\nL37033:     'Never',\nL37034:     'NoReturn',\nL37035:     'ReadOnly',\nL37036:     'Required',\nL37037:     'NotRequired',\nL37038: \nL37039:     # Pure aliases, have always been in typing\nL37040:     'AbstractSet',\nL37041:     'AnyStr',\nL37042:     'BinaryIO',\nL37043:     'Callable',\nL37044:     'Collection',\nL37045:     'Container',\nL37046:     'Dict',\nL37047:     'ForwardRef',\nL37048:     'FrozenSet',\nL37049:     'Generator',\nL37050:     'Generic',\nL37051:     'Hashable',\nL37052:     'IO',\nL37053:     'ItemsView',\nL37054:     'Iterable',\nL37055:     'Iterator',\nL37056:     'KeysView',\nL37057:     'List',\nL37058:     'Mapping',\nL37059:     'MappingView',\nL37060:     'Match',\nL37061:     'MutableMapping',\nL37062:     'MutableSequence',\nL37063:     'MutableSet',\nL37064:     'NoDefault',\nL37065:     'Optional',\nL37066:     'Pattern',\nL37067:     'Reversible',\nL37068:     'Sequence',\nL37069:     'Set',\nL37070:     'Sized',\nL37071:     'TextIO',\nL37072:     'Tuple',\nL37073:     'Union',\nL37074:     'ValuesView',\nL37075:     'cast',\nL37076:     'no_type_check',\nL37077:     'no_type_check_decorator',\nL37078: ]\nL37079: \nL37080: # for backward compatibility\nL37081: PEP_560 = True\nL37082: GenericMeta = type\nL37083: _PEP_696_IMPLEMENTED = sys.version_info >= (3, 13, 0, \"beta\")\nL37084: \nL37085: # The functions below are modified copies of typing internal helpers.\nL37086: # They are needed by _ProtocolMeta and they provide support for PEP 646.\nL37087: \nL37088: \nL37089: class _Sentinel:\nL37090:     def __repr__(self):\nL37091:         return \"<sentinel>\"\nL37092: \nL37093: \nL37094: _marker = _Sentinel()\nL37095: \nL37096: \nL37097: if sys.version_info >= (3, 10):\nL37098:     def _should_collect_from_parameters(t):\nL37099:         return isinstance(\nL37100:             t, (typing._GenericAlias, _types.GenericAlias, _types.UnionType)\nL37101:         )\nL37102: elif sys.version_info >= (3, 9):\nL37103:     def _should_collect_from_parameters(t):\nL37104:         return isinstance(t, (typing._GenericAlias, _types.GenericAlias))\nL37105: else:\nL37106:     def _should_collect_from_parameters(t):\nL37107:         return isinstance(t, typing._GenericAlias) and not t._special\nL37108: \nL37109: \nL37110: NoReturn = typing.NoReturn\nL37111: \nL37112: # Some unconstrained type variables.  These are used by the container types.\nL37113: # (These are not for export.)\nL37114: T = typing.TypeVar('T')  # Any type.\nL37115: KT = typing.TypeVar('KT')  # Key type.\nL37116: VT = typing.TypeVar('VT')  # Value type.\nL37117: T_co = typing.TypeVar('T_co', covariant=True)  # Any type covariant containers.\nL37118: T_contra = typing.TypeVar('T_contra', contravariant=True)  # Ditto contravariant.\nL37119: \nL37120: \nL37121: if sys.version_info >= (3, 11):\nL37122:     from typing import Any\nL37123: else:\nL37124: \nL37125:     class _AnyMeta(type):\nL37126:         def __instancecheck__(self, obj):\nL37127:             if self is Any:\nL37128:                 raise TypeError(\"typing_extensions.Any cannot be used with isinstance()\")\nL37129:             return super().__instancecheck__(obj)\nL37130: \nL37131:         def __repr__(self):\nL37132:             if self is Any:\nL37133:                 return \"typing_extensions.Any\"\nL37134:             return super().__repr__()\nL37135: \nL37136:     class Any(metaclass=_AnyMeta):\nL37137:         \"\"\"Special type indicating an unconstrained type.\nL37138:         - Any is compatible with every type.\nL37139:         - Any assumed to have all methods.\nL37140:         - All values assumed to be instances of Any.\nL37141:         Note that all the above statements are true from the point of view of\nL37142:         static type checkers. At runtime, Any should not be used with instance\nL37143:         checks.\nL37144:         \"\"\"\nL37145:         def __new__(cls, *args, **kwargs):\nL37146:             if cls is Any:\nL37147:                 raise TypeError(\"Any cannot be instantiated\")\nL37148:             return super().__new__(cls, *args, **kwargs)\nL37149: \nL37150: \nL37151: ClassVar = typing.ClassVar\nL37152: \nL37153: \nL37154: class _ExtensionsSpecialForm(typing._SpecialForm, _root=True):\nL37155:     def __repr__(self):\nL37156:         return 'typing_extensions.' + self._name\nL37157: \nL37158: \nL37159: Final = typing.Final\nL37160: \nL37161: if sys.version_info >= (3, 11):\nL37162:     final = typing.final\nL37163: else:\nL37164:     # @final exists in 3.8+, but we backport it for all versions\nL37165:     # before 3.11 to keep support for the __final__ attribute.\nL37166:     # See https://bugs.python.org/issue46342\nL37167:     def final(f):\nL37168:         \"\"\"This decorator can be used to indicate to type checkers that\nL37169:         the decorated method cannot be overridden, and decorated class\nL37170:         cannot be subclassed. For example:\nL37171: \nL37172:             class Base:\nL37173:                 @final\nL37174:                 def done(self) -> None:\nL37175:                     ...\nL37176:             class Sub(Base):\nL37177:                 def done(self) -> None:  # Error reported by type checker\nL37178:                     ...\nL37179:             @final\nL37180:             class Leaf:\nL37181:                 ...\nL37182:             class Other(Leaf):  # Error reported by type checker\nL37183:                 ...\nL37184: \nL37185:         There is no runtime checking of these properties. The decorator\nL37186:         sets the ``__final__`` attribute to ``True`` on the decorated object\nL37187:         to allow runtime introspection.\nL37188:         \"\"\"\nL37189:         try:\nL37190:             f.__final__ = True\nL37191:         except (AttributeError, TypeError):\nL37192:             # Skip the attribute silently if it is not writable.\nL37193:             # AttributeError happens if the object has __slots__ or a\nL37194:             # read-only property, TypeError if it's a builtin class.\nL37195:             pass\nL37196:         return f\nL37197: \nL37198: \nL37199: def IntVar(name):\nL37200:     return typing.TypeVar(name)\nL37201: \nL37202: \nL37203: # A Literal bug was fixed in 3.11.0, 3.10.1 and 3.9.8\nL37204: if sys.version_info >= (3, 10, 1):\nL37205:     Literal = typing.Literal\nL37206: else:\nL37207:     def _flatten_literal_params(parameters):\nL37208:         \"\"\"An internal helper for Literal creation: flatten Literals among parameters\"\"\"\nL37209:         params = []\nL37210:         for p in parameters:\nL37211:             if isinstance(p, _LiteralGenericAlias):\nL37212:                 params.extend(p.__args__)\nL37213:             else:\nL37214:                 params.append(p)\nL37215:         return tuple(params)\nL37216: \nL37217:     def _value_and_type_iter(params):\nL37218:         for p in params:\nL37219:             yield p, type(p)\nL37220: \nL37221:     class _LiteralGenericAlias(typing._GenericAlias, _root=True):\nL37222:         def __eq__(self, other):\nL37223:             if not isinstance(other, _LiteralGenericAlias):\nL37224:                 return NotImplemented\nL37225:             these_args_deduped = set(_value_and_type_iter(self.__args__))\nL37226:             other_args_deduped = set(_value_and_type_iter(other.__args__))\nL37227:             return these_args_deduped == other_args_deduped\nL37228: \nL37229:         def __hash__(self):\nL37230:             return hash(frozenset(_value_and_type_iter(self.__args__)))\nL37231: \nL37232:     class _LiteralForm(_ExtensionsSpecialForm, _root=True):\nL37233:         def __init__(self, doc: str):\nL37234:             self._name = 'Literal'\nL37235:             self._doc = self.__doc__ = doc\nL37236: \nL37237:         def __getitem__(self, parameters):\nL37238:             if not isinstance(parameters, tuple):\nL37239:                 parameters = (parameters,)\nL37240: \nL37241:             parameters = _flatten_literal_params(parameters)\nL37242: \nL37243:             val_type_pairs = list(_value_and_type_iter(parameters))\nL37244:             try:\nL37245:                 deduped_pairs = set(val_type_pairs)\nL37246:             except TypeError:\nL37247:                 # unhashable parameters\nL37248:                 pass\nL37249:             else:\nL37250:                 # similar logic to typing._deduplicate on Python 3.9+\nL37251:                 if len(deduped_pairs) < len(val_type_pairs):\nL37252:                     new_parameters = []\nL37253:                     for pair in val_type_pairs:\nL37254:                         if pair in deduped_pairs:\nL37255:                             new_parameters.append(pair[0])\nL37256:                             deduped_pairs.remove(pair)\nL37257:                     assert not deduped_pairs, deduped_pairs\nL37258:                     parameters = tuple(new_parameters)\nL37259: \nL37260:             return _LiteralGenericAlias(self, parameters)\nL37261: \nL37262:     Literal = _LiteralForm(doc=\"\"\"\\\nL37263:                            A type that can be used to indicate to type checkers\nL37264:                            that the corresponding value has a value literally equivalent\nL37265:                            to the provided parameter. For example:\nL37266: \nL37267:                                var: Literal[4] = 4\nL37268: \nL37269:                            The type checker understands that 'var' is literally equal to\nL37270:                            the value 4 and no other value.\nL37271: \nL37272:                            Literal[...] cannot be subclassed. There is no runtime\nL37273:                            checking verifying that the parameter is actually a value\nL37274:                            instead of a type.\"\"\")\nL37275: \nL37276: \nL37277: _overload_dummy = typing._overload_dummy\nL37278: \nL37279: \nL37280: if hasattr(typing, \"get_overloads\"):  # 3.11+\nL37281:     overload = typing.overload\nL37282:     get_overloads = typing.get_overloads\nL37283:     clear_overloads = typing.clear_overloads\nL37284: else:\nL37285:     # {module: {qualname: {firstlineno: func}}}\nL37286:     _overload_registry = collections.defaultdict(\nL37287:         functools.partial(collections.defaultdict, dict)\nL37288:     )\nL37289: \nL37290:     def overload(func):\nL37291:         \"\"\"Decorator for overloaded functions/methods.\nL37292: \nL37293:         In a stub file, place two or more stub definitions for the same\nL37294:         function in a row, each decorated with @overload.  For example:\nL37295: \nL37296:         @overload\nL37297:         def utf8(value: None) -> None: ...\nL37298:         @overload\nL37299:         def utf8(value: bytes) -> bytes: ...\nL37300:         @overload\nL37301:         def utf8(value: str) -> bytes: ...\nL37302: \nL37303:         In a non-stub file (i.e. a regular .py file), do the same but\nL37304:         follow it with an implementation.  The implementation should *not*\nL37305:         be decorated with @overload.  For example:\nL37306: \nL37307:         @overload\nL37308:         def utf8(value: None) -> None: ...\nL37309:         @overload\nL37310:         def utf8(value: bytes) -> bytes: ...\nL37311:         @overload\nL37312:         def utf8(value: str) -> bytes: ...\nL37313:         def utf8(value):\nL37314:             # implementation goes here\nL37315: \nL37316:         The overloads for a function can be retrieved at runtime using the\nL37317:         get_overloads() function.\nL37318:         \"\"\"\nL37319:         # classmethod and staticmethod\nL37320:         f = getattr(func, \"__func__\", func)\nL37321:         try:\nL37322:             _overload_registry[f.__module__][f.__qualname__][\nL37323:                 f.__code__.co_firstlineno\nL37324:             ] = func\nL37325:         except AttributeError:\nL37326:             # Not a normal function; ignore.\nL37327:             pass\nL37328:         return _overload_dummy\nL37329: \nL37330:     def get_overloads(func):\nL37331:         \"\"\"Return all defined overloads for *func* as a sequence.\"\"\"\nL37332:         # classmethod and staticmethod\nL37333:         f = getattr(func, \"__func__\", func)\nL37334:         if f.__module__ not in _overload_registry:\nL37335:             return []\nL37336:         mod_dict = _overload_registry[f.__module__]\nL37337:         if f.__qualname__ not in mod_dict:\nL37338:             return []\nL37339:         return list(mod_dict[f.__qualname__].values())\nL37340: \nL37341:     def clear_overloads():\nL37342:         \"\"\"Clear all overloads in the registry.\"\"\"\nL37343:         _overload_registry.clear()\nL37344: \nL37345: \nL37346: # This is not a real generic class.  Don't use outside annotations.\nL37347: Type = typing.Type\nL37348: \nL37349: # Various ABCs mimicking those in collections.abc.\nL37350: # A few are simply re-exported for completeness.\nL37351: Awaitable = typing.Awaitable\nL37352: Coroutine = typing.Coroutine\nL37353: AsyncIterable = typing.AsyncIterable\nL37354: AsyncIterator = typing.AsyncIterator\nL37355: Deque = typing.Deque\nL37356: DefaultDict = typing.DefaultDict\nL37357: OrderedDict = typing.OrderedDict\nL37358: Counter = typing.Counter\nL37359: ChainMap = typing.ChainMap\nL37360: Text = typing.Text\nL37361: TYPE_CHECKING = typing.TYPE_CHECKING\nL37362: \nL37363: \nL37364: if sys.version_info >= (3, 13, 0, \"beta\"):\nL37365:     from typing import AsyncContextManager, AsyncGenerator, ContextManager, Generator\nL37366: else:\nL37367:     def _is_dunder(attr):\nL37368:         return attr.startswith('__') and attr.endswith('__')\nL37369: \nL37370:     # Python <3.9 doesn't have typing._SpecialGenericAlias\nL37371:     _special_generic_alias_base = getattr(\nL37372:         typing, \"_SpecialGenericAlias\", typing._GenericAlias\nL37373:     )\nL37374: \nL37375:     class _SpecialGenericAlias(_special_generic_alias_base, _root=True):\nL37376:         def __init__(self, origin, nparams, *, inst=True, name=None, defaults=()):\nL37377:             if _special_generic_alias_base is typing._GenericAlias:\nL37378:                 # Python <3.9\nL37379:                 self.__origin__ = origin\nL37380:                 self._nparams = nparams\nL37381:                 super().__init__(origin, nparams, special=True, inst=inst, name=name)\nL37382:             else:\nL37383:                 # Python >= 3.9\nL37384:                 super().__init__(origin, nparams, inst=inst, name=name)\nL37385:             self._defaults = defaults\nL37386: \nL37387:         def __setattr__(self, attr, val):\nL37388:             allowed_attrs = {'_name', '_inst', '_nparams', '_defaults'}\nL37389:             if _special_generic_alias_base is typing._GenericAlias:\nL37390:                 # Python <3.9\nL37391:                 allowed_attrs.add(\"__origin__\")\nL37392:             if _is_dunder(attr) or attr in allowed_attrs:\nL37393:                 object.__setattr__(self, attr, val)\nL37394:             else:\nL37395:                 setattr(self.__origin__, attr, val)\nL37396: \nL37397:         @typing._tp_cache\nL37398:         def __getitem__(self, params):\nL37399:             if not isinstance(params, tuple):\nL37400:                 params = (params,)\nL37401:             msg = \"Parameters to generic types must be types.\"\nL37402:             params = tuple(typing._type_check(p, msg) for p in params)\nL37403:             if (\nL37404:                 self._defaults\nL37405:                 and len(params) < self._nparams\nL37406:                 and len(params) + len(self._defaults) >= self._nparams\nL37407:             ):\nL37408:                 params = (*params, *self._defaults[len(params) - self._nparams:])\nL37409:             actual_len = len(params)\nL37410: \nL37411:             if actual_len != self._nparams:\nL37412:                 if self._defaults:\nL37413:                     expected = f\"at least {self._nparams - len(self._defaults)}\"\nL37414:                 else:\nL37415:                     expected = str(self._nparams)\nL37416:                 if not self._nparams:\nL37417:                     raise TypeError(f\"{self} is not a generic class\")\nL37418:                 raise TypeError(\nL37419:                     f\"Too {'many' if actual_len > self._nparams else 'few'}\"\nL37420:                     f\" arguments for {self};\"\nL37421:                     f\" actual {actual_len}, expected {expected}\"\nL37422:                 )\nL37423:             return self.copy_with(params)\nL37424: \nL37425:     _NoneType = type(None)\nL37426:     Generator = _SpecialGenericAlias(\nL37427:         collections.abc.Generator, 3, defaults=(_NoneType, _NoneType)\nL37428:     )\nL37429:     AsyncGenerator = _SpecialGenericAlias(\nL37430:         collections.abc.AsyncGenerator, 2, defaults=(_NoneType,)\nL37431:     )\nL37432:     ContextManager = _SpecialGenericAlias(\nL37433:         contextlib.AbstractContextManager,\nL37434:         2,\nL37435:         name=\"ContextManager\",\nL37436:         defaults=(typing.Optional[bool],)\nL37437:     )\nL37438:     AsyncContextManager = _SpecialGenericAlias(\nL37439:         contextlib.AbstractAsyncContextManager,\nL37440:         2,\nL37441:         name=\"AsyncContextManager\",\nL37442:         defaults=(typing.Optional[bool],)\nL37443:     )\nL37444: \nL37445: \nL37446: _PROTO_ALLOWLIST = {\nL37447:     'collections.abc': [\nL37448:         'Callable', 'Awaitable', 'Iterable', 'Iterator', 'AsyncIterable',\nL37449:         'Hashable', 'Sized', 'Container', 'Collection', 'Reversible', 'Buffer',\nL37450:     ],\nL37451:     'contextlib': ['AbstractContextManager', 'AbstractAsyncContextManager'],\nL37452:     'typing_extensions': ['Buffer'],\nL37453: }\nL37454: \nL37455: \nL37456: _EXCLUDED_ATTRS = frozenset(typing.EXCLUDED_ATTRIBUTES) | {\nL37457:     \"__match_args__\", \"__protocol_attrs__\", \"__non_callable_proto_members__\",\nL37458:     \"__final__\",\nL37459: }\nL37460: \nL37461: \nL37462: def _get_protocol_attrs(cls):\nL37463:     attrs = set()\nL37464:     for base in cls.__mro__[:-1]:  # without object\nL37465:         if base.__name__ in {'Protocol', 'Generic'}:\nL37466:             continue\nL37467:         annotations = getattr(base, '__annotations__', {})\nL37468:         for attr in (*base.__dict__, *annotations):\nL37469:             if (not attr.startswith('_abc_') and attr not in _EXCLUDED_ATTRS):\nL37470:                 attrs.add(attr)\nL37471:     return attrs\nL37472: \nL37473: \nL37474: def _caller(depth=2):\nL37475:     try:\nL37476:         return sys._getframe(depth).f_globals.get('__name__', '__main__')\nL37477:     except (AttributeError, ValueError):  # For platforms without _getframe()\nL37478:         return None\nL37479: \nL37480: \nL37481: # `__match_args__` attribute was removed from protocol members in 3.13,\nL37482: # we want to backport this change to older Python versions.\nL37483: if sys.version_info >= (3, 13):\nL37484:     Protocol = typing.Protocol\nL37485: else:\nL37486:     def _allow_reckless_class_checks(depth=3):\nL37487:         \"\"\"Allow instance and class checks for special stdlib modules.\nL37488:         The abc and functools modules indiscriminately call isinstance() and\nL37489:         issubclass() on the whole MRO of a user class, which may contain protocols.\nL37490:         \"\"\"\nL37491:         return _caller(depth) in {'abc', 'functools', None}\nL37492: \nL37493:     def _no_init(self, *args, **kwargs):\nL37494:         if type(self)._is_protocol:\nL37495:             raise TypeError('Protocols cannot be instantiated')\nL37496: \nL37497:     def _type_check_issubclass_arg_1(arg):\nL37498:         \"\"\"Raise TypeError if `arg` is not an instance of `type`\nL37499:         in `issubclass(arg, <protocol>)`.\nL37500: \nL37501:         In most cases, this is verified by type.__subclasscheck__.\nL37502:         Checking it again unnecessarily would slow down issubclass() checks,\nL37503:         so, we don't perform this check unless we absolutely have to.\nL37504: \nL37505:         For various error paths, however,\nL37506:         we want to ensure that *this* error message is shown to the user\nL37507:         where relevant, rather than a typing.py-specific error message.\nL37508:         \"\"\"\nL37509:         if not isinstance(arg, type):\nL37510:             # Same error message as for issubclass(1, int).\nL37511:             raise TypeError('issubclass() arg 1 must be a class')\nL37512: \nL37513:     # Inheriting from typing._ProtocolMeta isn't actually desirable,\nL37514:     # but is necessary to allow typing.Protocol and typing_extensions.Protocol\nL37515:     # to mix without getting TypeErrors about \"metaclass conflict\"\nL37516:     class _ProtocolMeta(type(typing.Protocol)):\nL37517:         # This metaclass is somewhat unfortunate,\nL37518:         # but is necessary for several reasons...\nL37519:         #\nL37520:         # NOTE: DO NOT call super() in any methods in this class\nL37521:         # That would call the methods on typing._ProtocolMeta on Python 3.8-3.11\nL37522:         # and those are slow\nL37523:         def __new__(mcls, name, bases, namespace, **kwargs):\nL37524:             if name == \"Protocol\" and len(bases) < 2:\nL37525:                 pass\nL37526:             elif {Protocol, typing.Protocol} & set(bases):\nL37527:                 for base in bases:\nL37528:                     if not (\nL37529:                         base in {object, typing.Generic, Protocol, typing.Protocol}\nL37530:                         or base.__name__ in _PROTO_ALLOWLIST.get(base.__module__, [])\nL37531:                         or is_protocol(base)\nL37532:                     ):\nL37533:                         raise TypeError(\nL37534:                             f\"Protocols can only inherit from other protocols, \"\nL37535:                             f\"got {base!r}\"\nL37536:                         )\nL37537:             return abc.ABCMeta.__new__(mcls, name, bases, namespace, **kwargs)\nL37538: \nL37539:         def __init__(cls, *args, **kwargs):\nL37540:             abc.ABCMeta.__init__(cls, *args, **kwargs)\nL37541:             if getattr(cls, \"_is_protocol\", False):\nL37542:                 cls.__protocol_attrs__ = _get_protocol_attrs(cls)\nL37543: \nL37544:         def __subclasscheck__(cls, other):\nL37545:             if cls is Protocol:\nL37546:                 return type.__subclasscheck__(cls, other)\nL37547:             if (\nL37548:                 getattr(cls, '_is_protocol', False)\nL37549:                 and not _allow_reckless_class_checks()\nL37550:             ):\nL37551:                 if not getattr(cls, '_is_runtime_protocol', False):\nL37552:                     _type_check_issubclass_arg_1(other)\nL37553:                     raise TypeError(\nL37554:                         \"Instance and class checks can only be used with \"\nL37555:                         \"@runtime_checkable protocols\"\nL37556:                     )\nL37557:                 if (\nL37558:                     # this attribute is set by @runtime_checkable:\nL37559:                     cls.__non_callable_proto_members__\nL37560:                     and cls.__dict__.get(\"__subclasshook__\") is _proto_hook\nL37561:                 ):\nL37562:                     _type_check_issubclass_arg_1(other)\nL37563:                     non_method_attrs = sorted(cls.__non_callable_proto_members__)\nL37564:                     raise TypeError(\nL37565:                         \"Protocols with non-method members don't support issubclass().\"\nL37566:                         f\" Non-method members: {str(non_method_attrs)[1:-1]}.\"\nL37567:                     )\nL37568:             return abc.ABCMeta.__subclasscheck__(cls, other)\nL37569: \nL37570:         def __instancecheck__(cls, instance):\nL37571:             # We need this method for situations where attributes are\nL37572:             # assigned in __init__.\nL37573:             if cls is Protocol:\nL37574:                 return type.__instancecheck__(cls, instance)\nL37575:             if not getattr(cls, \"_is_protocol\", False):\nL37576:                 # i.e., it's a concrete subclass of a protocol\nL37577:                 return abc.ABCMeta.__instancecheck__(cls, instance)\nL37578: \nL37579:             if (\nL37580:                 not getattr(cls, '_is_runtime_protocol', False) and\nL37581:                 not _allow_reckless_class_checks()\nL37582:             ):\nL37583:                 raise TypeError(\"Instance and class checks can only be used with\"\nL37584:                                 \" @runtime_checkable protocols\")\nL37585: \nL37586:             if abc.ABCMeta.__instancecheck__(cls, instance):\nL37587:                 return True\nL37588: \nL37589:             for attr in cls.__protocol_attrs__:\nL37590:                 try:\nL37591:                     val = inspect.getattr_static(instance, attr)\nL37592:                 except AttributeError:\nL37593:                     break\nL37594:                 # this attribute is set by @runtime_checkable:\nL37595:                 if val is None and attr not in cls.__non_callable_proto_members__:\nL37596:                     break\nL37597:             else:\nL37598:                 return True\nL37599: \nL37600:             return False\nL37601: \nL37602:         def __eq__(cls, other):\nL37603:             # Hack so that typing.Generic.__class_getitem__\nL37604:             # treats typing_extensions.Protocol\nL37605:             # as equivalent to typing.Protocol\nL37606:             if abc.ABCMeta.__eq__(cls, other) is True:\nL37607:                 return True\nL37608:             return cls is Protocol and other is typing.Protocol\nL37609: \nL37610:         # This has to be defined, or the abc-module cache\nL37611:         # complains about classes with this metaclass being unhashable,\nL37612:         # if we define only __eq__!\nL37613:         def __hash__(cls) -> int:\nL37614:             return type.__hash__(cls)\nL37615: \nL37616:     @classmethod\nL37617:     def _proto_hook(cls, other):\nL37618:         if not cls.__dict__.get('_is_protocol', False):\nL37619:             return NotImplemented\nL37620: \nL37621:         for attr in cls.__protocol_attrs__:\nL37622:             for base in other.__mro__:\nL37623:                 # Check if the members appears in the class dictionary...\nL37624:                 if attr in base.__dict__:\nL37625:                     if base.__dict__[attr] is None:\nL37626:                         return NotImplemented\nL37627:                     break\nL37628: \nL37629:                 # ...or in annotations, if it is a sub-protocol.\nL37630:                 annotations = getattr(base, '__annotations__', {})\nL37631:                 if (\nL37632:                     isinstance(annotations, collections.abc.Mapping)\nL37633:                     and attr in annotations\nL37634:                     and is_protocol(other)\nL37635:                 ):\nL37636:                     break\nL37637:             else:\nL37638:                 return NotImplemented\nL37639:         return True\nL37640: \nL37641:     class Protocol(typing.Generic, metaclass=_ProtocolMeta):\nL37642:         __doc__ = typing.Protocol.__doc__\nL37643:         __slots__ = ()\nL37644:         _is_protocol = True\nL37645:         _is_runtime_protocol = False\nL37646: \nL37647:         def __init_subclass__(cls, *args, **kwargs):\nL37648:             super().__init_subclass__(*args, **kwargs)\nL37649: \nL37650:             # Determine if this is a protocol or a concrete subclass.\nL37651:             if not cls.__dict__.get('_is_protocol', False):\nL37652:                 cls._is_protocol = any(b is Protocol for b in cls.__bases__)\nL37653: \nL37654:             # Set (or override) the protocol subclass hook.\nL37655:             if '__subclasshook__' not in cls.__dict__:\nL37656:                 cls.__subclasshook__ = _proto_hook\nL37657: \nL37658:             # Prohibit instantiation for protocol classes\nL37659:             if cls._is_protocol and cls.__init__ is Protocol.__init__:\nL37660:                 cls.__init__ = _no_init\nL37661: \nL37662: \nL37663: if sys.version_info >= (3, 13):\nL37664:     runtime_checkable = typing.runtime_checkable\nL37665: else:\nL37666:     def runtime_checkable(cls):\nL37667:         \"\"\"Mark a protocol class as a runtime protocol.\nL37668: \nL37669:         Such protocol can be used with isinstance() and issubclass().\nL37670:         Raise TypeError if applied to a non-protocol class.\nL37671:         This allows a simple-minded structural check very similar to\nL37672:         one trick ponies in collections.abc such as Iterable.\nL37673: \nL37674:         For example::\nL37675: \nL37676:             @runtime_checkable\nL37677:             class Closable(Protocol):\nL37678:                 def close(self): ...\nL37679: \nL37680:             assert isinstance(open('/some/file'), Closable)\nL37681: \nL37682:         Warning: this will check only the presence of the required methods,\nL37683:         not their type signatures!\nL37684:         \"\"\"\nL37685:         if not issubclass(cls, typing.Generic) or not getattr(cls, '_is_protocol', False):\nL37686:             raise TypeError(f'@runtime_checkable can be only applied to protocol classes,'\nL37687:                             f' got {cls!r}')\nL37688:         cls._is_runtime_protocol = True\nL37689: \nL37690:         # typing.Protocol classes on <=3.11 break if we execute this block,\nL37691:         # because typing.Protocol classes on <=3.11 don't have a\nL37692:         # `__protocol_attrs__` attribute, and this block relies on the\nL37693:         # `__protocol_attrs__` attribute. Meanwhile, typing.Protocol classes on 3.12.2+\nL37694:         # break if we *don't* execute this block, because *they* assume that all\nL37695:         # protocol classes have a `__non_callable_proto_members__` attribute\nL37696:         # (which this block sets)\nL37697:         if isinstance(cls, _ProtocolMeta) or sys.version_info >= (3, 12, 2):\nL37698:             # PEP 544 prohibits using issubclass()\nL37699:             # with protocols that have non-method members.\nL37700:             # See gh-113320 for why we compute this attribute here,\nL37701:             # rather than in `_ProtocolMeta.__init__`\nL37702:             cls.__non_callable_proto_members__ = set()\nL37703:             for attr in cls.__protocol_attrs__:\nL37704:                 try:\nL37705:                     is_callable = callable(getattr(cls, attr, None))\nL37706:                 except Exception as e:\nL37707:                     raise TypeError(\nL37708:                         f\"Failed to determine whether protocol member {attr!r} \"\nL37709:                         \"is a method member\"\nL37710:                     ) from e\nL37711:                 else:\nL37712:                     if not is_callable:\nL37713:                         cls.__non_callable_proto_members__.add(attr)\nL37714: \nL37715:         return cls\nL37716: \nL37717: \nL37718: # The \"runtime\" alias exists for backwards compatibility.\nL37719: runtime = runtime_checkable\nL37720: \nL37721: \nL37722: # Our version of runtime-checkable protocols is faster on Python 3.8-3.11\nL37723: if sys.version_info >= (3, 12):\nL37724:     SupportsInt = typing.SupportsInt\nL37725:     SupportsFloat = typing.SupportsFloat\nL37726:     SupportsComplex = typing.SupportsComplex\nL37727:     SupportsBytes = typing.SupportsBytes\nL37728:     SupportsIndex = typing.SupportsIndex\nL37729:     SupportsAbs = typing.SupportsAbs\nL37730:     SupportsRound = typing.SupportsRound\nL37731: else:\nL37732:     @runtime_checkable\nL37733:     class SupportsInt(Protocol):\nL37734:         \"\"\"An ABC with one abstract method __int__.\"\"\"\nL37735:         __slots__ = ()\nL37736: \nL37737:         @abc.abstractmethod\nL37738:         def __int__(self) -> int:\nL37739:             pass\nL37740: \nL37741:     @runtime_checkable\nL37742:     class SupportsFloat(Protocol):\nL37743:         \"\"\"An ABC with one abstract method __float__.\"\"\"\nL37744:         __slots__ = ()\nL37745: \nL37746:         @abc.abstractmethod\nL37747:         def __float__(self) -> float:\nL37748:             pass\nL37749: \nL37750:     @runtime_checkable\nL37751:     class SupportsComplex(Protocol):\nL37752:         \"\"\"An ABC with one abstract method __complex__.\"\"\"\nL37753:         __slots__ = ()\nL37754: \nL37755:         @abc.abstractmethod\nL37756:         def __complex__(self) -> complex:\nL37757:             pass\nL37758: \nL37759:     @runtime_checkable\nL37760:     class SupportsBytes(Protocol):\nL37761:         \"\"\"An ABC with one abstract method __bytes__.\"\"\"\nL37762:         __slots__ = ()\nL37763: \nL37764:         @abc.abstractmethod\nL37765:         def __bytes__(self) -> bytes:\nL37766:             pass\nL37767: \nL37768:     @runtime_checkable\nL37769:     class SupportsIndex(Protocol):\nL37770:         __slots__ = ()\nL37771: \nL37772:         @abc.abstractmethod\nL37773:         def __index__(self) -> int:\nL37774:             pass\nL37775: \nL37776:     @runtime_checkable\nL37777:     class SupportsAbs(Protocol[T_co]):\nL37778:         \"\"\"\nL37779:         An ABC with one abstract method __abs__ that is covariant in its return type.\nL37780:         \"\"\"\nL37781:         __slots__ = ()\nL37782: \nL37783:         @abc.abstractmethod\nL37784:         def __abs__(self) -> T_co:\nL37785:             pass\nL37786: \nL37787:     @runtime_checkable\nL37788:     class SupportsRound(Protocol[T_co]):\nL37789:         \"\"\"\nL37790:         An ABC with one abstract method __round__ that is covariant in its return type.\nL37791:         \"\"\"\nL37792:         __slots__ = ()\nL37793: \nL37794:         @abc.abstractmethod\nL37795:         def __round__(self, ndigits: int = 0) -> T_co:\nL37796:             pass\nL37797: \nL37798: \nL37799: def _ensure_subclassable(mro_entries):\nL37800:     def inner(func):\nL37801:         if sys.implementation.name == \"pypy\" and sys.version_info < (3, 9):\nL37802:             cls_dict = {\nL37803:                 \"__call__\": staticmethod(func),\nL37804:                 \"__mro_entries__\": staticmethod(mro_entries)\nL37805:             }\nL37806:             t = type(func.__name__, (), cls_dict)\nL37807:             return functools.update_wrapper(t(), func)\nL37808:         else:\nL37809:             func.__mro_entries__ = mro_entries\nL37810:             return func\nL37811:     return inner\nL37812: \nL37813: \nL37814: # Update this to something like >=3.13.0b1 if and when\nL37815: # PEP 728 is implemented in CPython\nL37816: _PEP_728_IMPLEMENTED = False\nL37817: \nL37818: if _PEP_728_IMPLEMENTED:\nL37819:     # The standard library TypedDict in Python 3.8 does not store runtime information\nL37820:     # about which (if any) keys are optional.  See https://bugs.python.org/issue38834\nL37821:     # The standard library TypedDict in Python 3.9.0/1 does not honour the \"total\"\nL37822:     # keyword with old-style TypedDict().  See https://bugs.python.org/issue42059\nL37823:     # The standard library TypedDict below Python 3.11 does not store runtime\nL37824:     # information about optional and required keys when using Required or NotRequired.\nL37825:     # Generic TypedDicts are also impossible using typing.TypedDict on Python <3.11.\nL37826:     # Aaaand on 3.12 we add __orig_bases__ to TypedDict\nL37827:     # to enable better runtime introspection.\nL37828:     # On 3.13 we deprecate some odd ways of creating TypedDicts.\nL37829:     # Also on 3.13, PEP 705 adds the ReadOnly[] qualifier.\nL37830:     # PEP 728 (still pending) makes more changes.\nL37831:     TypedDict = typing.TypedDict\nL37832:     _TypedDictMeta = typing._TypedDictMeta\nL37833:     is_typeddict = typing.is_typeddict\nL37834: else:\nL37835:     # 3.10.0 and later\nL37836:     _TAKES_MODULE = \"module\" in inspect.signature(typing._type_check).parameters\nL37837: \nL37838:     def _get_typeddict_qualifiers(annotation_type):\nL37839:         while True:\nL37840:             annotation_origin = get_origin(annotation_type)\nL37841:             if annotation_origin is Annotated:\nL37842:                 annotation_args = get_args(annotation_type)\nL37843:                 if annotation_args:\nL37844:                     annotation_type = annotation_args[0]\nL37845:                 else:\nL37846:                     break\nL37847:             elif annotation_origin is Required:\nL37848:                 yield Required\nL37849:                 annotation_type, = get_args(annotation_type)\nL37850:             elif annotation_origin is NotRequired:\nL37851:                 yield NotRequired\nL37852:                 annotation_type, = get_args(annotation_type)\nL37853:             elif annotation_origin is ReadOnly:\nL37854:                 yield ReadOnly\nL37855:                 annotation_type, = get_args(annotation_type)\nL37856:             else:\nL37857:                 break\nL37858: \nL37859:     class _TypedDictMeta(type):\nL37860:         def __new__(cls, name, bases, ns, *, total=True, closed=False):\nL37861:             \"\"\"Create new typed dict class object.\nL37862: \nL37863:             This method is called when TypedDict is subclassed,\nL37864:             or when TypedDict is instantiated. This way\nL37865:             TypedDict supports all three syntax forms described in its docstring.\nL37866:             Subclasses and instances of TypedDict return actual dictionaries.\nL37867:             \"\"\"\nL37868:             for base in bases:\nL37869:                 if type(base) is not _TypedDictMeta and base is not typing.Generic:\nL37870:                     raise TypeError('cannot inherit from both a TypedDict type '\nL37871:                                     'and a non-TypedDict base class')\nL37872: \nL37873:             if any(issubclass(b, typing.Generic) for b in bases):\nL37874:                 generic_base = (typing.Generic,)\nL37875:             else:\nL37876:                 generic_base = ()\nL37877: \nL37878:             # typing.py generally doesn't let you inherit from plain Generic, unless\nL37879:             # the name of the class happens to be \"Protocol\"\nL37880:             tp_dict = type.__new__(_TypedDictMeta, \"Protocol\", (*generic_base, dict), ns)\nL37881:             tp_dict.__name__ = name\nL37882:             if tp_dict.__qualname__ == \"Protocol\":\nL37883:                 tp_dict.__qualname__ = name\nL37884: \nL37885:             if not hasattr(tp_dict, '__orig_bases__'):\nL37886:                 tp_dict.__orig_bases__ = bases\nL37887: \nL37888:             annotations = {}\nL37889:             if \"__annotations__\" in ns:\nL37890:                 own_annotations = ns[\"__annotations__\"]\nL37891:             elif \"__annotate__\" in ns:\nL37892:                 # TODO: Use inspect.VALUE here, and make the annotations lazily evaluated\nL37893:                 own_annotations = ns[\"__annotate__\"](1)\nL37894:             else:\nL37895:                 own_annotations = {}\nL37896:             msg = \"TypedDict('Name', {f0: t0, f1: t1, ...}); each t must be a type\"\nL37897:             if _TAKES_MODULE:\nL37898:                 own_annotations = {\nL37899:                     n: typing._type_check(tp, msg, module=tp_dict.__module__)\nL37900:                     for n, tp in own_annotations.items()\nL37901:                 }\nL37902:             else:\nL37903:                 own_annotations = {\nL37904:                     n: typing._type_check(tp, msg)\nL37905:                     for n, tp in own_annotations.items()\nL37906:                 }\nL37907:             required_keys = set()\nL37908:             optional_keys = set()\nL37909:             readonly_keys = set()\nL37910:             mutable_keys = set()\nL37911:             extra_items_type = None\nL37912: \nL37913:             for base in bases:\nL37914:                 base_dict = base.__dict__\nL37915: \nL37916:                 annotations.update(base_dict.get('__annotations__', {}))\nL37917:                 required_keys.update(base_dict.get('__required_keys__', ()))\nL37918:                 optional_keys.update(base_dict.get('__optional_keys__', ()))\nL37919:                 readonly_keys.update(base_dict.get('__readonly_keys__', ()))\nL37920:                 mutable_keys.update(base_dict.get('__mutable_keys__', ()))\nL37921:                 base_extra_items_type = base_dict.get('__extra_items__', None)\nL37922:                 if base_extra_items_type is not None:\nL37923:                     extra_items_type = base_extra_items_type\nL37924: \nL37925:             if closed and extra_items_type is None:\nL37926:                 extra_items_type = Never\nL37927:             if closed and \"__extra_items__\" in own_annotations:\nL37928:                 annotation_type = own_annotations.pop(\"__extra_items__\")\nL37929:                 qualifiers = set(_get_typeddict_qualifiers(annotation_type))\nL37930:                 if Required in qualifiers:\nL37931:                     raise TypeError(\nL37932:                         \"Special key __extra_items__