         # one for this particular filter call, then we'll use whatever the\nL14623:         # SpecifierSet thinks for whether or not we should support prereleases.\nL14624:         if prereleases is None:\nL14625:             prereleases = self.prereleases\nL14626: \nL14627:         # We can determine if we're going to allow pre-releases by looking to\nL14628:         # see if any of the underlying items supports them. If none of them do\nL14629:         # and this item is a pre-release then we do not allow it and we can\nL14630:         # short circuit that here.\nL14631:         # Note: This means that 1.0.dev1 would not be contained in something\nL14632:         #       like >=1.0.devabc however it would be in >=1.0.debabc,>0.0.dev0\nL14633:         if not prereleases and item.is_prerelease:\nL14634:             return False\nL14635: \nL14636:         if installed and item.is_prerelease:\nL14637:             item = Version(item.base_version)\nL14638: \nL14639:         # We simply dispatch to the underlying specs here to make sure that the\nL14640:         # given version is contained within all of them.\nL14641:         # Note: This use of all() here means that an empty set of specifiers\nL14642:         #       will always return True, this is an explicit design decision.\nL14643:         return all(s.contains(item, prereleases=prereleases) for s in self._specs)\nL14644: \nL14645:     def filter(\nL14646:         self, iterable: Iterable[UnparsedVersionVar], prereleases: Optional[bool] = None\nL14647:     ) -> Iterator[UnparsedVersionVar]:\nL14648:         \"\"\"Filter items in the given iterable, that match the specifiers in this set.\nL14649: \nL14650:         :param iterable:\nL14651:             An iterable that can contain version strings and :class:`Version` instances.\nL14652:             The items in the iterable will be filtered according to the specifier.\nL14653:         :param prereleases:\nL14654:             Whether or not to allow prereleases in the returned iterator. If set to\nL14655:             ``None`` (the default), it will be intelligently decide whether to allow\nL14656:             prereleases or not (based on the :attr:`prereleases` attribute, and\nL14657:             whether the only versions matching are prereleases).\nL14658: \nL14659:         This method is smarter than just ``filter(SpecifierSet(...).contains, [...])``\nL14660:         because it implements the rule from :pep:`440` that a prerelease item\nL14661:         SHOULD be accepted if no other versions match the given specifier.\nL14662: \nL14663:         >>> list(SpecifierSet(\">=1.2.3\").filter([\"1.2\", \"1.3\", \"1.5a1\"]))\nL14664:         ['1.3']\nL14665:         >>> list(SpecifierSet(\">=1.2.3\").filter([\"1.2\", \"1.3\", Version(\"1.4\")]))\nL14666:         ['1.3', <Version('1.4')>]\nL14667:         >>> list(SpecifierSet(\">=1.2.3\").filter([\"1.2\", \"1.5a1\"]))\nL14668:         []\nL14669:         >>> list(SpecifierSet(\">=1.2.3\").filter([\"1.3\", \"1.5a1\"], prereleases=True))\nL14670:         ['1.3', '1.5a1']\nL14671:         >>> list(SpecifierSet(\">=1.2.3\", prereleases=True).filter([\"1.3\", \"1.5a1\"]))\nL14672:         ['1.3', '1.5a1']\nL14673: \nL14674:         An \"empty\" SpecifierSet will filter items based on the presence of prerelease\nL14675:         versions in the set.\nL14676: \nL14677:         >>> list(SpecifierSet(\"\").filter([\"1.3\", \"1.5a1\"]))\nL14678:         ['1.3']\nL14679:         >>> list(SpecifierSet(\"\").filter([\"1.5a1\"]))\nL14680:         ['1.5a1']\nL14681:         >>> list(SpecifierSet(\"\", prereleases=True).filter([\"1.3\", \"1.5a1\"]))\nL14682:         ['1.3', '1.5a1']\nL14683:         >>> list(SpecifierSet(\"\").filter([\"1.3\", \"1.5a1\"], prereleases=True))\nL14684:         ['1.3', '1.5a1']\nL14685:         \"\"\"\nL14686:         # Determine if we're forcing a prerelease or not, if we're not forcing\nL14687:         # one for this particular filter call, then we'll use whatever the\nL14688:         # SpecifierSet thinks for whether or not we should support prereleases.\nL14689:         if prereleases is None:\nL14690:             prereleases = self.prereleases\nL14691: \nL14692:         # If we have any specifiers, then we want to wrap our iterable in the\nL14693:         # filter method for each one, this will act as a logical AND amongst\nL14694:         # each specifier.\nL14695:         if self._specs:\nL14696:             for spec in self._specs:\nL14697:                 iterable = spec.filter(iterable, prereleases=bool(prereleases))\nL14698:             return iter(iterable)\nL14699:         # If we do not have any specifiers, then we need to have a rough filter\nL14700:         # which will filter out any pre-releases, unless there are no final\nL14701:         # releases.\nL14702:         else:\nL14703:             filtered: List[UnparsedVersionVar] = []\nL14704:             found_prereleases: List[UnparsedVersionVar] = []\nL14705: \nL14706:             for item in iterable:\nL14707:                 parsed_version = _coerce_version(item)\nL14708: \nL14709:                 # Store any item which is a pre-release for later unless we've\nL14710:                 # already found a final version or we are accepting prereleases\nL14711:                 if parsed_version.is_prerelease and not prereleases:\nL14712:                     if not filtered:\nL14713:                         found_prereleases.append(item)\nL14714:                 else:\nL14715:                     filtered.append(item)\nL14716: \nL14717:             # If we've found no items except for pre-releases, then we'll go\nL14718:             # ahead and use the pre-releases\nL14719:             if not filtered and found_prereleases and prereleases is None:\nL14720:                 return iter(found_prereleases)\nL14721: \nL14722:             return iter(filtered)\nL14723: \nL14724: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/wheel/vendored/packaging/tags.py\nL14725: # This file is dual licensed under the terms of the Apache License, Version\nL14726: # 2.0, and the BSD License. See the LICENSE file in the root of this repository\nL14727: # for complete details.\nL14728: \nL14729: import logging\nL14730: import platform\nL14731: import re\nL14732: import struct\nL14733: import subprocess\nL14734: import sys\nL14735: import sysconfig\nL14736: from importlib.machinery import EXTENSION_SUFFIXES\nL14737: from typing import (\nL14738:     Dict,\nL14739:     FrozenSet,\nL14740:     Iterable,\nL14741:     Iterator,\nL14742:     List,\nL14743:     Optional,\nL14744:     Sequence,\nL14745:     Tuple,\nL14746:     Union,\nL14747:     cast,\nL14748: )\nL14749: \nL14750: from . import _manylinux, _musllinux\nL14751: \nL14752: logger = logging.getLogger(__name__)\nL14753: \nL14754: PythonVersion = Sequence[int]\nL14755: MacVersion = Tuple[int, int]\nL14756: \nL14757: INTERPRETER_SHORT_NAMES: Dict[str, str] = {\nL14758:     \"python\": \"py\",  # Generic.\nL14759:     \"cpython\": \"cp\",\nL14760:     \"pypy\": \"pp\",\nL14761:     \"ironpython\": \"ip\",\nL14762:     \"jython\": \"jy\",\nL14763: }\nL14764: \nL14765: \nL14766: _32_BIT_INTERPRETER = struct.calcsize(\"P\") == 4\nL14767: \nL14768: \nL14769: class Tag:\nL14770:     \"\"\"\nL14771:     A representation of the tag triple for a wheel.\nL14772: \nL14773:     Instances are considered immutable and thus are hashable. Equality checking\nL14774:     is also supported.\nL14775:     \"\"\"\nL14776: \nL14777:     __slots__ = [\"_interpreter\", \"_abi\", \"_platform\", \"_hash\"]\nL14778: \nL14779:     def __init__(self, interpreter: str, abi: str, platform: str) -> None:\nL14780:         self._interpreter = interpreter.lower()\nL14781:         self._abi = abi.lower()\nL14782:         self._platform = platform.lower()\nL14783:         # The __hash__ of every single element in a Set[Tag] will be evaluated each time\nL14784:         # that a set calls its `.disjoint()` method, which may be called hundreds of\nL14785:         # times when scanning a page of links for packages with tags matching that\nL14786:         # Set[Tag]. Pre-computing the value here produces significant speedups for\nL14787:         # downstream consumers.\nL14788:         self._hash = hash((self._interpreter, self._abi, self._platform))\nL14789: \nL14790:     @property\nL14791:     def interpreter(self) -> str:\nL14792:         return self._interpreter\nL14793: \nL14794:     @property\nL14795:     def abi(self) -> str:\nL14796:         return self._abi\nL14797: \nL14798:     @property\nL14799:     def platform(self) -> str:\nL14800:         return self._platform\nL14801: \nL14802:     def __eq__(self, other: object) -> bool:\nL14803:         if not isinstance(other, Tag):\nL14804:             return NotImplemented\nL14805: \nL14806:         return (\nL14807:             (self._hash == other._hash)  # Short-circuit ASAP for perf reasons.\nL14808:             and (self._platform == other._platform)\nL14809:             and (self._abi == other._abi)\nL14810:             and (self._interpreter == other._interpreter)\nL14811:         )\nL14812: \nL14813:     def __hash__(self) -> int:\nL14814:         return self._hash\nL14815: \nL14816:     def __str__(self) -> str:\nL14817:         return f\"{self._interpreter}-{self._abi}-{self._platform}\"\nL14818: \nL14819:     def __repr__(self) -> str:\nL14820:         return f\"<{self} @ {id(self)}>\"\nL14821: \nL14822: \nL14823: def parse_tag(tag: str) -> FrozenSet[Tag]:\nL14824:     \"\"\"\nL14825:     Parses the provided tag (e.g. `py3-none-any`) into a frozenset of Tag instances.\nL14826: \nL14827:     Returning a set is required due to the possibility that the tag is a\nL14828:     compressed tag set.\nL14829:     \"\"\"\nL14830:     tags = set()\nL14831:     interpreters, abis, platforms = tag.split(\"-\")\nL14832:     for interpreter in interpreters.split(\".\"):\nL14833:         for abi in abis.split(\".\"):\nL14834:             for platform_ in platforms.split(\".\"):\nL14835:                 tags.add(Tag(interpreter, abi, platform_))\nL14836:     return frozenset(tags)\nL14837: \nL14838: \nL14839: def _get_config_var(name: str, warn: bool = False) -> Union[int, str, None]:\nL14840:     value: Union[int, str, None] = sysconfig.get_config_var(name)\nL14841:     if value is None and warn:\nL14842:         logger.debug(\nL14843:             \"Config variable '%s' is unset, Python ABI tag may be incorrect\", name\nL14844:         )\nL14845:     return value\nL14846: \nL14847: \nL14848: def _normalize_string(string: str) -> str:\nL14849:     return string.replace(\".\", \"_\").replace(\"-\", \"_\").replace(\" \", \"_\")\nL14850: \nL14851: \nL14852: def _is_threaded_cpython(abis: List[str]) -> bool:\nL14853:     \"\"\"\nL14854:     Determine if the ABI corresponds to a threaded (`--disable-gil`) build.\nL14855: \nL14856:     The threaded builds are indicated by a \"t\" in the abiflags.\nL14857:     \"\"\"\nL14858:     if len(abis) == 0:\nL14859:         return False\nL14860:     # expect e.g., cp313\nL14861:     m = re.match(r\"cp\\d+(.*)\", abis[0])\nL14862:     if not m:\nL14863:         return False\nL14864:     abiflags = m.group(1)\nL14865:     return \"t\" in abiflags\nL14866: \nL14867: \nL14868: def _abi3_applies(python_version: PythonVersion, threading: bool) -> bool:\nL14869:     \"\"\"\nL14870:     Determine if the Python version supports abi3.\nL14871: \nL14872:     PEP 384 was first implemented in Python 3.2. The threaded (`--disable-gil`)\nL14873:     builds do not support abi3.\nL14874:     \"\"\"\nL14875:     return len(python_version) > 1 and tuple(python_version) >= (3, 2) and not threading\nL14876: \nL14877: \nL14878: def _cpython_abis(py_version: PythonVersion, warn: bool = False) -> List[str]:\nL14879:     py_version = tuple(py_version)  # To allow for version comparison.\nL14880:     abis = []\nL14881:     version = _version_nodot(py_version[:2])\nL14882:     threading = debug = pymalloc = ucs4 = \"\"\nL14883:     with_debug = _get_config_var(\"Py_DEBUG\", warn)\nL14884:     has_refcount = hasattr(sys, \"gettotalrefcount\")\nL14885:     # Windows doesn't set Py_DEBUG, so checking for support of debug-compiled\nL14886:     # extension modules is the best option.\nL14887:     # https://github.com/pypa/pip/issues/3383#issuecomment-173267692\nL14888:     has_ext = \"_d.pyd\" in EXTENSION_SUFFIXES\nL14889:     if with_debug or (with_debug is None and (has_refcount or has_ext)):\nL14890:         debug = \"d\"\nL14891:     if py_version >= (3, 13) and _get_config_var(\"Py_GIL_DISABLED\", warn):\nL14892:         threading = \"t\"\nL14893:     if py_version < (3, 8):\nL14894:         with_pymalloc = _get_config_var(\"WITH_PYMALLOC\", warn)\nL14895:         if with_pymalloc or with_pymalloc is None:\nL14896:             pymalloc = \"m\"\nL14897:         if py_version < (3, 3):\nL14898:             unicode_size = _get_config_var(\"Py_UNICODE_SIZE\", warn)\nL14899:             if unicode_size == 4 or (\nL14900:                 unicode_size is None and sys.maxunicode == 0x10FFFF\nL14901:             ):\nL14902:                 ucs4 = \"u\"\nL14903:     elif debug:\nL14904:         # Debug builds can also load \"normal\" extension modules.\nL14905:         # We can also assume no UCS-4 or pymalloc requirement.\nL14906:         abis.append(f\"cp{version}{threading}\")\nL14907:     abis.insert(0, f\"cp{version}{threading}{debug}{pymalloc}{ucs4}\")\nL14908:     return abis\nL14909: \nL14910: \nL14911: def cpython_tags(\nL14912:     python_version: Optional[PythonVersion] = None,\nL14913:     abis: Optional[Iterable[str]] = None,\nL14914:     platforms: Optional[Iterable[str]] = None,\nL14915:     *,\nL14916:     warn: bool = False,\nL14917: ) -> Iterator[Tag]:\nL14918:     \"\"\"\nL14919:     Yields the tags for a CPython interpreter.\nL14920: \nL14921:     The tags consist of:\nL14922:     - cp<python_version>-<abi>-<platform>\nL14923:     - cp<python_version>-abi3-<platform>\nL14924:     - cp<python_version>-none-<platform>\nL14925:     - cp<less than python_version>-abi3-<platform>  # Older Python versions down to 3.2.\nL14926: \nL14927:     If python_version only specifies a major version then user-provided ABIs and\nL14928:     the 'none' ABItag will be used.\nL14929: \nL14930:     If 'abi3' or 'none' are specified in 'abis' then they will be yielded at\nL14931:     their normal position and not at the beginning.\nL14932:     \"\"\"\nL14933:     if not python_version:\nL14934:         python_version = sys.version_info[:2]\nL14935: \nL14936:     interpreter = f\"cp{_version_nodot(python_version[:2])}\"\nL14937: \nL14938:     if abis is None:\nL14939:         if len(python_version) > 1:\nL14940:             abis = _cpython_abis(python_version, warn)\nL14941:         else:\nL14942:             abis = []\nL14943:     abis = list(abis)\nL14944:     # 'abi3' and 'none' are explicitly handled later.\nL14945:     for explicit_abi in (\"abi3\", \"none\"):\nL14946:         try:\nL14947:             abis.remove(explicit_abi)\nL14948:         except ValueError:\nL14949:             pass\nL14950: \nL14951:     platforms = list(platforms or platform_tags())\nL14952:     for abi in abis:\nL14953:         for platform_ in platforms:\nL14954:             yield Tag(interpreter, abi, platform_)\nL14955: \nL14956:     threading = _is_threaded_cpython(abis)\nL14957:     use_abi3 = _abi3_applies(python_version, threading)\nL14958:     if use_abi3:\nL14959:         yield from (Tag(interpreter, \"abi3\", platform_) for platform_ in platforms)\nL14960:     yield from (Tag(interpreter, \"none\", platform_) for platform_ in platforms)\nL14961: \nL14962:     if use_abi3:\nL14963:         for minor_version in range(python_version[1] - 1, 1, -1):\nL14964:             for platform_ in platforms:\nL14965:                 interpreter = \"cp{version}\".format(\nL14966:                     version=_version_nodot((python_version[0], minor_version))\nL14967:                 )\nL14968:                 yield Tag(interpreter, \"abi3\", platform_)\nL14969: \nL14970: \nL14971: def _generic_abi() -> List[str]:\nL14972:     \"\"\"\nL14973:     Return the ABI tag based on EXT_SUFFIX.\nL14974:     \"\"\"\nL14975:     # The following are examples of `EXT_SUFFIX`.\nL14976:     # We want to keep the parts which are related to the ABI and remove the\nL14977:     # parts which are related to the platform:\nL14978:     # - linux:   '.cpython-310-x86_64-linux-gnu.so' => cp310\nL14979:     # - mac:     '.cpython-310-darwin.so'           => cp310\nL14980:     # - win:     '.cp310-win_amd64.pyd'             => cp310\nL14981:     # - win:     '.pyd'                             => cp37 (uses _cpython_abis())\nL14982:     # - pypy:    '.pypy38-pp73-x86_64-linux-gnu.so' => pypy38_pp73\nL14983:     # - graalpy: '.graalpy-38-native-x86_64-darwin.dylib'\nL14984:     #                                               => graalpy_38_native\nL14985: \nL14986:     ext_suffix = _get_config_var(\"EXT_SUFFIX\", warn=True)\nL14987:     if not isinstance(ext_suffix, str) or ext_suffix[0] != \".\":\nL14988:         raise SystemError(\"invalid sysconfig.get_config_var('EXT_SUFFIX')\")\nL14989:     parts = ext_suffix.split(\".\")\nL14990:     if len(parts) < 3:\nL14991:         # CPython3.7 and earlier uses \".pyd\" on Windows.\nL14992:         return _cpython_abis(sys.version_info[:2])\nL14993:     soabi = parts[1]\nL14994:     if soabi.startswith(\"cpython\"):\nL14995:         # non-windows\nL14996:         abi = \"cp\" + soabi.split(\"-\")[1]\nL14997:     elif soabi.startswith(\"cp\"):\nL14998:         # windows\nL14999:         abi = soabi.split(\"-\")[0]\nL15000:     elif soabi.startswith(\"pypy\"):\nL15001:         abi = \"-\".join(soabi.split(\"-\")[:2])\nL15002:     elif soabi.startswith(\"graalpy\"):\nL15003:         abi = \"-\".join(soabi.split(\"-\")[:3])\nL15004:     elif soabi:\nL15005:         # pyston, ironpython, others?\nL15006:         abi = soabi\nL15007:     else:\nL15008:         return []\nL15009:     return [_normalize_string(abi)]\nL15010: \nL15011: \nL15012: def generic_tags(\nL15013:     interpreter: Optional[str] = None,\nL15014:     abis: Optional[Iterable[str]] = None,\nL15015:     platforms: Optional[Iterable[str]] = None,\nL15016:     *,\nL15017:     warn: bool = False,\nL15018: ) -> Iterator[Tag]:\nL15019:     \"\"\"\nL15020:     Yields the tags for a generic interpreter.\nL15021: \nL15022:     The tags consist of:\nL15023:     - <interpreter>-<abi>-<platform>\nL15024: \nL15025:     The \"none\" ABI will be added if it was not explicitly provided.\nL15026:     \"\"\"\nL15027:     if not interpreter:\nL15028:         interp_name = interpreter_name()\nL15029:         interp_version = interpreter_version(warn=warn)\nL15030:         interpreter = \"\".join([interp_name, interp_version])\nL15031:     if abis is None:\nL15032:         abis = _generic_abi()\nL15033:     else:\nL15034:         abis = list(abis)\nL15035:     platforms = list(platforms or platform_tags())\nL15036:     if \"none\" not in abis:\nL15037:         abis.append(\"none\")\nL15038:     for abi in abis:\nL15039:         for platform_ in platforms:\nL15040:             yield Tag(interpreter, abi, platform_)\nL15041: \nL15042: \nL15043: def _py_interpreter_range(py_version: PythonVersion) -> Iterator[str]:\nL15044:     \"\"\"\nL15045:     Yields Python versions in descending order.\nL15046: \nL15047:     After the latest version, the major-only version will be yielded, and then\nL15048:     all previous versions of that major version.\nL15049:     \"\"\"\nL15050:     if len(py_version) > 1:\nL15051:         yield f\"py{_version_nodot(py_version[:2])}\"\nL15052:     yield f\"py{py_version[0]}\"\nL15053:     if len(py_version) > 1:\nL15054:         for minor in range(py_version[1] - 1, -1, -1):\nL15055:             yield f\"py{_version_nodot((py_version[0], minor))}\"\nL15056: \nL15057: \nL15058: def compatible_tags(\nL15059:     python_version: Optional[PythonVersion] = None,\nL15060:     interpreter: Optional[str] = None,\nL15061:     platforms: Optional[Iterable[str]] = None,\nL15062: ) -> Iterator[Tag]:\nL15063:     \"\"\"\nL15064:     Yields the sequence of tags that are compatible with a specific version of Python.\nL15065: \nL15066:     The tags consist of:\nL15067:     - py*-none-<platform>\nL15068:     - <interpreter>-none-any  # ... if `interpreter` is provided.\nL15069:     - py*-none-any\nL15070:     \"\"\"\nL15071:     if not python_version:\nL15072:         python_version = sys.version_info[:2]\nL15073:     platforms = list(platforms or platform_tags())\nL15074:     for version in _py_interpreter_range(python_version):\nL15075:         for platform_ in platforms:\nL15076:             yield Tag(version, \"none\", platform_)\nL15077:     if interpreter:\nL15078:         yield Tag(interpreter, \"none\", \"any\")\nL15079:     for version in _py_interpreter_range(python_version):\nL15080:         yield Tag(version, \"none\", \"any\")\nL15081: \nL15082: \nL15083: def _mac_arch(arch: str, is_32bit: bool = _32_BIT_INTERPRETER) -> str:\nL15084:     if not is_32bit:\nL15085:         return arch\nL15086: \nL15087:     if arch.startswith(\"ppc\"):\nL15088:         return \"ppc\"\nL15089: \nL15090:     return \"i386\"\nL15091: \nL15092: \nL15093: def _mac_binary_formats(version: MacVersion, cpu_arch: str) -> List[str]:\nL15094:     formats = [cpu_arch]\nL15095:     if cpu_arch == \"x86_64\":\nL15096:         if version < (10, 4):\nL15097:             return []\nL15098:         formats.extend([\"intel\", \"fat64\", \"fat32\"])\nL15099: \nL15100:     elif cpu_arch == \"i386\":\nL15101:         if version < (10, 4):\nL15102:             return []\nL15103:         formats.extend([\"intel\", \"fat32\", \"fat\"])\nL15104: \nL15105:     elif cpu_arch == \"ppc64\":\nL15106:         # TODO: Need to care about 32-bit PPC for ppc64 through 10.2?\nL15107:         if version > (10, 5) or version < (10, 4):\nL15108:             return []\nL15109:         formats.append(\"fat64\")\nL15110: \nL15111:     elif cpu_arch == \"ppc\":\nL15112:         if version > (10, 6):\nL15113:             return []\nL15114:         formats.extend([\"fat32\", \"fat\"])\nL15115: \nL15116:     if cpu_arch in {\"arm64\", \"x86_64\"}:\nL15117:         formats.append(\"universal2\")\nL15118: \nL15119:     if cpu_arch in {\"x86_64\", \"i386\", \"ppc64\", \"ppc\", \"intel\"}:\nL15120:         formats.append(\"universal\")\nL15121: \nL15122:     return formats\nL15123: \nL15124: \nL15125: def mac_platforms(\nL15126:     version: Optional[MacVersion] = None, arch: Optional[str] = None\nL15127: ) -> Iterator[str]:\nL15128:     \"\"\"\nL15129:     Yields the platform tags for a macOS system.\nL15130: \nL15131:     The `version` parameter is a two-item tuple specifying the macOS version to\nL15132:     generate platform tags for. The `arch` parameter is the CPU architecture to\nL15133:     generate platform tags for. Both parameters default to the appropriate value\nL15134:     for the current system.\nL15135:     \"\"\"\nL15136:     version_str, _, cpu_arch = platform.mac_ver()\nL15137:     if version is None:\nL15138:         version = cast(\"MacVersion\", tuple(map(int, version_str.split(\".\")[:2])))\nL15139:         if version == (10, 16):\nL15140:             # When built against an older macOS SDK, Python will report macOS 10.16\nL15141:             # instead of the real version.\nL15142:             version_str = subprocess.run(\nL15143:                 [\nL15144:                     sys.executable,\nL15145:                     \"-sS\",\nL15146:                     \"-c\",\nL15147:                     \"import platform; print(platform.mac_ver()[0])\",\nL15148:                 ],\nL15149:                 check=True,\nL15150:                 env={\"SYSTEM_VERSION_COMPAT\": \"0\"},\nL15151:                 stdout=subprocess.PIPE,\nL15152:                 text=True,\nL15153:             ).stdout\nL15154:             version = cast(\"MacVersion\", tuple(map(int, version_str.split(\".\")[:2])))\nL15155:     else:\nL15156:         version = version\nL15157:     if arch is None:\nL15158:         arch = _mac_arch(cpu_arch)\nL15159:     else:\nL15160:         arch = arch\nL15161: \nL15162:     if (10, 0) <= version and version < (11, 0):\nL15163:         # Prior to Mac OS 11, each yearly release of Mac OS bumped the\nL15164:         # \"minor\" version number.  The major version was always 10.\nL15165:         for minor_version in range(version[1], -1, -1):\nL15166:             compat_version = 10, minor_version\nL15167:             binary_formats = _mac_binary_formats(compat_version, arch)\nL15168:             for binary_format in binary_formats:\nL15169:                 yield \"macosx_{major}_{minor}_{binary_format}\".format(\nL15170:                     major=10, minor=minor_version, binary_format=binary_format\nL15171:                 )\nL15172: \nL15173:     if version >= (11, 0):\nL15174:         # Starting with Mac OS 11, each yearly release bumps the major version\nL15175:         # number.   The minor versions are now the midyear updates.\nL15176:         for major_version in range(version[0], 10, -1):\nL15177:             compat_version = major_version, 0\nL15178:             binary_formats = _mac_binary_formats(compat_version, arch)\nL15179:             for binary_format in binary_formats:\nL15180:                 yield \"macosx_{major}_{minor}_{binary_format}\".format(\nL15181:                     major=major_version, minor=0, binary_format=binary_format\nL15182:                 )\nL15183: \nL15184:     if version >= (11, 0):\nL15185:         # Mac OS 11 on x86_64 is compatible with binaries from previous releases.\nL15186:         # Arm64 support was introduced in 11.0, so no Arm binaries from previous\nL15187:         # releases exist.\nL15188:         #\nL15189:         # However, the \"universal2\" binary format can have a\nL15190:         # macOS version earlier than 11.0 when the x86_64 part of the binary supports\nL15191:         # that version of macOS.\nL15192:         if arch == \"x86_64\":\nL15193:             for minor_version in range(16, 3, -1):\nL15194:                 compat_version = 10, minor_version\nL15195:                 binary_formats = _mac_binary_formats(compat_version, arch)\nL15196:                 for binary_format in binary_formats:\nL15197:                     yield \"macosx_{major}_{minor}_{binary_format}\".format(\nL15198:                         major=compat_version[0],\nL15199:                         minor=compat_version[1],\nL15200:                         binary_format=binary_format,\nL15201:                     )\nL15202:         else:\nL15203:             for minor_version in range(16, 3, -1):\nL15204:                 compat_version = 10, minor_version\nL15205:                 binary_format = \"universal2\"\nL15206:                 yield \"macosx_{major}_{minor}_{binary_format}\".format(\nL15207:                     major=compat_version[0],\nL15208:                     minor=compat_version[1],\nL15209:                     binary_format=binary_format,\nL15210:                 )\nL15211: \nL15212: \nL15213: def _linux_platforms(is_32bit: bool = _32_BIT_INTERPRETER) -> Iterator[str]:\nL15214:     linux = _normalize_string(sysconfig.get_platform())\nL15215:     if not linux.startswith(\"linux_\"):\nL15216:         # we should never be here, just yield the sysconfig one and return\nL15217:         yield linux\nL15218:         return\nL15219:     if is_32bit:\nL15220:         if linux == \"linux_x86_64\":\nL15221:             linux = \"linux_i686\"\nL15222:         elif linux == \"linux_aarch64\":\nL15223:             linux = \"linux_armv8l\"\nL15224:     _, arch = linux.split(\"_\", 1)\nL15225:     archs = {\"armv8l\": [\"armv8l\", \"armv7l\"]}.get(arch, [arch])\nL15226:     yield from _manylinux.platform_tags(archs)\nL15227:     yield from _musllinux.platform_tags(archs)\nL15228:     for arch in archs:\nL15229:         yield f\"linux_{arch}\"\nL15230: \nL15231: \nL15232: def _generic_platforms() -> Iterator[str]:\nL15233:     yield _normalize_string(sysconfig.get_platform())\nL15234: \nL15235: \nL15236: def platform_tags() -> Iterator[str]:\nL15237:     \"\"\"\nL15238:     Provides the platform tags for this installation.\nL15239:     \"\"\"\nL15240:     if platform.system() == \"Darwin\":\nL15241:         return mac_platforms()\nL15242:     elif platform.system() == \"Linux\":\nL15243:         return _linux_platforms()\nL15244:     else:\nL15245:         return _generic_platforms()\nL15246: \nL15247: \nL15248: def interpreter_name() -> str:\nL15249:     \"\"\"\nL15250:     Returns the name of the running interpreter.\nL15251: \nL15252:     Some implementations have a reserved, two-letter abbreviation which will\nL15253:     be returned when appropriate.\nL15254:     \"\"\"\nL15255:     name = sys.implementation.name\nL15256:     return INTERPRETER_SHORT_NAMES.get(name) or name\nL15257: \nL15258: \nL15259: def interpreter_version(*, warn: bool = False) -> str:\nL15260:     \"\"\"\nL15261:     Returns the version of the running interpreter.\nL15262:     \"\"\"\nL15263:     version = _get_config_var(\"py_version_nodot\", warn=warn)\nL15264:     if version:\nL15265:         version = str(version)\nL15266:     else:\nL15267:         version = _version_nodot(sys.version_info[:2])\nL15268:     return version\nL15269: \nL15270: \nL15271: def _version_nodot(version: PythonVersion) -> str:\nL15272:     return \"\".join(map(str, version))\nL15273: \nL15274: \nL15275: def sys_tags(*, warn: bool = False) -> Iterator[Tag]:\nL15276:     \"\"\"\nL15277:     Returns the sequence of tag triples for the running interpreter.\nL15278: \nL15279:     The order of the sequence corresponds to priority order for the\nL15280:     interpreter, from most to least important.\nL15281:     \"\"\"\nL15282: \nL15283:     interp_name = interpreter_name()\nL15284:     if interp_name == \"cp\":\nL15285:         yield from cpython_tags(warn=warn)\nL15286:     else:\nL15287:         yield from generic_tags()\nL15288: \nL15289:     if interp_name == \"pp\":\nL15290:         interp = \"pp3\"\nL15291:     elif interp_name == \"cp\":\nL15292:         interp = \"cp\" + interpreter_version(warn=warn)\nL15293:     else:\nL15294:         interp = None\nL15295:     yield from compatible_tags(interpreter=interp)\nL15296: \nL15297: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/wheel/vendored/packaging/utils.py\nL15298: #!/usr/bin/env python3\nL15299: # This file is dual licensed under the terms of the Apache License, Version\nL15300: # 2.0, and the BSD License. See the LICENSE file in the root of this repository\nL15301: # for complete details.\nL15302: \nL15303: import re\nL15304: from typing import FrozenSet, NewType, Tuple, Union, cast\nL15305: \nL15306: from .tags import Tag, parse_tag\nL15307: from .version import InvalidVersion, Version\nL15308: \nL15309: BuildTag = Union[Tuple[()], Tuple[int, str]]\nL15310: NormalizedName = NewType(\"NormalizedName\", str)\nL15311: \nL15312: \nL15313: class InvalidName(ValueError):\nL15314:     \"\"\"\nL15315:     An invalid distribution name; users should refer to the packaging user guide.\nL15316:     \"\"\"\nL15317: \nL15318: \nL15319: class InvalidWheelFilename(ValueError):\nL15320:     \"\"\"\nL15321:     An invalid wheel filename was found, users should refer to PEP 427.\nL15322:     \"\"\"\nL15323: \nL15324: \nL15325: class InvalidSdistFilename(ValueError):\nL15326:     \"\"\"\nL15327:     An invalid sdist filename was found, users should refer to the packaging user guide.\nL15328:     \"\"\"\nL15329: \nL15330: \nL15331: # Core metadata spec for `Name`\nL15332: _validate_regex = re.compile(\nL15333:     r\"^([A-Z0-9]|[A-Z0-9][A-Z0-9._-]*[A-Z0-9])$\", re.IGNORECASE\nL15334: )\nL15335: _canonicalize_regex = re.compile(r\"[-_.]+\")\nL15336: _normalized_regex = re.compile(r\"^([a-z0-9]|[a-z0-9]([a-z0-9-](?!--))*[a-z0-9])$\")\nL15337: # PEP 427: The build number must start with a digit.\nL15338: _build_tag_regex = re.compile(r\"(\\d+)(.*)\")\nL15339: \nL15340: \nL15341: def canonicalize_name(name: str, *, validate: bool = False) -> NormalizedName:\nL15342:     if validate and not _validate_regex.match(name):\nL15343:         raise InvalidName(f\"name is invalid: {name!r}\")\nL15344:     # This is taken from PEP 503.\nL15345:     value = _canonicalize_regex.sub(\"-\", name).lower()\nL15346:     return cast(NormalizedName, value)\nL15347: \nL15348: \nL15349: def is_normalized_name(name: str) -> bool:\nL15350:     return _normalized_regex.match(name) is not None\nL15351: \nL15352: \nL15353: def canonicalize_version(\nL15354:     version: Union[Version, str], *, strip_trailing_zero: bool = True\nL15355: ) -> str:\nL15356:     \"\"\"\nL15357:     This is very similar to Version.__str__, but has one subtle difference\nL15358:     with the way it handles the release segment.\nL15359:     \"\"\"\nL15360:     if isinstance(version, str):\nL15361:         try:\nL15362:             parsed = Version(version)\nL15363:         except InvalidVersion:\nL15364:             # Legacy versions cannot be normalized\nL15365:             return version\nL15366:     else:\nL15367:         parsed = version\nL15368: \nL15369:     parts = []\nL15370: \nL15371:     # Epoch\nL15372:     if parsed.epoch != 0:\nL15373:         parts.append(f\"{parsed.epoch}!\")\nL15374: \nL15375:     # Release segment\nL15376:     release_segment = \".\".join(str(x) for x in parsed.release)\nL15377:     if strip_trailing_zero:\nL15378:         # NB: This strips trailing '.0's to normalize\nL15379:         release_segment = re.sub(r\"(\\.0)+$\", \"\", release_segment)\nL15380:     parts.append(release_segment)\nL15381: \nL15382:     # Pre-release\nL15383:     if parsed.pre is not None:\nL15384:         parts.append(\"\".join(str(x) for x in parsed.pre))\nL15385: \nL15386:     # Post-release\nL15387:     if parsed.post is not None:\nL15388:         parts.append(f\".post{parsed.post}\")\nL15389: \nL15390:     # Development release\nL15391:     if parsed.dev is not None:\nL15392:         parts.append(f\".dev{parsed.dev}\")\nL15393: \nL15394:     # Local version segment\nL15395:     if parsed.local is not None:\nL15396:         parts.append(f\"+{parsed.local}\")\nL15397: \nL15398:     return \"\".join(parts)\nL15399: \nL15400: \nL15401: def parse_wheel_filename(\nL15402:     filename: str,\nL15403: ) -> Tuple[NormalizedName, Version, BuildTag, FrozenSet[Tag]]:\nL15404:     if not filename.endswith(\".whl\"):\nL15405:         raise InvalidWheelFilename(\nL15406:             f\"Invalid wheel filename (extension must be '.whl'): {filename}\"\nL15407:         )\nL15408: \nL15409:     filename = filename[:-4]\nL15410:     dashes = filename.count(\"-\")\nL15411:     if dashes not in (4, 5):\nL15412:         raise InvalidWheelFilename(\nL15413:             f\"Invalid wheel filename (wrong number of parts): {filename}\"\nL15414:         )\nL15415: \nL15416:     parts = filename.split(\"-\", dashes - 2)\nL15417:     name_part = parts[0]\nL15418:     # See PEP 427 for the rules on escaping the project name.\nL15419:     if \"__\" in name_part or re.match(r\"^[\\w\\d._]*$\", name_part, re.UNICODE) is None:\nL15420:         raise InvalidWheelFilename(f\"Invalid project name: {filename}\")\nL15421:     name = canonicalize_name(name_part)\nL15422: \nL15423:     try:\nL15424:         version = Version(parts[1])\nL15425:     except InvalidVersion as e:\nL15426:         raise InvalidWheelFilename(\nL15427:             f\"Invalid wheel filename (invalid version): {filename}\"\nL15428:         ) from e\nL15429: \nL15430:     if dashes == 5:\nL15431:         build_part = parts[2]\nL15432:         build_match = _build_tag_regex.match(build_part)\nL15433:         if build_match is None:\nL15434:             raise InvalidWheelFilename(\nL15435:                 f\"Invalid build number: {build_part} in '{filename}'\"\nL15436:             )\nL15437:         build = cast(BuildTag, (int(build_match.group(1)), build_match.group(2)))\nL15438:     else:\nL15439:         build = ()\nL15440:     tags = parse_tag(parts[-1])\nL15441:     return (name, version, build, tags)\nL15442: \nL15443: \nL15444: def parse_sdist_filename(filename: str) -> Tuple[NormalizedName, Version]:\nL15445:     if filename.endswith(\".tar.gz\"):\nL15446:         file_stem = filename[: -len(\".tar.gz\")]\nL15447:     elif filename.endswith(\".zip\"):\nL15448:         file_stem = filename[: -len(\".zip\")]\nL15449:     else:\nL15450:         raise InvalidSdistFilename(\nL15451:             f\"Invalid sdist filename (extension must be '.tar.gz' or '.zip'):\"\nL15452:             f\" {filename}\"\nL15453:         )\nL15454: \nL15455:     # We are requiring a PEP 440 version, which cannot contain dashes,\nL15456:     # so we split on the last dash.\nL15457:     name_part, sep, version_part = file_stem.rpartition(\"-\")\nL15458:     if not sep:\nL15459:         raise InvalidSdistFilename(f\"Invalid sdist filename: {filename}\")\nL15460: \nL15461:     name = canonicalize_name(name_part)\nL15462: \nL15463:     try:\nL15464:         version = Version(version_part)\nL15465:     except InvalidVersion as e:\nL15466:         raise InvalidSdistFilename(\nL15467:             f\"Invalid sdist filename (invalid version): {filename}\"\nL15468:         ) from e\nL15469: \nL15470:     return (name, version)\nL15471: \nL15472: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/wheel/vendored/packaging/version.py\nL15473: # This file is dual licensed under the terms of the Apache License, Version\nL15474: # 2.0, and the BSD License. See the LICENSE file in the root of this repository\nL15475: # for complete details.\nL15476: \"\"\"\nL15477: .. testsetup::\nL15478: \nL15479:     from packaging.version import parse, Version\nL15480: \"\"\"\nL15481: \nL15482: import itertools\nL15483: import re\nL15484: from typing import Any, Callable, NamedTuple, Optional, SupportsInt, Tuple, Union\nL15485: \nL15486: from ._structures import Infinity, InfinityType, NegativeInfinity, NegativeInfinityType\nL15487: \nL15488: __all__ = [\"VERSION_PATTERN\", \"parse\", \"Version\", \"InvalidVersion\"]\nL15489: \nL15490: LocalType = Tuple[Union[int, str], ...]\nL15491: \nL15492: CmpPrePostDevType = Union[InfinityType, NegativeInfinityType, Tuple[str, int]]\nL15493: CmpLocalType = Union[\nL15494:     NegativeInfinityType,\nL15495:     Tuple[Union[Tuple[int, str], Tuple[NegativeInfinityType, Union[int, str]]], ...],\nL15496: ]\nL15497: CmpKey = Tuple[\nL15498:     int,\nL15499:     Tuple[int, ...],\nL15500:     CmpPrePostDevType,\nL15501:     CmpPrePostDevType,\nL15502:     CmpPrePostDevType,\nL15503:     CmpLocalType,\nL15504: ]\nL15505: VersionComparisonMethod = Callable[[CmpKey, CmpKey], bool]\nL15506: \nL15507: \nL15508: class _Version(NamedTuple):\nL15509:     epoch: int\nL15510:     release: Tuple[int, ...]\nL15511:     dev: Optional[Tuple[str, int]]\nL15512:     pre: Optional[Tuple[str, int]]\nL15513:     post: Optional[Tuple[str, int]]\nL15514:     local: Optional[LocalType]\nL15515: \nL15516: \nL15517: def parse(version: str) -> \"Version\":\nL15518:     \"\"\"Parse the given version string.\nL15519: \nL15520:     >>> parse('1.0.dev1')\nL15521:     <Version('1.0.dev1')>\nL15522: \nL15523:     :param version: The version string to parse.\nL15524:     :raises InvalidVersion: When the version string is not a valid version.\nL15525:     \"\"\"\nL15526:     return Version(version)\nL15527: \nL15528: \nL15529: class InvalidVersion(ValueError):\nL15530:     \"\"\"Raised when a version string is not a valid version.\nL15531: \nL15532:     >>> Version(\"invalid\")\nL15533:     Traceback (most recent call last):\nL15534:         ...\nL15535:     packaging.version.InvalidVersion: Invalid version: 'invalid'\nL15536:     \"\"\"\nL15537: \nL15538: \nL15539: class _BaseVersion:\nL15540:     _key: Tuple[Any, ...]\nL15541: \nL15542:     def __hash__(self) -> int:\nL15543:         return hash(self._key)\nL15544: \nL15545:     # Please keep the duplicated `isinstance` check\nL15546:     # in the six comparisons hereunder\nL15547:     # unless you find a way to avoid adding overhead function calls.\nL15548:     def __lt__(self, other: \"_BaseVersion\") -> bool:\nL15549:         if not isinstance(other, _BaseVersion):\nL15550:             return NotImplemented\nL15551: \nL15552:         return self._key < other._key\nL15553: \nL15554:     def __le__(self, other: \"_BaseVersion\") -> bool:\nL15555:         if not isinstance(other, _BaseVersion):\nL15556:             return NotImplemented\nL15557: \nL15558:         return self._key <= other._key\nL15559: \nL15560:     def __eq__(self, other: object) -> bool:\nL15561:         if not isinstance(other, _BaseVersion):\nL15562:             return NotImplemented\nL15563: \nL15564:         return self._key == other._key\nL15565: \nL15566:     def __ge__(self, other: \"_BaseVersion\") -> bool:\nL15567:         if not isinstance(other, _BaseVersion):\nL15568:             return NotImplemented\nL15569: \nL15570:         return self._key >= other._key\nL15571: \nL15572:     def __gt__(self, other: \"_BaseVersion\") -> bool:\nL15573:         if not isinstance(other, _BaseVersion):\nL15574:             return NotImplemented\nL15575: \nL15576:         return self._key > other._key\nL15577: \nL15578:     def __ne__(self, other: object) -> bool:\nL15579:         if not isinstance(other, _BaseVersion):\nL15580:             return NotImplemented\nL15581: \nL15582:         return self._key != other._key\nL15583: \nL15584: \nL15585: # Deliberately not anchored to the start and end of the string, to make it\nL15586: # easier for 3rd party code to reuse\nL15587: _VERSION_PATTERN = r\"\"\"\nL15588:     v?\nL15589:     (?:\nL15590:         (?:(?P<epoch>[0-9]+)!)?                           # epoch\nL15591:         (?P<release>[0-9]+(?:\\.[0-9]+)*)                  # release segment\nL15592:         (?P<pre>                                          # pre-release\nL15593:             [-_\\.]?\nL15594:             (?P<pre_l>alpha|a|beta|b|preview|pre|c|rc)\nL15595:             [-_\\.]?\nL15596:             (?P<pre_n>[0-9]+)?\nL15597:         )?\nL15598:         (?P<post>                                         # post release\nL15599:             (?:-(?P<post_n1>[0-9]+))\nL15600:             |\nL15601:             (?:\nL15602:                 [-_\\.]?\nL15603:                 (?P<post_l>post|rev|r)\nL15604:                 [-_\\.]?\nL15605:                 (?P<post_n2>[0-9]+)?\nL15606:             )\nL15607:         )?\nL15608:         (?P<dev>                                          # dev release\nL15609:             [-_\\.]?\nL15610:             (?P<dev_l>dev)\nL15611:             [-_\\.]?\nL15612:             (?P<dev_n>[0-9]+)?\nL15613:         )?\nL15614:     )\nL15615:     (?:\\+(?P<local>[a-z0-9]+(?:[-_\\.][a-z0-9]+)*))?       # local version\nL15616: \"\"\"\nL15617: \nL15618: VERSION_PATTERN = _VERSION_PATTERN\nL15619: \"\"\"\nL15620: A string containing the regular expression used to match a valid version.\nL15621: \nL15622: The pattern is not anchored at either end, and is intended for embedding in larger\nL15623: expressions (for example, matching a version number as part of a file name). The\nL15624: regular expression should be compiled with the ``re.VERBOSE`` and ``re.IGNORECASE``\nL15625: flags set.\nL15626: \nL15627: :meta hide-value:\nL15628: \"\"\"\nL15629: \nL15630: \nL15631: class Version(_BaseVersion):\nL15632:     \"\"\"This class abstracts handling of a project's versions.\nL15633: \nL15634:     A :class:`Version` instance is comparison aware and can be compared and\nL15635:     sorted using the standard Python interfaces.\nL15636: \nL15637:     >>> v1 = Version(\"1.0a5\")\nL15638:     >>> v2 = Version(\"1.0\")\nL15639:     >>> v1\nL15640:     <Version('1.0a5')>\nL15641:     >>> v2\nL15642:     <Version('1.0')>\nL15643:     >>> v1 < v2\nL15644:     True\nL15645:     >>> v1 == v2\nL15646:     False\nL15647:     >>> v1 > v2\nL15648:     False\nL15649:     >>> v1 >= v2\nL15650:     False\nL15651:     >>> v1 <= v2\nL15652:     True\nL15653:     \"\"\"\nL15654: \nL15655:     _regex = re.compile(r\"^\\s*\" + VERSION_PATTERN + r\"\\s*$\", re.VERBOSE | re.IGNORECASE)\nL15656:     _key: CmpKey\nL15657: \nL15658:     def __init__(self, version: str) -> None:\nL15659:         \"\"\"Initialize a Version object.\nL15660: \nL15661:         :param version:\nL15662:             The string representation of a version which will be parsed and normalized\nL15663:             before use.\nL15664:         :raises InvalidVersion:\nL15665:             If the ``version`` does not conform to PEP 440 in any way then this\nL15666:             exception will be raised.\nL15667:         \"\"\"\nL15668: \nL15669:         # Validate the version and parse it into pieces\nL15670:         match = self._regex.search(version)\nL15671:         if not match:\nL15672:             raise InvalidVersion(f\"Invalid version: '{version}'\")\nL15673: \nL15674:         # Store the parsed out pieces of the version\nL15675:         self._version = _Version(\nL15676:             epoch=int(match.group(\"epoch\")) if match.group(\"epoch\") else 0,\nL15677:             release=tuple(int(i) for i in match.group(\"release\").split(\".\")),\nL15678:             pre=_parse_letter_version(match.group(\"pre_l\"), match.group(\"pre_n\")),\nL15679:             post=_parse_letter_version(\nL15680:                 match.group(\"post_l\"), match.group(\"post_n1\") or match.group(\"post_n2\")\nL15681:             ),\nL15682:             dev=_parse_letter_version(match.group(\"dev_l\"), match.group(\"dev_n\")),\nL15683:             local=_parse_local_version(match.group(\"local\")),\nL15684:         )\nL15685: \nL15686:         # Generate a key which will be used for sorting\nL15687:         self._key = _cmpkey(\nL15688:             self._version.epoch,\nL15689:             self._version.release,\nL15690:             self._version.pre,\nL15691:             self._version.post,\nL15692:             self._version.dev,\nL15693:             self._version.local,\nL15694:         )\nL15695: \nL15696:     def __repr__(self) -> str:\nL15697:         \"\"\"A representation of the Version that shows all internal state.\nL15698: \nL15699:         >>> Version('1.0.0')\nL15700:         <Version('1.0.0')>\nL15701:         \"\"\"\nL15702:         return f\"<Version('{self}')>\"\nL15703: \nL15704:     def __str__(self) -> str:\nL15705:         \"\"\"A string representation of the version that can be rounded-tripped.\nL15706: \nL15707:         >>> str(Version(\"1.0a5\"))\nL15708:         '1.0a5'\nL15709:         \"\"\"\nL15710:         parts = []\nL15711: \nL15712:         # Epoch\nL15713:         if self.epoch != 0:\nL15714:             parts.append(f\"{self.epoch}!\")\nL15715: \nL15716:         # Release segment\nL15717:         parts.append(\".\".join(str(x) for x in self.release))\nL15718: \nL15719:         # Pre-release\nL15720:         if self.pre is not None:\nL15721:             parts.append(\"\".join(str(x) for x in self.pre))\nL15722: \nL15723:         # Post-release\nL15724:         if self.post is not None:\nL15725:             parts.append(f\".post{self.post}\")\nL15726: \nL15727:         # Development release\nL15728:         if self.dev is not None:\nL15729:             parts.append(f\".dev{self.dev}\")\nL15730: \nL15731:         # Local version segment\nL15732:         if self.local is not None:\nL15733:             parts.append(f\"+{self.local}\")\nL15734: \nL15735:         return \"\".join(parts)\nL15736: \nL15737:     @property\nL15738:     def epoch(self) -> int:\nL15739:         \"\"\"The epoch of the version.\nL15740: \nL15741:         >>> Version(\"2.0.0\").epoch\nL15742:         0\nL15743:         >>> Version(\"1!2.0.0\").epoch\nL15744:         1\nL15745:         \"\"\"\nL15746:         return self._version.epoch\nL15747: \nL15748:     @property\nL15749:     def release(self) -> Tuple[int, ...]:\nL15750:         \"\"\"The components of the \"release\" segment of the version.\nL15751: \nL15752:         >>> Version(\"1.2.3\").release\nL15753:         (1, 2, 3)\nL15754:         >>> Version(\"2.0.0\").release\nL15755:         (2, 0, 0)\nL15756:         >>> Version(\"1!2.0.0.post0\").release\nL15757:         (2, 0, 0)\nL15758: \nL15759:         Includes trailing zeroes but not the epoch or any pre-release / development /\nL15760:         post-release suffixes.\nL15761:         \"\"\"\nL15762:         return self._version.release\nL15763: \nL15764:     @property\nL15765:     def pre(self) -> Optional[Tuple[str, int]]:\nL15766:         \"\"\"The pre-release segment of the version.\nL15767: \nL15768:         >>> print(Version(\"1.2.3\").pre)\nL15769:         None\nL15770:         >>> Version(\"1.2.3a1\").pre\nL15771:         ('a', 1)\nL15772:         >>> Version(\"1.2.3b1\").pre\nL15773:         ('b', 1)\nL15774:         >>> Version(\"1.2.3rc1\").pre\nL15775:         ('rc', 1)\nL15776:         \"\"\"\nL15777:         return self._version.pre\nL15778: \nL15779:     @property\nL15780:     def post(self) -> Optional[int]:\nL15781:         \"\"\"The post-release number of the version.\nL15782: \nL15783:         >>> print(Version(\"1.2.3\").post)\nL15784:         None\nL15785:         >>> Version(\"1.2.3.post1\").post\nL15786:         1\nL15787:         \"\"\"\nL15788:         return self._version.post[1] if self._version.post else None\nL15789: \nL15790:     @property\nL15791:     def dev(self) -> Optional[int]:\nL15792:         \"\"\"The development number of the version.\nL15793: \nL15794:         >>> print(Version(\"1.2.3\").dev)\nL15795:         None\nL15796:         >>> Version(\"1.2.3.dev1\").dev\nL15797:         1\nL15798:         \"\"\"\nL15799:         return self._version.dev[1] if self._version.dev else None\nL15800: \nL15801:     @property\nL15802:     def local(self) -> Optional[str]:\nL15803:         \"\"\"The local version segment of the version.\nL15804: \nL15805:         >>> print(Version(\"1.2.3\").local)\nL15806:         None\nL15807:         >>> Version(\"1.2.3+abc\").local\nL15808:         'abc'\nL15809:         \"\"\"\nL15810:         if self._version.local:\nL15811:             return \".\".join(str(x) for x in self._version.local)\nL15812:         else:\nL15813:             return None\nL15814: \nL15815:     @property\nL15816:     def public(self) -> str:\nL15817:         \"\"\"The public portion of the version.\nL15818: \nL15819:         >>> Version(\"1.2.3\").public\nL15820:         '1.2.3'\nL15821:         >>> Version(\"1.2.3+abc\").public\nL15822:         '1.2.3'\nL15823:         >>> Version(\"1.2.3+abc.dev1\").public\nL15824:         '1.2.3'\nL15825:         \"\"\"\nL15826:         return str(self).split(\"+\", 1)[0]\nL15827: \nL15828:     @property\nL15829:     def base_version(self) -> str:\nL15830:         \"\"\"The \"base version\" of the version.\nL15831: \nL15832:         >>> Version(\"1.2.3\").base_version\nL15833:         '1.2.3'\nL15834:         >>> Version(\"1.2.3+abc\").base_version\nL15835:         '1.2.3'\nL15836:         >>> Version(\"1!1.2.3+abc.dev1\").base_version\nL15837:         '1!1.2.3'\nL15838: \nL15839:         The \"base version\" is the public version of the project without any pre or post\nL15840:         release markers.\nL15841:         \"\"\"\nL15842:         parts = []\nL15843: \nL15844:         # Epoch\nL15845:         if self.epoch != 0:\nL15846:             parts.append(f\"{self.epoch}!\")\nL15847: \nL15848:         # Release segment\nL15849:         parts.append(\".\".join(str(x) for x in self.release))\nL15850: \nL15851:         return \"\".join(parts)\nL15852: \nL15853:     @property\nL15854:     def is_prerelease(self) -> bool:\nL15855:         \"\"\"Whether this version is a pre-release.\nL15856: \nL15857:         >>> Version(\"1.2.3\").is_prerelease\nL15858:         False\nL15859:         >>> Version(\"1.2.3a1\").is_prerelease\nL15860:         True\nL15861:         >>> Version(\"1.2.3b1\").is_prerelease\nL15862:         True\nL15863:         >>> Version(\"1.2.3rc1\").is_prerelease\nL15864:         True\nL15865:         >>> Version(\"1.2.3dev1\").is_prerelease\nL15866:         True\nL15867:         \"\"\"\nL15868:         return self.dev is not None or self.pre is not None\nL15869: \nL15870:     @property\nL15871:     def is_postrelease(self) -> bool:\nL15872:         \"\"\"Whether this version is a post-release.\nL15873: \nL15874:         >>> Version(\"1.2.3\").is_postrelease\nL15875:         False\nL15876:         >>> Version(\"1.2.3.post1\").is_postrelease\nL15877:         True\nL15878:         \"\"\"\nL15879:         return self.post is not None\nL15880: \nL15881:     @property\nL15882:     def is_devrelease(self) -> bool:\nL15883:         \"\"\"Whether this version is a development release.\nL15884: \nL15885:         >>> Version(\"1.2.3\").is_devrelease\nL15886:         False\nL15887:         >>> Version(\"1.2.3.dev1\").is_devrelease\nL15888:         True\nL15889:         \"\"\"\nL15890:         return self.dev is not None\nL15891: \nL15892:     @property\nL15893:     def major(self) -> int:\nL15894:         \"\"\"The first item of :attr:`release` or ``0`` if unavailable.\nL15895: \nL15896:         >>> Version(\"1.2.3\").major\nL15897:         1\nL15898:         \"\"\"\nL15899:         return self.release[0] if len(self.release) >= 1 else 0\nL15900: \nL15901:     @property\nL15902:     def minor(self) -> int:\nL15903:         \"\"\"The second item of :attr:`release` or ``0`` if unavailable.\nL15904: \nL15905:         >>> Version(\"1.2.3\").minor\nL15906:         2\nL15907:         >>> Version(\"1\").minor\nL15908:         0\nL15909:         \"\"\"\nL15910:         return self.release[1] if len(self.release) >= 2 else 0\nL15911: \nL15912:     @property\nL15913:     def micro(self) -> int:\nL15914:         \"\"\"The third item of :attr:`release` or ``0`` if unavailable.\nL15915: \nL15916:         >>> Version(\"1.2.3\").micro\nL15917:         3\nL15918:         >>> Version(\"1\").micro\nL15919:         0\nL15920:         \"\"\"\nL15921:         return self.release[2] if len(self.release) >= 3 else 0\nL15922: \nL15923: \nL15924: def _parse_letter_version(\nL15925:     letter: Optional[str], number: Union[str, bytes, SupportsInt, None]\nL15926: ) -> Optional[Tuple[str, int]]:\nL15927:     if letter:\nL15928:         # We consider there to be an implicit 0 in a pre-release if there is\nL15929:         # not a numeral associated with it.\nL15930:         if number is None:\nL15931:             number = 0\nL15932: \nL15933:         # We normalize any letters to their lower case form\nL15934:         letter = letter.lower()\nL15935: \nL15936:         # We consider some words to be alternate spellings of other words and\nL15937:         # in those cases we want to normalize the spellings to our preferred\nL15938:         # spelling.\nL15939:         if letter == \"alpha\":\nL15940:             letter = \"a\"\nL15941:         elif letter == \"beta\":\nL15942:             letter = \"b\"\nL15943:         elif letter in [\"c\", \"pre\", \"preview\"]:\nL15944:             letter = \"rc\"\nL15945:         elif letter in [\"rev\", \"r\"]:\nL15946:             letter = \"post\"\nL15947: \nL15948:         return letter, int(number)\nL15949:     if not letter and number:\nL15950:         # We assume if we are given a number, but we are not given a letter\nL15951:         # then this is using the implicit post release syntax (e.g. 1.0-1)\nL15952:         letter = \"post\"\nL15953: \nL15954:         return letter, int(number)\nL15955: \nL15956:     return None\nL15957: \nL15958: \nL15959: _local_version_separators = re.compile(r\"[\\._-]\")\nL15960: \nL15961: \nL15962: def _parse_local_version(local: Optional[str]) -> Optional[LocalType]:\nL15963:     \"\"\"\nL15964:     Takes a string like abc.1.twelve and turns it into (\"abc\", 1, \"twelve\").\nL15965:     \"\"\"\nL15966:     if local is not None:\nL15967:         return tuple(\nL15968:             part.lower() if not part.isdigit() else int(part)\nL15969:             for part in _local_version_separators.split(local)\nL15970:         )\nL15971:     return None\nL15972: \nL15973: \nL15974: def _cmpkey(\nL15975:     epoch: int,\nL15976:     release: Tuple[int, ...],\nL15977:     pre: Optional[Tuple[str, int]],\nL15978:     post: Optional[Tuple[str, int]],\nL15979:     dev: Optional[Tuple[str, int]],\nL15980:     local: Optional[LocalType],\nL15981: ) -> CmpKey:\nL15982:     # When we compare a release version, we want to compare it with all of the\nL15983:     # trailing zeros removed. So we'll use a reverse the list, drop all the now\nL15984:     # leading zeros until we come to something non zero, then take the rest\nL15985:     # re-reverse it back into the correct order and make it a tuple and use\nL15986:     # that for our sorting key.\nL15987:     _release = tuple(\nL15988:         reversed(list(itertools.dropwhile(lambda x: x == 0, reversed(release))))\nL15989:     )\nL15990: \nL15991:     # We need to \"trick\" the sorting algorithm to put 1.0.dev0 before 1.0a0.\nL15992:     # We'll do this by abusing the pre segment, but we _only_ want to do this\nL15993:     # if there is not a pre or a post segment. If we have one of those then\nL15994:     # the normal sorting rules will handle this case correctly.\nL15995:     if pre is None and post is None and dev is not None:\nL15996:         _pre: CmpPrePostDevType = NegativeInfinity\nL15997:     # Versions without a pre-release (except as noted above) should sort after\nL15998:     # those with one.\nL15999:     elif pre is None:\nL16000:         _pre = Infinity\nL16001:     else:\nL16002:         _pre = pre\nL16003: \nL16004:     # Versions without a post segment should sort before those with one.\nL16005:     if post is None:\nL16006:         _post: CmpPrePostDevType = NegativeInfinity\nL16007: \nL16008:     else:\nL16009:         _post = post\nL16010: \nL16011:     # Versions without a development segment should sort after those with one.\nL16012:     if dev is None:\nL16013:         _dev: CmpPrePostDevType = Infinity\nL16014: \nL16015:     else:\nL16016:         _dev = dev\nL16017: \nL16018:     if local is None:\nL16019:         # Versions without a local segment should sort before those with one.\nL16020:         _local: CmpLocalType = NegativeInfinity\nL16021:     else:\nL16022:         # Versions with a local segment need that segment parsed to implement\nL16023:         # the sorting rules in PEP440.\nL16024:         # - Alpha numeric segments sort before numeric segments\nL16025:         # - Alpha numeric segments sort lexicographically\nL16026:         # - Numeric segments sort numerically\nL16027:         # - Shorter versions sort before longer versions when the prefixes\nL16028:         #   match exactly\nL16029:         _local = tuple(\nL16030:             (i, \"\") if isinstance(i, int) else (NegativeInfinity, i) for i in local\nL16031:         )\nL16032: \nL16033:     return epoch, _release, _pre, _post, _dev, _local\nL16034: \nL16035: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/build/__init__.py\nL16036: \"\"\"\nL16037: build - A simple, correct Python build frontend\nL16038: \"\"\"\nL16039: \nL16040: from __future__ import annotations\nL16041: \nL16042: from ._builder import ProjectBuilder\nL16043: from ._exceptions import (\nL16044:     BuildBackendException,\nL16045:     BuildException,\nL16046:     BuildSystemTableValidationError,\nL16047:     FailedProcessError,\nL16048:     TypoWarning,\nL16049: )\nL16050: from ._types import ConfigSettings as ConfigSettingsType\nL16051: from ._types import Distribution as DistributionType\nL16052: from ._types import SubprocessRunner as RunnerType\nL16053: from ._util import check_dependency\nL16054: \nL16055: \nL16056: __version__ = '1.2.2.post1'\nL16057: \nL16058: __all__ = [\nL16059:     '__version__',\nL16060:     'BuildBackendException',\nL16061:     'BuildException',\nL16062:     'BuildSystemTableValidationError',\nL16063:     'check_dependency',\nL16064:     'ConfigSettingsType',\nL16065:     'DistributionType',\nL16066:     'FailedProcessError',\nL16067:     'ProjectBuilder',\nL16068:     'RunnerType',\nL16069:     'TypoWarning',\nL16070: ]\nL16071: \nL16072: \nL16073: def __dir__() -> list[str]:\nL16074:     return __all__\nL16075: \nL16076: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/build/__main__.py\nL16077: # SPDX-License-Identifier: MIT\nL16078: \nL16079: from __future__ import annotations\nL16080: \nL16081: import argparse\nL16082: import contextlib\nL16083: import contextvars\nL16084: import os\nL16085: import platform\nL16086: import shutil\nL16087: import subprocess\nL16088: import sys\nL16089: import tempfile\nL16090: import textwrap\nL16091: import traceback\nL16092: import warnings\nL16093: \nL16094: from collections.abc import Iterator, Sequence\nL16095: from functools import partial\nL16096: from typing import NoReturn, TextIO\nL16097: \nL16098: import build\nL16099: \nL16100: from . import ProjectBuilder, _ctx\nL16101: from . import env as _env\nL16102: from ._exceptions import BuildBackendException, BuildException, FailedProcessError\nL16103: from ._types import ConfigSettings, Distribution, StrPath\nL16104: from .env import DefaultIsolatedEnv\nL16105: \nL16106: \nL16107: _COLORS = {\nL16108:     'red': '\\33[91m',\nL16109:     'green': '\\33[92m',\nL16110:     'yellow': '\\33[93m',\nL16111:     'bold': '\\33[1m',\nL16112:     'dim': '\\33[2m',\nL16113:     'underline': '\\33[4m',\nL16114:     'reset': '\\33[0m',\nL16115: }\nL16116: _NO_COLORS = {color: '' for color in _COLORS}\nL16117: \nL16118: \nL16119: _styles = contextvars.ContextVar('_styles', default=_COLORS)\nL16120: \nL16121: \nL16122: def _init_colors() -> None:\nL16123:     if 'NO_COLOR' in os.environ:\nL16124:         if 'FORCE_COLOR' in os.environ:\nL16125:             warnings.warn('Both NO_COLOR and FORCE_COLOR environment variables are set, disabling color', stacklevel=2)\nL16126:         _styles.set(_NO_COLORS)\nL16127:     elif 'FORCE_COLOR' in os.environ or sys.stdout.isatty():\nL16128:         return\nL16129:     _styles.set(_NO_COLORS)\nL16130: \nL16131: \nL16132: def _cprint(fmt: str = '', msg: str = '', file: TextIO | None = None) -> None:\nL16133:     print(fmt.format(msg, **_styles.get()), file=file, flush=True)\nL16134: \nL16135: \nL16136: def _showwarning(\nL16137:     message: Warning | str,\nL16138:     category: type[Warning],\nL16139:     filename: str,\nL16140:     lineno: int,\nL16141:     file: TextIO | None = None,\nL16142:     line: str | None = None,\nL16143: ) -> None:  # pragma: no cover\nL16144:     _cprint('{yellow}WARNING{reset} {}', str(message))\nL16145: \nL16146: \nL16147: _max_terminal_width = shutil.get_terminal_size().columns - 2\nL16148: if _max_terminal_width <= 0:\nL16149:     _max_terminal_width = 78\nL16150: \nL16151: \nL16152: _fill = partial(textwrap.fill, subsequent_indent='  ', width=_max_terminal_width)\nL16153: \nL16154: \nL16155: def _log(message: str, *, origin: tuple[str, ...] | None = None) -> None:\nL16156:     if origin is None:\nL16157:         (first, *rest) = message.splitlines()\nL16158:         _cprint('{bold}{}{reset}', _fill(first, initial_indent='* '))\nL16159:         for line in rest:\nL16160:             print(_fill(line, initial_indent='  '))\nL16161: \nL16162:     elif origin[0] == 'subprocess':\nL16163:         initial_indent = '> ' if origin[1] == 'cmd' else '< '\nL16164:         file = sys.stderr if origin[1] == 'stderr' else None\nL16165:         for line in message.splitlines():\nL16166:             _cprint('{dim}{}{reset}', _fill(line, initial_indent=initial_indent), file=file)\nL16167: \nL16168: \nL16169: def _setup_cli(*, verbosity: int) -> None:\nL16170:     warnings.showwarning = _showwarning\nL16171: \nL16172:     if platform.system() == 'Windows':\nL16173:         try:\nL16174:             import colorama\nL16175: \nL16176:             colorama.init()\nL16177:         except ModuleNotFoundError:\nL16178:             pass\nL16179: \nL16180:     _init_colors()\nL16181: \nL16182:     _ctx.LOGGER.set(_log)\nL16183:     _ctx.VERBOSITY.set(verbosity)\nL16184: \nL16185: \nL16186: def _error(msg: str, code: int = 1) -> NoReturn:  # pragma: no cover\nL16187:     \"\"\"\nL16188:     Print an error message and exit. Will color the output when writing to a TTY.\nL16189: \nL16190:     :param msg: Error message\nL16191:     :param code: Error code\nL16192:     \"\"\"\nL16193:     _cprint('{red}ERROR{reset} {}', msg)\nL16194:     raise SystemExit(code)\nL16195: \nL16196: \nL16197: def _format_dep_chain(dep_chain: Sequence[str]) -> str:\nL16198:     return ' -> '.join(dep.partition(';')[0].strip() for dep in dep_chain)\nL16199: \nL16200: \nL16201: def _build_in_isolated_env(\nL16202:     srcdir: StrPath,\nL16203:     outdir: StrPath,\nL16204:     distribution: Distribution,\nL16205:     config_settings: ConfigSettings | None,\nL16206:     installer: _env.Installer,\nL16207: ) -> str:\nL16208:     with DefaultIsolatedEnv(installer=installer) as env:\nL16209:         builder = ProjectBuilder.from_isolated_env(env, srcdir)\nL16210:         # first install the build dependencies\nL16211:         env.install(builder.build_system_requires)\nL16212:         # then get the extra required dependencies from the backend (which was installed in the call above :P)\nL16213:         env.install(builder.get_requires_for_build(distribution, config_settings or {}))\nL16214:         return builder.build(distribution, outdir, config_settings or {})\nL16215: \nL16216: \nL16217: def _build_in_current_env(\nL16218:     srcdir: StrPath,\nL16219:     outdir: StrPath,\nL16220:     distribution: Distribution,\nL16221:     config_settings: ConfigSettings | None,\nL16222:     skip_dependency_check: bool = False,\nL16223: ) -> str:\nL16224:     builder = ProjectBuilder(srcdir)\nL16225: \nL16226:     if not skip_dependency_check:\nL16227:         missing = builder.check_dependencies(distribution, config_settings or {})\nL16228:         if missing:\nL16229:             dependencies = ''.join('\\n\\t' + dep for deps in missing for dep in (deps[0], _format_dep_chain(deps[1:])) if dep)\nL16230:             _cprint()\nL16231:             _error(f'Missing dependencies:{dependencies}')\nL16232: \nL16233:     return builder.build(distribution, outdir, config_settings or {})\nL16234: \nL16235: \nL16236: def _build(\nL16237:     isolation: bool,\nL16238:     srcdir: StrPath,\nL16239:     outdir: StrPath,\nL16240:     distribution: Distribution,\nL16241:     config_settings: ConfigSettings | None,\nL16242:     skip_dependency_check: bool,\nL16243:     installer: _env.Installer,\nL16244: ) -> str:\nL16245:     if isolation:\nL16246:         return _build_in_isolated_env(srcdir, outdir, distribution, config_settings, installer)\nL16247:     else:\nL16248:         return _build_in_current_env(srcdir, outdir, distribution, config_settings, skip_dependency_check)\nL16249: \nL16250: \nL16251: @contextlib.contextmanager\nL16252: def _handle_build_error() -> Iterator[None]:\nL16253:     try:\nL16254:         yield\nL16255:     except (BuildException, FailedProcessError) as e:\nL16256:         _error(str(e))\nL16257:     except BuildBackendException as e:\nL16258:         if isinstance(e.exception, subprocess.CalledProcessError):\nL16259:             _cprint()\nL16260:             _error(str(e))\nL16261: \nL16262:         if e.exc_info:\nL16263:             tb_lines = traceback.format_exception(\nL16264:                 e.exc_info[0],\nL16265:                 e.exc_info[1],\nL16266:                 e.exc_info[2],\nL16267:                 limit=-1,\nL16268:             )\nL16269:             tb = ''.join(tb_lines)\nL16270:         else:\nL16271:             tb = traceback.format_exc(-1)\nL16272:         _cprint('\\n{dim}{}{reset}\\n', tb.strip('\\n'))\nL16273:         _error(str(e))\nL16274:     except Exception as e:  # pragma: no cover\nL16275:         tb = traceback.format_exc().strip('\\n')\nL16276:         _cprint('\\n{dim}{}{reset}\\n', tb)\nL16277:         _error(str(e))\nL16278: \nL16279: \nL16280: def _natural_language_list(elements: Sequence[str]) -> str:\nL16281:     if len(elements) == 0:\nL16282:         msg = 'no elements'\nL16283:         raise IndexError(msg)\nL16284:     elif len(elements) == 1:\nL16285:         return elements[0]\nL16286:     else:\nL16287:         return '{} and {}'.format(\nL16288:             ', '.join(elements[:-1]),\nL16289:             elements[-1],\nL16290:         )\nL16291: \nL16292: \nL16293: def build_package(\nL16294:     srcdir: StrPath,\nL16295:     outdir: StrPath,\nL16296:     distributions: Sequence[Distribution],\nL16297:     config_settings: ConfigSettings | None = None,\nL16298:     isolation: bool = True,\nL16299:     skip_dependency_check: bool = False,\nL16300:     installer: _env.Installer = 'pip',\nL16301: ) -> Sequence[str]:\nL16302:     \"\"\"\nL16303:     Run the build process.\nL16304: \nL16305:     :param srcdir: Source directory\nL16306:     :param outdir: Output directory\nL16307:     :param distribution: Distribution to build (sdist or wheel)\nL16308:     :param config_settings: Configuration settings to be passed to the backend\nL16309:     :param isolation: Isolate the build in a separate environment\nL16310:     :param skip_dependency_check: Do not perform the dependency check\nL16311:     \"\"\"\nL16312:     built: list[str] = []\nL16313:     for distribution in distributions:\nL16314:         out = _build(isolation, srcdir, outdir, distribution, config_settings, skip_dependency_check, installer)\nL16315:         built.append(os.path.basename(out))\nL16316:     return built\nL16317: \nL16318: \nL16319: def build_package_via_sdist(\nL16320:     srcdir: StrPath,\nL16321:     outdir: StrPath,\nL16322:     distributions: Sequence[Distribution],\nL16323:     config_settings: ConfigSettings | None = None,\nL16324:     isolation: bool = True,\nL16325:     skip_dependency_check: bool = False,\nL16326:     installer: _env.Installer = 'pip',\nL16327: ) -> Sequence[str]:\nL16328:     \"\"\"\nL16329:     Build a sdist and then the specified distributions from it.\nL16330: \nL16331:     :param srcdir: Source directory\nL16332:     :param outdir: Output directory\nL16333:     :param distribution: Distribution to build (only wheel)\nL16334:     :param config_settings: Configuration settings to be passed to the backend\nL16335:     :param isolation: Isolate the build in a separate environment\nL16336:     :param skip_dependency_check: Do not perform the dependency check\nL16337:     \"\"\"\nL16338:     from ._compat import tarfile\nL16339: \nL16340:     if 'sdist' in distributions:\nL16341:         msg = 'Only binary distributions are allowed but sdist was specified'\nL16342:         raise ValueError(msg)\nL16343: \nL16344:     sdist = _build(isolation, srcdir, outdir, 'sdist', config_settings, skip_dependency_check, installer)\nL16345: \nL16346:     sdist_name = os.path.basename(sdist)\nL16347:     sdist_out = tempfile.mkdtemp(prefix='build-via-sdist-')\nL16348:     built: list[str] = []\nL16349:     if distributions:\nL16350:         # extract sdist\nL16351:         with tarfile.TarFile.open(sdist) as t:\nL16352:             t.extractall(sdist_out)\nL16353:             try:\nL16354:                 _ctx.log(f'Building {_natural_language_list(distributions)} from sdist')\nL16355:                 srcdir = os.path.join(sdist_out, sdist_name[: -len('.tar.gz')])\nL16356:                 for distribution in distributions:\nL16357:                     out = _build(isolation, srcdir, outdir, distribution, config_settings, skip_dependency_check, installer)\nL16358:                     built.append(os.path.basename(out))\nL16359:             finally:\nL16360:                 shutil.rmtree(sdist_out, ignore_errors=True)\nL16361:     return [sdist_name, *built]\nL16362: \nL16363: \nL16364: def main_parser() -> argparse.ArgumentParser:\nL16365:     \"\"\"\nL16366:     Construct the main parser.\nL16367:     \"\"\"\nL16368:     parser = argparse.ArgumentParser(\nL16369:         description=textwrap.indent(\nL16370:             textwrap.dedent(\nL16371:                 \"\"\"\nL16372:                 A simple, correct Python build frontend.\nL16373: \nL16374:                 By default, a source distribution (sdist) is built from {srcdir}\nL16375:                 and a binary distribution (wheel) is built from the sdist.\nL16376:                 This is recommended as it will ensure the sdist can be used\nL16377:                 to build wheels.\nL16378: \nL16379:                 Pass -s/--sdist and/or -w/--wheel to build a specific distribution.\nL16380:                 If you do this, the default behavior will be disabled, and all\nL16381:                 artifacts will be built from {srcdir} (even if you combine\nL16382:                 -w/--wheel with -s/--sdist, the wheel will be built from {srcdir}).\nL16383:                 \"\"\"\nL16384:             ).strip(),\nL16385:             '    ',\nL16386:         ),\nL16387:         # Prevent argparse from taking up the entire width of the terminal window\nL16388:         # which impedes readability.\nL16389:         formatter_class=partial(argparse.RawDescriptionHelpFormatter, width=min(_max_terminal_width, 127)),\nL16390:     )\nL16391:     parser.add_argument(\nL16392:         'srcdir',\nL16393:         type=str,\nL16394:         nargs='?',\nL16395:         default=os.getcwd(),\nL16396:         help='source directory (defaults to current directory)',\nL16397:     )\nL16398:     parser.add_argument(\nL16399:         '--version',\nL16400:         '-V',\nL16401:         action='version',\nL16402:         version=f\"build {build.__version__} ({','.join(build.__path__)})\",\nL16403:     )\nL16404:     parser.add_argument(\nL16405:         '--verbose',\nL16406:         '-v',\nL16407:         dest='verbosity',\nL16408:         action='count',\nL16409:         default=0,\nL16410:         help='increase verbosity',\nL16411:     )\nL16412:     parser.add_argument(\nL16413:         '--sdist',\nL16414:         '-s',\nL16415:         dest='distributions',\nL16416:         action='append_const',\nL16417:         const='sdist',\nL16418:         help='build a source distribution (disables the default behavior)',\nL16419:     )\nL16420:     parser.add_argument(\nL16421:         '--wheel',\nL16422:         '-w',\nL16423:         dest='distributions',\nL16424:         action='append_const',\nL16425:         const='wheel',\nL16426:         help='build a wheel (disables the default behavior)',\nL16427:     )\nL16428:     parser.add_argument(\nL16429:         '--outdir',\nL16430:         '-o',\nL16431:         type=str,\nL16432:         help=f'output directory (defaults to {{srcdir}}{os.sep}dist)',\nL16433:         metavar='PATH',\nL16434:     )\nL16435:     parser.add_argument(\nL16436:         '--skip-dependency-check',\nL16437:         '-x',\nL16438:         action='store_true',\nL16439:         help='do not check that build dependencies are installed',\nL16440:     )\nL16441:     env_group = parser.add_mutually_exclusive_group()\nL16442:     env_group.add_argument(\nL16443:         '--no-isolation',\nL16444:         '-n',\nL16445:         action='store_true',\nL16446:         help='disable building the project in an isolated virtual environment. '\nL16447:         'Build dependencies must be installed separately when this option is used',\nL16448:     )\nL16449:     env_group.add_argument(\nL16450:         '--installer',\nL16451:         choices=_env.INSTALLERS,\nL16452:         help='Python package installer to use (defaults to pip)',\nL16453:     )\nL16454:     parser.add_argument(\nL16455:         '--config-setting',\nL16456:         '-C',\nL16457:         dest='config_settings',\nL16458:         action='append',\nL16459:         help='settings to pass to the backend.  Multiple settings can be provided. '\nL16460:         'Settings beginning with a hyphen will erroneously be interpreted as options to build if separated '\nL16461:         'by a space character; use ``--config-setting=--my-setting -C--my-other-setting``',\nL16462:         metavar='KEY[=VALUE]',\nL16463:     )\nL16464:     return parser\nL16465: \nL16466: \nL16467: def main(cli_args: Sequence[str], prog: str | None = None) -> None:\nL16468:     \"\"\"\nL16469:     Parse the CLI arguments and invoke the build process.\nL16470: \nL16471:     :param cli_args: CLI arguments\nL16472:     :param prog: Program name to show in help text\nL16473:     \"\"\"\nL16474:     parser = main_parser()\nL16475:     if prog:\nL16476:         parser.prog = prog\nL16477:     args = parser.parse_args(cli_args)\nL16478: \nL16479:     _setup_cli(verbosity=args.verbosity)\nL16480: \nL16481:     config_settings = {}\nL16482: \nL16483:     if args.config_settings:\nL16484:         for arg in args.config_settings:\nL16485:             setting, _, value = arg.partition('=')\nL16486:             if setting not in config_settings:\nL16487:                 config_settings[setting] = value\nL16488:             else:\nL16489:                 if not isinstance(config_settings[setting], list):\nL16490:                     config_settings[setting] = [config_settings[setting]]\nL16491: \nL16492:                 config_settings[setting].append(value)\nL16493: \nL16494:     # outdir is relative to srcdir only if omitted.\nL16495:     outdir = os.path.join(args.srcdir, 'dist') if args.outdir is None else args.outdir\nL16496: \nL16497:     distributions: list[Distribution] = args.distributions\nL16498:     if distributions:\nL16499:         build_call = build_package\nL16500:     else:\nL16501:         build_call = build_package_via_sdist\nL16502:         distributions = ['wheel']\nL16503: \nL16504:     with _handle_build_error():\nL16505:         built = build_call(\nL16506:             args.srcdir,\nL16507:             outdir,\nL16508:             distributions,\nL16509:             config_settings,\nL16510:             not args.no_isolation,\nL16511:             args.skip_dependency_check,\nL16512:             args.installer,\nL16513:         )\nL16514:         artifact_list = _natural_language_list(\nL16515:             ['{underline}{}{reset}{bold}{green}'.format(artifact, **_styles.get()) for artifact in built]\nL16516:         )\nL16517:         _cprint('{bold}{green}Successfully built {}{reset}', artifact_list)\nL16518: \nL16519: \nL16520: def entrypoint() -> None:\nL16521:     main(sys.argv[1:])\nL16522: \nL16523: \nL16524: if __name__ == '__main__':  # pragma: no cover\nL16525:     main(sys.argv[1:], 'python -m build')\nL16526: \nL16527: \nL16528: __all__ = [\nL16529:     'main',\nL16530:     'main_parser',\nL16531: ]\nL16532: \nL16533: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/build/_builder.py\nL16534: # SPDX-License-Identifier: MIT\nL16535: \nL16536: from __future__ import annotations\nL16537: \nL16538: import contextlib\nL16539: import difflib\nL16540: import os\nL16541: import subprocess\nL16542: import sys\nL16543: import warnings\nL16544: import zipfile\nL16545: \nL16546: from collections.abc import Iterator\nL16547: from typing import Any, Mapping, Sequence, TypeVar\nL16548: \nL16549: import pyproject_hooks\nL16550: \nL16551: from . import _ctx, env\nL16552: from ._compat import tomllib\nL16553: from ._exceptions import (\nL16554:     BuildBackendException,\nL16555:     BuildException,\nL16556:     BuildSystemTableValidationError,\nL16557:     TypoWarning,\nL16558: )\nL16559: from ._types import ConfigSettings, Distribution, StrPath, SubprocessRunner\nL16560: from ._util import check_dependency, parse_wheel_filename\nL16561: \nL16562: \nL16563: _TProjectBuilder = TypeVar('_TProjectBuilder', bound='ProjectBuilder')\nL16564: \nL16565: \nL16566: _DEFAULT_BACKEND = {\nL16567:     'build-backend': 'setuptools.build_meta:__legacy__',\nL16568:     'requires': ['setuptools >= 40.8.0'],\nL16569: }\nL16570: \nL16571: \nL16572: def _find_typo(dictionary: Mapping[str, str], expected: str) -> None:\nL16573:     for obj in dictionary:\nL16574:         if difflib.SequenceMatcher(None, expected, obj).ratio() >= 0.8:\nL16575:             warnings.warn(\nL16576:                 f\"Found '{obj}' in pyproject.toml, did you mean '{expected}'?\",\nL16577:                 TypoWarning,\nL16578:                 stacklevel=2,\nL16579:             )\nL16580: \nL16581: \nL16582: def _validate_source_directory(source_dir: StrPath) -> None:\nL16583:     if not os.path.isdir(source_dir):\nL16584:         msg = f'Source {source_dir} is not a directory'\nL16585:         raise BuildException(msg)\nL16586:     pyproject_toml = os.path.join(source_dir, 'pyproject.toml')\nL16587:     setup_py = os.path.join(source_dir, 'setup.py')\nL16588:     if not os.path.exists(pyproject_toml) and not os.path.exists(setup_py):\nL16589:         msg = f'Source {source_dir} does not appear to be a Python project: no pyproject.toml or setup.py'\nL16590:         raise BuildException(msg)\nL16591: \nL16592: \nL16593: def _read_pyproject_toml(path: StrPath) -> Mapping[str, Any]:\nL16594:     try:\nL16595:         with open(path, 'rb') as f:\nL16596:             return tomllib.loads(f.read().decode())\nL16597:     except FileNotFoundError:\nL16598:         return {}\nL16599:     except PermissionError as e:\nL16600:         msg = f\"{e.strerror}: '{e.filename}' \"\nL16601:         raise BuildException(msg) from None\nL16602:     except tomllib.TOMLDecodeError as e:\nL16603:         msg = f'Failed to parse {path}: {e} '\nL16604:         raise BuildException(msg) from None\nL16605: \nL16606: \nL16607: def _parse_build_system_table(pyproject_toml: Mapping[str, Any]) -> Mapping[str, Any]:\nL16608:     # If pyproject.toml is missing (per PEP 517) or [build-system] is missing\nL16609:     # (per PEP 518), use default values\nL16610:     if 'build-system' not in pyproject_toml:\nL16611:         _find_typo(pyproject_toml, 'build-system')\nL16612:         return _DEFAULT_BACKEND\nL16613: \nL16614:     build_system_table = dict(pyproject_toml['build-system'])\nL16615: \nL16616:     # If [build-system] is present, it must have a ``requires`` field (per PEP 518)\nL16617:     if 'requires' not in build_system_table:\nL16618:         _find_typo(build_system_table, 'requires')\nL16619:         msg = '`requires` is a required property'\nL16620:         raise BuildSystemTableValidationError(msg)\nL16621:     elif not isinstance(build_system_table['requires'], list) or not all(\nL16622:         isinstance(i, str) for i in build_system_table['requires']\nL16623:     ):\nL16624:         msg = '`requires` must be an array of strings'\nL16625:         raise BuildSystemTableValidationError(msg)\nL16626: \nL16627:     if 'build-backend' not in build_system_table:\nL16628:         _find_typo(build_system_table, 'build-backend')\nL16629:         # If ``build-backend`` is missing, inject the legacy setuptools backend\nL16630:         # but leave ``requires`` intact to emulate pip\nL16631:         build_system_table['build-backend'] = _DEFAULT_BACKEND['build-backend']\nL16632:     elif not isinstance(build_system_table['build-backend'], str):\nL16633:         msg = '`build-backend` must be a string'\nL16634:         raise BuildSystemTableValidationError(msg)\nL16635: \nL16636:     if 'backend-path' in build_system_table and (\nL16637:         not isinstance(build_system_table['backend-path'], list)\nL16638:         or not all(isinstance(i, str) for i in build_system_table['backend-path'])\nL16639:     ):\nL16640:         msg = '`backend-path` must be an array of strings'\nL16641:         raise BuildSystemTableValidationError(msg)\nL16642: \nL16643:     unknown_props = build_system_table.keys() - {'requires', 'build-backend', 'backend-path'}\nL16644:     if unknown_props:\nL16645:         msg = f'Unknown properties: {\", \".join(unknown_props)}'\nL16646:         raise BuildSystemTableValidationError(msg)\nL16647: \nL16648:     return build_system_table\nL16649: \nL16650: \nL16651: def _wrap_subprocess_runner(runner: SubprocessRunner, env: env.IsolatedEnv) -> SubprocessRunner:\nL16652:     def _invoke_wrapped_runner(\nL16653:         cmd: Sequence[str], cwd: str | None = None, extra_environ: Mapping[str, str] | None = None\nL16654:     ) -> None:\nL16655:         runner(cmd, cwd, {**(env.make_extra_environ() or {}), **(extra_environ or {})})\nL16656: \nL16657:     return _invoke_wrapped_runner\nL16658: \nL16659: \nL16660: class ProjectBuilder:\nL16661:     \"\"\"\nL16662:     The PEP 517 consumer API.\nL16663:     \"\"\"\nL16664: \nL16665:     def __init__(\nL16666:         self,\nL16667:         source_dir: StrPath,\nL16668:         python_executable: str = sys.executable,\nL16669:         runner: SubprocessRunner = pyproject_hooks.default_subprocess_runner,\nL16670:     ) -> None:\nL16671:         \"\"\"\nL16672:         :param source_dir: The source directory\nL16673:         :param python_executable: The python executable where the backend lives\nL16674:         :param runner: Runner for backend subprocesses\nL16675: \nL16676:         The ``runner``, if provided, must accept the following arguments:\nL16677: \nL16678:         - ``cmd``: a list of strings representing the command and arguments to\nL16679:           execute, as would be passed to e.g. 'subprocess.check_call'.\nL16680:         - ``cwd``: a string representing the working directory that must be\nL16681:           used for the subprocess. Corresponds to the provided source_dir.\nL16682:         - ``extra_environ``: a dict mapping environment variable names to values\nL16683:           which must be set for the subprocess execution.\nL16684: \nL16685:         The default runner simply calls the backend hooks in a subprocess, writing backend output\nL16686:         to stdout/stderr.\nL16687:         \"\"\"\nL16688:         self._source_dir: str = os.path.abspath(source_dir)\nL16689:         _validate_source_directory(source_dir)\nL16690: \nL16691:         self._python_executable = python_executable\nL16692:         self._runner = runner\nL16693: \nL16694:         pyproject_toml_path = os.path.join(source_dir, 'pyproject.toml')\nL16695:         self._build_system = _parse_build_system_table(_read_pyproject_toml(pyproject_toml_path))\nL16696: \nL16697:         self._backend = self._build_system['build-backend']\nL16698: \nL16699:         self._hook = pyproject_hooks.BuildBackendHookCaller(\nL16700:             self._source_dir,\nL16701:             self._backend,\nL16702:             backend_path=self._build_system.get('backend-path'),\nL16703:             python_executable=self._python_executable,\nL16704:             runner=self._runner,\nL16705:         )\nL16706: \nL16707:     @classmethod\nL16708:     def from_isolated_env(\nL16709:         cls: type[_TProjectBuilder],\nL16710:         env: env.IsolatedEnv,\nL16711:         source_dir: StrPath,\nL16712:         runner: SubprocessRunner = pyproject_hooks.default_subprocess_runner,\nL16713:     ) -> _TProjectBuilder:\nL16714:         return cls(\nL16715:             source_dir=source_dir,\nL16716:             python_executable=env.python_executable,\nL16717:             runner=_wrap_subprocess_runner(runner, env),\nL16718:         )\nL16719: \nL16720:     @property\nL16721:     def source_dir(self) -> str:\nL16722:         \"\"\"Project source directory.\"\"\"\nL16723:         return self._source_dir\nL16724: \nL16725:     @property\nL16726:     def python_executable(self) -> str:\nL16727:         \"\"\"\nL16728:         The Python executable used to invoke the backend.\nL16729:         \"\"\"\nL16730:         return self._python_executable\nL16731: \nL16732:     @property\nL16733:     def build_system_requires(self) -> set[str]:\nL16734:         \"\"\"\nL16735:         The dependencies defined in the ``pyproject.toml``'s\nL16736:         ``build-system.requires`` field or the default build dependencies\nL16737:         if ``pyproject.toml`` is missing or ``build-system`` is undefined.\nL16738:         \"\"\"\nL16739:         return set(self._build_system['requires'])\nL16740: \nL16741:     def get_requires_for_build(\nL16742:         self,\nL16743:         distribution: Distribution,\nL16744:         config_settings: ConfigSettings | None = None,\nL16745:     ) -> set[str]:\nL16746:         \"\"\"\nL16747:         Return the dependencies defined by the backend in addition to\nL16748:         :attr:`build_system_requires` for a given distribution.\nL16749: \nL16750:         :param distribution: Distribution to get the dependencies of\nL16751:             (``sdist`` or ``wheel``)\nL16752:         :param config_settings: Config settings for the build backend\nL16753:         \"\"\"\nL16754:         _ctx.log(f'Getting build dependencies for {distribution}...')\nL16755:         hook_name = f'get_requires_for_build_{distribution}'\nL16756:         get_requires = getattr(self._hook, hook_name)\nL16757: \nL16758:         with self._handle_backend(hook_name):\nL16759:             return set(get_requires(config_settings))\nL16760: \nL16761:     def check_dependencies(\nL16762:         self,\nL16763:         distribution: Distribution,\nL16764:         config_settings: ConfigSettings | None = None,\nL16765:     ) -> set[tuple[str, ...]]:\nL16766:         \"\"\"\nL16767:         Return the dependencies which are not satisfied from the combined set of\nL16768:         :attr:`build_system_requires` and :meth:`get_requires_for_build` for a given\nL16769:         distribution.\nL16770: \nL16771:         :param distribution: Distribution to check (``sdist`` or ``wheel``)\nL16772:         :param config_settings: Config settings for the build backend\nL16773:         :returns: Set of variable-length unmet dependency tuples\nL16774:         \"\"\"\nL16775:         dependencies = self.get_requires_for_build(distribution, config_settings).union(self.build_system_requires)\nL16776:         return {u for d in dependencies for u in check_dependency(d)}\nL16777: \nL16778:     def prepare(\nL16779:         self,\nL16780:         distribution: Distribution,\nL16781:         output_directory: StrPath,\nL16782:         config_settings: ConfigSettings | None = None,\nL16783:     ) -> str | None:\nL16784:         \"\"\"\nL16785:         Prepare metadata for a distribution.\nL16786: \nL16787:         :param distribution: Distribution to build (must be ``wheel``)\nL16788:         :param output_directory: Directory to put the prepared metadata in\nL16789:         :param config_settings: Config settings for the build backend\nL16790:         :returns: The full path to the prepared metadata directory\nL16791:         \"\"\"\nL16792:         _ctx.log(f'Getting metadata for {distribution}...')\nL16793:         try:\nL16794:             return self._call_backend(\nL16795:                 f'prepare_metadata_for_build_{distribution}',\nL16796:                 output_directory,\nL16797:                 config_settings,\nL16798:                 _allow_fallback=False,\nL16799:             )\nL16800:         except BuildBackendException as exception:\nL16801:             if isinstance(exception.exception, pyproject_hooks.HookMissing):\nL16802:                 return None\nL16803:             raise\nL16804: \nL16805:     def build(\nL16806:         self,\nL16807:         distribution: Distribution,\nL16808:         output_directory: StrPath,\nL16809:         config_settings: ConfigSettings | None = None,\nL16810:         metadata_directory: str | None = None,\nL16811:     ) -> str:\nL16812:         \"\"\"\nL16813:         Build a distribution.\nL16814: \nL16815:         :param distribution: Distribution to build (``sdist`` or ``wheel``)\nL16816:         :param output_directory: Directory to put the built distribution in\nL16817:         :param config_settings: Config settings for the build backend\nL16818:         :param metadata_directory: If provided, should be the return value of a\nL16819:             previous ``prepare`` call on the same ``distribution`` kind\nL16820:         :returns: The full path to the built distribution\nL16821:         \"\"\"\nL16822:         _ctx.log(f'Building {distribution}...')\nL16823:         kwargs = {} if metadata_directory is None else {'metadata_directory': metadata_directory}\nL16824:         return self._call_backend(f'build_{distribution}', output_directory, config_settings, **kwargs)\nL16825: \nL16826:     def metadata_path(self, output_directory: StrPath) -> str:\nL16827:         \"\"\"\nL16828:         Generate the metadata directory of a distribution and return its path.\nL16829: \nL16830:         If the backend does not support the ``prepare_metadata_for_build_wheel``\nL16831:         hook, a wheel will be built and the metadata will be extracted from it.\nL16832: \nL16833:         :param output_directory: Directory to put the metadata distribution in\nL16834:         :returns: The path of the metadata directory\nL16835:         \"\"\"\nL16836:         # prepare_metadata hook\nL16837:         metadata = self.prepare('wheel', output_directory)\nL16838:         if metadata is not None:\nL16839:             return metadata\nL16840: \nL16841:         # fallback to build_wheel hook\nL16842:         wheel = self.build('wheel', output_directory)\nL16843:         match = parse_wheel_filename(os.path.basename(wheel))\nL16844:         if not match:\nL16845:             msg = 'Invalid wheel'\nL16846:             raise ValueError(msg)\nL16847:         distinfo = f\"{match['distribution']}-{match['version']}.dist-info\"\nL16848:         member_prefix = f'{distinfo}/'\nL16849:         with zipfile.ZipFile(wheel) as w:\nL16850:             w.extractall(\nL16851:                 output_directory,\nL16852:                 (member for member in w.namelist() if member.startswith(member_prefix)),\nL16853:             )\nL16854:         return os.path.join(output_directory, distinfo)\nL16855: \nL16856:     def _call_backend(\nL16857:         self, hook_name: str, outdir: StrPath, config_settings: ConfigSettings | None = None, **kwargs: Any\nL16858:     ) -> str:\nL16859:         outdir = os.path.abspath(outdir)\nL16860: \nL16861:         callback = getattr(self._hook, hook_name)\nL16862: \nL16863:         if os.path.exists(outdir):\nL16864:             if not os.path.isdir(outdir):\nL16865:                 msg = f\"Build path '{outdir}' exists and is not a directory\"\nL16866:                 raise BuildException(msg)\nL16867:         else:\nL16868:             os.makedirs(outdir)\nL16869: \nL16870:         with self._handle_backend(hook_name):\nL16871:             basename: str = callback(outdir, config_settings, **kwargs)\nL16872: \nL16873:         return os.path.join(outdir, basename)\nL16874: \nL16875:     @contextlib.contextmanager\nL16876:     def _handle_backend(self, hook: str) -> Iterator[None]:\nL16877:         try:\nL16878:             yield\nL16879:         except pyproject_hooks.BackendUnavailable as exception:\nL16880:             raise BuildBackendException(\nL16881:                 exception,\nL16882:                 f\"Backend '{self._backend}' is not available.\",\nL16883:                 sys.exc_info(),\nL16884:             ) from None\nL16885:         except subprocess.CalledProcessError as exception:\nL16886:             raise BuildBackendException(exception, f'Backend subprocess exited when trying to invoke {hook}') from None\nL16887:         except Exception as exception:\nL16888:             raise BuildBackendException(exception, exc_info=sys.exc_info()) from None\nL16889: \nL16890: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/build/_ctx.py\nL16891: from __future__ import annotations\nL16892: \nL16893: import contextvars\nL16894: import logging\nL16895: import subprocess\nL16896: import typing\nL16897: \nL16898: from collections.abc import Mapping, Sequence\nL16899: from functools import partial\nL16900: \nL16901: from ._types import StrPath\nL16902: \nL16903: \nL16904: class _Logger(typing.Protocol):  # pragma: no cover\nL16905:     def __call__(self, message: str, *, origin: tuple[str, ...] | None = None) -> None: ...\nL16906: \nL16907: \nL16908: _package_name = __spec__.parent  # type: ignore[name-defined]\nL16909: _default_logger = logging.getLogger(_package_name)\nL16910: \nL16911: \nL16912: def _log_default(message: str, *, origin: tuple[str, ...] | None = None) -> None:\nL16913:     if origin is None:\nL16914:         _default_logger.log(logging.INFO, message, stacklevel=2)\nL16915: \nL16916: \nL16917: LOGGER = contextvars.ContextVar('LOGGER', default=_log_default)\nL16918: VERBOSITY = contextvars.ContextVar('VERBOSITY', default=0)\nL16919: \nL16920: \nL16921: def log_subprocess_error(error: subprocess.CalledProcessError) -> None:\nL16922:     log = LOGGER.get()\nL16923: \nL16924:     log(subprocess.list2cmdline(error.cmd), origin=('subprocess', 'cmd'))\nL16925: \nL16926:     for stream_name in ('stdout', 'stderr'):\nL16927:         stream = getattr(error, stream_name)\nL16928:         if stream:\nL16929:             log(stream.decode() if isinstance(stream, bytes) else stream, origin=('subprocess', stream_name))\nL16930: \nL16931: \nL16932: def run_subprocess(cmd: Sequence[StrPath], env: Mapping[str, str] | None = None) -> None:\nL16933:     verbosity = VERBOSITY.get()\nL16934: \nL16935:     if verbosity:\nL1