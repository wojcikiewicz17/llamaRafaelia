tems__ = extra_items_type\nL37970:             return tp_dict\nL37971: \nL37972:         __call__ = dict  # static method\nL37973: \nL37974:         def __subclasscheck__(cls, other):\nL37975:             # Typed dicts are only for static structural subtyping.\nL37976:             raise TypeError('TypedDict does not support instance and class checks')\nL37977: \nL37978:         __instancecheck__ = __subclasscheck__\nL37979: \nL37980:     _TypedDict = type.__new__(_TypedDictMeta, 'TypedDict', (), {})\nL37981: \nL37982:     @_ensure_subclassable(lambda bases: (_TypedDict,))\nL37983:     def TypedDict(typename, fields=_marker, /, *, total=True, closed=False, **kwargs):\nL37984:         \"\"\"A simple typed namespace. At runtime it is equivalent to a plain dict.\nL37985: \nL37986:         TypedDict creates a dictionary type such that a type checker will expect all\nL37987:         instances to have a certain set of keys, where each key is\nL37988:         associated with a value of a consistent type. This expectation\nL37989:         is not checked at runtime.\nL37990: \nL37991:         Usage::\nL37992: \nL37993:             class Point2D(TypedDict):\nL37994:                 x: int\nL37995:                 y: int\nL37996:                 label: str\nL37997: \nL37998:             a: Point2D = {'x': 1, 'y': 2, 'label': 'good'}  # OK\nL37999:             b: Point2D = {'z': 3, 'label': 'bad'}           # Fails type check\nL38000: \nL38001:             assert Point2D(x=1, y=2, label='first') == dict(x=1, y=2, label='first')\nL38002: \nL38003:         The type info can be accessed via the Point2D.__annotations__ dict, and\nL38004:         the Point2D.__required_keys__ and Point2D.__optional_keys__ frozensets.\nL38005:         TypedDict supports an additional equivalent form::\nL38006: \nL38007:             Point2D = TypedDict('Point2D', {'x': int, 'y': int, 'label': str})\nL38008: \nL38009:         By default, all keys must be present in a TypedDict. It is possible\nL38010:         to override this by specifying totality::\nL38011: \nL38012:             class Point2D(TypedDict, total=False):\nL38013:                 x: int\nL38014:                 y: int\nL38015: \nL38016:         This means that a Point2D TypedDict can have any of the keys omitted. A type\nL38017:         checker is only expected to support a literal False or True as the value of\nL38018:         the total argument. True is the default, and makes all items defined in the\nL38019:         class body be required.\nL38020: \nL38021:         The Required and NotRequired special forms can also be used to mark\nL38022:         individual keys as being required or not required::\nL38023: \nL38024:             class Point2D(TypedDict):\nL38025:                 x: int  # the \"x\" key must always be present (Required is the default)\nL38026:                 y: NotRequired[int]  # the \"y\" key can be omitted\nL38027: \nL38028:         See PEP 655 for more details on Required and NotRequired.\nL38029:         \"\"\"\nL38030:         if fields is _marker or fields is None:\nL38031:             if fields is _marker:\nL38032:                 deprecated_thing = \"Failing to pass a value for the 'fields' parameter\"\nL38033:             else:\nL38034:                 deprecated_thing = \"Passing `None` as the 'fields' parameter\"\nL38035: \nL38036:             example = f\"`{typename} = TypedDict({typename!r}, {{}})`\"\nL38037:             deprecation_msg = (\nL38038:                 f\"{deprecated_thing} is deprecated and will be disallowed in \"\nL38039:                 \"Python 3.15. To create a TypedDict class with 0 fields \"\nL38040:                 \"using the functional syntax, pass an empty dictionary, e.g. \"\nL38041:             ) + example + \".\"\nL38042:             warnings.warn(deprecation_msg, DeprecationWarning, stacklevel=2)\nL38043:             if closed is not False and closed is not True:\nL38044:                 kwargs[\"closed\"] = closed\nL38045:                 closed = False\nL38046:             fields = kwargs\nL38047:         elif kwargs:\nL38048:             raise TypeError(\"TypedDict takes either a dict or keyword arguments,\"\nL38049:                             \" but not both\")\nL38050:         if kwargs:\nL38051:             if sys.version_info >= (3, 13):\nL38052:                 raise TypeError(\"TypedDict takes no keyword arguments\")\nL38053:             warnings.warn(\nL38054:                 \"The kwargs-based syntax for TypedDict definitions is deprecated \"\nL38055:                 \"in Python 3.11, will be removed in Python 3.13, and may not be \"\nL38056:                 \"understood by third-party type checkers.\",\nL38057:                 DeprecationWarning,\nL38058:                 stacklevel=2,\nL38059:             )\nL38060: \nL38061:         ns = {'__annotations__': dict(fields)}\nL38062:         module = _caller()\nL38063:         if module is not None:\nL38064:             # Setting correct module is necessary to make typed dict classes pickleable.\nL38065:             ns['__module__'] = module\nL38066: \nL38067:         td = _TypedDictMeta(typename, (), ns, total=total, closed=closed)\nL38068:         td.__orig_bases__ = (TypedDict,)\nL38069:         return td\nL38070: \nL38071:     if hasattr(typing, \"_TypedDictMeta\"):\nL38072:         _TYPEDDICT_TYPES = (typing._TypedDictMeta, _TypedDictMeta)\nL38073:     else:\nL38074:         _TYPEDDICT_TYPES = (_TypedDictMeta,)\nL38075: \nL38076:     def is_typeddict(tp):\nL38077:         \"\"\"Check if an annotation is a TypedDict class\nL38078: \nL38079:         For example::\nL38080:             class Film(TypedDict):\nL38081:                 title: str\nL38082:                 year: int\nL38083: \nL38084:             is_typeddict(Film)  # => True\nL38085:             is_typeddict(Union[list, str])  # => False\nL38086:         \"\"\"\nL38087:         # On 3.8, this would otherwise return True\nL38088:         if hasattr(typing, \"TypedDict\") and tp is typing.TypedDict:\nL38089:             return False\nL38090:         return isinstance(tp, _TYPEDDICT_TYPES)\nL38091: \nL38092: \nL38093: if hasattr(typing, \"assert_type\"):\nL38094:     assert_type = typing.assert_type\nL38095: \nL38096: else:\nL38097:     def assert_type(val, typ, /):\nL38098:         \"\"\"Assert (to the type checker) that the value is of the given type.\nL38099: \nL38100:         When the type checker encounters a call to assert_type(), it\nL38101:         emits an error if the value is not of the specified type::\nL38102: \nL38103:             def greet(name: str) -> None:\nL38104:                 assert_type(name, str)  # ok\nL38105:                 assert_type(name, int)  # type checker error\nL38106: \nL38107:         At runtime this returns the first argument unchanged and otherwise\nL38108:         does nothing.\nL38109:         \"\"\"\nL38110:         return val\nL38111: \nL38112: \nL38113: if hasattr(typing, \"ReadOnly\"):  # 3.13+\nL38114:     get_type_hints = typing.get_type_hints\nL38115: else:  # <=3.13\nL38116:     # replaces _strip_annotations()\nL38117:     def _strip_extras(t):\nL38118:         \"\"\"Strips Annotated, Required and NotRequired from a given type.\"\"\"\nL38119:         if isinstance(t, _AnnotatedAlias):\nL38120:             return _strip_extras(t.__origin__)\nL38121:         if hasattr(t, \"__origin__\") and t.__origin__ in (Required, NotRequired, ReadOnly):\nL38122:             return _strip_extras(t.__args__[0])\nL38123:         if isinstance(t, typing._GenericAlias):\nL38124:             stripped_args = tuple(_strip_extras(a) for a in t.__args__)\nL38125:             if stripped_args == t.__args__:\nL38126:                 return t\nL38127:             return t.copy_with(stripped_args)\nL38128:         if hasattr(_types, \"GenericAlias\") and isinstance(t, _types.GenericAlias):\nL38129:             stripped_args = tuple(_strip_extras(a) for a in t.__args__)\nL38130:             if stripped_args == t.__args__:\nL38131:                 return t\nL38132:             return _types.GenericAlias(t.__origin__, stripped_args)\nL38133:         if hasattr(_types, \"UnionType\") and isinstance(t, _types.UnionType):\nL38134:             stripped_args = tuple(_strip_extras(a) for a in t.__args__)\nL38135:             if stripped_args == t.__args__:\nL38136:                 return t\nL38137:             return functools.reduce(operator.or_, stripped_args)\nL38138: \nL38139:         return t\nL38140: \nL38141:     def get_type_hints(obj, globalns=None, localns=None, include_extras=False):\nL38142:         \"\"\"Return type hints for an object.\nL38143: \nL38144:         This is often the same as obj.__annotations__, but it handles\nL38145:         forward references encoded as string literals, adds Optional[t] if a\nL38146:         default value equal to None is set and recursively replaces all\nL38147:         'Annotated[T, ...]', 'Required[T]' or 'NotRequired[T]' with 'T'\nL38148:         (unless 'include_extras=True').\nL38149: \nL38150:         The argument may be a module, class, method, or function. The annotations\nL38151:         are returned as a dictionary. For classes, annotations include also\nL38152:         inherited members.\nL38153: \nL38154:         TypeError is raised if the argument is not of a type that can contain\nL38155:         annotations, and an empty dictionary is returned if no annotations are\nL38156:         present.\nL38157: \nL38158:         BEWARE -- the behavior of globalns and localns is counterintuitive\nL38159:         (unless you are familiar with how eval() and exec() work).  The\nL38160:         search order is locals first, then globals.\nL38161: \nL38162:         - If no dict arguments are passed, an attempt is made to use the\nL38163:           globals from obj (or the respective module's globals for classes),\nL38164:           and these are also used as the locals.  If the object does not appear\nL38165:           to have globals, an empty dictionary is used.\nL38166: \nL38167:         - If one dict argument is passed, it is used for both globals and\nL38168:           locals.\nL38169: \nL38170:         - If two dict arguments are passed, they specify globals and\nL38171:           locals, respectively.\nL38172:         \"\"\"\nL38173:         if hasattr(typing, \"Annotated\"):  # 3.9+\nL38174:             hint = typing.get_type_hints(\nL38175:                 obj, globalns=globalns, localns=localns, include_extras=True\nL38176:             )\nL38177:         else:  # 3.8\nL38178:             hint = 