urn self.args[1]\nL18228: \nL18229:     def report(self):\nL18230:         return self._template.format(**locals())\nL18231: \nL18232:     def with_context(\nL18233:         self, required_by: set[Distribution | str]\nL18234:     ) -> Self | ContextualVersionConflict:\nL18235:         \"\"\"\nL18236:         If required_by is non-empty, return a version of self that is a\nL18237:         ContextualVersionConflict.\nL18238:         \"\"\"\nL18239:         if not required_by:\nL18240:             return self\nL18241:         args = self.args + (required_by,)\nL18242:         return ContextualVersionConflict(*args)\nL18243: \nL18244: \nL18245: class ContextualVersionConflict(VersionConflict):\nL18246:     \"\"\"\nL18247:     A VersionConflict that accepts a third parameter, the set of the\nL18248:     requirements that required the installed Distribution.\nL18249:     \"\"\"\nL18250: \nL18251:     _template = VersionConflict._template + ' by {self.required_by}'\nL18252: \nL18253:     @property\nL18254:     def required_by(self) -> set[str]:\nL18255:         return self.args[2]\nL18256: \nL18257: \nL18258: class DistributionNotFound(ResolutionError):\nL18259:     \"\"\"A requested distribution was not found\"\"\"\nL18260: \nL18261:     _template = (\nL18262:         \"The '{self.req}' distribution was not found \"\nL18263:         \"and is required by {self.requirers_str}\"\nL18264:     )\nL18265: \nL18266:     @property\nL18267:     def req(self) -> Requirement:\nL18268:         return self.args[0]\nL18269: \nL18270:     @property\nL18271:     def requirers(self) -> set[str] | None:\nL18272:         return self.args[1]\nL18273: \nL18274:     @property\nL18275:     def requirers_str(self):\nL18276:         if not self.requirers:\nL18277:             return 'the application'\nL18278:         return ', '.join(self.requirers)\nL18279: \nL18280:     def report(self):\nL18281:         return self._template.format(**locals())\nL18282: \nL18283:     def __str__(self) -> str:\nL18284:         return self.report()\nL18285: \nL18286: \nL18287: class UnknownExtra(ResolutionError):\nL18288:     \"\"\"Distribution doesn't have an \"extra feature\" of the given name\"\"\"\nL18289: \nL18290: \nL18291: _provider_factories: dict[type[_ModuleLike], _ProviderFactoryType] = {}\nL18292: \nL18293: PY_MAJOR = f'{sys.version_info.major}.{sys.version_info.minor}'\nL18294: EGG_DIST = 3\nL18295: BINARY_DIST = 2\nL18296: SOURCE_DIST = 1\nL18297: CHECKOUT_DIST = 0\nL18298: DEVELOP_DIST = -1\nL18299: \nL18300: \nL18301: def register_loader_type(\nL18302:     loader_type: type[_ModuleLike], provider_factory: _ProviderFactoryType\nL18303: ) -> None:\nL18304:     \"\"\"Register `provider_factory` to make providers for `loader_type`\nL18305: \nL18306:     `loader_type` is the type or class of a PEP 302 ``module.__loader__``,\nL18307:     and `provider_factory` is a function that, passed a *module* object,\nL18308:     returns an ``IResourceProvider`` for that module.\nL18309:     \"\"\"\nL18310:     _provider_factories[loader_type] = provider_factory\nL18311: \nL18312: \nL18313: @overload\nL18314: def get_provider(moduleOrReq: str) -> IResourceProvider: ...\nL18315: @overload\nL18316: def get_provider(moduleOrReq: Requirement) -> Distribution: ...\nL18317: def get_provider(moduleOrReq: str | Requirement) -> IResourceProvider | Distribution:\nL18318:     \"\"\"Return an IResourceProvider for the named module or requirement\"\"\"\nL18319:     if isinstance(moduleOrReq, Requirement):\nL18320:         return working_set.find(moduleOrReq) or require(str(moduleOrReq))[0]\nL18321:     try:\nL18322:         module = sys.modules[moduleOrReq]\nL18323:     except KeyError:\nL18324:         __import__(moduleOrReq)\nL18325:         module = sys.modules[moduleOrReq]\nL18326:     loader = getattr(module, '__loader__', None)\nL18327:     return _find_adapter(_provider_factories, loader)(module)\nL18328: \nL18329: \nL18330: @functools.cache\nL18331: def _macos_vers():\nL18332:     version = platform.mac_ver()[0]\nL18333:     # fallback for MacPorts\nL18334:     if version == '':\nL18335:         plist = '/System/Library/CoreServices/SystemVersion.plist'\nL18336:         if os.path.exists(plist):\nL18337:             with open(plist, 'rb') as fh:\nL18338:                 plist_content = plistlib.load(fh)\nL18339:             if 'ProductVersion' in plist_content:\nL18340:                 version = plist_content['ProductVersion']\nL18341:     return version.split('.')\nL18342: \nL18343: \nL18344: def _macos_arch(machine):\nL18345:     return {'PowerPC': 'ppc', 'Power_Macintosh': 'ppc'}.get(machine, machine)\nL18346: \nL18347: \nL18348: def get_build_platform():\nL18349:     \"\"\"Return this platform's string for platform-specific distributions\"\"\"\nL18350:     from sysconfig import get_platform\nL18351: \nL18352:     plat = get_platform()\nL18353:     if sys.platform == \"darwin\" and not plat.startswith('macosx-'):\nL18354:         try:\nL18355:             version = _macos_vers()\nL18356:             machine = _macos_arch(os.uname()[4].replace(\" \", \"_\"))\nL18357:             return f\"macosx-{version[0]}.{version[1]}-{machine}\"\nL18358:         except ValueError:\nL18359:             # if someone is running a non-Mac darwin system, this will fall\nL18360:             # through to the default implementation\nL18361:             pass\nL18362:     return plat\nL18363: \nL18364: \nL18365: macosVersionString = re.compile(r\"macosx-(\\d+)\\.(\\d+)-(.*)\")\nL18366: darwinVersionString = re.compile(r\"darwin-(\\d+)\\.(\\d+)\\.(\\d+)-(.*)\")\nL18367: # XXX backward compat\nL18368: get_platform = get_build_platform\nL18369: \nL18370: \nL18371: def compatible_platforms(provided: str | None, required: str | None) -> bool:\nL18372:     \"\"\"Can code for the `provided` platform run on the `required` platform?\nL18373: \nL18374:     Returns true if either platform is ``None``, or the platforms are equal.\nL18375: \nL18376:     XXX Needs compatibility checks for Linux and other unixy OSes.\nL18377:     \"\"\"\nL18378:     if provided is None or required is None or provided == required:\nL18379:         # easy case\nL18380:         return True\nL18381: \nL18382:     # macOS special cases\nL18383:     reqMac = macosVersionString.match(required)\nL18384:     if reqMac:\nL18385:         provMac = macosVersionString.match(provided)\nL18386: \nL18387:         # is this a Mac package?\nL18388:         if not provMac:\nL18389:             # this is backwards compatibility for packages built before\nL18390:             # setuptools 0.6. All packages built after this point will\nL18391:             # use the new macOS designation.\nL18392:             provDarwin = darwinVersionString.match(provided)\nL18393:             if provDarwin:\nL18394:                 dversion = int(provDarwin.group(1))\nL18395:                 macosversion = f\"{reqMac.group(1)}.{reqMac.group(2)}\"\nL18396:                 if (\nL18397:                     dversion == 7\nL18398:                     and macosversion >= \"10.3\"\nL18399:                     or dversion == 8\nL18400:                     and macosversion >= \"10.4\"\nL18401:                 ):\nL18402:                     return True\nL18403:             # egg isn't macOS or legacy darwin\nL18404:             return False\nL18405: \nL18406:         # are they the same major version and machine type?\nL18407:         if provMac.group(1) != reqMac.group(1) or provMac.group(3) != reqMac.group(3):\nL18408:             return False\nL18409: \nL18410:         # is the required OS major update >= the provided one?\nL18411:         if int(provMac.group(2)) > int(reqMac.group(2)):\nL18412:             return False\nL18413: \nL18414:         return True\nL18415: \nL18416:     # XXX Linux and other platforms' special cases should go here\nL18417:     return False\nL18418: \nL18419: \nL18420: @overload\nL18421: def get_distribution(dist: _DistributionT) -> _DistributionT: ...\nL18422: @overload\nL18423: def get_distribution(dist: _PkgReqType) -> Distribution: ...\nL18424: def get_distribution(dist: Distribution | _PkgReqType) -> Distribution:\nL18425:     \"\"\"Return a current distribution object for a Requirement or string\"\"\"\nL18426:     if isinstance(dist, str):\nL18427:         dist = Requirement.parse(dist)\nL18428:     if isinstance(dist, Requirement):\nL18429:         dist = get_provider(dist)\nL18430:     if not isinstance(dist, Distribution):\nL18431:         raise TypeError(\"Expected str, Requirement, or Distribution\", dist)\nL18432:     return dist\nL18433: \nL18434: \nL18435: def load_entry_point(dist: _EPDistType, group: str, name: str) -> _ResolvedEntryPoint:\nL18436:     \"\"\"Return `name` entry point of `group` for `dist` or raise ImportError\"\"\"\nL18437:     return get_distribution(dist).load_entry_point(group, name)\nL18438: \nL18439: \nL18440: @overload\nL18441: def get_entry_map(\nL18442:     dist: _EPDistType, group: None = None\nL18443: ) -> dict[str, dict[str, EntryPoint]]: ...\nL18444: @overload\nL18445: def get_entry_map(dist: _EPDistType, group: str) -> dict[str, EntryPoint]: ...\nL18446: def get_entry_map(dist: _EPDistType, group: str | None = None):\nL18447:     \"\"\"Return the entry point map for `group`, or the full entry map\"\"\"\nL18448:     return get_distribution(dist).get_entry_map(group)\nL18449: \nL18450: \nL18451: def get_entry_info(dist: _EPDistType, group: str, name: str) -> EntryPoint | None:\nL18452:     \"\"\"Return the EntryPoint object for `group`+`name`, or ``None``\"\"\"\nL18453:     return get_distribution(dist).get_entry_info(group, name)\nL18454: \nL18455: \nL18456: class IMetadataProvider(Protocol):\nL18457:     def has_metadata(self, name: str) -> bool:\nL18458:         \"\"\"Does the package's distribution contain the named metadata?\"\"\"\nL18459:         ...\nL18460: \nL18461:     def get_metadata(self, name: str) -> str:\nL18462:         \"\"\"The named metadata resource as a string\"\"\"\nL18463:         ...\nL18464: \nL18465:     def get_metadata_lines(self, name: str) -> Iterator[str]:\nL18466:         \"\"\"Yield named metadata resource as list of non-blank non-comment lines\nL18467: \nL18468:         Leading and trailing whitespace is stripped from each line, and lines\nL18469:         with ``#`` as the first non-blank character are omitted.\"\"\"\nL18470:         ...\nL18471: \nL18472:     def metadata_isdir(self, name: str) -> bool:\nL18473:         \"\"\"Is the named metadata a directory?  (like ``os.path.isdir()``)\"\"\"\nL18474:         ...\nL18475: \nL18476:     def metadata_listdir(self, name: str) -> list[str]:\nL18477:         \"\"\"List of metadata names in the directory (like ``os.listdir()``)\"\"\"\nL18478:         ...\nL18479: \nL18480:     def run_script(self, script_name: str, namespace: dict[str, Any]) -> None:\nL18481:         \"\"\"Execute the named script in the supplied namespace dictionary\"\"\"\nL18482:         ...\nL18483: \nL18484: \nL18485: class IResourceProvider(IMetadataProvider, Protocol):\nL18486:     \"\"\"An object that provides access to package resources\"\"\"\nL18487: \nL18488:     def get_resource_filename(\nL18489:         self, manager: ResourceManager, resource_name: str\nL18490:     ) -> str:\nL18491:         \"\"\"Return a true filesystem path for `resource_name`\nL18492: \nL18493:         `manager` must be a ``ResourceManager``\"\"\"\nL18494:         ...\nL18495: \nL18496:     def get_resource_stream(\nL18497:         self, manager: ResourceManager, resource_name: str\nL18498:     ) -> _ResourceStream:\nL18499:         \"\"\"Return a readable file-like object for `resource_name`\nL18500: \nL18501:         `manager` must be a ``ResourceManager``\"\"\"\nL18502:         ...\nL18503: \nL18504:     def get_resource_string(\nL18505:         self, manager: ResourceManager, resource_name: str\nL18506:     ) -> bytes:\nL18507:         \"\"\"Return the contents of `resource_name` as :obj:`bytes`\nL18508: \nL18509:         `manager` must be a ``ResourceManager``\"\"\"\nL18510:         ...\nL18511: \nL18512:     def has_resource(self, resource_name: str) -> bool:\nL18513:         \"\"\"Does the package contain the named resource?\"\"\"\nL18514:         ...\nL18515: \nL18516:     def resource_isdir(self, resource_name: str) -> bool:\nL18517:         \"\"\"Is the named resource a directory?  (like ``os.path.isdir()``)\"\"\"\nL18518:         ...\nL18519: \nL18520:     def resource_listdir(self, resource_name: str) -> list[str]:\nL18521:         \"\"\"List of resource names in the directory (like ``os.listdir()``)\"\"\"\nL18522:         ...\nL18523: \nL18524: \nL18525: class WorkingSet:\nL18526:     \"\"\"A collection of active distributions on sys.path (or a similar list)\"\"\"\nL18527: \nL18528:     def __init__(self, entries: Iterable[str] | None = None) -> None:\nL18529:         \"\"\"Create working set from list of path entries (default=sys.path)\"\"\"\nL18530:         self.entries: list[str] = []\nL18531:         self.entry_keys: dict[str | None, list[str]] = {}\nL18532:         self.by_key: dict[str, Distribution] = {}\nL18533:         self.normalized_to_canonical_keys: dict[str, str] = {}\nL18534:         self.callbacks: list[Callable[[Distribution], object]] = []\nL18535: \nL18536:         if entries is None:\nL18537:             entries = sys.path\nL18538: \nL18539:         for entry in entries:\nL18540:             self.add_entry(entry)\nL18541: \nL18542:     @classmethod\nL18543:     def _build_master(cls):\nL18544:         \"\"\"\nL18545:         Prepare the master working set.\nL18546:         \"\"\"\nL18547:         ws = cls()\nL18548:         try:\nL18549:             from __main__ import __requires__\nL18550:         except ImportError:\nL18551:             # The main program does not list any requirements\nL18552:             return ws\nL18553: \nL18554:         # ensure the requirements are met\nL18555:         try:\nL18556:             ws.require(__requires__)\nL18557:         except VersionConflict:\nL18558:             return cls._build_from_requirements(__requires__)\nL18559: \nL18560:         return ws\nL18561: \nL18562:     @classmethod\nL18563:     def _build_from_requirements(cls, req_spec):\nL18564:         \"\"\"\nL18565:         Build a working set from a requirement spec. Rewrites sys.path.\nL18566:         \"\"\"\nL18567:         # try it without defaults already on sys.path\nL18568:         # by starting with an empty path\nL18569:         ws = cls([])\nL18570:         reqs = parse_requirements(req_spec)\nL18571:         dists = ws.resolve(reqs, Environment())\nL18572:         for dist in dists:\nL18573:             ws.add(dist)\nL18574: \nL18575:         # add any missing entries from sys.path\nL18576:         for entry in sys.path:\nL18577:             if entry not in ws.entries:\nL18578:                 ws.add_entry(entry)\nL18579: \nL18580:         # then copy back to sys.path\nL18581:         sys.path[:] = ws.entries\nL18582:         return ws\nL18583: \nL18584:     def add_entry(self, entry: str) -> None:\nL18585:         \"\"\"Add a path item to ``.entries``, finding any distributions on it\nL18586: \nL18587:         ``find_distributions(entry, True)`` is used to find distributions\nL18588:         corresponding to the path entry, and they are added.  `entry` is\nL18589:         always appended to ``.entries``, even if it is already present.\nL18590:         (This is because ``sys.path`` can contain the same value more than\nL18591:         once, and the ``.entries`` of the ``sys.path`` WorkingSet should always\nL18592:         equal ``sys.path``.)\nL18593:         \"\"\"\nL18594:         self.entry_keys.setdefault(entry, [])\nL18595:         self.entries.append(entry)\nL18596:         for dist in find_distributions(entry, True):\nL18597:             self.add(dist, entry, False)\nL18598: \nL18599:     def __contains__(self, dist: Distribution) -> bool:\nL18600:         \"\"\"True if `dist` is the active distribution for its project\"\"\"\nL18601:         return self.by_key.get(dist.key) == dist\nL18602: \nL18603:     def find(self, req: Requirement) -> Distribution | None:\nL18604:         \"\"\"Find a distribution matching requirement `req`\nL18605: \nL18606:         If there is an active distribution for the requested project, this\nL18607:         returns it as long as it meets the version requirement specified by\nL18608:         `req`.  But, if there is an active distribution for the project and it\nL18609:         does *not* meet the `req` requirement, ``VersionConflict`` is raised.\nL18610:         If there is no active distribution for the requested project, ``None``\nL18611:         is returned.\nL18612:         \"\"\"\nL18613:         dist: Distribution | None = None\nL18614: \nL18615:         candidates = (\nL18616:             req.key,\nL18617:             self.normalized_to_canonical_keys.get(req.key),\nL18618:             safe_name(req.key).replace(\".\", \"-\"),\nL18619:         )\nL18620: \nL18621:         for candidate in filter(None, candidates):\nL18622:             dist = self.by_key.get(candidate)\nL18623:             if dist:\nL18624:                 req.key = candidate\nL18625:                 break\nL18626: \nL18627:         if dist is not None and dist not in req:\nL18628:             # XXX add more info\nL18629:             raise VersionConflict(dist, req)\nL18630:         return dist\nL18631: \nL18632:     def iter_entry_points(\nL18633:         self, group: str, name: str | None = None\nL18634:     ) -> Iterator[EntryPoint]:\nL18635:         \"\"\"Yield entry point objects from `group` matching `name`\nL18636: \nL18637:         If `name` is None, yields all entry points in `group` from all\nL18638:         distributions in the working set, otherwise only ones matching\nL18639:         both `group` and `name` are yielded (in distribution order).\nL18640:         \"\"\"\nL18641:         return (\nL18642:             entry\nL18643:             for dist in self\nL18644:             for entry in dist.get_entry_map(group).values()\nL18645:             if name is None or name == entry.name\nL18646:         )\nL18647: \nL18648:     def run_script(self, requires: str, script_name: str) -> None:\nL18649:         \"\"\"Locate distribution for `requires` and run `script_name` script\"\"\"\nL18650:         ns = sys._getframe(1).f_globals\nL18651:         name = ns['__name__']\nL18652:         ns.clear()\nL18653:         ns['__name__'] = name\nL18654:         self.require(requires)[0].run_script(script_name, ns)\nL18655: \nL18656:     def __iter__(self) -> Iterator[Distribution]:\nL18657:         \"\"\"Yield distributions for non-duplicate projects in the working set\nL18658: \nL18659:         The yield order is the order in which the items' path entries were\nL18660:         added to the working set.\nL18661:         \"\"\"\nL18662:         seen = set()\nL18663:         for item in self.entries:\nL18664:             if item not in self.entry_keys:\nL18665:                 # workaround a cache issue\nL18666:                 continue\nL18667: \nL18668:             for key in self.entry_keys[item]:\nL18669:                 if key not in seen:\nL18670:                     seen.add(key)\nL18671:                     yield self.by_key[key]\nL18672: \nL18673:     def add(\nL18674:         self,\nL18675:         dist: Distribution,\nL18676:         entry: str | None = None,\nL18677:         insert: bool = True,\nL18678:         replace: bool = False,\nL18679:     ) -> None:\nL18680:         \"\"\"Add `dist` to working set, associated with `entry`\nL18681: \nL18682:         If `entry` is unspecified, it defaults to the ``.location`` of `dist`.\nL18683:         On exit from this routine, `entry` is added to the end of the working\nL18684:         set's ``.entries`` (if it wasn't already present).\nL18685: \nL18686:         `dist` is only added to the working set if it's for a project that\nL18687:         doesn't already have a distribution in the set, unless `replace=True`.\nL18688:         If it's added, any callbacks registered with the ``subscribe()`` method\nL18689:         will be called.\nL18690:         \"\"\"\nL18691:         if insert:\nL18692:             dist.insert_on(self.entries, entry, replace=replace)\nL18693: \nL18694:         if entry is None:\nL18695:             entry = dist.location\nL18696:         keys = self.entry_keys.setdefault(entry, [])\nL18697:         keys2 = self.entry_keys.setdefault(dist.location, [])\nL18698:         if not replace and dist.key in self.by_key:\nL18699:             # ignore hidden distros\nL18700:             return\nL18701: \nL18702:         self.by_key[dist.key] = dist\nL18703:         normalized_name = packaging.utils.canonicalize_name(dist.key)\nL18704:         self.normalized_to_canonical_keys[normalized_name] = dist.key\nL18705:         if dist.key not in keys:\nL18706:             keys.append(dist.key)\nL18707:         if dist.key not in keys2:\nL18708:             keys2.append(dist.key)\nL18709:         self._added_new(dist)\nL18710: \nL18711:     @overload\nL18712:     def resolve(\nL18713:         self,\nL18714:         requirements: Iterable[Requirement],\nL18715:         env: Environment | None,\nL18716:         installer: _StrictInstallerType[_DistributionT],\nL18717:         replace_conflicting: bool = False,\nL18718:         extras: tuple[str, ...] | None = None,\nL18719:     ) -> list[_DistributionT]: ...\nL18720:     @overload\nL18721:     def resolve(\nL18722:         self,\nL18723:         requirements: Iterable[Requirement],\nL18724:         env: Environment | None = None,\nL18725:         *,\nL18726:         installer: _StrictInstallerType[_DistributionT],\nL18727:         replace_conflicting: bool = False,\nL18728:         extras: tuple[str, ...] | None = None,\nL18729:     ) -> list[_DistributionT]: ...\nL18730:     @overload\nL18731:     def resolve(\nL18732:         self,\nL18733:         requirements: Iterable[Requirement],\nL18734:         env: Environment | None = None,\nL18735:         installer: _InstallerType | None = None,\nL18736:         replace_conflicting: bool = False,\nL18737:         extras: tuple[str, ...] | None = None,\nL18738:     ) -> list[Distribution]: ...\nL18739:     def resolve(\nL18740:         self,\nL18741:         requirements: Iterable[Requirement],\nL18742:         env: Environment | None = None,\nL18743:         installer: _InstallerType | None | _StrictInstallerType[_DistributionT] = None,\nL18744:         replace_conflicting: bool = False,\nL18745:         extras: tuple[str, ...] | None = None,\nL18746:     ) -> list[Distribution] | list[_DistributionT]:\nL18747:         \"\"\"List all distributions needed to (recursively) meet `requirements`\nL18748: \nL18749:         `requirements` must be a sequence of ``Requirement`` objects.  `env`,\nL18750:         if supplied, should be an ``Environment`` instance.  If\nL18751:         not supplied, it defaults to all distributions available within any\nL18752:         entry or distribution in the working set.  `installer`, if supplied,\nL18753:         will be invoked with each requirement that cannot be met by an\nL18754:         already-installed distribution; it should return a ``Distribution`` or\nL18755:         ``None``.\nL18756: \nL18757:         Unless `replace_conflicting=True`, raises a VersionConflict exception\nL18758:         if\nL18759:         any requirements are found on the path that have the correct name but\nL18760:         the wrong version.  Otherwise, if an `installer` is supplied it will be\nL18761:         invoked to obtain the correct version of the requirement and activate\nL18762:         it.\nL18763: \nL18764:         `extras` is a list of the extras to be used with these requirements.\nL18765:         This is important because extra requirements may look like `my_req;\nL18766:         extra = \"my_extra\"`, which would otherwise be interpreted as a purely\nL18767:         optional requirement.  Instead, we want to be able to assert that these\nL18768:         requirements are truly required.\nL18769:         \"\"\"\nL18770: \nL18771:         # set up the stack\nL18772:         requirements = list(requirements)[::-1]\nL18773:         # set of processed requirements\nL18774:         processed = set()\nL18775:         # key -> dist\nL18776:         best: dict[str, Distribution] = {}\nL18777:         to_activate: list[Distribution] = []\nL18778: \nL18779:         req_extras = _ReqExtras()\nL18780: \nL18781:         # Mapping of requirement to set of distributions that required it;\nL18782:         # useful for reporting info about conflicts.\nL18783:         required_by = collections.defaultdict[Requirement, set[str]](set)\nL18784: \nL18785:         while requirements:\nL18786:             # process dependencies breadth-first\nL18787:             req = requirements.pop(0)\nL18788:             if req in processed:\nL18789:                 # Ignore cyclic or redundant dependencies\nL18790:                 continue\nL18791: \nL18792:             if not req_extras.markers_pass(req, extras):\nL18793:                 continue\nL18794: \nL18795:             dist = self._resolve_dist(\nL18796:                 req, best, replace_conflicting, env, installer, required_by, to_activate\nL18797:             )\nL18798: \nL18799:             # push the new requirements onto the stack\nL18800:             new_requirements = dist.requires(req.extras)[::-1]\nL18801:             requirements.extend(new_requirements)\nL18802: \nL18803:             # Register the new requirements needed by req\nL18804:             for new_requirement in new_requirements:\nL18805:                 required_by[new_requirement].add(req.project_name)\nL18806:                 req_extras[new_requirement] = req.extras\nL18807: \nL18808:             processed.add(req)\nL18809: \nL18810:         # return list of distros to activate\nL18811:         return to_activate\nL18812: \nL18813:     def _resolve_dist(\nL18814:         self, req, best, replace_conflicting, env, installer, required_by, to_activate\nL18815:     ) -> Distribution:\nL18816:         dist = best.get(req.key)\nL18817:         if dist is None:\nL18818:             # Find the best distribution and add it to the map\nL18819:             dist = self.by_key.get(req.key)\nL18820:             if dist is None or (dist not in req and replace_conflicting):\nL18821:                 ws = self\nL18822:                 if env is None:\nL18823:                     if dist is None:\nL18824:                         env = Environment(self.entries)\nL18825:                     else:\nL18826:                         # Use an empty environment and workingset to avoid\nL18827:                         # any further conflicts with the conflicting\nL18828:                         # distribution\nL18829:                         env = Environment([])\nL18830:                         ws = WorkingSet([])\nL18831:                 dist = best[req.key] = env.best_match(\nL18832:                     req, ws, installer, replace_conflicting=replace_conflicting\nL18833:                 )\nL18834:                 if dist is None:\nL18835:                     requirers = required_by.get(req, None)\nL18836:                     raise DistributionNotFound(req, requirers)\nL18837:             to_activate.append(dist)\nL18838:         if dist not in req:\nL18839:             # Oops, the \"best\" so far conflicts with a dependency\nL18840:             dependent_req = required_by[req]\nL18841:             raise VersionConflict(dist, req).with_context(dependent_req)\nL18842:         return dist\nL18843: \nL18844:     @overload\nL18845:     def find_plugins(\nL18846:         self,\nL18847:         plugin_env: Environment,\nL18848:         full_env: Environment | None,\nL18849:         installer: _StrictInstallerType[_DistributionT],\nL18850:         fallback: bool = True,\nL18851:     ) -> tuple[list[_DistributionT], dict[Distribution, Exception]]: ...\nL18852:     @overload\nL18853:     def find_plugins(\nL18854:         self,\nL18855:         plugin_env: Environment,\nL18856:         full_env: Environment | None = None,\nL18857:         *,\nL18858:         installer: _StrictInstallerType[_DistributionT],\nL18859:         fallback: bool = True,\nL18860:     ) -> tuple[list[_DistributionT], dict[Distribution, Exception]]: ...\nL18861:     @overload\nL18862:     def find_plugins(\nL18863:         self,\nL18864:         plugin_env: Environment,\nL18865:         full_env: Environment | None = None,\nL18866:         installer: _InstallerType | None = None,\nL18867:         fallback: bool = True,\nL18868:     ) -> tuple[list[Distribution], dict[Distribution, Exception]]: ...\nL18869:     def find_plugins(\nL18870:         self,\nL18871:         plugin_env: Environment,\nL18872:         full_env: Environment | None = None,\nL18873:         installer: _InstallerType | None | _StrictInstallerType[_DistributionT] = None,\nL18874:         fallback: bool = True,\nL18875:     ) -> tuple[\nL18876:         list[Distribution] | list[_DistributionT],\nL18877:         dict[Distribution, Exception],\nL18878:     ]:\nL18879:         \"\"\"Find all activatable distributions in `plugin_env`\nL18880: \nL18881:         Example usage::\nL18882: \nL18883:             distributions, errors = working_set.find_plugins(\nL18884:                 Environment(plugin_dirlist)\nL18885:             )\nL18886:             # add plugins+libs to sys.path\nL18887:             map(working_set.add, distributions)\nL18888:             # display errors\nL18889:             print('Could not load', errors)\nL18890: \nL18891:         The `plugin_env` should be an ``Environment`` instance that contains\nL18892:         only distributions that are in the project's \"plugin directory\" or\nL18893:         directories. The `full_env`, if supplied, should be an ``Environment``\nL18894:         contains all currently-available distributions.  If `full_env` is not\nL18895:         supplied, one is created automatically from the ``WorkingSet`` this\nL18896:         method is called on, which will typically mean that every directory on\nL18897:         ``sys.path`` will be scanned for distributions.\nL18898: \nL18899:         `installer` is a standard installer callback as used by the\nL18900:         ``resolve()`` method. The `fallback` flag indicates whether we should\nL18901:         attempt to resolve older versions of a plugin if the newest version\nL18902:         cannot be resolved.\nL18903: \nL18904:         This method returns a 2-tuple: (`distributions`, `error_info`), where\nL18905:         `distributions` is a list of the distributions found in `plugin_env`\nL18906:         that were loadable, along with any other distributions that are needed\nL18907:         to resolve their dependencies.  `error_info` is a dictionary mapping\nL18908:         unloadable plugin distributions to an exception instance describing the\nL18909:         error that occurred. Usually this will be a ``DistributionNotFound`` or\nL18910:         ``VersionConflict`` instance.\nL18911:         \"\"\"\nL18912: \nL18913:         plugin_projects = list(plugin_env)\nL18914:         # scan project names in alphabetic order\nL18915:         plugin_projects.sort()\nL18916: \nL18917:         error_info: dict[Distribution, Exception] = {}\nL18918:         distributions: dict[Distribution, Exception | None] = {}\nL18919: \nL18920:         if full_env is None:\nL18921:             env = Environment(self.entries)\nL18922:             env += plugin_env\nL18923:         else:\nL18924:             env = full_env + plugin_env\nL18925: \nL18926:         shadow_set = self.__class__([])\nL18927:         # put all our entries in shadow_set\nL18928:         list(map(shadow_set.add, self))\nL18929: \nL18930:         for project_name in plugin_projects:\nL18931:             for dist in plugin_env[project_name]:\nL18932:                 req = [dist.as_requirement()]\nL18933: \nL18934:                 try:\nL18935:                     resolvees = shadow_set.resolve(req, env, installer)\nL18936: \nL18937:                 except ResolutionError as v:\nL18938:                     # save error info\nL18939:                     error_info[dist] = v\nL18940:                     if fallback:\nL18941:                         # try the next older version of project\nL18942:                         continue\nL18943:                     else:\nL18944:                         # give up on this project, keep going\nL18945:                         break\nL18946: \nL18947:                 else:\nL18948:                     list(map(shadow_set.add, resolvees))\nL18949:                     distributions.update(dict.fromkeys(resolvees))\nL18950: \nL18951:                     # success, no need to try any more versions of this project\nL18952:                     break\nL18953: \nL18954:         sorted_distributions = list(distributions)\nL18955:         sorted_distributions.sort()\nL18956: \nL18957:         return sorted_distributions, error_info\nL18958: \nL18959:     def require(self, *requirements: _NestedStr) -> list[Distribution]:\nL18960:         \"\"\"Ensure that distributions matching `requirements` are activated\nL18961: \nL18962:         `requirements` must be a string or a (possibly-nested) sequence\nL18963:         thereof, specifying the distributions and versions required.  The\nL18964:         return value is a sequence of the distributions that needed to be\nL18965:         activated to fulfill the requirements; all relevant distributions are\nL18966:         included, even if they were already activated in this working set.\nL18967:         \"\"\"\nL18968:         needed = self.resolve(parse_requirements(requirements))\nL18969: \nL18970:         for dist in needed:\nL18971:             self.add(dist)\nL18972: \nL18973:         return needed\nL18974: \nL18975:     def subscribe(\nL18976:         self, callback: Callable[[Distribution], object], existing: bool = True\nL18977:     ) -> None:\nL18978:         \"\"\"Invoke `callback` for all distributions\nL18979: \nL18980:         If `existing=True` (default),\nL18981:         call on all existing ones, as well.\nL18982:         \"\"\"\nL18983:         if callback in self.callbacks:\nL18984:             return\nL18985:         self.callbacks.append(callback)\nL18986:         if not existing:\nL18987:             return\nL18988:         for dist in self:\nL18989:             callback(dist)\nL18990: \nL18991:     def _added_new(self, dist) -> None:\nL18992:         for callback in self.callbacks:\nL18993:             callback(dist)\nL18994: \nL18995:     def __getstate__(\nL18996:         self,\nL18997:     ) -> tuple[\nL18998:         list[str],\nL18999:         dict[str | None, list[str]],\nL19000:         dict[str, Distribution],\nL19001:         dict[str, str],\nL19002:         list[Callable[[Distribution], object]],\nL19003:     ]:\nL19004:         return (\nL19005:             self.entries[:],\nL19006:             self.entry_keys.copy(),\nL19007:             self.by_key.copy(),\nL19008:             self.normalized_to_canonical_keys.copy(),\nL19009:             self.callbacks[:],\nL19010:         )\nL19011: \nL19012:     def __setstate__(self, e_k_b_n_c) -> None:\nL19013:         entries, keys, by_key, normalized_to_canonical_keys, callbacks = e_k_b_n_c\nL19014:         self.entries = entries[:]\nL19015:         self.entry_keys = keys.copy()\nL19016:         self.by_key = by_key.copy()\nL19017:         self.normalized_to_canonical_keys = normalized_to_canonical_keys.copy()\nL19018:         self.callbacks = callbacks[:]\nL19019: \nL19020: \nL19021: class _ReqExtras(dict[\"Requirement\", tuple[str, ...]]):\nL19022:     \"\"\"\nL19023:     Map each requirement to the extras that demanded it.\nL19024:     \"\"\"\nL19025: \nL19026:     def markers_pass(self, req: Requirement, extras: tuple[str, ...] | None = None):\nL19027:         \"\"\"\nL19028:         Evaluate markers for req against each extra that\nL19029:         demanded it.\nL19030: \nL19031:         Return False if the req has a marker and fails\nL19032:         evaluation. Otherwise, return True.\nL19033:         \"\"\"\nL19034:         return not req.marker or any(\nL19035:             req.marker.evaluate({'extra': extra})\nL19036:             for extra in self.get(req, ()) + (extras or (\"\",))\nL19037:         )\nL19038: \nL19039: \nL19040: class Environment:\nL19041:     \"\"\"Searchable snapshot of distributions on a search path\"\"\"\nL19042: \nL19043:     def __init__(\nL19044:         self,\nL19045:         search_path: Iterable[str] | None = None,\nL19046:         platform: str | None = get_supported_platform(),\nL19047:         python: str | None = PY_MAJOR,\nL19048:     ) -> None:\nL19049:         \"\"\"Snapshot distributions available on a search path\nL19050: \nL19051:         Any distributions found on `search_path` are added to the environment.\nL19052:         `search_path` should be a sequence of ``sys.path`` items.  If not\nL19053:         supplied, ``sys.path`` is used.\nL19054: \nL19055:         `platform` is an optional string specifying the name of the platform\nL19056:         that platform-specific distributions must be compatible with.  If\nL19057:         unspecified, it defaults to the current platform.  `python` is an\nL19058:         optional string naming the desired version of Python (e.g. ``'3.6'``);\nL19059:         it defaults to the current version.\nL19060: \nL19061:         You may explicitly set `platform` (and/or `python`) to ``None`` if you\nL19062:         wish to map *all* distributions, not just those compatible with the\nL19063:         running platform or Python version.\nL19064:         \"\"\"\nL19065:         self._distmap: dict[str, list[Distribution]] = {}\nL19066:         self.platform = platform\nL19067:         self.python = python\nL19068:         self.scan(search_path)\nL19069: \nL19070:     def can_add(self, dist: Distribution) -> bool:\nL19071:         \"\"\"Is distribution `dist` acceptable for this environment?\nL19072: \nL19073:         The distribution must match the platform and python version\nL19074:         requirements specified when this environment was created, or False\nL19075:         is returned.\nL19076:         \"\"\"\nL19077:         py_compat = (\nL19078:             self.python is None\nL19079:             or dist.py_version is None\nL19080:             or dist.py_version == self.python\nL19081:         )\nL19082:         return py_compat and compatible_platforms(dist.platform, self.platform)\nL19083: \nL19084:     def remove(self, dist: Distribution) -> None:\nL19085:         \"\"\"Remove `dist` from the environment\"\"\"\nL19086:         self._distmap[dist.key].remove(dist)\nL19087: \nL19088:     def scan(self, search_path: Iterable[str] | None = None) -> None:\nL19089:         \"\"\"Scan `search_path` for distributions usable in this environment\nL19090: \nL19091:         Any distributions found are added to the environment.\nL19092:         `search_path` should be a sequence of ``sys.path`` items.  If not\nL19093:         supplied, ``sys.path`` is used.  Only distributions conforming to\nL19094:         the platform/python version defined at initialization are added.\nL19095:         \"\"\"\nL19096:         if search_path is None:\nL19097:             search_path = sys.path\nL19098: \nL19099:         for item in search_path:\nL19100:             for dist in find_distributions(item):\nL19101:                 self.add(dist)\nL19102: \nL19103:     def __getitem__(self, project_name: str) -> list[Distribution]:\nL19104:         \"\"\"Return a newest-to-oldest list of distributions for `project_name`\nL19105: \nL19106:         Uses case-insensitive `project_name` comparison, assuming all the\nL19107:         project's distributions use their project's name converted to all\nL19108:         lowercase as their key.\nL19109: \nL19110:         \"\"\"\nL19111:         distribution_key = project_name.lower()\nL19112:         return self._distmap.get(distribution_key, [])\nL19113: \nL19114:     def add(self, dist: Distribution) -> None:\nL19115:         \"\"\"Add `dist` if we ``can_add()`` it and it has not already been added\"\"\"\nL19116:         if self.can_add(dist) and dist.has_version():\nL19117:             dists = self._distmap.setdefault(dist.key, [])\nL19118:             if dist not in dists:\nL19119:                 dists.append(dist)\nL19120:                 dists.sort(key=operator.attrgetter('hashcmp'), reverse=True)\nL19121: \nL19122:     @overload\nL19123:     def best_match(\nL19124:         self,\nL19125:         req: Requirement,\nL19126:         working_set: WorkingSet,\nL19127:         installer: _StrictInstallerType[_DistributionT],\nL19128:         replace_conflicting: bool = False,\nL19129:     ) -> _DistributionT: ...\nL19130:     @overload\nL19131:     def best_match(\nL19132:         self,\nL19133:         req: Requirement,\nL19134:         working_set: WorkingSet,\nL19135:         installer: _InstallerType | None = None,\nL19136:         replace_conflicting: bool = False,\nL19137:     ) -> Distribution | None: ...\nL19138:     def best_match(\nL19139:         self,\nL19140:         req: Requirement,\nL19141:         working_set: WorkingSet,\nL19142:         installer: _InstallerType | None | _StrictInstallerType[_DistributionT] = None,\nL19143:         replace_conflicting: bool = False,\nL19144:     ) -> Distribution | None:\nL19145:         \"\"\"Find distribution best matching `req` and usable on `working_set`\nL19146: \nL19147:         This calls the ``find(req)`` method of the `working_set` to see if a\nL19148:         suitable distribution is already active.  (This may raise\nL19149:         ``VersionConflict`` if an unsuitable version of the project is already\nL19150:         active in the specified `working_set`.)  If a suitable distribution\nL19151:         isn't active, this method returns the newest distribution in the\nL19152:         environment that meets the ``Requirement`` in `req`.  If no suitable\nL19153:         distribution is found, and `installer` is supplied, then the result of\nL19154:         calling the environment's ``obtain(req, installer)`` method will be\nL19155:         returned.\nL19156:         \"\"\"\nL19157:         try:\nL19158:             dist = working_set.find(req)\nL19159:         except VersionConflict:\nL19160:             if not replace_conflicting:\nL19161:                 raise\nL19162:             dist = None\nL19163:         if dist is not None:\nL19164:             return dist\nL19165:         for dist in self[req.key]:\nL19166:             if dist in req:\nL19167:                 return dist\nL19168:         # try to download/install\nL19169:         return self.obtain(req, installer)\nL19170: \nL19171:     @overload\nL19172:     def obtain(\nL19173:         self,\nL19174:         requirement: Requirement,\nL19175:         installer: _StrictInstallerType[_DistributionT],\nL19176:     ) -> _DistributionT: ...\nL19177:     @overload\nL19178:     def obtain(\nL19179:         self,\nL19180:         requirement: Requirement,\nL19181:         installer: Callable[[Requirement], None] | None = None,\nL19182:     ) -> None: ...\nL19183:     @overload\nL19184:     def obtain(\nL19185:         self,\nL19186:         requirement: Requirement,\nL19187:         installer: _InstallerType | None = None,\nL19188:     ) -> Distribution | None: ...\nL19189:     def obtain(\nL19190:         self,\nL19191:         requirement: Requirement,\nL19192:         installer: Callable[[Requirement], None]\nL19193:         | _InstallerType\nL19194:         | None\nL19195:         | _StrictInstallerType[_DistributionT] = None,\nL19196:     ) -> Distribution | None:\nL19197:         \"\"\"Obtain a distribution matching `requirement` (e.g. via download)\nL19198: \nL19199:         Obtain a distro that matches requirement (e.g. via download).  In the\nL19200:         base ``Environment`` class, this routine just returns\nL19201:         ``installer(requirement)``, unless `installer` is None, in which case\nL19202:         None is returned instead.  This method is a hook that allows subclasses\nL19203:         to attempt other ways of obtaining a distribution before falling back\nL19204:         to the `installer` argument.\"\"\"\nL19205:         return installer(requirement) if installer else None\nL19206: \nL19207:     def __iter__(self) -> Iterator[str]:\nL19208:         \"\"\"Yield the unique project names of the available distributions\"\"\"\nL19209:         for key in self._distmap.keys():\nL19210:             if self[key]:\nL19211:                 yield key\nL19212: \nL19213:     def __iadd__(self, other: Distribution | Environment) -> Self:\nL19214:         \"\"\"In-place addition of a distribution or environment\"\"\"\nL19215:         if isinstance(other, Distribution):\nL19216:             self.add(other)\nL19217:         elif isinstance(other, Environment):\nL19218:             for project in other:\nL19219:                 for dist in other[project]:\nL19220:                     self.add(dist)\nL19221:         else:\nL19222:             raise TypeError(f\"Can't add {other!r} to environment\")\nL19223:         return self\nL19224: \nL19225:     def __add__(self, other: Distribution | Environment) -> Self:\nL19226:         \"\"\"Add an environment or distribution to an environment\"\"\"\nL19227:         new = self.__class__([], platform=None, python=None)\nL19228:         for env in self, other:\nL19229:             new += env\nL19230:         return new\nL19231: \nL19232: \nL19233: # XXX backward compatibility\nL19234: AvailableDistributions = Environment\nL19235: \nL19236: \nL19237: class ExtractionError(RuntimeError):\nL19238:     \"\"\"An error occurred extracting a resource\nL19239: \nL19240:     The following attributes are available from instances of this exception:\nL19241: \nL19242:     manager\nL19243:         The resource manager that raised this exception\nL19244: \nL19245:     cache_path\nL19246:         The base directory for resource extraction\nL19247: \nL19248:     original_error\nL19249:         The exception instance that caused extraction to fail\nL19250:     \"\"\"\nL19251: \nL19252:     manager: ResourceManager\nL19253:     cache_path: str\nL19254:     original_error: BaseException | None\nL19255: \nL19256: \nL19257: class ResourceManager:\nL19258:     \"\"\"Manage resource extraction and packages\"\"\"\nL19259: \nL19260:     extraction_path: str | None = None\nL19261: \nL19262:     def __init__(self) -> None:\nL19263:         # acts like a set\nL19264:         self.cached_files: dict[str, Literal[True]] = {}\nL19265: \nL19266:     def resource_exists(\nL19267:         self, package_or_requirement: _PkgReqType, resource_name: str\nL19268:     ) -> bool:\nL19269:         \"\"\"Does the named resource exist?\"\"\"\nL19270:         return get_provider(package_or_requirement).has_resource(resource_name)\nL19271: \nL19272:     def resource_isdir(\nL19273:         self, package_or_requirement: _PkgReqType, resource_name: str\nL19274:     ) -> bool:\nL19275:         \"\"\"Is the named resource an existing directory?\"\"\"\nL19276:         return get_provider(package_or_requirement).resource_isdir(resource_name)\nL19277: \nL19278:     def resource_filename(\nL19279:         self, package_or_requirement: _PkgReqType, resource_name: str\nL19280:     ) -> str:\nL19281:         \"\"\"Return a true filesystem path for specified resource\"\"\"\nL19282:         return get_provider(package_or_requirement).get_resource_filename(\nL19283:             self, resource_name\nL19284:         )\nL19285: \nL19286:     def resource_stream(\nL19287:         self, package_or_requirement: _PkgReqType, resource_name: str\nL19288:     ) -> _ResourceStream:\nL19289:         \"\"\"Return a readable file-like object for specified resource\"\"\"\nL19290:         return get_provider(package_or_requirement).get_resource_stream(\nL19291:             self, resource_name\nL19292:         )\nL19293: \nL19294:     def resource_string(\nL19295:         self, package_or_requirement: _PkgReqType, resource_name: str\nL19296:     ) -> bytes:\nL19297:         \"\"\"Return specified resource as :obj:`bytes`\"\"\"\nL19298:         return get_provider(package_or_requirement).get_resource_string(\nL19299:             self, resource_name\nL19300:         )\nL19301: \nL19302:     def resource_listdir(\nL19303:         self, package_or_requirement: _PkgReqType, resource_name: str\nL19304:     ) -> list[str]:\nL19305:         \"\"\"List the contents of the named resource directory\"\"\"\nL19306:         return get_provider(package_or_requirement).resource_listdir(resource_name)\nL19307: \nL19308:     def extraction_error(self) -> NoReturn:\nL19309:         \"\"\"Give an error message for problems extracting file(s)\"\"\"\nL19310: \nL19311:         old_exc = sys.exc_info()[1]\nL19312:         cache_path = self.extraction_path or get_default_cache()\nL19313: \nL19314:         tmpl = textwrap.dedent(\nL19315:             \"\"\"\nL19316:             Can't extract file(s) to egg cache\nL19317: \nL19318:             The following error occurred while trying to extract file(s)\nL19319:             to the Python egg cache:\nL19320: \nL19321:               {old_exc}\nL19322: \nL19323:             The Python egg cache directory is currently set to:\nL19324: \nL19325:               {cache_path}\nL19326: \nL19327:             Perhaps your account does not have write access to this directory?\nL19328:             You can change the cache directory by setting the PYTHON_EGG_CACHE\nL19329:             environment variable to point to an accessible directory.\nL19330:             \"\"\"\nL19331:         ).lstrip()\nL19332:         err = ExtractionError(tmpl.format(**locals()))\nL19333:         err.manager = self\nL19334:         err.cache_path = cache_path\nL19335:         err.original_error = old_exc\nL19336:         raise err\nL19337: \nL19338:     def get_cache_path(self, archive_name: str, names: Iterable[StrPath] = ()) -> str:\nL19339:         \"\"\"Return absolute location in cache for `archive_name` and `names`\nL19340: \nL19341:         The parent directory of the resulting path will be created if it does\nL19342:         not already exist.  `archive_name` should be the base filename of the\nL19343:         enclosing egg (which may not be the name of the enclosing zipfile!),\nL19344:         including its \".egg\" extension.  `names`, if provided, should be a\nL19345:         sequence of path name parts \"under\" the egg's extraction location.\nL19346: \nL19347:         This method should only be called by resource providers that need to\nL19348:         obtain an extraction location, and only for names they intend to\nL19349:         extract, as it tracks the generated names for possible cleanup later.\nL19350:         \"\"\"\nL19351:         extract_path = self.extraction_path or get_default_cache()\nL19352:         target_path = os.path.join(extract_path, archive_name + '-tmp', *names)\nL19353:         try:\nL19354:             _bypass_ensure_directory(target_path)\nL19355:         except Exception:\nL19356:             self.extraction_error()\nL19357: \nL19358:         self._warn_unsafe_extraction_path(extract_path)\nL19359: \nL19360:         self.cached_files[target_path] = True\nL19361:         return target_path\nL19362: \nL19363:     @staticmethod\nL19364:     def _warn_unsafe_extraction_path(path) -> None:\nL19365:         \"\"\"\nL19366:         If the default extraction path is overridden and set to an insecure\nL19367:         location, such as /tmp, it opens up an opportunity for an attacker to\nL19368:         replace an extracted file with an unauthorized payload. Warn the user\nL19369:         if a known insecure location is used.\nL19370: \nL19371:         See Distribute #375 for more details.\nL19372:         \"\"\"\nL19373:         if os.name == 'nt' and not path.startswith(os.environ['windir']):\nL19374:             # On Windows, permissions are generally restrictive by default\nL19375:             #  and temp directories are not writable by other users, so\nL19376:             #  bypass the warning.\nL19377:             return\nL19378:         mode = os.stat(path).st_mode\nL19379:         if mode & stat.S_IWOTH or mode & stat.S_IWGRP:\nL19380:             msg = (\nL19381:                 \"Extraction path is writable by group/others \"\nL19382:                 \"and vulnerable to attack when \"\nL19383:                 \"used with get_resource_filename ({path}). \"\nL19384:                 \"Consider a more secure \"\nL19385:                 \"location (set with .set_extraction_path or the \"\nL19386:                 \"PYTHON_EGG_CACHE environment variable).\"\nL19387:             ).format(**locals())\nL19388:             warnings.warn(msg, UserWarning)\nL19389: \nL19390:     def postprocess(self, tempname: StrOrBytesPath, filename: StrOrBytesPath) -> None:\nL19391:         \"\"\"Perform any platform-specific postprocessing of `tempname`\nL19392: \nL19393:         This is where Mac header rewrites should be done; other platforms don't\nL19394:         have anything special they should do.\nL19395: \nL19396:         Resource providers should call this method ONLY after successfully\nL19397:         extracting a compressed resource.  They must NOT call it on resources\nL19398:         that are already in the filesystem.\nL19399: \nL19400:         `tempname` is the current (temporary) name of the file, and `filename`\nL19401:         is the name it will be renamed to by the caller after this routine\nL19402:         returns.\nL19403:         \"\"\"\nL19404: \nL19405:         if os.name == 'posix':\nL19406:             # Make the resource executable\nL19407:             mode = ((os.stat(tempname).st_mode) | 0o555) & 0o7777\nL19408:             os.chmod(tempname, mode)\nL19409: \nL19410:     def set_extraction_path(self, path: str) -> None:\nL19411:         \"\"\"Set the base path where resources will be extracted to, if needed.\nL19412: \nL19413:         If you do not call this routine before any extractions take place, the\nL19414:         path defaults to the return value of ``get_default_cache()``.  (Which\nL19415:         is based on the ``PYTHON_EGG_CACHE`` environment variable, with various\nL19416:         platform-specific fallbacks.  See that routine's documentation for more\nL19417:         details.)\nL19418: \nL19419:         Resources are extracted to subdirectories of this path based upon\nL19420:         information given by the ``IResourceProvider``.  You may set this to a\nL19421:         temporary directory, but then you must call ``cleanup_resources()`` to\nL19422:         delete the extracted files when done.  There is no guarantee that\nL19423:         ``cleanup_resources()`` will be able to remove all extracted files.\nL19424: \nL19425:         (Note: you may not change the extraction path for a given resource\nL19426:         manager once resources have been extracted, unless you first call\nL19427:         ``cleanup_resources()``.)\nL19428:         \"\"\"\nL19429:         if self.cached_files:\nL19430:             raise ValueError(\"Can't change extraction path, files already extracted\")\nL19431: \nL19432:         self.extraction_path = path\nL19433: \nL19434:     def cleanup_resources(self, force: bool = False) -> list[str]:\nL19435:         \"\"\"\nL19436:         Delete all extracted resource files and directories, returning a list\nL19437:         of the file and directory names that could not be successfully removed.\nL19438:         This function does not have any concurrency protection, so it should\nL19439:         generally only be called when the extraction path is a temporary\nL19440:         directory exclusive to a single process.  This method is not\nL19441:         automatically called; you must call it explicitly or register it as an\nL19442:         ``atexit`` function if you wish to ensure cleanup of a temporary\nL19443:         directory used for extractions.\nL19444:         \"\"\"\nL19445:         # XXX\nL19446:         return []\nL19447: \nL19448: \nL19449: def get_default_cache() -> str:\nL19450:     \"\"\"\nL19451:     Return the ``PYTHON_EGG_CACHE`` environment variable\nL19452:     or a platform-relevant user cache dir for an app\nL19453:     named \"Python-Eggs\".\nL19454:     \"\"\"\nL19455:     return os.environ.get('PYTHON_EGG_CACHE') or _user_cache_dir(appname='Python-Eggs')\nL19456: \nL19457: \nL19458: def safe_name(name: str) -> str:\nL19459:     \"\"\"Convert an arbitrary string to a standard distribution name\nL19460: \nL19461:     Any runs of non-alphanumeric/. characters are replaced with a single '-'.\nL19462:     \"\"\"\nL19463:     return re.sub('[^A-Za-z0-9.]+', '-', name)\nL19464: \nL19465: \nL19466: def safe_version(version: str) -> str:\nL19467:     \"\"\"\nL19468:     Convert an arbitrary string to a standard version string\nL19469:     \"\"\"\nL19470:     try:\nL19471:         # normalize the version\nL19472:         return str(packaging.version.Version(version))\nL19473:     except packaging.version.InvalidVersion:\nL19474:         version = version.replace(' ', '.')\nL19475:         return re.sub('[^A-Za-z0-9.]+', '-', version)\nL19476: \nL19477: \nL19478: def _forgiving_version(version) -> str:\nL19479:     \"\"\"Fallback when ``safe_version`` is not safe enough\nL19480:     >>> parse_version(_forgiving_version('0.23ubuntu1'))\nL19481:     <Version('0.23.dev0+sanitized.ubuntu1')>\nL19482:     >>> parse_version(_forgiving_version('0.23-'))\nL19483:     <Version('0.23.dev0+sanitized')>\nL19484:     >>> parse_version(_forgiving_version('0.-_'))\nL19485:     <Version('0.dev0+sanitized')>\nL19486:     >>> parse_version(_forgiving_version('42.+?1'))\nL19487:     <Version('42.dev0+sanitized.1')>\nL19488:     >>> parse_version(_forgiving_version('hello world'))\nL19489:     <Version('0.dev0+sanitized.hello.world')>\nL19490:     \"\"\"\nL19491:     version = version.replace(' ', '.')\nL19492:     match = _PEP440_FALLBACK.search(version)\nL19493:     if match:\nL19494:         safe = match[\"safe\"]\nL19495:         rest = version[len(safe) :]\nL19496:     else:\nL19497:         safe = \"0\"\nL19498:         rest = version\nL19499:     local = f\"sanitized.{_safe_segment(rest)}\".strip(\".\")\nL19500:     return f\"{safe}.dev0+{local}\"\nL19501: \nL19502: \nL19503: def _safe_segment(segment):\nL19504:     \"\"\"Convert an arbitrary string into a safe segment\"\"\"\nL19505:     segment = re.sub('[^A-Za-z0-9.]+', '-', segment)\nL19506:     segment = re.sub('-[^A-Za-z0-9]+', '-', segment)\nL19507:     return re.sub(r'\\.[^A-Za-z0-9]+', '.', segment).strip(\".-\")\nL19508: \nL19509: \nL19510: def safe_extra(extra: str) -> str:\nL19511:     \"\"\"Convert an arbitrary string to a standard 'extra' name\nL19512: \nL19513:     Any runs of non-alphanumeric characters are replaced with a single '_',\nL19514:     and the result is always lowercased.\nL19515:     \"\"\"\nL19516:     return re.sub('[^A-Za-z0-9.-]+', '_', extra).lower()\nL19517: \nL19518: \nL19519: def to_filename(name: str) -> str:\nL19520:     \"\"\"Convert a project or version name to its filename-escaped form\nL19521: \nL19522:     Any '-' characters are currently replaced with '_'.\nL19523:     \"\"\"\nL19524:     return name.replace('-', '_')\nL19525: \nL19526: \nL19527: def invalid_marker(text: str) -> SyntaxError | Literal[False]:\nL19528:     \"\"\"\nL19529:     Validate text as a PEP 508 environment marker; return an exception\nL19530:     if invalid or False otherwise.\nL19531:     \"\"\"\nL19532:     try:\nL19533:         evaluate_marker(text)\nL19534:     except SyntaxError as e:\nL19535:         e.filename = None\nL19536:         e.lineno = None\nL19537:         return e\nL19538:     return False\nL19539: \nL19540: \nL19541: def evaluate_marker(text: str, extra: str | None = None) -> bool:\nL19542:     \"\"\"\nL19543:     Evaluate a PEP 508 environment marker.\nL19544:     Return a boolean indicating the marker result in this environment.\nL19545:     Raise SyntaxError if marker is invalid.\nL19546: \nL19547:     This implementation uses the 'pyparsing' module.\nL19548:     \"\"\"\nL19549:     try:\nL19550:         marker = packaging.markers.Marker(text)\nL19551:         return marker.evaluate()\nL19552:     except packaging.markers.InvalidMarker as e:\nL19553:         raise SyntaxError(e) from e\nL19554: \nL19555: \nL19556: class NullProvider:\nL19557:     \"\"\"Try to implement resources and metadata for arbitrary PEP 302 loaders\"\"\"\nL19558: \nL19559:     egg_name: str | None = None\nL19560:     egg_info: str | None = None\nL19561:     loader: LoaderProtocol | None = None\nL19562: \nL19563:     def __init__(self, module: _ModuleLike) -> None:\nL19564:         self.loader = getattr(module, '__loader__', None)\nL19565:         self.module_path = os.path.dirname(getattr(module, '__file__', ''))\nL19566: \nL19567:     def get_resource_filename(\nL19568:         self, manager: ResourceManager, resource_name: str\nL19569:     ) -> str:\nL19570:         return self._fn(self.module_path, resource_name)\nL19571: \nL19572:     def get_resource_stream(\nL19573:         self, manager: ResourceManager, resource_name: str\nL19574:     ) -> BinaryIO:\nL19575:         return io.BytesIO(self.get_resource_string(manager, resource_name))\nL19576: \nL19577:     def get_resource_string(\nL19578:         self, manager: ResourceManager, resource_name: str\nL19579:     ) -> bytes:\nL19580:         return self._get(self._fn(self.module_path, resource_name))\nL19581: \nL19582:     def has_resource(self, resource_name: str) -> bool:\nL19583:         return self._has(self._fn(self.module_path, resource_name))\nL19584: \nL19585:     def _get_metadata_path(self, name):\nL19586:         return self._fn(self.egg_info, name)\nL19587: \nL19588:     def has_metadata(self, name: str) -> bool:\nL19589:         if not self.egg_info:\nL19590:             return False\nL19591: \nL19592:         path = self._get_metadata_path(name)\nL19593:         return self._has(path)\nL19594: \nL19595:     def get_metadata(self, name: str) -> str:\nL19596:         if not self.egg_info:\nL19597:             return \"\"\nL19598:         path = self._get_metadata_path(name)\nL19599:         value = self._get(path)\nL19600:         try:\nL19601:             return value.decode('utf-8')\nL19602:         except UnicodeDecodeError as exc:\nL19603:             # Include the path in the error message to simplify\nL19604:             # troubleshooting, and without changing the exception type.\nL19605:             exc.reason += f' in {name} file at path: {path}'\nL19606:             raise\nL19607: \nL19608:     def get_metadata_lines(self, name: str) -> Iterator[str]:\nL19609:         return yield_lines(self.get_metadata(name))\nL19610: \nL19611:     def resource_isdir(self, resource_name: str) -> bool:\nL19612:         return self._isdir(self._fn(self.module_path, resource_name))\nL19613: \nL19614:     def metadata_isdir(self, name: str) -> bool:\nL19615:         return bool(self.egg_info and self._isdir(self._fn(self.egg_info, name)))\nL19616: \nL19617:     def resource_listdir(self, resource_name: str) -> list[str]:\nL19618:         return self._listdir(self._fn(self.module_path, resource_name))\nL19619: \nL19620:     def metadata_listdir(self, name: str) -> list[str]:\nL19621:         if self.egg_info:\nL19622:             return self._listdir(self._fn(self.egg_info, name))\nL19623:         return []\nL19624: \nL19625:     def run_script(self, script_name: str, namespace: dict[str, Any]) -> None:\nL19626:         script = 'scripts/' + script_name\nL19627:         if not self.has_metadata(script):\nL19628:             raise ResolutionError(\nL19629:                 \"Script {script!r} not found in metadata at {self.egg_info!r}\".format(\nL19630:                     **locals()\nL19631:                 ),\nL19632:             )\nL19633: \nL19634:         script_text = self.get_metadata(script).replace('\\r\\n', '\\n')\nL19635:         script_text = script_text.replace('\\r', '\\n')\nL19636:         script_filename = self._fn(self.egg_info, script)\nL19637:         namespace['__file__'] = script_filename\nL19638:         if os.path.exists(script_filename):\nL19639:             source = _read_utf8_with_fallback(script_filename)\nL19640:             code = compile(source, script_filename, 'exec')\nL19641:             exec(code, namespace, namespace)\nL19642:         else:\nL19643:             from linecache import cache\nL19644: \nL19645:             cache[script_filename] = (\nL19646:                 len(script_text),\nL19647:                 0,\nL19648:                 script_text.split('\\n'),\nL19649:                 script_filename,\nL19650:             )\nL19651:             script_code = compile(script_text, script_filename, 'exec')\nL19652:             exec(script_code, namespace, namespace)\nL19653: \nL19654:     def _has(self, path) -> bool:\nL19655:         raise NotImplementedError(\nL19656:             \"Can't perform this operation for unregistered loader type\"\nL19657:         )\nL19658: \nL19659:     def _isdir(self, path) -> bool:\nL19660:         raise NotImplementedError(\nL19661:             \"Can't perform this operation for unregistered loader type\"\nL19662:         )\nL19663: \nL19664:     def _listdir(self, path) -> list[str]:\nL19665:         raise NotImplementedError(\nL19666:             \"Can't perform this operation for unregistered loader type\"\nL19667:         )\nL19668: \nL19669:     def _fn(self, base: str | None, resource_name: str):\nL19670:         if base is None:\nL19671:             raise TypeError(\nL19672:                 \"`base` parameter in `_fn` is `None`. Either override this method or check the parameter first.\"\nL19673:             )\nL19674:         self._validate_resource_path(resource_name)\nL19675:         if resource_name:\nL19676:             return os.path.join(base, *resource_name.split('/'))\nL19677:         return base\nL19678: \nL19679:     @staticmethod\nL19680:     def _validate_resource_path(path) -> None:\nL19681:         \"\"\"\nL19682:         Validate the resource paths according to the docs.\nL19683:         https://setuptools.pypa.io/en/latest/pkg_resources.html#basic-resource-access\nL19684: \nL19685:         >>> warned = getfixture('recwarn')\nL19686:         >>> warnings.simplefilter('always')\nL19687:         >>> vrp = NullProvider._validate_resource_path\nL19688:         >>> vrp('foo/bar.txt')\nL19689:         >>> bool(warned)\nL19690:         False\nL19691:         >>> vrp('../foo/bar.txt')\nL19692:         >>> bool(warned)\nL19693:         True\nL19694:         >>> warned.clear()\nL19695:         >>> vrp('/foo/bar.txt')\nL19696:         >>> bool(warned)\nL19697:         True\nL19698:         >>> vrp('foo/../../bar.txt')\nL19699:         >>> bool(warned)\nL19700:         True\nL19701:         >>> warned.clear()\nL19702:         >>> vrp('foo/f../bar.txt')\nL19703:         >>> bool(warned)\nL19704:         False\nL19705: \nL19706:         Windows path separators are straight-up disallowed.\nL19707:         >>> vrp(r'\\\\foo/bar.txt')\nL19708:         Traceback (most recent call last):\nL19709:         ...\nL19710:         ValueError: Use of .. or absolute path in a resource path \\\nL19711: is not allowed.\nL19712: \nL19713:         >>> vrp(r'C:\\\\foo/bar.txt')\nL19714:         Traceback (most recent call last):\nL19715:         ...\nL19716:         ValueError: Use of .. or absolute path in a resource path \\\nL19717: is not allowed.\nL19718: \nL19719:         Blank values are allowed\nL19720: \nL19721:         >>> vrp('')\nL19722:         >>> bool(warned)\nL19723:         False\nL19724: \nL19725:         Non-string values are not.\nL19726: \nL19727:         >>> vrp(None)\nL19728:         Traceback (most recent call last):\nL19729:         ...\nL19730:         AttributeError: ...\nL19731:         \"\"\"\nL19732:         invalid = (\nL19733:             os.path.pardir in path.split(posixpath.sep)\nL19734:             or posixpath.isabs(path)\nL19735:             or ntpath.isabs(path)\nL19736:             or path.startswith(\"\\\\\")\nL19737:         )\nL19738:         if not invalid:\nL19739:             return\nL19740: \nL19741:         msg = \"Use of .. or absolute path in a resource path is not allowed.\"\nL19742: \nL19743:         # Aggressively disallow Windows absolute paths\nL19744:         if (path.startswith(\"\\\\\") or ntpath.isabs(path)) and not posixpath.isabs(path):\nL19745:             raise ValueError(msg)\nL19746: \nL19747:         # for compatibility, warn; in future\nL19748:         # raise ValueError(msg)\nL19749:         issue_warning(\nL19750:             msg[:-1] + \" and will raise exceptions in a future release.\",\nL19751:             DeprecationWarning,\nL19752:         )\nL19753: \nL19754:     def _get(self, path) -> bytes:\nL19755:         if hasattr(self.loader, 'get_data') and self.loader:\nL19756:             # Already checked get_data exists\nL19757:             return self.loader.get_data(path)  # type: ignore[attr-defined]\nL19758:         raise NotImplementedError(\nL19759:             \"Can't perform this operation for loaders without 'get_data()'\"\nL19760:         )\nL19761: \nL19762: \nL19763: register_loader_type(object, NullProvider)\nL19764: \nL19765: \nL19766: def _parents(path):\nL19767:     \"\"\"\nL19768:     yield all parents of path including path\nL19769:     \"\"\"\nL19770:     last = None\nL19771:     while path != last:\nL19772:         yield path\nL19773:         last = path\nL19774:         path, _ = os.path.split(path)\nL19775: \nL19776: \nL19777: class EggProvider(NullProvider):\nL19778:     \"\"\"Provider based on a virtual filesystem\"\"\"\nL19779: \nL19780:     def __init__(self, module: _ModuleLike) -> None:\nL19781:         super().__init__(module)\nL19782:         self._setup_prefix()\nL19783: \nL19784:     def _setup_prefix(self):\nL19785:         # Assume that metadata may be nested inside a \"basket\"\nL19786:         # of multiple eggs and use module_path instead of .archive.\nL19787:         eggs = filter(_is_egg_path, _parents(self.module_path))\nL19788:         egg = next(eggs, None)\nL19789:         egg and self._set_egg(egg)\nL19790: \nL19791:     def _set_egg(self, path: str) -> None:\nL19792:         self.egg_name = os.path.basename(path)\nL19793:         self.egg_info = os.path.join(path, 'EGG-INFO')\nL19794:         self.egg_root = path\nL19795: \nL19796: \nL19797: class DefaultProvider(EggProvider):\nL19798:     \"\"\"Provides access to package resources in the filesystem\"\"\"\nL19799: \nL19800:     def _has(self, path) -> bool:\nL19801:         return os.path.exists(path)\nL19802: \nL19803:     def _isdir(self, path) -> bool:\nL19804:         return os.path.isdir(path)\nL19805: \nL19806:     def _listdir(self, path):\nL19807:         return os.listdir(path)\nL19808: \nL19809:     def get_resource_stream(\nL19810:         self, manager: object, resource_name: str\nL19811:     ) -> io.BufferedReader:\nL19812:         return open(self._fn(self.module_path, resource_name), 'rb')\nL19813: \nL19814:     def _get(self, path) -> bytes:\nL19815:         with open(path, 'rb') as stream:\nL19816:             return stream.read()\nL19817: \nL19818:     @classmethod\nL19819:     def _register(cls) -> None:\nL19820:         loader_names = (\nL19821:             'SourceFileLoader',\nL19822:             'SourcelessFileLoader',\nL19823:         )\nL19824:         for name in loader_names:\nL19825:             loader_cls = getattr(importlib.machinery, name, type(None))\nL19826:             register_loader_type(loader_cls, cls)\nL19827: \nL19828: \nL19829: DefaultProvider._register()\nL19830: \nL19831: \nL19832: class EmptyProvider(NullProvider):\nL19833:     \"\"\"Provider that returns nothing for all requests\"\"\"\nL19834: \nL19835:     # A special case, we don't want all Providers inheriting from NullProvider to have a potentially None module_path\nL19836:     module_path: str | None = None  # type: ignore[assignment]\nL19837: \nL19838:     _isdir = _has = lambda self, path: False\nL19839: \nL19840:     def _get(self, path) -> bytes:\nL19841:         return b''\nL19842: \nL19843:     def _listdir(self, path):\nL19844:         return []\nL19845: \nL19846:     def __init__(self) -> None:\nL19847:         pass\nL19848: \nL19849: \nL19850: empty_provider = EmptyProvider()\nL19851: \nL19852: \nL19853: class ZipManifests(dict[str, \"MemoizedZipManifests.manifest_mod\"]):\nL19854:     \"\"\"\nL19855:     zip manifest builder\nL19856:     \"\"\"\nL19857: \nL19858:     # `path` could be `StrPath | IO[bytes]` but that violates the LSP for `MemoizedZipManifests.load`\nL19859:     @classmethod\nL19860:     def build(cls, path: str) -> dict[str, zipfile.ZipInfo]:\nL19861:         \"\"\"\nL19862:         Build a dictionary similar to the zipimport directory\nL19863:         caches, except instead of tuples, store ZipInfo objects.\nL19864: \nL19865:         Use a platform-specific path separator (os.sep) for the path keys\nL19866:         for compatibility with pypy on Windows.\nL19867:         \"\"\"\nL19868:         with zipfile.ZipFile(path) as zfile:\nL19869:             items = (\nL19870:                 (\nL19871:                     name.replace('/', os.sep),\nL19872:                     zfile.getinfo(name),\nL19873:                 )\nL19874:                 for name in zfile.namelist()\nL19875:             )\nL19876:             return dict(items)\nL19877: \nL19878:     load = build\nL19879: \nL19880: \nL19881: class MemoizedZipManifests(ZipManifests):\nL19882:     \"\"\"\nL19883:     Memoized zipfile manifests.\nL19884:     \"\"\"\nL19885: \nL19886:     class manifest_mod(NamedTuple):\nL19887:         manifest: dict[str, zipfile.ZipInfo]\nL19888:         mtime: float\nL19889: \nL19890:     def load(self, path: str) -> dict[str, zipfile.ZipInfo]:  # type: ignore[override] # ZipManifests.load is a classmethod\nL19891:         \"\"\"\nL19892:         Load a manifest at path or return a suitable manifest already loaded.\nL19893:         \"\"\"\nL19894:         path = os.path.normpath(path)\nL19895:         mtime = os.stat(path).st_mtime\nL19896: \nL19897:         if path not in self or self[path].mtime != mtime:\nL19898:             manifest = self.build(path)\nL19899:             self[path] = self.manifest_mod(manifest, mtime)\nL19900: \nL19901:         return self[path].manifest\nL19902: \nL19903: \nL19904: class ZipProvider(EggProvider):\nL19905:     \"\"\"Resource support for zips and eggs\"\"\"\nL19906: \nL19907:     eagers: list[str] | None = None\nL19908:     _zip_manifests = MemoizedZipManifests()\nL19909:     # ZipProvider's loader should always be a zipimporter or equivalent\nL19910:     loader: zipimport.zipimporter\nL19911: \nL19912:     def __init__(self, module: _ZipLoaderModule) -> None:\nL19913:         super().__init__(module)\nL19914:         self.zip_pre = self.loader.archive + os.sep\nL19915: \nL19916:     def _zipinfo_name(self, fspath):\nL19917:         # Convert a virtual filename (full path to file) into a zipfile subpath\nL19918:         # usable with the zipimport directory cache for our target archive\nL19919:         fspath = fspath.rstrip(os.sep)\nL19920:         if fspath == self.loader.archive:\nL19921:             return ''\nL19922:         if fspath.startswith(self.zip_pre):\nL19923:             return fspath[len(self.zip_pre) :]\nL19924:         raise AssertionError(f\"{fspath} is not a subpath of {self.zip_pre}\")\nL19925: \nL19926:     def _parts(self, zip_path):\nL19927:         # Convert a zipfile subpath into an egg-relative path part list.\nL19928:         # pseudo-fs path\nL19929:         fspath = self.zip_pre + zip_path\nL19930:         if fspath.startswith(self.egg_root + os.sep):\nL19931:             return fspath[len(self.egg_root) + 1 :].split(os.sep)\nL19932:         raise AssertionError(f\"{fspath} is not a subpath of {self.egg_root}\")\nL19933: \nL19934:     @property\nL19935:     def zipinfo(self):\nL19936:         return self._zip_manifests.load(self.loader.archive)\nL19937: \nL19938:     def get_resource_filename(\nL19939:         self, manager: ResourceManager, resource_name: str\nL19940:     ) -> str:\nL19941:         if not self.egg_name:\nL19942:             raise NotImplementedError(\nL19943:                 \"resource_filename() only supported for .egg, not .zip\"\nL19944:             )\nL19945:         # no need to lock for extraction, since we use temp names\nL19946:         zip_path = self._resource_to_zip(resource_name)\nL19947:         eagers = self._get_eager_resources()\nL19948:         if '/'.join(self._parts(zip_path)) in eagers:\nL19949:             for name in eagers:\nL19950:                 self._extract_resource(manager, self._eager_to_zip(name))\nL19951:         return self._extract_resource(manager, zip_path)\nL19952: \nL19953:     @staticmethod\nL19954:     def _get_date_and_size(zip_stat):\nL19955:         size = zip_stat.file_size\nL19956:         # ymdhms+wday, yday, dst\nL19957:         date_time = zip_stat.date_time + (0, 0, -1)\nL19958:         # 1980 offset already done\nL19959:         timestamp = time.mktime(date_time)\nL19960:         return timestamp, size\nL19961: \nL19962:     # FIXME: 'ZipProvider._extract_resource' is too complex (12)\nL19963:     def _extract_resource(self, manager: ResourceManager, zip_path) -> str:  # noqa: C901\nL19964:         if zip_path in self._index():\nL19965:             for name in self._index()[zip_path]:\nL19966:                 last = self._extract_resource(manager, os.path.join(zip_path, name))\nL19967:             # return the extracted directory name\nL19968:             return os.path.dirname(last)\nL19969: \nL19970:         timestamp, _size = self._get_date_and_size(self.zipinfo[zip_path])\nL19971: \nL19972:         if not WRITE_SUPPORT:\nL19973:             raise OSError(\nL19974:                 '\"os.rename\" and \"os.unlink\" are not supported on this platform'\nL19975:             )\nL19976:         try:\nL19977:             if not self.egg_name:\nL19978:                 raise OSError(\nL19979:                     '\"egg_name\" is empty. This likely means no egg could be found from the \"module_path\".'\nL19980:                 )\nL19981:             real_path = manager.get_cache_path(self.egg_name, self._parts(zip_path))\nL19982: \nL19983:             if self._is_current(real_path, zip_path):\nL19984:                 return real_path\nL19985: \nL19986:             outf, tmpnam = _mkstemp(\nL19987:                 \".$extract\",\nL19988:                 dir=os.path.dirname(real_path),\nL19989:             )\nL19990:             os.write(outf, self.loader.get_data(zip_path))\nL19991:             os.close(outf)\nL19992:             utime(tmpnam, (timestamp, timestamp))\nL19993:             manager.postprocess(tmpnam, real_path)\nL19994: \nL19995:             try:\nL19996:                 rename(tmpnam, real_path)\nL19997: \nL19998:             except OSError:\nL19999:                 if os.path.isfile(real_path):\nL20000:                     if self._is_current(real_path, zip_path):\nL20001:                         # the file became current since it was checked above,\nL20002:                         #  so proceed.\nL20003:                         return real_path\nL20004:                     # Windows, del old file and retry\nL20005:                     elif os.name == 'nt':\nL20006:                         unlink(real_path)\nL20007:                         rename(tmpnam, real_path)\nL20008:                         return real_path\nL20009:                 raise\nL20010: \nL20011:         except OSError:\nL20012:             # report a user-friendly error\nL20013:             manager.extraction_error()\nL20014: \nL20015:         return real_path\nL20016: \nL20017:     def _is_current(self, file_path, zip_path):\nL20018:         \"\"\"\nL20019:         Return True if the file_path is current for this zip_path\nL20020:         \"\"\"\nL20021:         timestamp, size = self._get_date_and_size(self.zipinfo[zip_path])\nL20022:         if not os.path.isfile(file_path):\nL20023:             return False\nL20024:         stat = os.stat(file_path)\nL20025:         if stat.st_size != size or stat.st_mtime != timestamp:\nL20026:             return False\nL20027:         # check that the contents match\nL20028:         zip_contents = self.loader.get_data(zip_path)\nL20029:         with open(file_path, 'rb') as f:\nL20030:             file_contents = f.read()\nL20031:         return zip_contents == file_contents\nL20032: \nL20033:     def _get_eager_resources(self):\nL20034:         if self.eagers is None:\nL20035:             eagers = []\nL20036:             for name in ('native_libs.txt', 'eager_resources.txt'):\nL20037:                 if self.has_metadata(name):\nL20038:                     eagers.extend(self.get_metadata_lines(name))\nL20039:             self.eagers = eagers\nL20040:         return self.eagers\nL20041: \nL20042:     def _index(self):\nL20043:         try:\nL20044:             return self._dirindex\nL20045:         except AttributeError:\nL20046:             ind = {}\nL20047:             for path in self.zipinfo:\nL20048:                 parts = path.split(os.sep)\nL20049:                 while parts:\nL20050:                     parent = os.sep.join(parts[:-1])\nL20051:                     if parent in ind:\nL20052:                         ind[parent].append(parts[-1])\nL20053:                         break\nL20054:                     else:\nL20055:                         ind[parent] = [parts.pop()]\nL20056:             self._dirindex = ind\nL20057:             return ind\nL20058: \nL20059:     def _has(self, fspath) -> bool:\nL20060:         zip_path = self._zipinfo_name(fspath)\nL20061:         return zip_path in self.zipinfo or zip_path in self._index()\nL20062: \nL20063:     def _isdir(self, fspath) -> bool:\nL20064:         return self._zipinfo_name(fspath) in self._index()\nL20065: \nL20066:     def _listdir(self, fspath):\nL20067:         return list(self._index().get(self._zipinfo_name(fspath), ()))\nL20068: \nL20069:     def _eager_to_zip(self, resource_name: str):\nL20070:         return self._zipinfo_name(self._fn(self.egg_root, resource_name))\nL20071: \nL20072:     def _resource_to_zip(self, resource_name: str):\nL20073:         return self._zipinfo_name(self._fn(self.module_path, resource_name))\nL20074: \nL20075: \nL20076: register_loader_type(zipimport.zipimporter, ZipProvider)\nL20077: \nL20078: \nL20079: class FileMetadata(EmptyProvider):\nL20080:     \"\"\"Metadata handler for standalone PKG-INFO files\nL20081: \nL20082:     Usage::\nL20083: \nL20084:         metadata = FileMetadata(\"/path/to/PKG-INFO\")\nL20085: \nL20086:     This provider rejects all data and metadata requests except for PKG-INFO,\nL20087:     which is treated as existing, and will be the contents of the file at\nL20088:     the provided location.\nL20089:     \"\"\"\nL20090: \nL20091:     def __init__(self, path: StrPath) -> None:\nL20092:         self.path = path\nL20093: \nL20094:     def _get_metadata_path(self, name):\nL20095:         return self.path\nL20096: \nL20097:     def has_metadata(self, name: str) -> bool:\nL20098:         return name == 'PKG-INFO' and os.path.isfile(self.path)\nL20099: \nL20100:     def get_metadata(self, name: str) -> str:\nL20101:         if name != 'PKG-INFO':\nL20102:             raise KeyError(\"No metadata except PKG-INFO is available\")\nL20103: \nL20104:         with open(self.path, encoding='utf-8', errors=\"replace\") as f:\nL20105:             metadata = f.read()\nL20106:         self._warn_on_replacement(metadata)\nL20107:         return metadata\nL20108: \nL20109:     def _warn_on_replacement(self, metadata) -> None:\nL20110:         replacement_char = '\ufffd'\nL20111:         if replacement_char in metadata:\nL20112:             tmpl = \"{self.path} could not be properly decoded in UTF-8\"\nL20113:             msg = tmpl.format(**locals())\nL20114:             warnings.warn(msg)\nL20115: \nL20116:     def get_metadata_lines(self, name: str) -> Iterator[str]:\nL20117:         return yield_lines(self.get_metadata(name))\nL20118: \nL20119: \nL20120: class PathMetadata(DefaultProvider):\nL20121:     \"\"\"Metadata provider for egg directories\nL20122: \nL20123:     Usage::\nL20124: \nL20125:         # Development eggs:\nL20126: \nL20127:         egg_info = \"/path/to/PackageName.egg-info\"\nL20128:         base_dir = os.path.dirname(egg_info)\nL20129:         metadata = PathMetadata(base_dir, egg_info)\nL20130:         dist_name = os.path.splitext(os.path.basename(egg_info))[0]\nL20131:         dist = Distribution(basedir, project_name=dist_name, metadata=metadata)\nL20132: \nL20133:         # Unpacked egg directories:\nL20134: \nL20135:         egg_path = \"/path/to/PackageName-ver-pyver-etc.egg\"\nL20136:         metadata = PathMetadata(egg_path, os.path.join(egg_path,'EGG-INFO'))\nL20137:         dist = Distribution.from_filename(egg_path, metadata=metadata)\nL20138:     \"\"\"\nL20139: \nL20140:     def __init__(self, path: str, egg_info: str) -> None:\nL20141:         self.module_path = path\nL20142:         self.egg_info = egg_info\nL20143: \nL20144: \nL20145: class EggMetadata(ZipProvider):\nL20146:     \"\"\"Metadata provider for .egg files\"\"\"\nL20147: \nL20148:     def __init__(self, importer: zipimport.zipimporter) -> None:\nL20149:         \"\"\"Create a metadata provider from a zipimporter\"\"\"\nL20150: \nL20151:         self.zip_pre = importer.archive + os.sep\nL20152:         self.loader = importe