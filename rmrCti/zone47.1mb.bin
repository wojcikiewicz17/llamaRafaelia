nL17327:     def _get_minimum_pip_version_str() -> str:\nL17328:         if platform.system() == 'Darwin':\nL17329:             release, _, machine = platform.mac_ver()\nL17330:             if int(release[: release.find('.')]) >= 11:\nL17331:                 # macOS 11+ name scheme change requires 20.3. Intel macOS 11.0 can be\nL17332:                 # told to report 10.16 for backwards compatibility; but that also fixes\nL17333:                 # earlier versions of pip so this is only needed for 11+.\nL17334:                 is_apple_silicon_python = machine != 'x86_64'\nL17335:                 return '21.0.1' if is_apple_silicon_python else '20.3.0'\nL17336: \nL17337:         # PEP-517 and manylinux1 was first implemented in 19.1\nL17338:         return '19.1.0'\nL17339: \nL17340:     def create(self, path: str) -> None:\nL17341:         if self._create_with_virtualenv:\nL17342:             import virtualenv\nL17343: \nL17344:             result = virtualenv.cli_run(\nL17345:                 [\nL17346:                     path,\nL17347:                     '--activators',\nL17348:                     '',\nL17349:                     '--no-setuptools',\nL17350:                     '--no-wheel',\nL17351:                 ],\nL17352:                 setup_logging=False,\nL17353:             )\nL17354: \nL17355:             # The creator attributes are `pathlib.Path`s.\nL17356:             self.python_executable = str(result.creator.exe)\nL17357:             self.scripts_dir = str(result.creator.script_dir)\nL17358: \nL17359:         else:\nL17360:             import venv\nL17361: \nL17362:             with_pip = not self._has_valid_outer_pip\nL17363: \nL17364:             try:\nL17365:                 venv.EnvBuilder(symlinks=_fs_supports_symlink(), with_pip=with_pip).create(path)\nL17366:             except subprocess.CalledProcessError as exc:\nL17367:                 _ctx.log_subprocess_error(exc)\nL17368:                 raise FailedProcessError(exc, 'Failed to create venv. Maybe try installing virtualenv.') from None\nL17369: \nL17370:             self.python_executable, self.scripts_dir, purelib = _find_executable_and_scripts(path)\nL17371: \nL17372:             if with_pip:\nL17373:                 minimum_pip_version_str = self._get_minimum_pip_version_str()\nL17374:                 if not _has_dependency(\nL17375:                     'pip',\nL17376:                     minimum_pip_version_str,\nL17377:                     path=[purelib],\nL17378:                 ):\nL17379:                     run_subprocess([self.python_executable, '-Im', 'pip', 'install', f'pip>={minimum_pip_version_str}'])\nL17380: \nL17381:                 # Uninstall setuptools from the build env to prevent depending on it implicitly.\nL17382:                 # Pythons 3.12 and up do not install setuptools, check if it exists first.\nL17383:                 if _has_dependency(\nL17384:                     'setuptools',\nL17385:                     path=[purelib],\nL17386:                 ):\nL17387:                     run_subprocess([self.python_executable, '-Im', 'pip', 'uninstall', '-y', 'setuptools'])\nL17388: \nL17389:     def install_requirements(self, requirements: Collection[str]) -> None:\nL17390:         # pip does not honour environment markers in command line arguments\nL17391:         # but it does from requirement files.\nL17392:         with tempfile.NamedTemporaryFile('w', prefix='build-reqs-', suffix='.txt', delete=False, encoding='utf-8') as req_file:\nL17393:             req_file.write(os.linesep.join(requirements))\nL17394: \nL17395:         try:\nL17396:             if self._has_valid_outer_pip:\nL17397:                 cmd = [sys.executable, '-m', 'pip', '--python', self.python_executable]\nL17398:             else:\nL17399:                 cmd = [self.python_executable, '-Im', 'pip']\nL17400: \nL17401:             if _ctx.verbosity > 1:\nL17402:                 cmd += [f'-{\"v\" * (_ctx.verbosity - 1)}']\nL17403: \nL17404:             cmd += [\nL17405:                 'install',\nL17406:                 '--use-pep517',\nL17407:                 '--no-warn-script-location',\nL17408:                 '--no-compile',\nL17409:                 '-r',\nL17410:                 os.path.abspath(req_file.name),\nL17411:             ]\nL17412:             run_subprocess(cmd)\nL17413: \nL17414:         finally:\nL17415:             os.unlink(req_file.name)\nL17416: \nL17417:     @property\nL17418:     def display_name(self) -> str:\nL17419:         return 'virtualenv+pip' if self._create_with_virtualenv else 'venv+pip'\nL17420: \nL17421: \nL17422: class _UvBackend(_EnvBackend):\nL17423:     def create(self, path: str) -> None:\nL17424:         import venv\nL17425: \nL17426:         self._env_path = path\nL17427: \nL17428:         try:\nL17429:             import uv\nL17430: \nL17431:             self._uv_bin = uv.find_uv_bin()\nL17432:         except (ModuleNotFoundError, FileNotFoundError):\nL17433:             uv_bin = shutil.which('uv')\nL17434:             if uv_bin is None:\nL17435:                 msg = 'uv executable not found'\nL17436:                 raise RuntimeError(msg) from None\nL17437: \nL17438:             _ctx.log(f'Using external uv from {uv_bin}')\nL17439:             self._uv_bin = uv_bin\nL17440: \nL17441:         venv.EnvBuilder(symlinks=_fs_supports_symlink(), with_pip=False).create(self._env_path)\nL17442:         self.python_executable, self.scripts_dir, _ = _find_executable_and_scripts(self._env_path)\nL17443: \nL17444:     def install_requirements(self, requirements: Collection[str]) -> None:\nL17445:         cmd = [self._uv_bin, 'pip']\nL17446:         if _ctx.verbosity > 1:\nL17447:             cmd += [f'-{\"v\" * min(2, _ctx.verbosity - 1)}']\nL17448:         run_subprocess([*cmd, 'install', *requirements], env={**os.environ, 'VIRTUAL_ENV': self._env_path})\nL17449: \nL17450:     @property\nL17451:     def display_name(self) -> str:\nL17452:         return 'venv+uv'\nL17453: \nL17454: \nL17455: @functools.lru_cache(maxsize=None)\nL17456: def _fs_supports_symlink() -> bool:\nL17457:     \"\"\"Return True if symlinks are supported\"\"\"\nL17458:     # Using definition used by venv.main()\nL17459:     if os.name != 'nt':\nL17460:         return True\nL17461: \nL17462:     # Windows may support symlinks (setting in Windows 10)\nL17463:     with tempfile.NamedTemporaryFile(prefix='build-symlink-') as tmp_file:\nL17464:         dest = f'{tmp_file}-b'\nL17465:         try:\nL17466:             os.symlink(tmp_file.name, dest)\nL17467:             os.unlink(dest)\nL17468:         except (OSError, NotImplementedError, AttributeError):\nL17469:             return False\nL17470:         return True\nL17471: \nL17472: \nL17473: def _find_executable_and_scripts(path: str) -> tuple[str, str, str]:\nL17474:     \"\"\"\nL17475:     Detect the Python executable and script folder of a virtual environment.\nL17476: \nL17477:     :param path: The location of the virtual environment\nL17478:     :return: The Python executable, script folder, and purelib folder\nL17479:     \"\"\"\nL17480:     config_vars = sysconfig.get_config_vars().copy()  # globally cached, copy before altering it\nL17481:     config_vars['base'] = path\nL17482:     scheme_names = sysconfig.get_scheme_names()\nL17483:     if 'venv' in scheme_names:\nL17484:         # Python distributors with custom default installation scheme can set a\nL17485:         # scheme that can't be used to expand the paths in a venv.\nL17486:         # This can happen if build itself is not installed in a venv.\nL17487:         # The distributors are encouraged to set a \"venv\" scheme to be used for this.\nL17488:         # See https://bugs.python.org/issue45413\nL17489:         # and https://github.com/pypa/virtualenv/issues/2208\nL17490:         paths = sysconfig.get_paths(scheme='venv', vars=config_vars)\nL17491:     elif 'posix_local' in scheme_names:\nL17492:         # The Python that ships on Debian/Ubuntu varies the default scheme to\nL17493:         # install to /usr/local\nL17494:         # But it does not (yet) set the \"venv\" scheme.\nL17495:         # If we're the Debian \"posix_local\" scheme is available, but \"venv\"\nL17496:         # is not, we use \"posix_prefix\" instead which is venv-compatible there.\nL17497:         paths = sysconfig.get_paths(scheme='posix_prefix', vars=config_vars)\nL17498:     elif 'osx_framework_library' in scheme_names:\nL17499:         # The Python that ships with the macOS developer tools varies the\nL17500:         # default scheme depending on whether the ``sys.prefix`` is part of a framework.\nL17501:         # But it does not (yet) set the \"venv\" scheme.\nL17502:         # If the Apple-custom \"osx_framework_library\" scheme is available but \"venv\"\nL17503:         # is not, we use \"posix_prefix\" instead which is venv-compatible there.\nL17504:         paths = sysconfig.get_paths(scheme='posix_prefix', vars=config_vars)\nL17505:     else:\nL17506:         paths = sysconfig.get_paths(vars=config_vars)\nL17507: \nL17508:     executable = os.path.join(paths['scripts'], 'python.exe' if os.name == 'nt' else 'python')\nL17509:     if not os.path.exists(executable):\nL17510:         msg = f'Virtual environment creation failed, executable {executable} missing'\nL17511:         raise RuntimeError(msg)\nL17512: \nL17513:     return executable, paths['scripts'], paths['purelib']\nL17514: \nL17515: \nL17516: __all__ = [\nL17517:     'IsolatedEnv',\nL17518:     'DefaultIsolatedEnv',\nL17519: ]\nL17520: \nL17521: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/build/util.py\nL17522: # SPDX-License-Identifier: MIT\nL17523: \nL17524: from __future__ import annotations\nL17525: \nL17526: import pathlib\nL17527: import tempfile\nL17528: \nL17529: import pyproject_hooks\nL17530: \nL17531: from . import ProjectBuilder\nL17532: from ._compat import importlib\nL17533: from ._types import StrPath, SubprocessRunner\nL17534: from .env import DefaultIsolatedEnv\nL17535: \nL17536: \nL17537: def _project_wheel_metadata(builder: ProjectBuilder) -> importlib.metadata.PackageMetadata:\nL17538:     with tempfile.TemporaryDirectory() as tmpdir:\nL17539:         path = pathlib.Path(builder.metadata_path(tmpdir))\nL17540:         return importlib.metadata.PathDistribution(path).metadata\nL17541: \nL17542: \nL17543: def project_wheel_metadata(\nL17544:     source_dir: StrPath,\nL17545:     isolated: bool = True,\nL17546:     *,\nL17547:     runner: SubprocessRunner = pyproject_hooks.quiet_subprocess_runner,\nL17548: ) -> importlib.metadata.PackageMetadata:\nL17549:     \"\"\"\nL17550:     Return the wheel metadata for a project.\nL17551: \nL17552:     Uses the ``prepare_metadata_for_build_wheel`` hook if available,\nL17553:     otherwise ``build_wheel``.\nL17554: \nL17555:     :param source_dir: Project source directory\nL17556:     :param isolated: Whether or not to run invoke the backend in the current\nL17557:                      environment or to create an isolated one and invoke it\nL17558:                      there.\nL17559:     :param runner: An alternative runner for backend subprocesses\nL17560:     \"\"\"\nL17561: \nL17562:     if isolated:\nL17563:         with DefaultIsolatedEnv() as env:\nL17564:             builder = ProjectBuilder.from_isolated_env(\nL17565:                 env,\nL17566:                 source_dir,\nL17567:                 runner=runner,\nL17568:             )\nL17569:             env.install(builder.build_system_requires)\nL17570:             env.install(builder.get_requires_for_build('wheel'))\nL17571:             return _project_wheel_metadata(builder)\nL17572:     else:\nL17573:         builder = ProjectBuilder(\nL17574:             source_dir,\nL17575:             runner=runner,\nL17576:         )\nL17577:         return _project_wheel_metadata(builder)\nL17578: \nL17579: \nL17580: __all__ = [\nL17581:     'project_wheel_metadata',\nL17582: ]\nL17583: \nL17584: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/build/_compat/importlib.py\nL17585: from __future__ import annotations\nL17586: \nL17587: import sys\nL17588: import typing\nL17589: \nL17590: \nL17591: if typing.TYPE_CHECKING:\nL17592:     import importlib_metadata as metadata\nL17593: else:\nL17594:     if sys.version_info >= (3, 10, 2):\nL17595:         from importlib import metadata\nL17596:     else:\nL17597:         try:\nL17598:             import importlib_metadata as metadata\nL17599:         except ModuleNotFoundError:\nL17600:             # helps bootstrapping when dependencies aren't installed\nL17601:             from importlib import metadata\nL17602: \nL17603: \nL17604: __all__ = [\nL17605:     'metadata',\nL17606: ]\nL17607: \nL17608: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/build/_compat/tarfile.py\nL17609: from __future__ import annotations\nL17610: \nL17611: import sys\nL17612: import tarfile\nL17613: import typing\nL17614: \nL17615: \nL17616: if typing.TYPE_CHECKING:\nL17617:     TarFile = tarfile.TarFile\nL17618: \nL17619: else:\nL17620:     # Per https://peps.python.org/pep-0706/, the \"data\" filter will become\nL17621:     # the default in Python 3.14. The first series of releases with the filter\nL17622:     # had a broken filter that could not process symlinks correctly.\nL17623:     if (\nL17624:         (3, 8, 18) <= sys.version_info < (3, 9)\nL17625:         or (3, 9, 18) <= sys.version_info < (3, 10)\nL17626:         or (3, 10, 13) <= sys.version_info < (3, 11)\nL17627:         or (3, 11, 5) <= sys.version_info < (3, 12)\nL17628:         or (3, 12) <= sys.version_info < (3, 14)\nL17629:     ):\nL17630: \nL17631:         class TarFile(tarfile.TarFile):\nL17632:             extraction_filter = staticmethod(tarfile.data_filter)\nL17633: \nL17634:     else:\nL17635:         TarFile = tarfile.TarFile\nL17636: \nL17637: \nL17638: __all__ = [\nL17639:     'TarFile',\nL17640: ]\nL17641: \nL17642: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/build/_compat/tomllib.py\nL17643: from __future__ import annotations\nL17644: \nL17645: import sys\nL17646: \nL17647: \nL17648: if sys.version_info >= (3, 11):\nL17649:     from tomllib import TOMLDecodeError, load, loads\nL17650: else:\nL17651:     from tomli import TOMLDecodeError, load, loads\nL17652: \nL17653: \nL17654: __all__ = [\nL17655:     'TOMLDecodeError',\nL17656:     'load',\nL17657:     'loads',\nL17658: ]\nL17659: \nL17660: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/_distutils_hack/__init__.py\nL17661: #!/usr/bin/env python3\nL17662: # don't import any costly modules\nL17663: import os\nL17664: import sys\nL17665: \nL17666: report_url = (\nL17667:     \"https://github.com/pypa/setuptools/issues/new?template=distutils-deprecation.yml\"\nL17668: )\nL17669: \nL17670: \nL17671: def warn_distutils_present():\nL17672:     if 'distutils' not in sys.modules:\nL17673:         return\nL17674:     import warnings\nL17675: \nL17676:     warnings.warn(\nL17677:         \"Distutils was imported before Setuptools, but importing Setuptools \"\nL17678:         \"also replaces the `distutils` module in `sys.modules`. This may lead \"\nL17679:         \"to undesirable behaviors or errors. To avoid these issues, avoid \"\nL17680:         \"using distutils directly, ensure that setuptools is installed in the \"\nL17681:         \"traditional way (e.g. not an editable install), and/or make sure \"\nL17682:         \"that setuptools is always imported before distutils.\"\nL17683:     )\nL17684: \nL17685: \nL17686: def clear_distutils():\nL17687:     if 'distutils' not in sys.modules:\nL17688:         return\nL17689:     import warnings\nL17690: \nL17691:     warnings.warn(\nL17692:         \"Setuptools is replacing distutils. Support for replacing \"\nL17693:         \"an already imported distutils is deprecated. In the future, \"\nL17694:         \"this condition will fail. \"\nL17695:         f\"Register concerns at {report_url}\"\nL17696:     )\nL17697:     mods = [\nL17698:         name\nL17699:         for name in sys.modules\nL17700:         if name == \"distutils\" or name.startswith(\"distutils.\")\nL17701:     ]\nL17702:     for name in mods:\nL17703:         del sys.modules[name]\nL17704: \nL17705: \nL17706: def enabled():\nL17707:     \"\"\"\nL17708:     Allow selection of distutils by environment variable.\nL17709:     \"\"\"\nL17710:     which = os.environ.get('SETUPTOOLS_USE_DISTUTILS', 'local')\nL17711:     if which == 'stdlib':\nL17712:         import warnings\nL17713: \nL17714:         warnings.warn(\nL17715:             \"Reliance on distutils from stdlib is deprecated. Users \"\nL17716:             \"must rely on setuptools to provide the distutils module. \"\nL17717:             \"Avoid importing distutils or import setuptools first, \"\nL17718:             \"and avoid setting SETUPTOOLS_USE_DISTUTILS=stdlib. \"\nL17719:             f\"Register concerns at {report_url}\"\nL17720:         )\nL17721:     return which == 'local'\nL17722: \nL17723: \nL17724: def ensure_local_distutils():\nL17725:     import importlib\nL17726: \nL17727:     clear_distutils()\nL17728: \nL17729:     # With the DistutilsMetaFinder in place,\nL17730:     # perform an import to cause distutils to be\nL17731:     # loaded from setuptools._distutils. Ref #2906.\nL17732:     with shim():\nL17733:         importlib.import_module('distutils')\nL17734: \nL17735:     # check that submodules load as expected\nL17736:     core = importlib.import_module('distutils.core')\nL17737:     assert '_distutils' in core.__file__, core.__file__\nL17738:     assert 'setuptools._distutils.log' not in sys.modules\nL17739: \nL17740: \nL17741: def do_override():\nL17742:     \"\"\"\nL17743:     Ensure that the local copy of distutils is preferred over stdlib.\nL17744: \nL17745:     See https://github.com/pypa/setuptools/issues/417#issuecomment-392298401\nL17746:     for more motivation.\nL17747:     \"\"\"\nL17748:     if enabled():\nL17749:         warn_distutils_present()\nL17750:         ensure_local_distutils()\nL17751: \nL17752: \nL17753: class _TrivialRe:\nL17754:     def __init__(self, *patterns) -> None:\nL17755:         self._patterns = patterns\nL17756: \nL17757:     def match(self, string):\nL17758:         return all(pat in string for pat in self._patterns)\nL17759: \nL17760: \nL17761: class DistutilsMetaFinder:\nL17762:     def find_spec(self, fullname, path, target=None):\nL17763:         # optimization: only consider top level modules and those\nL17764:         # found in the CPython test suite.\nL17765:         if path is not None and not fullname.startswith('test.'):\nL17766:             return None\nL17767: \nL17768:         method_name = 'spec_for_{fullname}'.format(**locals())\nL17769:         method = getattr(self, method_name, lambda: None)\nL17770:         return method()\nL17771: \nL17772:     def spec_for_distutils(self):\nL17773:         if self.is_cpython():\nL17774:             return None\nL17775: \nL17776:         import importlib\nL17777:         import importlib.abc\nL17778:         import importlib.util\nL17779: \nL17780:         try:\nL17781:             mod = importlib.import_module('setuptools._distutils')\nL17782:         except Exception:\nL17783:             # There are a couple of cases where setuptools._distutils\nL17784:             # may not be present:\nL17785:             # - An older Setuptools without a local distutils is\nL17786:             #   taking precedence. Ref #2957.\nL17787:             # - Path manipulation during sitecustomize removes\nL17788:             #   setuptools from the path but only after the hook\nL17789:             #   has been loaded. Ref #2980.\nL17790:             # In either case, fall back to stdlib behavior.\nL17791:             return None\nL17792: \nL17793:         class DistutilsLoader(importlib.abc.Loader):\nL17794:             def create_module(self, spec):\nL17795:                 mod.__name__ = 'distutils'\nL17796:                 return mod\nL17797: \nL17798:             def exec_module(self, module):\nL17799:                 pass\nL17800: \nL17801:         return importlib.util.spec_from_loader(\nL17802:             'distutils', DistutilsLoader(), origin=mod.__file__\nL17803:         )\nL17804: \nL17805:     @staticmethod\nL17806:     def is_cpython():\nL17807:         \"\"\"\nL17808:         Suppress supplying distutils for CPython (build and tests).\nL17809:         Ref #2965 and #3007.\nL17810:         \"\"\"\nL17811:         return os.path.isfile('pybuilddir.txt')\nL17812: \nL17813:     def spec_for_pip(self):\nL17814:         \"\"\"\nL17815:         Ensure stdlib distutils when running under pip.\nL17816:         See pypa/pip#8761 for rationale.\nL17817:         \"\"\"\nL17818:         if sys.version_info >= (3, 12) or self.pip_imported_during_build():\nL17819:             return\nL17820:         clear_distutils()\nL17821:         self.spec_for_distutils = lambda: None\nL17822: \nL17823:     @classmethod\nL17824:     def pip_imported_during_build(cls):\nL17825:         \"\"\"\nL17826:         Detect if pip is being imported in a build script. Ref #2355.\nL17827:         \"\"\"\nL17828:         import traceback\nL17829: \nL17830:         return any(\nL17831:             cls.frame_file_is_setup(frame) for frame, line in traceback.walk_stack(None)\nL17832:         )\nL17833: \nL17834:     @staticmethod\nL17835:     def frame_file_is_setup(frame):\nL17836:         \"\"\"\nL17837:         Return True if the indicated frame suggests a setup.py file.\nL17838:         \"\"\"\nL17839:         # some frames may not have __file__ (#2940)\nL17840:         return frame.f_globals.get('__file__', '').endswith('setup.py')\nL17841: \nL17842:     def spec_for_sensitive_tests(self):\nL17843:         \"\"\"\nL17844:         Ensure stdlib distutils when running select tests under CPython.\nL17845: \nL17846:         python/cpython#91169\nL17847:         \"\"\"\nL17848:         clear_distutils()\nL17849:         self.spec_for_distutils = lambda: None\nL17850: \nL17851:     sensitive_tests = (\nL17852:         [\nL17853:             'test.test_distutils',\nL17854:             'test.test_peg_generator',\nL17855:             'test.test_importlib',\nL17856:         ]\nL17857:         if sys.version_info < (3, 10)\nL17858:         else [\nL17859:             'test.test_distutils',\nL17860:         ]\nL17861:     )\nL17862: \nL17863: \nL17864: for name in DistutilsMetaFinder.sensitive_tests:\nL17865:     setattr(\nL17866:         DistutilsMetaFinder,\nL17867:         f'spec_for_{name}',\nL17868:         DistutilsMetaFinder.spec_for_sensitive_tests,\nL17869:     )\nL17870: \nL17871: \nL17872: DISTUTILS_FINDER = DistutilsMetaFinder()\nL17873: \nL17874: \nL17875: def add_shim():\nL17876:     DISTUTILS_FINDER in sys.meta_path or insert_shim()\nL17877: \nL17878: \nL17879: class shim:\nL17880:     def __enter__(self) -> None:\nL17881:         insert_shim()\nL17882: \nL17883:     def __exit__(self, exc: object, value: object, tb: object) -> None:\nL17884:         _remove_shim()\nL17885: \nL17886: \nL17887: def insert_shim():\nL17888:     sys.meta_path.insert(0, DISTUTILS_FINDER)\nL17889: \nL17890: \nL17891: def _remove_shim():\nL17892:     try:\nL17893:         sys.meta_path.remove(DISTUTILS_FINDER)\nL17894:     except ValueError:\nL17895:         pass\nL17896: \nL17897: \nL17898: if sys.version_info < (3, 12):\nL17899:     # DistutilsMetaFinder can only be disabled in Python < 3.12 (PEP 632)\nL17900:     remove_shim = _remove_shim\nL17901: \nL17902: \ud83d\udd39 /data/data/com.termux/files/home/RAFAELIA/HCPM/CORE/venv_rafaelia/lib/python3.12/site-packages/pkg_resources/__init__.py\nL17903: #!/usr/bin/env python3\nL17904: \"\"\"\nL17905: Package resource API\nL17906: --------------------\nL17907: \nL17908: A resource is a logical file contained within a package, or a logical\nL17909: subdirectory thereof.  The package resource API expects resource names\nL17910: to have their path parts separated with ``/``, *not* whatever the local\nL17911: path separator is.  Do not use os.path operations to manipulate resource\nL17912: names being passed into the API.\nL17913: \nL17914: The package resource API is designed to work with normal filesystem packages,\nL17915: .egg files, and unpacked .egg files.  It can also work in a limited way with\nL17916: .zip files and with custom PEP 302 loaders that support the ``get_data()``\nL17917: method.\nL17918: \nL17919: This module is deprecated. Users are directed to :mod:`importlib.resources`,\nL17920: :mod:`importlib.metadata` and :pypi:`packaging` instead.\nL17921: \"\"\"\nL17922: \nL17923: from __future__ import annotations\nL17924: \nL17925: import sys\nL17926: \nL17927: if sys.version_info < (3, 9):  # noqa: UP036 # Check for unsupported versions\nL17928:     raise RuntimeError(\"Python 3.9 or later is required\")\nL17929: \nL17930: import _imp\nL17931: import collections\nL17932: import email.parser\nL17933: import errno\nL17934: import functools\nL17935: import importlib\nL17936: import importlib.abc\nL17937: import importlib.machinery\nL17938: import inspect\nL17939: import io\nL17940: import ntpath\nL17941: import operator\nL17942: import os\nL17943: import pkgutil\nL17944: import platform\nL17945: import plistlib\nL17946: import posixpath\nL17947: import re\nL17948: import stat\nL17949: import tempfile\nL17950: import textwrap\nL17951: import time\nL17952: import types\nL17953: import warnings\nL17954: import zipfile\nL17955: import zipimport\nL17956: from collections.abc import Iterable, Iterator, Mapping, MutableSequence\nL17957: from pkgutil import get_importer\nL17958: from typing import (\nL17959:     TYPE_CHECKING,\nL17960:     Any,\nL17961:     BinaryIO,\nL17962:     Callable,\nL17963:     Literal,\nL17964:     NamedTuple,\nL17965:     NoReturn,\nL17966:     Protocol,\nL17967:     TypeVar,\nL17968:     Union,\nL17969:     overload,\nL17970: )\nL17971: \nL17972: sys.path.extend(((vendor_path := os.path.join(os.path.dirname(os.path.dirname(__file__)), 'setuptools', '_vendor')) not in sys.path) * [vendor_path])  # fmt: skip\nL17973: # workaround for #4476\nL17974: sys.modules.pop('backports', None)\nL17975: \nL17976: # capture these to bypass sandboxing\nL17977: from os import open as os_open, utime  # isort: skip\nL17978: from os.path import isdir, split  # isort: skip\nL17979: \nL17980: try:\nL17981:     from os import mkdir, rename, unlink\nL17982: \nL17983:     WRITE_SUPPORT = True\nL17984: except ImportError:\nL17985:     # no write support, probably under GAE\nL17986:     WRITE_SUPPORT = False\nL17987: \nL17988: import packaging.markers\nL17989: import packaging.requirements\nL17990: import packaging.specifiers\nL17991: import packaging.utils\nL17992: import packaging.version\nL17993: from jaraco.text import drop_comment, join_continuation, yield_lines\nL17994: from platformdirs import user_cache_dir as _user_cache_dir\nL17995: \nL17996: if TYPE_CHECKING:\nL17997:     from _typeshed import BytesPath, StrOrBytesPath, StrPath\nL17998:     from _typeshed.importlib import LoaderProtocol\nL17999:     from typing_extensions import Self, TypeAlias\nL18000: \nL18001: warnings.warn(\nL18002:     \"pkg_resources is deprecated as an API. \"\nL18003:     \"See https://setuptools.pypa.io/en/latest/pkg_resources.html. \"\nL18004:     \"The pkg_resources package is slated for removal as early as \"\nL18005:     \"2025-11-30. Refrain from using this package or pin to \"\nL18006:     \"Setuptools<81.\",\nL18007:     UserWarning,\nL18008:     stacklevel=2,\nL18009: )\nL18010: \nL18011: _T = TypeVar(\"_T\")\nL18012: _DistributionT = TypeVar(\"_DistributionT\", bound=\"Distribution\")\nL18013: # Type aliases\nL18014: _NestedStr: TypeAlias = Union[str, Iterable[Union[str, Iterable[\"_NestedStr\"]]]]\nL18015: _StrictInstallerType: TypeAlias = Callable[[\"Requirement\"], \"_DistributionT\"]\nL18016: _InstallerType: TypeAlias = Callable[[\"Requirement\"], Union[\"Distribution\", None]]\nL18017: _PkgReqType: TypeAlias = Union[str, \"Requirement\"]\nL18018: _EPDistType: TypeAlias = Union[\"Distribution\", _PkgReqType]\nL18019: _MetadataType: TypeAlias = Union[\"IResourceProvider\", None]\nL18020: _ResolvedEntryPoint: TypeAlias = Any  # Can be any attribute in the module\nL18021: _ResourceStream: TypeAlias = Any  # TODO / Incomplete: A readable file-like object\nL18022: # Any object works, but let's indicate we expect something like a module (optionally has __loader__ or __file__)\nL18023: _ModuleLike: TypeAlias = Union[object, types.ModuleType]\nL18024: # Any: Should be _ModuleLike but we end up with issues where _ModuleLike doesn't have _ZipLoaderModule's __loader__\nL18025: _ProviderFactoryType: TypeAlias = Callable[[Any], \"IResourceProvider\"]\nL18026: _DistFinderType: TypeAlias = Callable[[_T, str, bool], Iterable[\"Distribution\"]]\nL18027: _NSHandlerType: TypeAlias = Callable[[_T, str, str, types.ModuleType], Union[str, None]]\nL18028: _AdapterT = TypeVar(\nL18029:     \"_AdapterT\", _DistFinderType[Any], _ProviderFactoryType, _NSHandlerType[Any]\nL18030: )\nL18031: \nL18032: \nL18033: class _ZipLoaderModule(Protocol):\nL18034:     __loader__: zipimport.zipimporter\nL18035: \nL18036: \nL18037: _PEP440_FALLBACK = re.compile(r\"^v?(?P<safe>(?:[0-9]+!)?[0-9]+(?:\\.[0-9]+)*)\", re.I)\nL18038: \nL18039: \nL18040: class PEP440Warning(RuntimeWarning):\nL18041:     \"\"\"\nL18042:     Used when there is an issue with a version or specifier not complying with\nL18043:     PEP 440.\nL18044:     \"\"\"\nL18045: \nL18046: \nL18047: parse_version = packaging.version.Version\nL18048: \nL18049: _state_vars: dict[str, str] = {}\nL18050: \nL18051: \nL18052: def _declare_state(vartype: str, varname: str, initial_value: _T) -> _T:\nL18053:     _state_vars[varname] = vartype\nL18054:     return initial_value\nL18055: \nL18056: \nL18057: def __getstate__() -> dict[str, Any]:\nL18058:     state = {}\nL18059:     g = globals()\nL18060:     for k, v in _state_vars.items():\nL18061:         state[k] = g['_sget_' + v](g[k])\nL18062:     return state\nL18063: \nL18064: \nL18065: def __setstate__(state: dict[str, Any]) -> dict[str, Any]:\nL18066:     g = globals()\nL18067:     for k, v in state.items():\nL18068:         g['_sset_' + _state_vars[k]](k, g[k], v)\nL18069:     return state\nL18070: \nL18071: \nL18072: def _sget_dict(val):\nL18073:     return val.copy()\nL18074: \nL18075: \nL18076: def _sset_dict(key, ob, state) -> None:\nL18077:     ob.clear()\nL18078:     ob.update(state)\nL18079: \nL18080: \nL18081: def _sget_object(val):\nL18082:     return val.__getstate__()\nL18083: \nL18084: \nL18085: def _sset_object(key, ob, state) -> None:\nL18086:     ob.__setstate__(state)\nL18087: \nL18088: \nL18089: _sget_none = _sset_none = lambda *args: None\nL18090: \nL18091: \nL18092: def get_supported_platform():\nL18093:     \"\"\"Return this platform's maximum compatible version.\nL18094: \nL18095:     distutils.util.get_platform() normally reports the minimum version\nL18096:     of macOS that would be required to *use* extensions produced by\nL18097:     distutils.  But what we want when checking compatibility is to know the\nL18098:     version of macOS that we are *running*.  To allow usage of packages that\nL18099:     explicitly require a newer version of macOS, we must also know the\nL18100:     current version of the OS.\nL18101: \nL18102:     If this condition occurs for any other platform with a version in its\nL18103:     platform strings, this function should be extended accordingly.\nL18104:     \"\"\"\nL18105:     plat = get_build_platform()\nL18106:     m = macosVersionString.match(plat)\nL18107:     if m is not None and sys.platform == \"darwin\":\nL18108:         try:\nL18109:             major_minor = '.'.join(_macos_vers()[:2])\nL18110:             build = m.group(3)\nL18111:             plat = f'macosx-{major_minor}-{build}'\nL18112:         except ValueError:\nL18113:             # not macOS\nL18114:             pass\nL18115:     return plat\nL18116: \nL18117: \nL18118: __all__ = [\nL18119:     # Basic resource access and distribution/entry point discovery\nL18120:     'require',\nL18121:     'run_script',\nL18122:     'get_provider',\nL18123:     'get_distribution',\nL18124:     'load_entry_point',\nL18125:     'get_entry_map',\nL18126:     'get_entry_info',\nL18127:     'iter_entry_points',\nL18128:     'resource_string',\nL18129:     'resource_stream',\nL18130:     'resource_filename',\nL18131:     'resource_listdir',\nL18132:     'resource_exists',\nL18133:     'resource_isdir',\nL18134:     # Environmental control\nL18135:     'declare_namespace',\nL18136:     'working_set',\nL18137:     'add_activation_listener',\nL18138:     'find_distributions',\nL18139:     'set_extraction_path',\nL18140:     'cleanup_resources',\nL18141:     'get_default_cache',\nL18142:     # Primary implementation classes\nL18143:     'Environment',\nL18144:     'WorkingSet',\nL18145:     'ResourceManager',\nL18146:     'Distribution',\nL18147:     'Requirement',\nL18148:     'EntryPoint',\nL18149:     # Exceptions\nL18150:     'ResolutionError',\nL18151:     'VersionConflict',\nL18152:     'DistributionNotFound',\nL18153:     'UnknownExtra',\nL18154:     'ExtractionError',\nL18155:     # Warnings\nL18156:     'PEP440Warning',\nL18157:     # Parsing functions and string utilities\nL18158:     'parse_requirements',\nL18159:     'parse_version',\nL18160:     'safe_name',\nL18161:     'safe_version',\nL18162:     'get_platform',\nL18163:     'compatible_platforms',\nL18164:     'yield_lines',\nL18165:     'split_sections',\nL18166:     'safe_extra',\nL18167:     'to_filename',\nL18168:     'inval