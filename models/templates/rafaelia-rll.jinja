{% set default_system_message = 'Você é RAFAELIA-RLL. Responda com precisão, clareza e foco em coerência determinística.' %}
{% set ns = namespace(provided_system_messages=[]) %}
{% for message in messages %}
{% if message['role'] == 'system' %}
{% set content = message['content'] %}
{% if content is string %}
{% set ns.provided_system_messages = ns.provided_system_messages + [content] %}
{% elif content is iterable and content is not string %}
{% for item in content %}
{% if item is mapping and item.get('type') == 'text' and item.get('text') %}
{% set ns.provided_system_messages = ns.provided_system_messages + [item.get('text')] %}
{% endif %}
{% endfor %}
{% endif %}
{% endif %}
{% endfor %}

[RAFAELIA::RLL::SYSTEM]
{{ default_system_message }}
{% if ns.provided_system_messages %}

{{ ns.provided_system_messages | join('\n\n') }}
{% endif %}
[/RAFAELIA::RLL::SYSTEM]

{% for message in messages %}
{% if message['role'] == 'user' %}
[USER]
{{ message['content'] }}
[/USER]
{% elif message['role'] == 'assistant' %}
[ASSISTANT]
{{ message['content'] }}
[/ASSISTANT]
{% endif %}
{% endfor %}
{% if add_generation_prompt %}
[ASSISTANT]
{% endif %}
{%- if not add_generation_prompt is defined -%}
    {%- set add_generation_prompt = true -%}
{%- endif -%}
{%- set ns = namespace(system_prompt='') -%}
{%- for message in messages -%}
    {%- if message['role'] == 'system' and message['content'] is not none -%}
        {%- set ns.system_prompt = (ns.system_prompt + '\n' + message['content'])|trim -%}
    {%- endif -%}
{%- endfor -%}
{{- bos_token -}}
{{- 'System: Operador RLL obrigatório. Em TODA resposta, use exatamente os quatro blocos abaixo, nesta ordem e com estes títulos literais: CONTEXT, STATE, TRANSITION, RESULT. Não omita blocos, não renomeie blocos e não adicione blocos extras.\n' -}}
{%- if ns.system_prompt != '' -%}
{{- 'System: ' + ns.system_prompt + '\n' -}}
{%- endif -%}
{%- for message in messages -%}
    {%- if message['role'] == 'user' and message['content'] is not none -%}
{{- 'User: ' + message['content']|trim + '\n' -}}
    {%- elif message['role'] == 'assistant' and message['content'] is not none -%}
{{- 'Assistant: ' + message['content']|trim + '\n' -}}
    {%- endif -%}
{%- endfor -%}
{%- if add_generation_prompt -%}
{{- 'Assistant:' -}}
{%- endif -%}
